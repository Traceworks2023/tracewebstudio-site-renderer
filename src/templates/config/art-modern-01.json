{
  "id": "art-modern-01",
  "name": "Art Modern Gallery",
  "category": "art",
  "subcategory": "modern-gallery",
  "description": "Modern art gallery with bold exhibition spaces",
  "version": "1.0.0",
  "tags": ["art", "gallery", "modern", "exhibition"],
  "components": {
    "header": {
      "layout": "gallery-white",
      "logo": { "type": "text", "position": "center" },
      "navigation": { "type": "minimal", "position": "below" },
      "actions": ["visit"]
    },
    "footer": {
      "layout": "exhibition-dark",
      "columns": ["current", "upcoming", "artists", "contact"]
    },
    "artworkCard": { "layout": "museum-piece" }
  },
  "pages": {
    "home": { "layout": "exhibition", "sections": ["hero", "current", "upcoming", "artists", "visit"] },
    "gallery": { "layout": "white-cube" },
    "artwork": { "layout": "detail-view" }
  },
  "colors": {
    "primary": "#1A1A1A",
    "secondary": "#FFFFFF",
    "accent": "#D4AF37",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "text": "#1A1A1A",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Helvetica Neue", "weight": "300" },
    "body": { "font": "Helvetica Neue", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "100px" },
  "borderRadius": { "buttons": "0px", "cards": "0px" },
  "shadows": { "cards": "none" }
}
