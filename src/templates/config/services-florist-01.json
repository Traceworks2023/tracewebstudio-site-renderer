{
  "id": "services-florist-01",
  "name": "Services Florist",
  "category": "services",
  "subcategory": "florist",
  "description": "Florist with fresh, botanical design",
  "version": "1.0.0",
  "tags": ["services", "florist", "flowers", "arrangements"],
  "components": {
    "header": {
      "layout": "bloom-light",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "occasions", "position": "below" },
      "actions": ["order", "contact"]
    },
    "footer": {
      "layout": "petal-dark",
      "columns": ["bouquets", "occasions", "subscriptions", "contact"]
    },
    "bouquetCard": { "layout": "flower-photo" },
    "orderForm": { "layout": "custom-order" }
  },
  "pages": {
    "home": { "layout": "blooms", "sections": ["hero", "bouquets", "occasions", "subscriptions", "about"] },
    "bouquets": { "layout": "flower-gallery" },
    "order": { "layout": "order-form" }
  },
  "colors": {
    "primary": "#8BC34A",
    "secondary": "#E8F5E9",
    "accent": "#E91E63",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#33691E",
    "textMuted": "#689F38"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "20px", "cards": "8px" },
  "shadows": { "cards": "0 4px 15px rgba(139,195,74,0.15)" }
}
