    "category": { "layout": "parts-grid" },
    "product": { "layout": "part-spec" }
  },
  "colors": {
    "primary": "#37474F",
    "secondary": "#1A1A1A",
    "accent": "#FF6D00",
    "background": "#1A1A1A",
    "surface": "#263238",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Roboto Condensed", "weight": "700" },
    "body": { "font": "Roboto", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
