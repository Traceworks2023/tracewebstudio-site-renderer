{
  "id": "automotive-parts-01",
  "name": "Automotive Parts",
  "category": "automotive",
  "subcategory": "parts",
  "description": "Auto parts with technical, parts-focused design",
  "version": "1.0.0",
  "tags": ["automotive", "parts", "repair", "accessories"],
  "components": {
    "header": {
      "layout": "garage-dark",
      "logo": { "type": "bold", "position": "left" },
      "navigation": { "type": "parts-types", "position": "center" },
