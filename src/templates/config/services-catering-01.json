{
  "id": "services-catering-01",
  "name": "Services Catering",
  "category": "services",
  "subcategory": "catering",
  "description": "Catering service with elegant event presentation",
  "version": "1.0.0",
  "tags": ["services", "catering", "events", "food"],
  "components": {
    "header": {
      "layout": "elegant-light",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "event-types", "position": "below" },
      "actions": ["quote"]
    },
    "footer": {
      "layout": "event-dark",
      "columns": ["corporate", "weddings", "private", "contact"]
    },
    "menuCard": { "layout": "tasting-preview" },
    "eventCard": { "layout": "gallery-event" }
  },
  "pages": {
    "home": { "layout": "culinary", "sections": ["hero", "services", "menus", "events", "quote"] },
    "menus": { "layout": "course-gallery" },
    "quote": { "layout": "event-form" }
  },
  "colors": {
    "primary": "#5D4037",
    "secondary": "#FFF8E1",
    "accent": "#9E9E9E",
    "background": "#FFFFFF",
    "surface": "#FFF8E1",
    "text": "#3E2723",
    "textMuted": "#6D4C41"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 4px 15px rgba(93,64,55,0.1)" }
}
