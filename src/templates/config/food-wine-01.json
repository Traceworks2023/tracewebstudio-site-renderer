{
  "id": "food-wine-01",
  "name": "Food Wine Shop",
  "category": "food",
  "subcategory": "wine",
  "description": "Wine shop with sophisticated, Old World aesthetic",
  "version": "1.0.0",
  "tags": ["food", "wine", "spirits", "elegant"],
  "components": {
    "header": {
      "layout": "cellar-dark",
      "logo": { "type": "classic", "position": "center" },
      "navigation": { "type": "regions", "position": "below" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "vintage-dark",
      "columns": ["reds", "whites", "regions", "events"]
    },
    "productCard": { "layout": "bottle-shot" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "wine-cellar", "sections": ["hero", "new-arrivals", "regions", "events", "club"] },
    "category": { "layout": "region-map" },
    "product": { "layout": "vintage-detail" }
  },
  "colors": {
    "primary": "#7B1FA2",
    "secondary": "#1A1A1A",
    "accent": "#D4AF37",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "0px", "cards": "0px" },
  "shadows": { "cards": "0 4px 20px rgba(123,31,162,0.25)" }
}
