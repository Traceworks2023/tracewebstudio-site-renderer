{
  "id": "landing-webinar-02",
  "name": "Landing Webinar Light",
  "category": "landing",
  "subcategory": "webinar",
  "description": "Webinar registration with light theme",
  "version": "1.0.0",
  "tags": ["landing", "webinar", "light", "event"],
  "components": {
    "header": {
      "layout": "minimal-light",
      "logo": { "type": "text", "position": "center" },
      "navigation": { "type": "none" },
      "actions": []
    },
    "footer": {
      "layout": "minimal-light",
      "columns": ["privacy", "terms"]
    },
    "ctaForm": { "layout": "event-registration-light" }
  },
  "pages": {
    "home": { "layout": "event-landing-light", "sections": ["headline", "date-time", "hosts", "what-you-learn", "register"] }
  },
  "colors": {
    "primary": "#FF7043",
    "secondary": "#FFFFFF",
    "accent": "#26A69A",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "8px", "cards": "12px" },
  "shadows": { "cards": "0 8px 40px rgba(255,112,67,0.15)" }
}
