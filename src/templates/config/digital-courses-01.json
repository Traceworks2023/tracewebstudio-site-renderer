{
  "id": "digital-courses-01",
  "name": "Digital Online Courses",
  "category": "digital",
  "subcategory": "courses",
  "description": "Online courses and educational content platform",
  "version": "1.0.0",
  "tags": ["digital", "courses", "learning", "education"],
  "components": {
    "header": {
      "layout": "learn-dark",
      "logo": { "type": "text", "position": "left" },
      "navigation": { "type": "topics", "position": "center" },
      "actions": ["search", "my-courses", "cart"]
    },
    "footer": {
      "layout": "educator-dark",
      "columns": ["browse", "instructors", "for-business", "support"]
    },
    "courseCard": { "layout": "preview-card", "showDuration": true },
    "cartDrawer": { "layout": "enroll-slide" }
  },
  "pages": {
    "home": { "layout": "learning-platform", "sections": ["hero", "featured", "paths", "instructors", "business"] },
    "category": { "layout": "course-grid" },
    "course": { "layout": "curriculum-first" }
  },
  "colors": {
    "primary": "#FF6B35",
    "secondary": "#1A1A2E",
    "accent": "#00D9A5",
    "background": "#0F0F1A",
    "surface": "#1A1A2E",
    "text": "#FFFFFF",
    "textMuted": "#8892B0"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "8px", "cards": "12px" },
  "shadows": { "cards": "0 4px 20px rgba(255,107,53,0.15)" }
}
