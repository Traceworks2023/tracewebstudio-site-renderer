{
  "id": "gym-boxing-01",
  "name": "Gym Boxing",
  "category": "gym",
  "subcategory": "boxing",
  "description": "Boxing gym with powerful, aggressive design",
  "version": "1.0.0",
  "tags": ["gym", "boxing", "mma", "combat"],
  "components": {
    "header": {
      "layout": "fight-dark",
      "logo": { "type": "bold", "position": "center" },
      "navigation": { "type": "combat-types", "position": "below" },
      "actions": ["join"]
    },
    "footer": {
      "layout": "gym-dark",
      "columns": ["classes", "trainers", "schedule", "contact"]
    },
    "classCard": { "layout": "fight-card" },
    "trainerCard": { "layout": "champ-profile" }
  },
  "pages": {
    "home": { "layout": "fight-night", "sections": ["hero", "classes", "trainers", "schedule", "join"] },
    "classes": { "layout": "class-grid" },
    "schedule": { "layout": "week-view" }
  },
  "colors": {
    "primary": "#FF0000",
    "secondary": "#1A1A1A",
    "accent": "#FFD700",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Roboto", "weight": "500" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "0px", "cards": "0px" },
  "shadows": { "cards": "0 5px 25px rgba(255,0,0,0.3)" }
}
