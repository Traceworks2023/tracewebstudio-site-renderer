  "colors": {
    "primary": "#FF6D00",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "500" }
