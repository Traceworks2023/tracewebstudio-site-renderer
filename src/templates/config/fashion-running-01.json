{
  "id": "fashion-running-01",
  "name": "Fashion Running",
  "category": "fashion",
  "subcategory": "running",
  "description": "Running shoes and apparel with energetic design",
  "version": "1.0.0",
  "tags": ["fashion", "running", "athletic", "shoes"],
  "components": {
    "header": {
      "layout": "speed-dark",
      "logo": { "type": "bold", "position": "left" },
