{
  "id": "digital-fonts-01",
  "name": "Digital Fonts",
  "category": "digital",
  "subcategory": "fonts",
  "description": "Font marketplace with typography-focused design",
  "version": "1.0.0",
  "tags": ["digital", "fonts", "typography", "design"],
  "components": {
    "header": {
      "layout": "type-light",
      "logo": { "type": "Aa", "position": "center" },
      "navigation": { "type": "styles", "position": "below" },
      "actions": ["pricing", "designers"]
    },
    "footer": {
      "layout": "font-dark",
      "columns": ["families", "styles", "designers", "license"]
    },
    "fontCard": { "layout": "specimen-preview" }
  },
  "pages": {
    "home": { "layout": "type-foundry", "sections": ["hero", "new", "popular", "designers", "pricing"] },
    "category": { "layout": "family-grid" },
    "font": { "layout": "specimen-full" }
  },
  "colors": {
    "primary": "#1A1A1A",
    "secondary": "#FFFFFF",
    "accent": "#FF5722",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "text": "#1A1A1A",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Inter", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "none" }
}
