{
  "id": "digital-templates-01",
  "name": "Digital Design Templates",
  "category": "digital",
  "subcategory": "templates",
  "description": "Design templates marketplace with creative aesthetic",
  "version": "1.0.0",
  "tags": ["digital", "templates", "design", "creative"],
  "components": {
    "header": {
      "layout": "creative-dark",
      "logo": { "type": "bold", "position": "left" },
      "navigation": { "type": "categories", "position": "center" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "design-dark",
      "columns": ["graphics", "ui-kits", "mockups", "fonts"]
    },
    "templateCard": { "layout": "preview-thumb" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "create-with", "sections": ["hero", "new", "popular", "categories", "designers"] },
    "category": { "layout": "template-grid" },
    "template": { "layout": "preview-detail" }
  },
  "colors": {
    "primary": "#7C4DFF",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "8px", "cards": "8px" },
  "shadows": { "cards": "0 4px 20px rgba(124,77,255,0.25)" }
}
