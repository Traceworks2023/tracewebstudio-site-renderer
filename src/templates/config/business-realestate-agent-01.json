{
  "id": "business-realestate-agent-01",
  "name": "Business Real Estate Agent",
  "category": "business",
  "subcategory": "realestate-agent",
  "description": "Real estate agent personal brand with professional design",
  "version": "1.0.0",
  "tags": ["business", "realestate", "agent", "realtor"],
  "components": {
    "header": {
      "layout": "professional-light",
      "logo": { "type": "name", "position": "left" },
      "navigation": { "type": "buysell", "position": "center" },
      "actions": ["contact", "listings"]
    },
    "footer": {
      "layout": "agent-dark",
      "columns": ["listings", "neighborhoods", "about", "contact"]
    },
    "listingCard": { "layout": "home-photo" },
    "testimonialCard": { "layout": "client-story" }
  },
  "pages": {
    "home": { "layout": "find-home", "sections": ["hero", "featured", "neighborhoods", "testimonials", "contact"] },
    "listings": { "layout": "listing-grid" },
    "listing": { "layout": "home-tour" }
  },
  "colors": {
    "primary": "#1565C0",
    "secondary": "#263238",
    "accent": "#00897B",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 2px 10px rgba(0,0,0,0.1)" }
}
