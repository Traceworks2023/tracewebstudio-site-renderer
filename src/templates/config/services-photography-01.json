{
  "id": "services-photography-01",
  "name": "Services Photography",
  "category": "services",
  "subcategory": "photography",
  "description": "Photography studio with bold visual portfolio",
  "version": "1.0.0",
  "tags": ["services", "photography", "studio", "sessions"],
  "components": {
    "header": {
      "layout": "photo-dark",
      "logo": { "type": "text", "position": "center" },
      "navigation": { "type": "session-types", "position": "below" },
      "actions": ["book"]
    },
    "footer": {
      "layout": "portfolio-dark",
      "columns": ["portrait", "events", "commercial", "contact"]
    },
    "photoCard": { "layout": "large-frame" },
    "sessionCard": { "layout": "package-info" }
  },
  "pages": {
    "home": { "layout": "visual-portfolio", "sections": ["hero", "portfolio", "sessions", "reviews", "book"] },
    "portfolio": { "layout": "photo-grid" },
    "session": { "layout": "package-selection" }
  },
  "colors": {
    "primary": "#212121",
    "secondary": "#FFFFFF",
    "accent": "#FF5722",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Oswald", "weight": "400" },
    "body": { "font": "Roboto", "weight": "300" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "0px", "cards": "0px" },
  "shadows": { "cards": "0 8px 30px rgba(0,0,0,0.5)" }
}
