{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Template Theme Configuration",
  "description": "Configuration for a template theme with unique structure and styling",
  "type": "object",
  "required": ["id", "name", "category", "structure", "theme"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique template identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name of the template"
    },
    "slug": {
      "type": "string",
      "description": "URL-friendly identifier"
    },
    "category": {
      "type": "string",
      "enum": [
        "fashion", "electronics", "food", "beauty", "furniture",
        "health", "real-estate", "education", "services", "portfolio",
        "restaurant", "gym", "salon", "jewelry", "books", "pets",
        "automotive", "music", "art", "blog", "landing", "other"
      ]
    },
    "subcategory": {
      "type": "string",
      "description": "Subcategory within the main category"
    },
    "isPremium": {
      "type": "boolean",
      "default": false
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "description": {
      "type": "string",
      "description": "Brief description of the template"
    },
    "previewImage": {
      "type": "string",
      "description": "URL to preview image"
    },
    "structure": {
      "$ref": "#/definitions/structure"
    },
    "theme": {
      "$ref": "#/definitions/theme"
    },
    "components": {
      "$ref": "#/definitions/components"
    },
    "fonts": {
      "$ref": "#/definitions/fonts"
    },
    "spacing": {
      "$ref": "#/definitions/spacing"
    },
    "effects": {
      "$ref": "#/definitions/effects"
    },
    "metadata": {
      "$ref": "#/definitions/metadata"
    }
  },
  "definitions": {
    "structure": {
      "type": "object",
      "description": "Page structure definitions",
      "properties": {
        "home": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": [
                "fullscreen-hero",
                "split-hero-left",
                "split-hero-right", 
                "hero-with-sidebar",
                "video-background",
                "parallax-scroll",
                "grid-showcase",
                "magazine-layout",
                "minimal-hero",
                "no-hero-showcase"
              ]
            },
            "sections": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "description": "Ordered list of sections on homepage"
            },
            "heroStyle": {
              "type": "object",
              "properties": {
                "height": { "type": "string", "enum": ["full", "large", "medium", "small"] },
                "textAlignment": { "type": "string", "enum": ["left", "center", "right"] },
                "showOverlay": { "type": "boolean" },
                "overlayOpacity": { "type": "number" },
                "showScrollIndicator": { "type": "boolean" }
              }
            },
            "productGrid": {
              "type": "object",
              "properties": {
                "columns": { "type": "integer", "minimum": 2, "maximum": 6 },
                "aspectRatio": { "type": "string" },
                "showQuickView": { "type": "boolean" },
                "showAddToCart": { "type": "boolean" }
              }
            },
            "navigation": {
              "type": "object",
              "properties": {
                "style": { "type": "string", "enum": ["top-bar", "sidebar", "hamburger", "mega-menu", "minimal", "centered"] },
                "sticky": { "type": "boolean" },
                "showSearch": { "type": "boolean" },
                "showCart": { "type": "boolean" },
                "showWishlist": { "type": "boolean" }
              }
            },
            "footer": {
              "type": "object",
              "properties": {
                "style": { "type": "string", "enum": ["simple", "detailed", "minimal", "links-grid", "centered"] },
                "columns": { "type": "integer", "minimum": 1, "maximum": 6 },
                "showSocial": { "type": "boolean" },
                "showPayment": { "type": "boolean" }
              }
            }
          }
        },
        "category": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": [
                "sidebar-filter-left",
                "sidebar-filter-right",
                "top-filter-bar",
                "filter-drawer",
                "no-filter",
                "filter-above-grid"
              ]
            },
            "grid": {
              "type": "object",
              "properties": {
                "columns": { "type": "integer", "minimum": 2, "maximum": 5 },
                "style": { "type": "string", "enum": ["grid", "list", "masonry", "carousel"] },
                "showImage": { "type": "boolean" },
                "aspectRatio": { "type": "string" }
              }
            },
            "sidebar": {
              "type": "object",
              "properties": {
                "width": { "type": "string" },
                "collapsible": { "type": "boolean" },
                "showClearAll": { "type": "boolean" }
              }
            },
            "pagination": {
              "type": "object",
              "properties": {
                "style": { "type": "string", "enum": ["numbered", "load-more", "infinite-scroll"] },
                "position": { "type": "string", "enum": ["bottom", "top", "both"] }
              }
            },
            "hero": {
              "type": "object",
              "properties": {
                "showBanner": { "type": "boolean" },
                "bannerStyle": { "type": "string", "enum": ["full-width", "contained", "sidebar"] }
              }
            },
            "sortOptions": {
              "type": "object",
              "properties": {
                "position": { "type": "string", "enum": ["top", "bottom"] },
                "showResultCount": { "type": "boolean" }
              }
            }
          }
        },
        "product": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": [
                "gallery-left-info-right",
                "gallery-top-info-bottom",
                "gallery-right-info-left",
                "gallery-full-left",
                "stepper-layout",
                "minimal-layout",
                "detailed-layout",
                "tabs-layout"
              ]
            },
            "gallery": {
              "type": "object",
              "properties": {
                "thumbnailPosition": { "type": "string", "enum": ["bottom", "left", "right"] },
                "showZoom": { "type": "boolean" },
                "showThumbnails": { "type": "boolean" },
                "thumbnailColumns": { "type": "integer" }
              }
            },
            "info": {
              "type": "object",
              "properties": {
                "showRating": { "type": "boolean" },
                "showPrice": { "type": "boolean" },
                "showStock": { "type": "boolean" },
                "showSku": { "type": "boolean" },
                "showShare": { "type": "boolean" },
                "showWishlist": { "type": "boolean" }
              }
            },
            "variants": {
              "type": "object",
              "properties": {
                "showColorSwatches": { "type": "boolean" },
                "showSizeSelector": { "type": "boolean" },
                "swatchStyle": { "type": "string", "enum": ["circle", "square", "dropdown"] }
              }
            },
            "addToCart": {
              "type": "object",
              "properties": {
                "showQuantity": { "type": "boolean" },
                "buttonStyle": { "type": "string", "enum": ["full-width", "split", "icon-only"] }
              }
            },
            "tabs": {
              "type": "object",
              "properties": {
                "style": { "type": "string", "enum": ["underline", "box", "pills", "accordion"] },
                "position": { "type": "string", "enum": ["below-gallery", "below-info", "side-by-side"] }
              }
            },
            "relatedProducts": {
              "type": "object",
              "properties": {
                "show": { "type": "boolean" },
                "style": { "type": "string", "enum": ["grid", "carousel"] },
                "columns": { "type": "integer", "minimum": 2, "maximum": 5 }
              }
            }
          }
        },
        "cart": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["page", "drawer", "modal", "sidebar", "minimal"]
            },
            "showImages": { "type": "boolean" },
            "showQuantities": { "type": "boolean" },
            "showRemove": { "type": "boolean" },
            "showCoupon": { "type": "boolean" },
            "showSummary": { "type": "boolean" },
            "continueShoppingUrl": { "type": "string" }
          }
        },
        "checkout": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["single-page", "multi-step", "stepper", "express", "minimal"]
            },
            "steps": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["contact", "shipping", "billing", "delivery", "payment", "review", "confirmation"]
              }
            },
            "showOrderSummary": { "type": "boolean" },
            "summaryPosition": { "type": "string", "enum": ["right", "left", "bottom"] },
            "expressCheckout": { "type": "boolean" }
          }
        },
        "account": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["sidebar-nav", "top-nav", "minimal", "dashboard-cards"]
            },
            "sidebar": {
              "type": "object",
              "properties": {
                "width": { "type": "string" },
                "collapsible": { "type": "boolean" }
              }
            },
            "showAvatar": { "type": "boolean" },
            "showQuickStats": { "type": "boolean" }
          }
        },
        "auth": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["split", "centered", "minimal", "full-page", "card"]
            },
            "showSocialLogin": { "type": "boolean" },
            "showRememberMe": { "type": "boolean" },
            "showForgotPassword": { "type": "boolean" }
          }
        },
        "search": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["full-page", "overlay", "sidebar", "minimal"]
            },
            "showFilters": { "type": "boolean" },
            "showRecent": { "type": "boolean" },
            "showSuggestions": { "type": "boolean" },
            "autocomplete": { "type": "boolean" }
          }
        },
        "tenant": {
          "type": "object",
          "properties": {
            "layout": {
              "type": "string",
              "enum": ["sidebar-nav", "top-nav", "minimal", "dashboard-cards"]
            },
            "sidebar": {
              "type": "object",
              "properties": {
                "width": { "type": "string" },
                "collapsible": { "type": "boolean" },
                "showLogo": { "type": "boolean" },
                "showStoreName": { "type": "boolean" }
              }
            },
            "header": {
              "type": "object",
              "properties": {
                "showSearch": { "type": "boolean" },
                "showNotifications": { "type": "boolean" },
                "showProfile": { "type": "boolean" }
              }
            },
            "dashboard": {
              "type": "object",
              "properties": {
                "showStats": { "type": "boolean" },
                "showRecentOrders": { "type": "boolean" },
                "showQuickActions": { "type": "boolean" },
                "showRevenueChart": { "type": "boolean" },
                "showTopProducts": { "type": "boolean" }
              }
            },
            "products": {
              "type": "object",
              "properties": {
                "showGrid": { "type": "boolean" },
                "showFilters": { "type": "boolean" },
                "showBulkActions": { "type": "boolean" },
                "showImportExport": { "type": "boolean" }
              }
            },
            "orders": {
              "type": "object",
              "properties": {
                "showStatusFilters": { "type": "boolean" },
                "showDateRange": { "type": "boolean" },
                "showExport": { "type": "boolean" },
                "showBulkActions": { "type": "boolean" }
              }
            }
          }
        }
      }
    },
    "theme": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["light", "dark", "both"]
        },
        "defaultMode": {
          "type": "string",
          "enum": ["light", "dark"]
        },
        "colors": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "primaryHover": { "type": "string" },
            "secondary": { "type": "string" },
            "secondaryHover": { "type": "string" },
            "accent": { "type": "string" },
            "accentHover": { "type": "string" },
            "background": { "type": "string" },
            "surface": { "type": "string" },
            "surfaceAlt": { "type": "string" },
            "textPrimary": { "type": "string" },
            "textSecondary": { "type": "string" },
            "textMuted": { "type": "string" },
            "border": { "type": "string" },
            "borderLight": { "type": "string" },
            "success": { "type": "string" },
            "warning": { "type": "string" },
            "error": { "type": "string" },
            "info": { "type": "string" }
          }
        },
        "dark": {
          "type": "object",
          "description": "Dark mode color overrides",
          "properties": {
            "background": { "type": "string" },
            "surface": { "type": "string" },
            "textPrimary": { "type": "string" },
            "textSecondary": { "type": "string" }
          }
        }
      }
    },
    "components": {
      "type": "object",
      "properties": {
        "buttons": {
          "type": "object",
          "properties": {
            "primary": {
              "type": "object",
              "properties": {
                "borderRadius": { "type": "string" },
                "padding": { "type": "string" },
                "fontWeight": { "type": "string" },
                "textTransform": { "type": "string" },
                "shadow": { "type": "string" },
                "hoverEffect": { "type": "string", "enum": ["scale", "shadow", "color", "none"] }
              }
            },
            "secondary": { "$ref": "#/definitions/componentStyle" },
            "outline": { "$ref": "#/definitions/componentStyle" },
            "ghost": { "$ref": "#/definitions/componentStyle" }
          }
        },
        "cards": {
          "type": "object",
          "properties": {
            "borderRadius": { "type": "string" },
            "shadow": { "type": "string" },
            "shadowHover": { "type": "string" },
            "border": { "type": "string" },
            "padding": { "type": "string" },
            "hoverEffect": { "type": "string", "enum": ["lift", "scale", "border", "none"] }
          }
        },
        "inputs": {
          "type": "object",
          "properties": {
            "borderRadius": { "type": "string" },
            "border": { "type": "string" },
            "focusBorder": { "type": "string" },
            "padding": { "type": "string" },
            "background": { "type": "string" }
          }
        },
        "badges": {
          "type": "object",
          "properties": {
            "borderRadius": { "type": "string" },
            "padding": { "type": "string" },
            "fontSize": { "type": "string" },
            "fontWeight": { "type": "string" }
          }
        },
        "navigation": {
          "type": "object",
          "properties": {
            "itemSpacing": { "type": "string" },
            "activeIndicator": { "type": "string", "enum": ["underline", "background", "border", "none"] },
            "dropdownStyle": { "type": "string", "enum": ["default", "mega", "flyout", "none"] }
          }
        },
        "productCard": {
          "type": "object",
          "properties": {
            "imageAspectRatio": { "type": "string" },
            "showBadges": { "type": "boolean" },
            "showQuickView": { "type": "boolean" },
            "showAddToCart": { "type": "boolean" },
            "showWishlist": { "type": "boolean" },
            "showRating": { "type": "boolean" },
            "hoverEffect": { "type": "string", "enum": ["zoom", "second-image", "overlay", "none"] }
          }
        }
      }
    },
    "componentStyle": {
      "type": "object",
      "properties": {
        "borderRadius": { "type": "string" },
        "padding": { "type": "string" },
        "fontWeight": { "type": "string" },
        "shadow": { "type": "string" }
      }
    },
    "fonts": {
      "type": "object",
      "properties": {
        "heading": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "weight": { "type": "string" },
            "transform": { "type": "string" },
            "letterSpacing": { "type": "string" }
          }
        },
        "body": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "weight": { "type": "string" },
            "size": { "type": "string" },
            "lineHeight": { "type": "string" }
          }
        },
        "accent": {
          "type": "object",
          "properties": {
            "family": { "type": "string" },
            "weight": { "type": "string" }
          }
        }
      }
    },
    "spacing": {
      "type": "object",
      "properties": {
        "sectionPadding": { "type": "string" },
        "containerWidth": { "type": "string" },
        "gridGap": { "type": "string" },
        "cardGap": { "type": "string" }
      }
    },
    "effects": {
      "type": "object",
      "properties": {
        "shadows": {
          "type": "object",
          "properties": {
            "sm": { "type": "string" },
            "md": { "type": "string" },
            "lg": { "type": "string" },
            "xl": { "type": "string" }
          }
        },
        "borderRadius": {
          "type": "object",
          "properties": {
            "none": { "type": "string" },
            "sm": { "type": "string" },
            "md": { "type": "string" },
            "lg": { "type": "string" },
            "xl": { "type": "string" },
            "full": { "type": "string" }
          }
        },
        "transitions": {
          "type": "object",
          "properties": {
            "fast": { "type": "string" },
            "normal": { "type": "string" },
            "slow": { "type": "string" }
          }
        },
        "animations": {
          "type": "object",
          "properties": {
            "entrance": { "type": "string", "enum": ["fade", "slide-up", "slide-down", "scale", "none"] },
            "hover": { "type": "string", "enum": ["lift", "glow", "color", "none"] }
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "version": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "compatibility": {
          "type": "object",
          "properties": {
            "minVersion": { "type": "string" },
            "features": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
