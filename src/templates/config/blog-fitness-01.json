{
  "id": "blog-fitness-01",
  "name": "Blog Fitness Health",
  "category": "blog",
  "subcategory": "fitness",
  "description": "Fitness and health blog with energetic design",
  "version": "1.0.0",
  "tags": ["blog", "fitness", "health", "workout"],
  "components": {
    "header": {
      "layout": "energy-light",
      "logo": { "type": "bold", "position": "center" },
      "navigation": { "type": "categories", "position": "below" },
      "actions": ["programs", "newsletter"]
    },
    "footer": {
      "layout": "fit-dark",
      "columns": ["workouts", "nutrition", "mindset", "social"]
    },
    "postCard": { "layout": "workout-preview" }
  },
  "pages": {
    "home": { "layout": "fit-life", "sections": ["hero", "workouts", "nutrition", "mindset", "community"] },
    "category": { "layout": "workout-grid" },
    "post": { "layout": "workout-detail" }
  },
  "colors": {
    "primary": "#FF5722",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 4px 12px rgba(255,87,34,0.15)" }
}
