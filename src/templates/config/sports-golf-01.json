{
  "id": "sports-golf-01",
  "name": "Sports Golf",
  "category": "sports",
  "subcategory": "golf",
  "description": "Golf shop with country club aesthetic",
  "version": "1.0.0",
  "tags": ["sports", "golf", "country-club", "equipment"],
  "components": {
    "header": {
      "layout": "club-dark",
      "logo": { "type": "classic", "position": "center" },
      "navigation": { "type": "gear-types", "position": "below" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "fairway-dark",
      "columns": ["clubs", "apparel", "bags", "lessons"]
    },
    "productCard": { "layout": "course-ready" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "club-life", "sections": ["hero", "new", "clubs", "apparel", "lessons"] },
    "category": { "layout": "gear-grid" },
    "product": { "layout": "spec-detail" }
  },
  "colors": {
    "primary": "#1B5E20",
    "secondary": "#263238",
    "accent": "#D4AF37",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Roboto Slab", "weight": "500" },
    "body": { "font": "Roboto", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "0 4px 15px rgba(27,94,32,0.25)" }
}
