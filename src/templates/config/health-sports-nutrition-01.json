    "category": { "layout": "filter-grid" },
    "product": { "layout": "nutrition facts" }
  },
  "colors": {
    "primary": "#FF6D00",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#121212",
    "surface": "#1E1E1E",
    "text": "#FFFFFF",
    "textMuted": "#B0B0B0"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "500" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
