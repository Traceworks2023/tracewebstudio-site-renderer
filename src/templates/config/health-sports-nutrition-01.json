{
  "id": "health-sports-nutrition-01",
  "name": "Health Sports Nutrition",
  "category": "health",
  "subcategory": "sports-nutrition",
  "description": "Sports nutrition and supplements store",
  "version": "1.0.0",
  "tags": ["health", "nutrition", "supplements", "fitness"],
  "components": {
    "header": {
      "layout": "power-dark",
      "logo": { "type": "image", "position": "left" },
      "navigation": { "type": "categories", "position": "center" },
      "actions": ["search", "account", "cart"]
    },
    "footer": {
      "layout": "performance-dark",
      "columns": ["protein", "preworkout", "recovery", "nutrition"]
    },
    "productCard": { "layout": "label-focused", "showNutrition": true },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
