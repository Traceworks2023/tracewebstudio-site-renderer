{
  "id": "blog-news-local-01",
  "name": "Blog Local News",
  "category": "blog",
  "subcategory": "local-news",
  "description": "Local news publication with community focus",
  "version": "1.0.0",
  "tags": ["blog", "news", "local", "community"],
  "components": {
    "header": {
      "layout": "news-header",
      "logo": { "type": "masthead", "position": "center" },
      "navigation": { "type": "sections", "position": "below" },
      "actions": ["subscribe"]
    },
    "footer": {
      "layout": "community-dark",
      "columns": ["news", "events", "about", "contact"]
    },
    "articleCard": { "layout": "headline-local" }
  },
  "pages": {
    "home": { "layout": "local-news", "sections": ["hero", "top-stories", "local", "events", "opinion"] },
    "section": { "layout": "news-feed" },
    "article": { "layout": "local-article" }
  },
  "colors": {
    "primary": "#1565C0",
    "secondary": "#1A1A1A",
    "accent": "#FF6F00",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Roboto Slab", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "none" }
}
