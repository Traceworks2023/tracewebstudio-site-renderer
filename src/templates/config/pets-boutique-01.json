{
  "id": "pets-boutique-01",
  "name": "Pets Boutique",
  "category": "pets",
  "subcategory": "boutique",
  "description": "Pet boutique with luxury accessories and treats",
  "version": "1.0.0",
  "tags": ["pets", "boutique", "luxury", "accessories"],
  "components": {
    "header": {
      "layout": "pampered-light",
      "logo": { "type": "cute", "position": "center" },
      "navigation": { "type": "categories", "position": "below" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "paw-dark",
      "columns": ["apparel", "accessories", "treats", "about"]
    },
    "productCard": { "layout": "pet-photo" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "pampered-pets", "sections": ["hero", "apparel", "accessories", "treats", "gifts"] },
    "category": { "layout": "pet-gallery" },
    "product": { "layout": "pet-detail" }
  },
  "colors": {
    "primary": "#AB47BC",
    "secondary": "#F3E5F5",
    "accent": "#FF7043",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#4A148C",
    "textMuted": "#7B1FA2"
  },
  "typography": {
    "heading": { "font": "Fredoka One", "weight": "400" },
    "body": { "font": "Nunito", "weight": "600" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "20px", "cards": "12px" },
  "shadows": { "cards": "0 4px 15px rgba(171,71,188,0.15)" }
}
