{
  "id": "business-travel-agency-01",
  "name": "Business Travel Agency",
  "category": "business",
  "subcategory": "travel-agency",
  "description": "Luxury travel agency with wanderlust-inspiring design",
  "version": "1.0.0",
  "tags": ["business", "travel", "agency", "luxury"],
  "components": {
    "header": {
      "layout": "wanderlust-dark",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "destinations", "position": "below" },
      "actions": ["plan-trip"]
    },
    "footer": {
      "layout": "adventure-dark",
      "columns": ["destinations", "experiences", "about", "contact"]
    },
    "destinationCard": { "layout": "landscape-photo" },
    "tripForm": { "layout": "itinerary-builder" }
  },
  "pages": {
    "home": { "layout": "dream-trip", "sections": ["hero", "destinations", "experiences", "testimonials", "plan"] },
    "destinations": { "layout": "map-gallery" },
    "trip": { "layout": "itinerary-detail" }
  },
  "colors": {
    "primary": "#00796B",
    "secondary": "#263238",
    "accent": "#FFB300",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#B0B0B0"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "300" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 5px 20px rgba(0,121,107,0.3)" }
}
