{
  "id": "art-photography-gallery-01",
  "name": "Art Photography Gallery",
  "category": "art",
  "subcategory": "photography",
  "description": "Fine art photography gallery with dramatic presentation",
  "version": "1.0.0",
  "tags": ["art", "photography", "fine-art", "gallery"],
  "components": {
    "header": {
      "layout": "photo-dark",
      "logo": { "type": "text", "position": "center" },
      "navigation": { "type": "series", "position": "below" },
      "actions": ["collect"]
    },
    "footer": {
      "layout": "print-dark",
      "columns": ["series", "photographers", "prints", "contact"]
    },
    "photoCard": { "layout": "large-print" }
  },
  "pages": {
    "home": { "layout": "photo-exhibition", "sections": ["hero", "featured", "series", "photographers", "collect"] },
    "series": { "layout": "photo-wall" },
    "photograph": { "layout": "print-detail" }
  },
  "colors": {
    "primary": "#424242",
    "secondary": "#1A1A1A",
    "accent": "#BDBDBD",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Roboto Condensed", "weight": "300" },
    "body": { "font": "Roboto", "weight": "300" }
  },
  "spacing": { "base": "16px", "section": "100px" },
  "borderRadius": { "buttons": "0px", "cards": "0px" },
  "shadows": { "cards": "none" }
}
