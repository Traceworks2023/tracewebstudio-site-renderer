{
  "id": "blog-parenting-01",
  "name": "Blog Parenting",
  "category": "blog",
  "subcategory": "parenting",
  "description": "Parenting blog with supportive, warm community feel",
  "version": "1.0.0",
  "tags": ["blog", "parenting", "family", "community"],
  "components": {
    "header": {
      "layout": "parenting-light",
      "logo": { "type": "warm", "position": "center" },
      "navigation": { "type": "stages", "position": "below" },
      "actions": ["community", "newsletter"]
    },
    "footer": {
      "layout": "community-light",
      "columns": ["stages", "advice", "community", "about"]
    },
    "postCard": { "layout": "advice-card" }
  },
  "pages": {
    "home": { "layout": "parent-hub", "sections": ["hero", "advice", "stages", "community", "newsletter"] },
    "category": { "layout": "stage-posts" },
    "post": { "layout": "advice-article" }
  },
  "colors": {
    "primary": "#AB47BC",
    "secondary": "#F3E5F5",
    "accent": "#26A69A",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#4A148C",
    "textMuted": "#7B1FA2"
  },
  "typography": {
    "heading": { "font": "Quicksand", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "25px", "cards": "12px" },
  "shadows": { "cards": "0 3px 10px rgba(171,71,188,0.12)" }
}
