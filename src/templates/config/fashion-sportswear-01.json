{
  "id": "fashion-sportswear-01",
  "name": "Fashion Sportswear",
  "category": "fashion",
  "subcategory": "sportswear",
  "description": "Athletic fashion and activewear store",
  "version": "1.0.0",
  "tags": ["fashion", "sportswear", "athletic", "activewear"],
  "components": {
    "header": {
      "layout": "active-dark",
      "logo": { "type": "bold", "position": "left" },
      "navigation": { "type": "activity", "position": "center" },
      "actions": ["search", "account", "cart"]
    },
    "footer": {
      "layout": "energy-dark",
      "columns": ["women", "men", "gear", "training"]
    },
    "productCard": { "layout": "action-shot" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "get-active", "sections": ["hero", "women", "men", "gear", "training"] },
    "category": { "layout": "activity-grid" },
    "product": { "layout": "tech-detail" }
  },
  "colors": {
    "primary": "#FF5722",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#B0B0B0"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "500" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 4px 15px rgba(255,87,34,0.2)" }
}
