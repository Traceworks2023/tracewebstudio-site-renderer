{
  "id": "blog-lifestyle-01",
  "name": "Blog Lifestyle",
  "category": "blog",
  "subcategory": "lifestyle",
  "description": "Lifestyle blog with warm, personal aesthetic",
  "version": "1.0.0",
  "tags": ["blog", "lifestyle", "personal", "inspiration"],
  "components": {
    "header": {
      "layout": "warm-minimal",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "categories", "position": "below" },
      "actions": ["about", "contact"]
    },
    "footer": {
      "layout": "connect-light",
      "columns": ["categories", "about", "social", "newsletter"]
    },
    "postCard": { "layout": "lifestyle-featured" }
  },
  "pages": {
    "home": { "layout": "life-stories", "sections": ["hero", "recent", "categories", "about", "connect"] },
    "category": { "layout": "masonry-posts" },
    "post": { "layout": "story-view" }
  },
  "colors": {
    "primary": "#8D6E63",
    "secondary": "#EFEBE9",
    "accent": "#E91E63",
    "background": "#FFFBF5",
    "surface": "#FFFFFF",
    "text": "#4E342E",
    "textMuted": "#6D4C41"
  },
  "typography": {
    "heading": { "font": "Cormorant Garamond", "weight": "400" },
    "body": { "font": "Nunito", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "30px", "cards": "8px" },
  "shadows": { "cards": "0 3px 10px rgba(0,0,0,0.06)" }
}
