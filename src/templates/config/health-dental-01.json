  },
  "colors": {
    "primary": "#00BCD4",
    "secondary": "#E0F7FA",
    "accent": "#FFFFFF",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#37474F",
    "textMuted": "#78909C"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
