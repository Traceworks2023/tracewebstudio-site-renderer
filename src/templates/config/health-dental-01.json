{
  "id": "health-dental-01",
  "name": "Health Dental",
  "category": "health",
  "subcategory": "dental",
  "description": "Dental practice with clean, trustworthy design",
  "version": "1.0.0",
  "tags": ["health", "dental", "dentist", "smile"],
  "components": {
    "header": {
      "layout": "clean-light",
