{
  "id": "blog-food-recipes-01",
  "name": "Blog Food Recipes",
  "category": "blog",
  "subcategory": "recipes",
  "description": "Food recipe blog with beautiful photography",
  "version": "1.0.0",
  "tags": ["blog", "food", "recipes", "cooking"],
  "components": {
    "header": {
      "layout": "culinary-light",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "meal-types", "position": "below" },
      "actions": ["recipes", "newsletter"]
    },
    "footer": {
      "layout": "kitchen-light",
      "columns": ["recipes", "techniques", "equipment", "about"]
    },
    "recipeCard": { "layout": "dish-photo" }
  },
  "pages": {
    "home": { "layout": "taste", "sections": ["hero", "seasonal", "categories", "technique", "newsletter"] },
    "category": { "layout": "recipe-grid" },
    "recipe": { "layout": "recipe-detail" }
  },
  "colors": {
    "primary": "#5D4037",
    "secondary": "#FFF8E1",
    "accent": "#8D6E63",
    "background": "#FFFBF5",
    "surface": "#FFFFFF",
    "text": "#4E342E",
    "textMuted": "#6D4C41"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 3px 10px rgba(0,0,0,0.06)" }
}
