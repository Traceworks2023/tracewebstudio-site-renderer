{
  "id": "fashion-outdoor-01",
  "name": "Fashion Outdoor",
  "category": "fashion",
  "subcategory": "outdoor",
  "description": "Outdoor and hiking apparel with adventure design",
  "version": "1.0.0",
  "tags": ["fashion", "outdoor", "hiking", "adventure"],
  "components": {
    "header": {
      "layout": "trail-ready",
      "logo": { "type": "bold", "position": "left" },
      "navigation": { "type": "activity", "position": "center" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "summit-dark",
      "columns": ["hiking", "climbing", "camping", "apparel"]
    },
    "productCard": { "layout": "trail-shot" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "adventure", "sections": ["hero", "hiking", "climbing", "camping", "apparel"] },
    "category": { "layout": "gear-grid" },
    "product": { "layout": "terrain-detail" }
  },
  "colors": {
    "primary": "#2E7D32",
    "secondary": "#1A1A1A",
    "accent": "#FF6F00",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Bebas Neue", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "500" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "0 4px 15px rgba(46,125,50,0.25)" }
}
