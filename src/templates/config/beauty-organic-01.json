{
  "id": "beauty-organic-01",
  "name": "Beauty Organic",
  "category": "beauty",
  "subcategory": "organic-natural",
  "description": "Natural and organic beauty products with earthy aesthetic",
  "version": "1.0.0",
  "tags": ["beauty", "organic", "natural", "skincare"],
  "components": {
    "header": {
      "layout": "natural-light",
      "logo": { "type": "image", "position": "center" },
      "navigation": { "type": "centered", "position": "below" },
      "actions": ["search", "account", "cart"]
    },
    "footer": {
      "layout": "earthy-dark",
      "columns": ["about", "ingredients", "shop", "contact"]
    },
    "productCard": { "layout": "organic-card", "showIngredients": true },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "ingredients-story", "sections": ["hero", "philosophy", "bestsellers", "ingredients", "reviews"] },
    "category": { "layout": "grid-3col" },
    "product": { "layout": "ingredients-first" }
  },
  "colors": {
    "primary": "#7CB342",
    "secondary": "#F5F0E8",
    "accent": "#8D6E63",
    "background": "#FFFEF9",
    "surface": "#F5F0E8",
    "text": "#3E3E3E",
    "textMuted": "#7A7A7A"
  },
  "typography": {
    "heading": { "font": "Serif", "weight": "600" },
    "body": { "font": "Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "30px", "cards": "20px" },
  "shadows": { "cards": "0 4px 12px rgba(0,0,0,0.06)" }
}
