{
  "id": "business-healthcare-01",
  "name": "Business Healthcare",
  "category": "business",
  "subcategory": "healthcare",
  "description": "Healthcare provider with clean, accessible design",
  "version": "1.0.0",
  "tags": ["business", "healthcare", "medical", "doctor"],
  "components": {
    "header": {
      "layout": "medical-clean",
      "logo": { "type": "image", "position": "left" },
      "navigation": { "type": "services", "position": "center" },
      "actions": ["emergency", "appointments"]
    },
    "footer": {
      "layout": "care-info",
      "columns": ["services", "locations", "resources", "contact"]
    },
    "serviceCard": { "layout": "care-card" },
    "appointmentForm": { "layout": "easy-book" }
  },
  "pages": {
    "home": { "layout": "patient-focused", "sections": ["hero", "services", "providers", "locations", "appointments"] },
    "services": { "layout": "service-directory" },
    "appointments": { "layout": "booking-flow" }
  },
  "colors": {
    "primary": "#00897B",
    "secondary": "#E0F2F1",
    "accent": "#FF7043",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#37474F",
    "textMuted": "#78909C"
  },
  "typography": {
    "heading": { "font": "Roboto", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 2px 8px rgba(0,0,0,0.08)" }
}
