{
  "id": "food-meat-01",
  "name": "Food Premium Meats",
  "category": "food",
  "subcategory": "premium-meats",
  "description": "Premium butcher shop with high-quality meats and specialty cuts",
  "version": "1.0.0",
  "tags": ["food", "meat", "butcher", "premium"],
  "components": {
    "header": {
      "layout": "rustic-modern",
      "logo": { "type": "image", "position": "center" },
      "navigation": { "type": "cuts", "position": "below" },
      "actions": ["cart"]
    },
    "footer": {
      "layout": "dark-wood",
      "columns": ["cuts", "recipes", "about", "contact"]
    },
    "productCard": { "layout": "meat-photo", "showGrade": true },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "butcher-block", "sections": ["hero", "prime-cuts", " bundles", "recipes", "story"] },
    "category": { "layout": "grid-cuts" },
    "product": { "layout": "detailed-cut" }
  },
  "colors": {
    "primary": "#B71C1C",
    "secondary": "#3E2723",
    "accent": "#FFD54F",
    "background": "#F5F5F5",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Oswald", "weight": "500" },
    "body": { "font": "Roboto", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "0 2px 6px rgba(0,0,0,0.1)" }
}
