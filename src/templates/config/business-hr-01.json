{
  "id": "business-hr-01",
  "name": "Business HR Services",
  "category": "business",
  "subcategory": "hr-services",
  "description": "Human resources consultancy with professional approach",
  "version": "1.0.0",
  "tags": ["business", "hr", "recruitment", "consulting"],
  "components": {
    "header": {
      "layout": "corporate-light",
      "logo": { "type": "text", "position": "left" },
      "navigation": { "type": "services", "position": "center" },
      "actions": ["contact", "login"]
    },
    "footer": {
      "layout": "professional-dark",
      "columns": ["services", "insights", "careers", "contact"]
    },
    "serviceCard": { "layout": "consulting-card" },
    "insightCard": { "layout": "article-preview" }
  },
  "pages": {
    "home": { "layout": "people-first", "sections": ["hero", "services", "insights", "clients", "contact"] },
    "services": { "layout": "service-detail" },
    "careers": { "layout": "job-listings" }
  },
  "colors": {
    "primary": "#5C6BC0",
    "secondary": "#E8EAF6",
    "accent": "#00ACC1",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "500" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 2px 8px rgba(0,0,0,0.08)" }
}
