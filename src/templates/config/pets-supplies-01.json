{
  "id": "pets-supplies-01",
  "name": "Pets Supplies",
  "category": "pets",
  "subcategory": "supplies",
  "description": "Pet supplies with practical, pet-friendly design",
  "version": "1.0.0",
  "tags": ["pets", "supplies", "food", "toys"],
  "components": {
    "header": {
      "layout": "pet-friendly",
      "logo": { "type": "bold", "position": "left" },
      "navigation": { "type": "pet-types", "position": "center" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "animal-dark",
      "columns": ["dogs", "cats", "birds", "fish"]
    },
    "productCard": { "layout": "supply-photo" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "happy-pets", "sections": ["hero", "dogs", "cats", "deals", "brands"] },
    "category": { "layout": "pet-grid" },
    "product": { "layout": "supply-detail" }
  },
  "colors": {
    "primary": "#4CAF50",
    "secondary": "#E8F5E9",
    "accent": "#FF9800",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#1B5E20",
    "textMuted": "#388E3C"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 2px 8px rgba(0,0,0,0.08)" }
}
