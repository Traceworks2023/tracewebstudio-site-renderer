{
  "id": "portfolio-events-01",
  "name": "Portfolio Events Planner",
  "category": "portfolio",
  "subcategory": "events",
  "description": "Events planner portfolio with celebration aesthetic",
  "version": "1.0.0",
  "tags": ["portfolio", "events", "planner", "celebration"],
  "components": {
    "header": {
      "layout": "celebration",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "event-types", "position": "below" },
      "actions": ["inquiries"]
    },
    "footer": {
      "layout": "party-dark",
      "columns": ["corporate", "social", "weddings", "contact"]
    },
    "eventCard": { "layout": "celebration-photo" }
  },
  "pages": {
    "home": { "layout": "create-memories", "sections": ["hero", "events", "testimonials", "process", "inquiries"] },
    "events": { "layout": "gallery-grid" },
    "event": { "layout": "detail-gallery" }
  },
  "colors": {
    "primary": "#E91E63",
    "secondary": "#1A1A1A",
    "accent": "#FFD54F",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Great Vibes", "weight": "400" },
    "body": { "font": "Montserrat", "weight": "300" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "30px", "cards": "8px" },
  "shadows": { "cards": "0 5px 25px rgba(233,30,99,0.25)" }
}
