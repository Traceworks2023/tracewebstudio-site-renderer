{
  "id": "books-children-01",
  "name": "Books Children",
  "category": "books",
  "subcategory": "children",
  "description": "Children's books with colorful, illustrated design",
  "version": "1.0.0",
  "tags": ["books", "children", "kids", "illustrated"],
  "components": {
    "header": {
      "layout": "storybook-light",
      "logo": { "type": "fun", "position": "center" },
      "navigation": { "type": "age-groups", "position": "below" },
      "actions": ["search", "cart"]
    },
    "footer": {
      "layout": "reading-fun",
      "columns": ["picture", "chapter", "series", "gifts"]
    },
    "bookCard": { "layout": "cover-illustrated" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "story-time", "sections": ["hero", "picture-books", "age-7-12", "series", "gifts"] },
    "category": { "layout": "age-graded" },
    "book": { "layout": "story-preview" }
  },
  "colors": {
    "primary": "#FF9800",
    "secondary": "#E3F2FD",
    "accent": "#E91E63",
    "background": "#FFFFF5",
    "surface": "#FFFFFF",
    "text": "#37474F",
    "textMuted": "#78909C"
  },
  "typography": {
    "heading": { "font": "Fredoka One", "weight": "400" },
    "body": { "font": "Nunito", "weight": "600" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "20px", "cards": "16px" },
