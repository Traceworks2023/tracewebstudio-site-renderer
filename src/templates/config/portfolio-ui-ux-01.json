{
  "id": "portfolio-ui-ux-01",
  "name": "Portfolio UI/UX Designer",
  "category": "portfolio",
  "subcategory": "ui-ux",
  "description": "UI/UX designer portfolio with clean, process-focused design",
  "version": "1.0.0",
  "tags": ["portfolio", "ui-ux", "designer", "product"],
  "components": {
    "header": {
      "layout": "design-light",
      "logo": { "type": "name", "position": "left" },
      "navigation": { "type": "work-process", "position": "center" },
      "actions": ["resume", "contact"]
    },
    "footer": {
      "layout": "design-dark",
      "columns": ["work", "process", "about", "social"]
    },
    "projectCard": { "layout": "case-study" }
