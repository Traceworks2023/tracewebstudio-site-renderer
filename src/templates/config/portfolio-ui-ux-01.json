    "work": { "layout": "case-study-grid" },
    "project": { "layout": "full-case-study" }
  },
  "colors": {
    "primary": "#1A1A1A",
    "secondary": "#FFFFFF",
    "accent": "#00E676",
    "background": "#FFFFFF",
    "surface": "#F5F5F5",
    "text": "#1A1A1A",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Inter", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "8px", "cards": "8px" },
  "shadows": { "cards": "0 2px 8px rgba(0,0,0,0.08)" }
