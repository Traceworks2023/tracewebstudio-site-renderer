{
  "id": "blog-diy-01",
  "name": "Blog DIY Crafts",
  "category": "blog",
  "subcategory": "diy-crafts",
  "description": "DIY and crafts blog with colorful, creative design",
  "version": "1.0.0",
  "tags": ["blog", "diy", "crafts", "creative"],
  "components": {
    "header": {
      "layout": "crafty-light",
      "logo": { "type": "handwritten", "position": "center" },
      "navigation": { "type": "categories", "position": "below" },
      "actions": ["tutorials", "newsletter"]
    },
    "footer": {
      "layout": "creative-light",
      "columns": ["tutorials", "supplies", "community", "social"]
    },
    "postCard": { "layout": "project-preview" }
  },
  "pages": {
    "home": { "layout": "craft-corner", "sections": ["hero", "featured", "categories", "tutorials", "newsletter"] },
    "category": { "layout": "project-grid" },
    "post": { "layout": "tutorial-view" }
  },
  "colors": {
    "primary": "#FF7043",
    "secondary": "#FFF3E0",
    "accent": "#8D6E63",
    "background": "#FFFAF5",
    "surface": "#FFFFFF",
    "text": "#4E342E",
    "textMuted": "#6D4C41"
  },
  "typography": {
    "heading": { "font": "Chewy", "weight": "400" },
    "body": { "font": "Nunito", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "20px", "cards": "12px" },
  "shadows": { "cards": "0 4px 12px rgba(255,112,67,0.15)" }
}
