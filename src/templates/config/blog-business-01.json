{
  "id": "blog-business-01",
  "name": "Blog Business Insights",
  "category": "blog",
  "subcategory": "business-insights",
  "description": "Business insights blog with executive-focused design",
  "version": "1.0.0",
  "tags": ["blog", "business", "insights", "executive"],
  "components": {
    "header": {
      "layout": "executive-dark",
      "logo": { "type": "professional", "position": "center" },
      "navigation": { "type": "topics", "position": "below" },
      "actions": ["newsletter"]
    },
    "footer": {
      "layout": "insights-dark",
      "columns": ["strategy", "leadership", "innovation", "about"]
    },
    "articleCard": { "layout": "insight-card" }
  },
  "pages": {
    "home": { "layout": "executive-reads", "sections": ["hero", "featured", "strategy", "leadership", "newsletter"] },
    "category": { "layout": "insight-grid" },
    "article": { "layout": "executive-article" }
  },
  "colors": {
    "primary": "#1A237E",
    "secondary": "#1A1A1A",
    "accent": "#00ACC1",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Roboto Slab", "weight": "500" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "0px" },
  "shadows": { "cards": "0 4px 15px rgba(0,0,0,0.3)" }
}
