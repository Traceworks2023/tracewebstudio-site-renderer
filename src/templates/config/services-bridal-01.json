{
  "id": "services-bridal-01",
  "name": "Services Bridal Shop",
  "category": "services",
  "subcategory": "bridal",
  "description": "Bridal shop with romantic, gown-focused design",
  "version": "1.0.0",
  "tags": ["services", "bridal", "gown", "wedding"],
  "components": {
    "header": {
      "layout": "bride-light",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "collections", "position": "below" },
      "actions": ["appointments"]
    },
    "footer": {
      "layout": "gown-dark",
      "columns": ["gowns", "accessories", "appointments", "contact"]
    },
    "gownCard": { "layout": "gown-photo" },
    "appointmentForm": { "layout": "bridal-consultation" }
  },
  "pages": {
    "home": { "layout": "say-yes", "sections": ["hero", "gowns", "accessories", "appointments", "about"] },
    "gowns": { "layout": "gown-gallery" },
    "appointment": { "layout": "consultation-form" }
  },
  "colors": {
    "primary": "#E91E63",
    "secondary": "#FCE4EC",
    "accent": "#D4AF37",
    "background": "#FFFBF5",
    "surface": "#FFFFFF",
    "text": "#4A148C",
    "textMuted": "#7B1FA2"
  },
  "typography": {
    "heading": { "font": "Great Vibes", "weight": "400" },
    "body": { "font": "Cormorant Garamond", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "30px", "cards": "8px" },
  "shadows": { "cards": "0 5px 25px rgba(233,30,99,0.15)" }
}
