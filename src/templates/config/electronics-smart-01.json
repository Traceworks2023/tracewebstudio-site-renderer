{
  "id": "electronics-smart-01",
  "name": "Electronics Smart",
  "category": "electronics",
  "subcategory": "smart-home",
  "description": "Modern smart home electronics store with tech-forward design",
  "version": "1.0.0",
  "tags": ["electronics", "smart-home", "tech", "gadgets"],
  "components": {
    "header": {
      "layout": "transparent-dark",
      "logo": { "type": "image", "position": "left" },
      "navigation": { "type": "mega-menu", "position": "center" },
      "actions": ["search", "account", "cart"]
    },
    "footer": {
      "layout": "multi-column-dark",
      "columns": ["about", "links", "support", "newsletter"]
    },
    "productCard": { "layout": "hover-zoom", "showQuickView": true },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "hero-carousel", "sections": ["hero", "featured-categories", "new-arrivals", "best-sellers", "promo-banner", "testimonials"] },
    "category": { "layout": "grid-sidebar", "sidebar": "filters" },
    "product": { "layout": "gallery-left", "stickyAtc": true }
  },
  "colors": {
    "primary": "#00D4AA",
    "secondary": "#1A1A2E",
    "accent": "#FF6B6B",
    "background": "#0F0F1A",
    "surface": "#16213E",
    "text": "#EAEAEA",
    "textMuted": "#8892B0"
  },
  "typography": {
    "heading": { "font": "Inter", "weight": "700" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "8px", "cards": "12px" },
  "shadows": { "cards": "0 4px 20px rgba(0,0,0,0.3)" }
}
