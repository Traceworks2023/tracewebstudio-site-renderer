{
  "id": "blog-travel-01",
  "name": "Blog Travel Stories",
  "category": "blog",
  "subcategory": "travel",
  "description": "Travel blog with beautiful destination photography",
  "version": "1.0.0",
  "tags": ["blog", "travel", "adventure", "destinations"],
  "components": {
    "header": {
      "layout": "wanderer-light",
      "logo": { "type": "script", "position": "center" },
      "navigation": { "type": "destinations", "position": "below" },
      "actions": ["newsletter"]
    },
    "footer": {
      "layout": "adventure-light",
      "columns": ["destinations", "travel-tips", "about", "social"]
    },
    "postCard": { "layout": "destination-featured" }
  },
  "pages": {
    "home": { "layout": "travel-journal", "sections": ["hero", "featured", "destinations", "tips", "newsletter"] },
    "destinations": { "layout": "map-grid" },
    "post": { "layout": "travel-story" }
  },
  "colors": {
    "primary": "#00796B",
    "secondary": "#E0F2F1",
    "accent": "#FF7043",
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "text": "#37474F",
    "textMuted": "#78909C"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "20px", "cards": "8px" },
  "shadows": { "cards": "0 4px 15px rgba(0,0,0,0.08)" }
}
