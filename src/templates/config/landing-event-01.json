{
  "id": "landing-event-01",
  "name": "Landing Event Conference",
  "category": "landing",
  "subcategory": "conference",
  "description": "Conference event landing page with schedule focus",
  "version": "1.0.0",
  "tags": ["landing", "event", "conference", "schedule"],
  "components": {
    "header": {
      "layout": "event-dark",
      "logo": { "type": "bold", "position": "center" },
      "navigation": { "type": "schedule", "position": "below" },
      "actions": ["register"]
    },
    "footer": {
      "layout": "venue-dark",
      "columns": ["speakers", "schedule", "venue", "sponsors"]
    },
    "speakerCard": { "layout": "bio-headshot" },
    "scheduleCard": { "layout": "session-info" }
  },
  "pages": {
    "home": { "layout": "conference", "sections": ["hero", "speakers", "schedule", "sponsors", "register"] }
  },
  "colors": {
    "primary": "#7C4DFF",
    "secondary": "#1A1A1A",
    "accent": "#FFD54F",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#888888"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 8px 40px rgba(124,77,255,0.25)" }
}
