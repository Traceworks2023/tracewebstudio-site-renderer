{
  "id": "realestate-residential-01",
  "name": "Real Estate Residential",
  "category": "realestate",
  "subcategory": "residential",
  "description": "Residential real estate with modern home listings",
  "version": "1.0.0",
  "tags": ["realestate", "residential", "homes", "listings"],
  "components": {
    "header": {
      "layout": "professional",
      "logo": { "type": "image", "position": "left" },
      "navigation": { "type": "property-types", "position": "center" },
      "actions": ["search", "contact"]
    },
    "footer": {
      "layout": "agency-dark",
      "columns": ["buy", "sell", "rent", "agents"]
    },
    "propertyCard": { "layout": "listing-card", "showDetails": true },
    "searchForm": { "layout": "advanced-filter" }
  },
  "pages": {
    "home": { "layout": "property-showcase", "sections": ["hero", "featured", "neighborhoods", "sold", "agents"] },
    "listings": { "layout": "split-map" },
    "property": { "layout": "gallery-tour" }
  },
  "colors": {
    "primary": "#1565C0",
    "secondary": "#263238",
    "accent": "#00897B",
    "background": "#F5F5F5",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Roboto Slab", "weight": "500" },
    "body": { "font": "Open Sans", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "4px", "cards": "8px" },
  "shadows": { "cards": "0 2px 10px rgba(0,0,0,0.1)" }
}
