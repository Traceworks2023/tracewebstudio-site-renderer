{
  "id": "landing-ebook-02",
  "name": "Landing Ebook Light",
  "category": "landing",
  "subcategory": "ebook",
  "description": "Ebook download landing page with light theme",
  "version": "1.0.0",
  "tags": ["landing", "ebook", "light", "conversion"],
  "components": {
    "header": {
      "layout": "minimal-light",
      "logo": { "type": "text", "position": "center" },
      "navigation": { "type": "none" },
      "actions": []
    },
    "footer": {
      "layout": "minimal-light",
      "columns": ["privacy", "terms"]
    },
    "ctaForm": { "layout": "lead-capture-light" }
  },
  "pages": {
    "home": { "layout": "book-magnet-light", "sections": ["headline", "cover", "benefits", "testimonials", "download"] }
  },
  "colors": {
    "primary": "#5C6BC0",
    "secondary": "#FFFFFF",
    "accent": "#FF6B6B",
    "background": "#F5F5F5",
    "surface": "#FFFFFF",
    "text": "#1A1A1A",
    "textMuted": "#666666"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "8px", "cards": "12px" },
  "shadows": { "cards": "0 8px 40px rgba(92,107,192,0.2)" }
}
