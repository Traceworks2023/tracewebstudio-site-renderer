{
  "id": "fashion-vintage-01",
  "name": "Fashion Vintage",
  "category": "fashion",
  "subcategory": "vintage",
  "description": "Vintage fashion with retro aesthetic",
  "version": "1.0.0",
  "tags": ["fashion", "vintage", "retro", "thrift"],
  "components": {
    "header": {
      "layout": "retro-light",
      "logo": { "type": "retro", "position": "center" },
      "navigation": { "type": "eras", "position": "below" },
      "actions": ["cart"]
    },
    "footer": {
      "layout": "vintage-dark",
      "columns": ["new-arrivals", "eras", "about", "newsletter"]
    },
    "productCard": { "layout": "retro-card" },
    "cartDrawer": { "layout": "slide-right" }
  },
  "pages": {
    "home": { "layout": "retro-revival", "sections": ["hero", "new-arrivals", "eras", "story", "newsletter"] },
    "category": { "layout": "era-grid" },
    "product": { "layout": "vintage-detail" }
  },
  "colors": {
    "primary": "#D4AF37",
    "secondary": "#FFF8E1",
    "accent": "#E91E63",
    "background": "#FFFBF5",
    "surface": "#FFF8E1",
    "text": "#5D4037",
    "textMuted": "#8D6E63"
  },
  "typography": {
    "heading": { "font": "Playfair Display", "weight": "400" },
    "body": { "font": "Lato", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "60px" },
  "borderRadius": { "buttons": "0px", "cards": "4px" },
  "shadows": { "cards": "0 3px 10px rgba(0,0,0,0.08)" }
}
