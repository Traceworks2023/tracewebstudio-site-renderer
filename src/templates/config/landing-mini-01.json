{
  "id": "landing-mini-01",
  "name": "Landing SaaS Feature",
  "category": "landing",
  "subcategory": "saas-feature",
  "description": "Single feature highlight landing page",
  "version": "1.0.0",
  "tags": ["landing", "saas", "feature", "product"],
  "components": {
    "header": {
      "layout": "minimal",
      "logo": { "type": "text", "position": "left" },
      "navigation": { "type": "none" },
      "actions": []
    },
    "footer": {
      "layout": "minimal",
      "columns": ["privacy", "terms"]
    },
    "featureShowcase": { "layout": "demo-video" }
  },
  "pages": {
    "home": { "layout": "feature-spotlight", "sections": ["headline", "demo", "benefits", "testimonial", "cta"] }
  },
  "colors": {
    "primary": "#00ACC1",
    "secondary": "#1A1A1A",
    "accent": "#00E676",
    "background": "#0D0D0D",
    "surface": "#1A1A1A",
    "text": "#FFFFFF",
    "textMuted": "#B0B0B0"
  },
  "typography": {
    "heading": { "font": "Poppins", "weight": "600" },
    "body": { "font": "Inter", "weight": "400" }
  },
  "spacing": { "base": "16px", "section": "80px" },
  "borderRadius": { "buttons": "8px", "cards": "12px" },
  "shadows": { "cards": "0 8px 40px rgba(0,172,193,0.25)" }
}
