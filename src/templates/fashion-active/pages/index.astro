---
// Fashion Active - Sportswear & Athletic Fashion
// Dynamic, energetic, performance-focused

const siteConfig = {
  site_name: 'PERFORM',
  site_tagline: 'Push Your Limits'
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  
  <!-- Google Fonts - Athletic/Fitness fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Russo+One&family=Roboto+Condensed:wght@300;400;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Russo One', 'sans-serif'],
            heading: ['Roboto Condensed', 'sans-serif'],
            body: ['Roboto', 'sans-serif'],
          },
          colors: {
            energy: '#00D4FF',
            power: '#FF3366',
            dark: '#0A0A0A',
            gym: '#1A1A1A'
          }
        }
      }
    }
  </script>
  
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Roboto', sans-serif; background: #0A0A0A; color: #fff; }
    .font-display { font-family: 'Russo One', sans-serif; }
    .font-heading { font-family: 'Roboto Condensed', sans-serif; }
    
    /* Energy glow */
    .energy-glow {
      box-shadow: 0 0 20px rgba(0, 212, 255, 0.5), 0 0 40px rgba(0, 212, 255, 0.3);
    }
    
    /* Gradient text */
    .gradient-text {
      background: linear-gradient(135deg, #00D4FF 0%, #FF3366 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    
    /* Animated border */
    .animated-border {
      position: relative;
    }
    .animated-border::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 3px;
      background: linear-gradient(90deg, #00D4FF, #FF3366);
      transition: width 0.3s ease;
    }
    .animated-border:hover::after {
      width: 100%;
    }
    
    /* Pulse animation */
    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.5; }
    }
    .pulse { animation: pulse 2s infinite; }
  </style>
</head>
<body class="min-h-screen flex flex-col bg-dark">
  <!-- Header -->
  <header class="bg-gym border-b border-gray-800 sticky top-0 z-50">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between h-16 md:h-20">
        <!-- Logo -->
        <a href="/" class="font-display text-2xl md:text-3xl tracking-wider text-white">
          {siteConfig.site_name}
        </a>
        
        <!-- Navigation -->
        <nav class="hidden lg:flex items-center space-x-1">
          {['New', 'Men', 'Women', 'Footwear', 'Equipment', 'Accessories'].map((item) => (
            <a 
              href={`/${item.toLowerCase()}`}
              class="font-heading text-sm tracking-wider text-gray-300 hover:text-energy px-4 py-2 animated-border transition-colors"
            >
              {item.toUpperCase()}
            </a>
          ))}
        </nav>
        
        <!-- Actions -->
        <div class="flex items-center space-x-4">
          <button class="text-gray-300 hover:text-energy transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
          </button>
          <button class="text-gray-300 hover:text-energy transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </button>
          <button class="text-gray-300 hover:text-energy transition-colors relative">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
            </svg>
            <span class="absolute -top-2 -right-2 w-5 h-5 bg-power text-white text-xs font-bold rounded-full flex items-center justify-center">2</span>
          </button>
        </div>
      </div>
    </div>
  </header>
  
  <!-- Main Content -->
  <main class="flex-1">
    <!-- Hero with Split -->
    <section class="flex flex-col lg:flex-row min-h-[80vh]">
      <!-- Left Content -->
      <div class="flex-1 flex items-center bg-gradient-to-br from-gym to-dark p-8 lg:p-16">
        <div class="max-w-xl">
          <p class="font-heading text-energy tracking-widest text-sm mb-4">NEW COLLECTION 2024</p>
          <h1 class="font-display text-5xl md:text-7xl mb-6 leading-tight">
            <span class="gradient-text">PERFORM</span><br/>
            <span class="text-white">LIKE A</span><br/>
            <span class="text-power">BEAST</span>
          </h1>
          <p class="text-gray-400 text-lg mb-8">
            Engineered for peak performance. Designed for champions. Elevate your workout with cutting-edge athletic wear.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/new" class="bg-energy text-dark px-8 py-4 font-heading font-bold tracking-wider hover:bg-white transition-colors energy-glow">
              SHOP NOW
            </a>
            <a href="/men" class="border-2 border-power text-power px-8 py-4 font-heading font-bold tracking-wider hover:bg-power hover:text-white transition-colors">
              EXPLORE MEN
            </a>
          </div>
        </div>
      </div>
      
      <!-- Right Image -->
      <div class="lg:w-1/2 relative">
        <img 
          src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=800"
          alt="Athletic Performance"
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-dark via-transparent to-transparent"></div>
      </div>
    </section>
    
    <!-- Stats Bar -->
    <section class="bg-gym border-y border-gray-800 py-8">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
          {[
            { value: '500+', label: 'Products' },
            { value: '50K+', label: 'Athletes' },
            { value: '98%', label: 'Satisfaction' },
            { value: '24/7', label: 'Support' }
          ].map((stat) => (
            <div>
              <div class="font-display text-3xl md:text-4xl gradient-text mb-1">{stat.value}</div>
              <div class="font-heading text-gray-400 tracking-wider text-sm">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Categories -->
    <section class="py-16">
      <div class="container mx-auto px-4">
        <div class="flex items-center justify-between mb-12">
          <h2 class="font-display text-3xl md:text-4xl">SHOP BY SPORT</h2>
          <a href="/all" class="font-heading text-sm tracking-wider text-energy hover:text-white transition-colors">
            VIEW ALL →
          </a>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { name: 'Running', image: 'https://images.unsplash.com/photo-1552674605-db6ffd4facb5?w=500', items: 124 },
            { name: 'Training', image: 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=500', items: 89 },
            { name: 'Yoga', image: 'https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=500', items: 67 },
            { name: 'Cycling', image: 'https://images.unsplash.com/photo-1541625602330-2277a4c46182?w=500', items: 45 },
            { name: 'Swimming', image: 'https://images.unsplash.com/photo-1530549387789-4c1017266635?w=500', items: 32 },
            { name: 'Team Sports', image: 'https://images.unsplash.com/photo-1574629810360-7efbbe195018?w=500', items: 156 }
          ].map((sport) => (
            <a href={`/${sport.name.toLowerCase().replace(' ', '-')}`} class="group relative aspect-[4/3] overflow-hidden rounded-lg">
              <img src={sport.image} alt={sport.name} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
              <div class="absolute inset-0 bg-gradient-to-t from-dark via-dark/50 to-transparent"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <h3 class="font-display text-2xl mb-1">{sport.name.toUpperCase()}</h3>
                <p class="font-heading text-gray-400 text-sm">{sport.items} Products</p>
              </div>
              <div class="absolute top-4 right-4 w-10 h-10 bg-energy rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                <svg class="w-5 h-5 text-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
    
    <!-- Featured Products -->
    <section class="py-16 bg-gym">
      <div class="container mx-auto px-4">
        <div class="text-center mb-12">
          <h2 class="font-display text-4xl mb-4">TOP PERFORMERS</h2>
          <p class="text-gray-400">Our bestselling athletic gear</p>
        </div>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          {[
            { name: 'Performance Tee', price: 1499, original: 1999, image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400', badge: 'BESTSELLER', rating: 4.9 },
            { name: 'Training Shorts', price: 1999, image: 'https://images.unsplash.com/photo-1591195853828-11db59a44f6b?w=400', badge: 'NEW', rating: 4.7 },
            { name: 'Running Shoes', price: 5999, original: 7999, image: 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400', badge: 'HOT DEAL', rating: 4.8 },
            { name: 'Gym Bag', price: 2499, image: 'https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=400', rating: 4.6 },
            { name: 'Sports Bra', price: 1299, original: 1799, image: 'https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?w=400', badge: 'SALE', rating: 4.5 },
            { name: 'Training Hoodie', price: 2999, image: 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?w=400', badge: 'NEW', rating: 4.8 },
            { name: 'Compression Leggings', price: 2199, image: 'https://images.unsplash.com/photo-1506629082955-511b1aa562c8?w=400', rating: 4.7 },
            { name: 'Weightlifting Belt', price: 3499, image: 'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=400', badge: 'PRO', rating: 4.9 }
          ].map((product) => (
            <a href={`/product/${product.name.toLowerCase().replace(' ', '-')}`} class="group bg-dark rounded-lg overflow-hidden border border-gray-800 hover:border-energy transition-colors">
              <div class="relative aspect-square overflow-hidden">
                <img src={product.image} alt={product.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                {product.badge && (
                  <span class={`absolute top-3 left-3 text-xs font-bold px-2 py-1 tracking-wider ${
                    product.badge === 'HOT DEAL' || product.badge === 'SALE' ? 'bg-power' :
                    product.badge === 'NEW' ? 'bg-energy text-dark' :
                    product.badge === 'BESTSELLER' ? 'bg-yellow-500 text-dark' :
                    'bg-white text-dark'
                  }`}>
                    {product.badge}
                  </span>
                )}
              </div>
              <div class="p-4">
                <h3 class="font-heading text-sm tracking-wider text-white mb-2">{product.name.toUpperCase()}</h3>
                <div class="flex items-center gap-2 mb-2">
                  <span class="font-bold text-energy">₹{product.price.toLocaleString()}</span>
                  {product.original && (
                    <span class="text-gray-500 line-through text-sm">₹{product.original.toLocaleString()}</span>
                  )}
                </div>
                <div class="flex items-center gap-1">
                  {[...Array(5)].map((_, i) => (
                    <svg class={`w-4 h-4 ${i < Math.floor(product.rating) ? 'text-energy' : 'text-gray-600'}`} fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                  <span class="text-gray-500 text-xs ml-1">{product.rating}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
    
    <!-- CTA Section -->
    <section class="relative py-24 overflow-hidden">
      <div class="absolute inset-0">
        <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1920" alt="Gym" class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-dark/90"></div>
      </div>
      <div class="relative z-10 container mx-auto px-4 text-center">
        <h2 class="font-display text-5xl md:text-6xl mb-6">READY TO <span class="gradient-text">LEVEL UP</span>?</h2>
        <p class="text-gray-400 text-lg mb-8 max-w-xl mx-auto">Join thousands of athletes who trust PERFORM for their training needs.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/signup" class="bg-energy text-dark px-10 py-4 font-heading font-bold tracking-wider hover:bg-white transition-colors energy-glow">
            START TRAINING
          </a>
          <a href="/membership" class="border-2 border-white px-10 py-4 font-heading font-bold tracking-wider hover:bg-white hover:text-dark transition-colors">
            JOIN MEMBERSHIP
          </a>
        </div>
      </div>
    </section>
    
    <!-- Newsletter -->
    <section class="py-16 border-y border-gray-800">
      <div class="container mx-auto px-4 max-w-2xl text-center">
        <h2 class="font-display text-3xl mb-4">STAY <span class="text-power">ENERGIZED</span></h2>
        <p class="text-gray-400 mb-8">Get exclusive deals, new product alerts, and training tips.</p>
        <form class="flex flex-col sm:flex-row gap-4">
          <input type="email" placeholder="Enter your email" class="flex-1 bg-gym border border-gray-700 text-white px-6 py-4 focus:outline-none focus:border-energy transition-colors" required />
          <button type="submit" class="bg-power text-white px-8 py-4 font-heading font-bold tracking-wider hover:bg-energy hover:text-dark transition-colors">
            SUBSCRIBE
          </button>
        </form>
      </div>
    </section>
  </main>
  
  <!-- Footer -->
  <footer class="bg-gym">
    <div class="container mx-auto px-4 py-16">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 mb-12">
        <div class="col-span-2">
          <h3 class="font-display text-3xl mb-4">{siteConfig.site_name}</h3>
          <p class="text-gray-400 text-sm mb-6">Push your limits. Break your records. Be your best.</p>
          <div class="flex space-x-4">
            {['IG', 'FB', 'TW', 'YT'].map((social) => (
              <a href="#" class="w-10 h-10 bg-dark flex items-center justify-center text-xs font-bold hover:bg-energy hover:text-dark transition-colors">
                {social}
              </a>
            ))}
          </div>
        </div>
        {[
          { title: 'SHOP', links: ['New Arrivals', 'Men', 'Women', 'Sale'] },
          { title: 'SPORTS', links: ['Running', 'Training', 'Yoga', 'Cycling'] },
          { title: 'HELP', links: ['Contact', 'FAQs', 'Shipping', 'Returns'] }
        ].map((col) => (
          <div>
            <h4 class="font-heading text-sm tracking-wider text-gray-400 mb-4">{col.title}</h4>
            <ul class="space-y-2">
              {col.links.map((link) => (
                <li><a href="#" class="text-sm text-gray-300 hover:text-energy transition-colors">{link}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div class="border-t border-gray-800 pt-8 text-center text-gray-500 text-sm">
        <p>© {new Date().getFullYear()} {siteConfig.site_name}. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>
