---
// Newsletter Section
interface Props {
  content: {
    heading?: string;
    description?: string;
    placeholder_text?: string;
    button_text?: string;
    background_color?: string;
  };
}

const { content } = Astro.props;
const {
  heading = 'Join Our Newsletter',
  description = 'Subscribe to get special offers, free giveaways, and exclusive deals.',
  placeholder_text = 'Enter your email',
  button_text = 'Subscribe',
  background_color = '#f9fafb'
} = content;
---

<section class="py-20" style={`background-color: ${background_color}`}>
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-4xl font-bold text-gray-900 mb-4">{heading}</h2>
      <p class="text-gray-600 text-lg mb-8">{description}</p>
      
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input 
          type="email" 
          placeholder={placeholder_text}
          class="flex-1 px-6 py-4 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent"
          required
        />
        <button 
          type="submit"
          class="bg-black text-white px-8 py-4 font-semibold hover:bg-gray-800 transition-colors rounded-lg"
        >
          {button_text}
        </button>
      </form>
      
      <p class="text-sm text-gray-500 mt-4">
        By subscribing, you agree to our Privacy Policy and consent to receive updates.
      </p>
    </div>
  </div>
</section>
