---
// Product Gallery Section
interface GalleryImage {
  id: string;
  url: string;
  alt_text?: string;
}

interface Props {
  content: {
    images: GalleryImage[];
    thumbnail_position?: 'bottom' | 'left' | 'right';
    show_zoom?: boolean;
    aspect_ratio?: string;
  };
}

const { content } = Astro.props;
const {
  images = [
    { id: '1', url: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=800', alt_text: 'Product image 1' },
    { id: '2', url: 'https://images.unsplash.com/photo-1583391733956-3750e0ff4e8b?w=800', alt_text: 'Product image 2' },
    { id: '3', url: 'https://images.unsplash.com/photo-1594938298603-c8148c4dae35?w=800', alt_text: 'Product image 3' },
    { id: '4', url: 'https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?w=800', alt_text: 'Product image 4' }
  ],
  thumbnail_position = 'bottom',
  show_zoom = true
} = content;

const [mainImage, ...thumbnails] = images;
---

<div class="space-y-4">
  <!-- Main Image -->
  <div class="relative aspect-[3/4] bg-gray-100 rounded-lg overflow-hidden">
    <img 
      id="mainImage"
      src={mainImage.url}
      alt={mainImage.alt_text || 'Product image'}
      class="w-full h-full object-cover"
    />
    {show_zoom && (
      <div id="zoomLens" class="hidden absolute border-2 border-black/20 bg-white/50 cursor-zoom-in"></div>
    )}
  </div>
  
  <!-- Thumbnails -->
  {thumbnails.length > 0 && (
    <div class="grid grid-cols-4 gap-3">
      {thumbnails.map((thumb, index) => (
        <button 
          class="aspect-square bg-gray-100 rounded-lg overflow-hidden border-2 border-transparent hover:border-black transition-colors"
          data-image={thumb.url}
          aria-label={`View image ${index + 2}`}
        >
          <img 
            src={thumb.url}
            alt={thumb.alt_text || `Thumbnail ${index + 2}`}
            class="w-full h-full object-cover"
          />
        </button>
      ))}
    </div>
  )}
</div>

<script>
  // Thumbnail click handler
  document.querySelectorAll('[data-image]').forEach(button => {
    button.addEventListener('click', () => {
      const mainImage = document.getElementById('mainImage') as HTMLImageElement;
      if (mainImage && button.dataset.image) {
        mainImage.src = button.dataset.image;
      }
    });
  });
</script>
