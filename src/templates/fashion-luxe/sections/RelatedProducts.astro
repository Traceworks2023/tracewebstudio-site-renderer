---
// Related Products Section
interface Product {
  id: string;
  name: string;
  price: number;
  original_price?: number;
  image: string;
  badge?: string;
  rating?: number;
}

interface Props {
  content: {
    title?: string;
    subtitle?: string;
    products: Product[];
    columns?: number;
  };
}

const { content } = Astro.props;
const {
  title = 'Related Products',
  subtitle = '',
  products = [],
  columns = 4
} = content;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4',
  5: 'grid-cols-2 md:grid-cols-5'
}[columns] || 'grid-cols-2 md:grid-cols-4';
---

<section class="py-16 bg-white">
  <div class="container mx-auto px-4">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">{title}</h2>
      {subtitle && <p class="text-gray-600">{subtitle}</p>}
    </div>
    
    <!-- Products Grid -->
    <div class={`grid ${gridCols} gap-6`}>
      {products.map((product) => (
        <a 
          href={`/product/${product.id}`}
          class="group bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-shadow"
        >
          <div class="relative aspect-[3/4] overflow-hidden">
            <img 
              src={product.image}
              alt={product.name}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
            {product.badge && (
              <span class="absolute top-3 left-3 bg-black text-white text-xs font-bold px-2 py-1 uppercase">
                {product.badge}
              </span>
            )}
          </div>
          <div class="p-4">
            <h3 class="font-medium text-gray-900 mb-2 group-hover:text-gray-600 transition-colors">
              {product.name}
            </h3>
            <div class="flex items-center gap-2">
              <span class="text-lg font-bold text-gray-900">₹{product.price.toLocaleString()}</span>
              {product.original_price && (
                <span class="text-sm text-gray-500 line-through">₹{product.original_price.toLocaleString()}</span>
              )}
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
