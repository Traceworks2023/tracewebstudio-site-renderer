---
// Product Info Section
interface Product {
  id: string;
  name: string;
  price: number;
  original_price?: number;
  short_description?: string;
  sku?: string;
  stock?: number;
  rating?: number;
  review_count?: number;
}

interface Props {
  content: {
    section_id: string;
    product: Product;
  };
}

const { content } = Astro.props;
const { product } = content;
const {
  name = 'Product Name',
  price = 0,
  original_price,
  short_description = '',
  sku = '',
  stock = 10,
  rating = 0,
  review_count = 0
} = product;

const discount = original_price ? Math.round((1 - price / original_price) * 100) : 0;
const inStock = stock > 0;
---

<div class="space-y-6">
  <!-- Product Name -->
  <h1 class="text-4xl font-bold text-gray-900">{name}</h1>
  
  <!-- Rating -->
  {rating > 0 && (
    <div class="flex items-center gap-3">
      <div class="flex items-center">
        {[...Array(5)].map((_, i) => (
          <svg 
            class={`w-5 h-5 ${i < Math.floor(rating) ? 'text-yellow-400' : 'text-gray-300'}`}
            fill="currentColor" viewBox="0 0 20 20"
          >
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
        ))}
      </div>
      <span class="text-gray-600">{rating} ({review_count} reviews)</span>
    </div>
  )}
  
  <!-- Price -->
  <div class="flex items-baseline gap-4">
    <span class="text-3xl font-bold text-gray-900">₹{price.toLocaleString()}</span>
    {original_price && (
      <>
        <span class="text-xl text-gray-500 line-through">₹{original_price.toLocaleString()}</span>
        <span class="bg-black text-white text-sm font-semibold px-3 py-1 rounded">{discount}% OFF</span>
      </>
    )}
  </div>
  
  <!-- Short Description -->
  {short_description && (
    <p class="text-gray-600 text-lg">{short_description}</p>
  )}
  
  <!-- SKU -->
  {sku && (
    <p class="text-sm text-gray-500">SKU: {sku}</p>
  )}
  
  <!-- Stock Status -->
  <div class="flex items-center gap-2">
    {inStock ? (
      <>
        <span class="w-3 h-3 bg-green-500 rounded-full"></span>
        <span class="text-green-700 font-medium">In Stock ({stock} available)</span>
      </>
    ) : (
      <>
        <span class="w-3 h-3 bg-red-500 rounded-full"></span>
        <span class="text-red-700 font-medium">Out of Stock</span>
      </>
    )}
  </div>
  
  <!-- Size Selector -->
  <div class="space-y-3">
    <label class="font-semibold text-gray-900">Select Size</label>
    <div class="flex flex-wrap gap-3">
      {['XS', 'S', 'M', 'L', 'XL'].map((size) => (
        <button class="w-12 h-12 border-2 border-gray-300 rounded-lg hover:border-black transition-colors">
          {size}
        </button>
      ))}
    </div>
    <a href="#" class="text-sm text-gray-600 underline">Size Guide</a>
  </div>
  
  <!-- Color Selector -->
  <div class="space-y-3">
    <label class="font-semibold text-gray-900">Select Color</label>
    <div class="flex gap-3">
      <button class="w-10 h-10 rounded-full bg-black border-2 border-black ring-2 ring-offset-2 ring-black"></button>
      <button class="w-10 h-10 rounded-full bg-gray-300 border-2 border-gray-300 hover:border-black"></button>
      <button class="w-10 h-10 rounded-full bg-red-600 border-2 border-red-600 hover:border-black"></button>
      <button class="w-10 h-10 rounded-full bg-blue-600 border-2 border-blue-600 hover:border-black"></button>
    </div>
  </div>
  
  <!-- Quantity -->
  <div class="space-y-3">
    <label class="font-semibold text-gray-900">Quantity</label>
    <div class="flex items-center border border-gray-300 rounded-lg w-max">
      <button class="px-4 py-3 hover:bg-gray-100 transition-colors">−</button>
      <input type="number" value="1" min="1" max={stock} class="w-16 text-center border-x border-gray-300 py-3 focus:outline-none" />
      <button class="px-4 py-3 hover:bg-gray-100 transition-colors">+</button>
    </div>
  </div>
  
  <!-- Action Buttons -->
  <div class="flex flex-col sm:flex-row gap-4 pt-4">
    <button class="flex-1 bg-black text-white py-4 px-8 font-semibold rounded-lg hover:bg-gray-800 transition-colors flex items-center justify-center gap-3">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
      </svg>
      Add to Cart
    </button>
    <button class="flex-1 border-2 border-black py-4 px-8 font-semibold rounded-lg hover:bg-black hover:text-white transition-colors flex items-center justify-center gap-3">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
      </svg>
      Add to Wishlist
    </button>
  </div>
  
  <!-- Share -->
  <div class="flex items-center gap-4 pt-4 border-t border-gray-200">
    <span class="text-gray-600">Share:</span>
    <div class="flex gap-3">
      <a href="#" class="text-gray-500 hover:text-black">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
      </a>
      <a href="#" class="text-gray-500 hover:text-black">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"/></svg>
      </a>
      <a href="#" class="text-gray-500 hover:text-black">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <a href="#" class="text-gray-500 hover:text-black">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
      </a>
    </div>
  </div>
</div>
