---
// Hero Section - Full width hero with background image
interface Props {
  content: {
    heading: string;
    subheading?: string;
    cta_text?: string;
    cta_url?: string;
    background_image?: string;
    overlay_opacity?: number;
    text_alignment?: 'left' | 'center' | 'right';
    height?: 'full' | 'large' | 'medium' | 'small';
  };
}

const { content } = Astro.props;
const {
  heading = 'Welcome to Our Store',
  subheading = '',
  cta_text = 'Shop Now',
  cta_url = '/products',
  background_image = 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920',
  overlay_opacity = 0.4,
  text_alignment = 'center',
  height = 'large'
} = content;

const heightClass = {
  full: 'min-h-screen',
  large: 'min-h-[80vh]',
  medium: 'min-h-[60vh]',
  small: 'min-h-[40vh]'
}[height];
---

<section class={`relative ${heightClass} flex items-center justify-center overflow-hidden`}>
  <!-- Background Image -->
  <div 
    class="absolute inset-0 bg-cover bg-center bg-no-repeat"
    style={`background-image: url('${background_image}');`}
  ></div>
  
  <!-- Overlay -->
  <div 
    class="absolute inset-0 bg-black"
    style={`opacity: ${overlay_opacity};`}
  ></div>
  
  <!-- Content -->
  <div class={`relative z-10 container mx-auto px-4 text-white text-${text_alignment}`}>
    {text_alignment === 'left' && (
      <div class="max-w-2xl">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">{heading}</h1>
        {subheading && <p class="text-xl md:text-2xl mb-8 opacity-90">{subheading}</p>}
        <a 
          href={cta_url}
          class="inline-block bg-white text-black px-8 py-4 text-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          {cta_text}
        </a>
      </div>
    )}
    
    {text_alignment === 'center' && (
      <div class="max-w-3xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">{heading}</h1>
        {subheading && <p class="text-xl md:text-2xl mb-8 opacity-90">{subheading}</p>}
        <a 
          href={cta_url}
          class="inline-block bg-white text-black px-8 py-4 text-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          {cta_text}
        </a>
      </div>
    )}
    
    {text_alignment === 'right' && (
      <div class="max-w-2xl ml-auto text-right">
        <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">{heading}</h1>
        {subheading && <p class="text-xl md:text-2xl mb-8 opacity-90">{subheading}</p>}
        <a 
          href={cta_url}
          class="inline-block bg-white text-black px-8 py-4 text-lg font-semibold hover:bg-gray-100 transition-colors"
        >
          {cta_text}
        </a>
      </div>
    )}
  </div>
  
  <!-- Scroll Indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
