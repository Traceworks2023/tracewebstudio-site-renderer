---
// Product Grid Section
interface Product {
  id: string;
  name: string;
  price: number;
  original_price?: number;
  image: string;
  badge?: string;
  rating?: number;
}

interface Props {
  content: {
    products: Product[];
    columns?: number;
    show_prices?: boolean;
    show_ratings?: boolean;
  };
}

const { content } = Astro.props;
const {
  products = [],
  columns = 3,
  show_prices = true,
  show_ratings = true
} = content;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4'
}[columns] || 'grid-cols-2 md:grid-cols-3';
---

<div class={`grid ${gridCols} gap-6`}>
  {products.map((product) => (
    <a 
      href={`/product/${product.id}`}
      class="group bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300"
    >
      <!-- Product Image -->
      <div class="relative aspect-[3/4] overflow-hidden bg-gray-100">
        <img 
          src={product.image}
          alt={product.name}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        {product.badge && (
          <span class="absolute top-3 left-3 bg-black text-white text-xs font-bold px-2 py-1 uppercase tracking-wider">
            {product.badge}
          </span>
        )}
        
        <!-- Quick Actions Overlay -->
        <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors flex items-center justify-center opacity-0 group-hover:opacity-100">
          <div class="flex gap-2">
            <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
              </svg>
            </button>
            <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center hover:bg-gray-100 transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
              </svg>
            </button>
          </div>
        </div>
        
        <!-- Add to Cart Button -->
        <div class="absolute bottom-0 left-0 right-0 p-4 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <button class="w-full bg-black text-white py-3 font-semibold rounded-lg hover:bg-gray-800 transition-colors">
            Add to Cart
          </button>
        </div>
      </div>
      
      <!-- Product Info -->
      <div class="p-4">
        <h3 class="font-medium text-gray-900 mb-2 group-hover:text-gray-600 transition-colors line-clamp-2">
          {product.name}
        </h3>
        
        {show_ratings && product.rating && (
          <div class="flex items-center gap-1 mb-2">
            <div class="flex">
              {[...Array(5)].map((_, i) => (
                <svg 
                  class={`w-4 h-4 ${i < Math.floor(product.rating) ? 'text-yellow-400' : 'text-gray-300'}`}
                  fill="currentColor" viewBox="0 0 20 20"
                >
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="text-sm text-gray-500">({product.rating})</span>
          </div>
        )}
        
        {show_prices && (
          <div class="flex items-center gap-2">
            <span class="text-lg font-bold text-gray-900">₹{product.price.toLocaleString()}</span>
            {product.original_price && (
              <span class="text-sm text-gray-500 line-through">₹{product.original_price.toLocaleString()}</span>
            )}
          </div>
        )}
      </div>
    </a>
  ))}
</div>
