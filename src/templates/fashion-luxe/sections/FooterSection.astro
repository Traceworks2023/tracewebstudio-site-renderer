};
---

<footer class="bg-gray-900 text-white">
  <!-- Main Footer -->
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand Column -->
      <div class="col-span-2 md:col-span-1">
        <h3 class="text-2xl font-bold mb-4">{siteConfig.site_name || 'Store Name'}</h3>
        <p class="text-gray-400 text-sm mb-6">
          Your one-stop shop for premium fashion and accessories.
        </p>
        <!-- Social Links -->
        <div class="flex space-x-4">
          {social_links.map((social) => (
            <a 
              href={social.url} 
              class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-colors"
              aria-label={social.platform}
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcons[social.platform] || socialIcons.instagram}></path>
              </svg>
            </a>
          ))}
        </div>
      </div>
      
      <!-- Link Columns -->
      {columns.map((column) => (
        <div>
          <h4 class="font-semibold text-white mb-4">{column.title}</h4>
          <ul class="space-y-3">
            {column.links.map((link) => (
              <li>
                <a 
                  href={link.url}
                  class="text-gray-400 hover:text-white transition-colors text-sm"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
  
  <!-- Bottom Bar -->
  <div class="border-t border-gray-800">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm">{copyright_text}</p>
        <div class="flex items-center gap-4">
          <img src="https://cdn-icons-png.flaticon.com/128/349/349221.png" alt="Visa" class="h-6 opacity-70">
          <img src="https://cdn-icons-png.flaticon.com/128/349/349228.png" alt="Mastercard" class="h-6 opacity-70">
          <img src="https://cdn-icons-png.flaticon.com/128/349/349230.png" alt="American Express" class="h-6 opacity-70">
          <img src="https://cdn-icons-png.flaticon.com/128/888/888870.png" alt="UPI" class="h-6 opacity-70">
        </div>
      </div>
    </div>
  </div>
</footer>
