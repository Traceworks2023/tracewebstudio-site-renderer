---
// Promo Banner Section
interface Props {
  content: {
    heading: string;
    subheading?: string;
    cta_text?: string;
    cta_url?: string;
    background_image?: string;
    background_color?: string;
    text_color?: string;
    height?: 'full' | 'large' | 'medium' | 'small';
  };
}

const { content } = Astro.props;
const {
  heading = 'Summer Sale',
  subheading = 'Up to 50% off on selected items',
  cta_text = 'Shop Now',
  cta_url = '/sale',
  background_image = '',
  background_color = '#000000',
  text_color = '#ffffff',
  height = 'medium'
} = content;

const heightClass = {
  full: 'min-h-screen',
  large: 'min-h-[60vh]',
  medium: 'min-h-[40vh]',
  small: 'min-h-[30vh]'
}[height];

const bgStyle = background_image 
  ? `background-image: url('${background_image}'); background-size: cover; background-position: center;`
  : `background-color: ${background_color};`;
---

<section 
  class={`relative ${heightClass} flex items-center justify-center ${background_image ? 'bg-cover bg-center' : ''}`}
  style={bgStyle}
>
  {background_image && <div class="absolute inset-0 bg-black/40"></div>}
  
  <div class="relative z-10 text-center px-4">
    <h2 class={`text-5xl md:text-7xl font-bold mb-4 ${background_image ? 'text-white' : ''}`} style={!background_image ? `color: ${text_color}` : ''}>
      {heading}
    </h2>
    {subheading && (
      <p class={`text-xl md:text-2xl mb-8 ${background_image ? 'text-white/90' : ''}`} style={!background_image ? `color: ${text_color}` : ''}>
        {subheading}
      </p>
    )}
    <a 
      href={cta_url}
      class={`inline-block px-8 py-4 font-semibold transition-colors ${
        background_image 
          ? 'bg-white text-black hover:bg-gray-100' 
          : 'text-white'
      }`}
      style={!background_image ? `background-color: ${text_color}; color: ${background_color}` : ''}
    >
      {cta_text}
    </a>
  </div>
</section>
