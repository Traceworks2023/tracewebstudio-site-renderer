---
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const returns = [
  { 
    id: 'RET-2024-0156', 
    orderId: 'ORD-2024-1047', 
    date: 'Mar 20, 2024', 
    status: 'Approved', 
    items: 1,
    reason: 'Wrong size',
    refundAmount: 79.99
  },
  { 
    id: 'RET-2024-0148', 
    orderId: 'ORD-2024-1025', 
    date: 'Mar 5, 2024', 
    status: 'Completed', 
    items: 1,
    reason: 'Defective',
    refundAmount: 149.99
  }
];

const policy = [
  { title: '30-Day Return Window', desc: 'Items must be returned within 30 days of delivery' },
  { title: 'Original Condition', desc: 'Items must be unworn, unwashed, and with all tags attached' },
  { title: 'Free Returns', desc: 'Free return shipping on all domestic orders' },
  { title: 'Refund Timeline', desc: 'Refunds processed within 5-7 business days' }
];
---

<BaseLayout title="Returns & Refunds - LUXE Account" showHeader={true} showFooter={true}>
  <section class="returns" style={cssVars}>
    <div class="returns__container">
      <div class="returns__header">
        <h1 class="returns__title">Returns & Refunds</h1>
        <p class="returns__subtitle">Track and manage your return requests</p>
      </div>

      <section class="returns__policy">
        <h2 class="returns__section-title">Return Policy</h2>
        <div class="returns__policy-grid">
          {policy.map((item) => (
            <div class="returns__policy-card">
              <h3 class="returns__policy-title">{item.title}</h3>
              <p class="returns__policy-desc">{item.desc}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="returns__section">
        <div class="returns__section-header">
          <h2 class="returns__section-title">Your Returns</h2>
          <button class="returns__btn returns__btn--primary">Request New Return</button>
        </div>

        {returns.length === 0 ? (
          <div class="returns__empty">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <polyline points="1 4 1 10 7 10"></polyline>
              <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"></path>
            </svg>
            <h3>No returns yet</h3>
            <p>Items you return will appear here</p>
          </div>
        ) : (
          <div class="returns__list">
            {returns.map((ret) => (
              <div class="returns__return">
                <div class="returns__return-header">
                  <div class="returns__return-info">
                    <span class="returns__return-id">{ret.id}</span>
                    <span class="returns__return-order">Order: {ret.orderId}</span>
                  </div>
                  <span class={`returns__badge returns__badge--${ret.status.toLowerCase()}`}>
                    {ret.status}
                  </span>
                </div>

                <div class="returns__return-content">
                  <div class="returns__return-details">
                    <div class="returns__return-detail">
                      <span class="returns__return-label">Date Requested</span>
                      <span class="returns__return-value">{ret.date}</span>
                    </div>
                    <div class="returns__return-detail">
                      <span class="returns__return-label">Items</span>
                      <span class="returns__return-value">{ret.items} item{ret.items > 1 ? 's' : ''}</span>
                    </div>
                    <div class="returns__return-detail">
                      <span class="returns__return-label">Reason</span>
                      <span class="returns__return-value">{ret.reason}</span>
                    </div>
                    <div class="returns__return-detail">
                      <span class="returns__return-label">Refund Amount</span>
                      <span class="returns__return-value returns__return-value--highlight">${ret.refundAmount.toFixed(2)}</span>
                    </div>
                  </div>

                  <div class="returns__return-actions">
                    <a href={`/account/returns/${ret.id}`} class="returns__action-btn">View Details</a>
                    {ret.status === 'Approved' && (
                      <button class="returns__action-btn returns__action-btn--secondary">Print Label</button>
                    )}
                  </div>
                </div>

                {ret.status === 'Approved' && (
                  <div class="returns__return-shipping">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <rect x="1" y="3" width="15" height="13"></rect>
                      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                      <circle cx="5.5" cy="18.5" r="2.5"></circle>
                      <circle cx="18.5" cy="18.5" r="2.5"></circle>
                    </svg>
                    <span>Return shipping label has been emailed to you</span>
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </section>

      <section class="returns__faq">
        <h2 class="returns__section-title">Frequently Asked Questions</h2>
        <div class="returns__faq-list">
          <details class="returns__faq-item">
            <summary class="returns__faq-question">How long does it take to process a return?</summary>
            <p class="returns__faq-answer">Once we receive your return package, refunds are typically processed within 5-7 business days. The refund will be credited to your original payment method.</p>
          </details>
          <details class="returns__faq-item">
            <summary class="returns__faq-question">Can I exchange an item instead of returning it?</summary>
            <p class="returns__faq-answer">Yes, you can request an exchange for a different size or color. During the return process, select "Exchange" and indicate your preferred option.</p>
          </details>
          <details class="returns__faq-item">
            <summary class="returns__faq-question">What items cannot be returned?</summary>
            <p class="returns__faq-answer">Final sale items, underwear, swimwear, earrings, and personalized items cannot be returned unless defective.</p>
          </details>
          <details class="returns__faq-item">
            <summary class="returns__faq-question">How will I be notified about my return?</summary>
            <p class="returns__faq-answer">You'll receive email updates at each stage of your return process, including when we receive your package and when your refund is processed.</p>
          </details>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .returns {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .returns__container {
    max-width: 900px;
    margin: 0 auto;
  }

  .returns__header {
    margin-bottom: 40px;
  }

  .returns__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .returns__subtitle {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .returns__section {
    margin-bottom: 48px;
  }

  .returns__section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .returns__section-title {
    font-family: var(--font-heading);
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 24px;
    color: var(--theme-text);
  }

  .returns__section-header .returns__section-title {
    margin-bottom: 0;
  }

  .returns__policy {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
    margin-bottom: 40px;
  }

  .returns__policy-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .returns__policy-card {
    padding: 16px;
    background: var(--theme-background);
    border-radius: var(--btn-radius);
  }

  .returns__policy-title {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 6px;
    color: var(--theme-text);
  }

  .returns__policy-desc {
    font-size: 13px;
    color: var(--theme-text-muted);
    margin: 0;
    line-height: 1.5;
  }

  .returns__btn {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 500;
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: background 0.2s ease;
    border: none;
  }

  .returns__btn--primary {
    background: var(--theme-primary);
    color: var(--theme-background);
  }

  .returns__btn--primary:hover {
    background: var(--theme-primary-hover);
  }

  .returns__empty {
    text-align: center;
    padding: 60px 20px;
    background: var(--theme-surface);
    border-radius: var(--card-radius);
  }

  .returns__empty svg {
    color: var(--theme-text-muted);
    opacity: 0.5;
    margin-bottom: 16px;
  }

  .returns__empty h3 {
    font-size: 18px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .returns__empty p {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .returns__list {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .returns__return {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    overflow: hidden;
  }

  .returns__return-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20px 24px;
    background: var(--theme-background);
    border-bottom: 1px solid var(--theme-border);
  }

  .returns__return-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .returns__return-id {
    font-weight: 600;
    font-size: 15px;
    color: var(--theme-text);
  }

  .returns__return-order {
    font-size: 13px;
    color: var(--theme-text-muted);
  }

  .returns__badge {
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 500;
  }

  .returns__badge--approved {
    background: rgba(59, 130, 246, 0.1);
    color: var(--theme-info);
  }

  .returns__badge--completed {
    background: rgba(16, 185, 129, 0.1);
    color: var(--theme-success);
  }

  .returns__badge--pending {
    background: rgba(245, 158, 11, 0.1);
    color: var(--theme-warning);
  }

  .returns__badge--rejected {
    background: rgba(239, 68, 68, 0.1);
    color: var(--theme-error);
  }

  .returns__return-content {
    padding: 24px;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .returns__return-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .returns__return-detail {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .returns__return-label {
    font-size: 12px;
    color: var(--theme-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .returns__return-value {
    font-size: 14px;
    color: var(--theme-text);
  }

  .returns__return-value--highlight {
    font-weight: 600;
    color: var(--theme-primary);
  }

  .returns__return-actions {
    display: flex;
    gap: 12px;
  }

  .returns__action-btn {
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    background: var(--theme-primary);
    color: var(--theme-background);
    border: 1px solid var(--theme-primary);
  }

  .returns__action-btn:hover {
    background: var(--theme-primary-hover);
    border-color: var(--theme-primary-hover);
  }

  .returns__action-btn--secondary {
    background: transparent;
    color: var(--theme-text);
    border-color: var(--theme-border);
  }

  .returns__action-btn--secondary:hover {
    border-color: var(--theme-primary);
    color: var(--theme-primary);
  }

  .returns__return-shipping {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    background: rgba(59, 130, 246, 0.05);
    border-top: 1px solid var(--theme-border);
    font-size: 13px;
    color: var(--theme-info);
  }

  .returns__faq {
    margin-top: 48px;
  }

  .returns__faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .returns__faq-item {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    overflow: hidden;
  }

  .returns__faq-question {
    display: block;
    width: 100%;
    padding: 18px 24px;
    font-size: 15px;
    font-weight: 500;
    color: var(--theme-text);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .returns__faq-question::-webkit-details-marker {
    display: none;
  }

  .returns__faq-question::after {
    content: '+';
    font-size: 20px;
    color: var(--theme-text-muted);
    transition: transform 0.2s ease;
  }

  .returns__faq-item[open] .returns__faq-question::after {
    transform: rotate(45deg);
  }

  .returns__faq-answer {
    padding: 0 24px 18px;
    font-size: 14px;
    color: var(--theme-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 768px) {
    .returns__return-content {
      flex-direction: column;
      gap: 20px;
      align-items: flex-start;
    }

    .returns__return-details {
      grid-template-columns: repeat(2, 1fr);
    }

    .returns__policy-grid {
      grid-template-columns: 1fr;
    }

    .returns__return-actions {
      width: 100%;
      flex-direction: column;
    }

    .returns__action-btn {
      text-align: center;
    }
  }
</style>