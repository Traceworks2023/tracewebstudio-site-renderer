---
// Fashion Luxe FAQ Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'faq');
const faqContent = pageContent?.content || {};

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const faqCategories = [
  {
    title: 'Orders & Shipping',
    faqs: [
      { question: 'How long will my order take to arrive?', answer: 'Standard shipping typically takes 5-7 business days. Express shipping takes 2-3 business days, and overnight shipping delivers the next business day.' },
      { question: 'Do you ship internationally?', answer: 'Yes, we ship to over 100 countries worldwide. International shipping times vary by destination, typically 7-14 business days.' },
      { question: 'How can I track my order?', answer: 'Once your order ships, you\'ll receive an email with tracking information. You can also track your order in your account dashboard.' },
      { question: 'What if my item is out of stock?', answer: 'If an item is out of stock, you can sign up for restock notifications on the product page. We regularly restock popular items.' }
    ]
  },
  {
    title: 'Returns & Exchanges',
    faqs: [
      { question: 'What is your return policy?', answer: 'We accept returns within 30 days of delivery. Items must be unworn, unwashed, and have all original tags attached.' },
      { question: 'How do I initiate a return?', answer: 'Log into your account, go to Orders, and click "Return Item" next to the item you wish to return. Follow the prompts to print a return label.' },
      { question: 'How long do refunds take?', answer: 'Refunds are processed within 3-5 business days of receiving your return. The refund will be credited to your original payment method.' },
      { question: 'Can I exchange an item for a different size?', answer: 'Yes! You can exchange items for a different size within 30 days. Exchanges are processed as a separate order - we\'ll ship the new size once we receive your return.' }
    ]
  },
  {
    title: 'Payments & Pricing',
    faqs: [
      { question: 'What payment methods do you accept?', answer: 'We accept Visa, MasterCard, American Express, Discover, PayPal, Apple Pay, and Google Pay.' },
      { question: 'Is my payment information secure?', answer: 'Absolutely. All payments are processed through encrypted, PCI-compliant payment processors. We never store your full credit card information.' },
      { question: 'Do you offer gift cards?', answer: 'Yes! Gift cards are available in denominations from $25 to $500. They never expire and can be used on any purchase.' },
      { question: 'Can I use multiple discount codes?', answer: 'Only one discount code can be applied per order. Sale items are already discounted and may not be combined with other offers.' }
    ]
  },
  {
    title: 'Account & Rewards',
    faqs: [
      { question: 'How do I create an account?', answer: 'Click "Sign In" at the top of the page, then select "Create Account." Fill in your details and you\'ll be ready to shop!' },
      { question: 'How does the rewards program work?', answer: 'Earn 1 point for every $1 spent. Points can be redeemed for discounts, free shipping, and exclusive rewards. Sign up is free!' },
      { question: 'How do I earn bonus points?', answer: 'Write product reviews (100 points), share on social media (50 points), and celebrate your birthday (200 points)!' },
      { question: 'When do my points expire?', answer: 'Points are valid for 24 months from the date they were earned. Stay active by making purchases to keep your points from expiring.' }
    ]
  }
];
---

<BaseLayout title="FAQ - LUXE" showHeader={true} showFooter={true}>
  <section class="faq" style={cssVars}>
    <div class="faq__hero">
      <h1 class="faq__title">{faqContent.page_title || 'Frequently Asked Questions'}</h1>
      <p class="faq__subtitle">{faqContent.hero_title || 'Find answers to common questions about shopping with LUXE'}</p>
    </div>

    <div class="faq__container">
      <div class="faq__categories">
        {faqCategories.map((category, catIndex) => (
          <div class="faq__category">
            <h2 class="faq__category-title">{category.title}</h2>
            <div class="faq__list">
              {category.faqs.map((faq, faqIndex) => (
                <div class="faq__item" data-faq-id={`${catIndex}-${faqIndex}`}>
                  <button class="faq__question">
                    <span>{faq.question}</span>
                    <svg class="faq__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M6 9l6 6 6-6"/>
                    </svg>
                  </button>
                  <div class="faq__answer">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      {/* Contact CTA */}
      <div class="faq__contact">
        <h3 class="faq__contact-title">Still have questions?</h3>
        <p class="faq__contact-text">Our customer service team is here to help.</p>
        <a href="/contact" class="faq__contact-btn">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq__question').forEach(button => {
    button.addEventListener('click', () => {
      const item = button.closest('.faq__item');
      const isOpen = item.classList.contains('faq__item--open');
      
      // Close all other items
      document.querySelectorAll('.faq__item--open').forEach(openItem => {
        openItem.classList.remove('faq__item--open');
      });
      
      // Toggle current item
      if (!isOpen) {
        item.classList.add('faq__item--open');
      }
    });
  });
</script>

<style define:vars={cssVars}>
  .faq {
    padding-bottom: 0;
  }

  .faq__hero {
    background: var(--theme-surface);
    padding: 80px 24px;
    text-align: center;
  }

  .faq__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    margin: 0 0 16px;
    color: var(--theme-text);
  }

  .faq__subtitle {
    font-size: 18px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .faq__container {
    max-width: 900px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .faq__category {
    margin-bottom: 60px;
  }

  .faq__category:last-of-type {
    margin-bottom: 0;
  }

  .faq__category-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 24px;
    padding-bottom: 16px;
    border-bottom: 2px solid var(--theme-primary);
    color: var(--theme-text);
  }

  .faq__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq__item {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    overflow: hidden;
  }

  .faq__question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 24px;
    background: none;
    border: none;
    text-align: left;
    font-size: 15px;
    font-weight: 500;
    color: var(--theme-text);
    cursor: pointer;
    gap: 16px;
  }

  .faq__question:hover {
    color: var(--theme-primary);
  }

  .faq__icon {
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .faq__item--open .faq__icon {
    transform: rotate(180deg);
  }

  .faq__answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .faq__item--open .faq__answer {
    max-height: 500px;
  }

  .faq__answer p {
    padding: 0 24px 24px;
    margin: 0;
    font-size: 14px;
    line-height: 1.7;
    color: var(--theme-text-secondary);
  }

  .faq__contact {
    text-align: center;
    padding: 60px;
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    margin-top: 80px;
  }

  .faq__contact-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 12px;
    color: var(--theme-text);
  }

  .faq__contact-text {
    font-size: 15px;
    color: var(--theme-text-muted);
    margin: 0 0 24px;
  }

  .faq__contact-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--theme-primary);
    color: var(--theme-background);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    border-radius: var(--btn-radius);
    transition: background 0.2s ease;
  }

  .faq__contact-btn:hover {
    background: var(--theme-primary-hover);
  }

  @media (max-width: 640px) {
    .faq__hero {
      padding: 60px 24px;
    }

    .faq__title {
      font-size: 32px;
    }

    .faq__container {
      padding: 48px 24px;
    }

    .faq__contact {
      padding: 40px 24px;
    }
  }
</style>
