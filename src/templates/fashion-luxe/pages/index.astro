---
// Fashion Luxe Homepage
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../sections/HeroSection.astro';
import FeaturedCategories from '../sections/FeaturedCategories.astro';
import FeaturedProducts from '../sections/FeaturedProducts.astro';
import PromoBanner from '../sections/PromoBanner.astro';
import TrustIndicators from '../sections/TrustIndicators.astro';
import NewsletterSection from '../sections/NewsletterSection.astro';
import FooterSection from '../sections/FooterSection.astro';
import Header from '../sections/Header.astro';
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'home');

const siteConfig = {
  site_id: siteId,
  site_name: site?.name || 'LUXE',
  site_tagline: 'Premium Fashion & Accessories',
  logo_url: '',
  theme: {
    mode: 'light' as const,
    primary_color: '#000000',
    secondary_color: '#333333',
    accent_color: '#FA5014',
    background_color: '#FFFFFF',
    surface_color: '#F9FAFB',
    text_primary: '#111827',
    text_secondary: '#6B7280',
    border_color: '#E5E7EB'
  },
  pages: [
    {
      page_id: 'home',
      slug: '/',
      title: 'Home',
      is_homepage: true,
      sections: [],
      seo: {
        title: 'LUXE - Premium Fashion & Accessories',
        description: 'Discover our curated collection of premium fashion and accessories. Shop the latest trends in clothing, handbags, jewelry, and more.'
      },
      status: 'published' as const
    }
  ],
  navigation: [
    { id: '1', label: 'New Arrivals', url: '/new', is_visible: true },
    { id: '2', label: 'Women', url: '/category/women', is_visible: true },
    { id: '3', label: 'Men', url: '/category/men', is_visible: true },
    { id: '4', label: 'Accessories', url: '/category/accessories', is_visible: true },
    { id: '5', label: 'Sale', url: '/sale', is_visible: true }
  ]
};

const heroContent = pageContent?.content || {};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <meta name="description" content={siteConfig.pages[0].seo.description}>
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Inter', 'sans-serif'],
          }
        }
      }
    }
  </script>
  
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <Header siteConfig={siteConfig} />
  
  <!-- Main Content -->
  <main class="flex-1">
    <!-- Hero Section -->
    <HeroSection content={{
      heading: heroContent.hero_title || 'Elevate Your Style',
      subheading: heroContent.hero_subtitle || 'Discover the latest collection of premium fashion and accessories',
      cta_text: heroContent.hero_button_text || 'Shop Now',
      cta_url: '/products',
      background_image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920',
      overlay_opacity: 0.5,
      text_alignment: 'center',
      height: 'large'
    }} />
    
    <!-- Featured Categories -->
    <FeaturedCategories content={{
      title: heroContent.categories_title || 'Shop by Category',
      columns: 4,
      categories: [
        { name: 'Women', slug: 'women', image: 'https://images.unsplash.com/photo-1483985988355-763728e1935b?w=600' },
        { name: 'Men', slug: 'men', image: 'https://images.unsplash.com/photo-1507680434567-5739c80be1ac?w=600' },
        { name: 'Accessories', slug: 'accessories', image: 'https://images.unsplash.com/photo-1606760227091-3dd870d97f1d?w=600' },
        { name: 'Shoes', slug: 'shoes', image: 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=600' }
      ]
    }} />
    
    <!-- Featured Products -->
    <FeaturedProducts content={{
      title: heroContent.featured_products_title || 'Featured Products',
      subtitle: 'Our most loved pieces this season',
      columns: 4,
      show_prices: true,
      show_ratings: true,
      products: [
        { id: '1', name: 'Elegant Silk Dress', price: 4999, original_price: 7999, image: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=400', badge: '50% OFF', rating: 4.5 },
        { id: '2', name: 'Designer Handbag', price: 4999, image: 'https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=400', badge: 'NEW', rating: 4.8 },
        { id: '3', name: 'Classic Watch', price: 7999, original_price: 9999, image: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400', badge: 'BESTSELLER', rating: 4.6 },
        { id: '4', name: 'Gold Necklace', price: 12999, image: 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=400', rating: 4.9 }
      ]
    }} />
    
    <!-- Promo Banner -->
    <PromoBanner content={{
      heading: 'Summer Sale',
      subheading: 'Up to 50% off on selected items',
      cta_text: 'Shop Sale',
      cta_url: '/sale',
      background_color: '#000000',
      text_color: '#ffffff',
      height: 'medium'
    }} />
    
    <!-- Trust Indicators -->
    <TrustIndicators content={{}} />
    
    <!-- More Products -->
    <FeaturedProducts content={{
      title: 'New Arrivals',
      subtitle: 'Fresh styles just landed',
      columns: 4,
      show_prices: true,
      show_ratings: true,
      products: [
        { id: '5', name: 'Silk Scarf', price: 1999, original_price: 2999, image: 'https://images.unsplash.com/photo-1601370690183-1c7796ecec61?w=400', badge: 'SALE', rating: 4.3 },
        { id: '6', name: 'Leather Belt', price: 1499, image: 'https://images.unsplash.com/photo-1553062407-98eeb64c6a62?w=400', rating: 4.4 },
        { id: '7', name: 'Sunglasses', price: 2499, original_price: 3999, image: 'https://images.unsplash.com/photo-1572635196237-14b3f281503f?w=400', badge: 'HOT', rating: 4.7 },
        { id: '8', name: 'Premium Wallet', price: 3499, image: 'https://images.unsplash.com/photo-1627123424574-724758594e93?w=400', rating: 4.5 }
      ]
    }} />
    
    <!-- Newsletter -->
    <NewsletterSection content={{
      heading: 'Join Our Newsletter',
      description: 'Subscribe to get special offers, free giveaways, and exclusive deals.',
      placeholder_text: 'Enter your email',
      button_text: 'Subscribe',
      background_color: '#f9fafb'
    }} />
  </main>
  
  <!-- Footer -->
  <FooterSection siteConfig={siteConfig} />
</body>
</html>
