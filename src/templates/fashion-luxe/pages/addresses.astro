---
// Fashion Luxe Account Addresses Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const addresses = [
  {
    id: '1',
    type: 'shipping',
    isDefault: true,
    name: 'John Doe',
    address: '123 Main Street',
    city: 'New York',
    state: 'NY',
    zip: '10001',
    country: 'United States',
    phone: '+1 (555) 123-4567'
  },
  {
    id: '2',
    type: 'billing',
    isDefault: true,
    name: 'John Doe',
    address: '123 Main Street',
    city: 'New York',
    state: 'NY',
    zip: '10001',
    country: 'United States',
    phone: '+1 (555) 123-4567'
  }
];
---

<BaseLayout title="My Addresses - LUXE Account" showHeader={true} showFooter={true}>
  <section class="addresses" style={cssVars}>
    <div class="addresses__container">
      <div class="addresses__header">
        <div>
          <h1 class="addresses__title">My Addresses</h1>
          <p class="addresses__subtitle">Manage your shipping and billing addresses</p>
        </div>
        <button class="addresses__add-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Add New Address
        </button>
      </div>

      <div class="addresses__grid">
        {addresses.map((address) => (
          <div class="addresses__card">
            <div class="addresses__card-header">
              <span class="addresses__card-type">
                {address.type === 'shipping' ? 'Shipping' : 'Billing'}
              </span>
              {address.isDefault && (
                <span class="addresses__card-default">Default</span>
              )}
            </div>
            <div class="addresses__card-content">
              <p class="addresses__card-name">{address.name}</p>
              <p class="addresses__card-address">
                {address.address}<br />
                {address.city}, {address.state} {address.zip}<br />
                {address.country}
              </p>
              <p class="addresses__card-phone">{address.phone}</p>
            </div>
            <div class="addresses__card-actions">
              <button class="addresses__card-edit">Edit</button>
              <button class="addresses__card-delete">Delete</button>
            </div>
          </div>
        ))}

        {/* Add New Card */}
        <button class="addresses__add-card">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          <span>Add New Address</span>
        </button>
      </div>
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .addresses {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .addresses__container {
    max-width: 1000px;
    margin: 0 auto;
  }

  .addresses__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 40px;
  }

  .addresses__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .addresses__subtitle {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .addresses__add-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: var(--theme-primary);
    color: var(--theme-background);
    border: none;
    border-radius: var(--btn-radius);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .addresses__add-btn:hover {
    background: var(--theme-primary-hover);
  }

  .addresses__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .addresses__card {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
    border: 1px solid var(--theme-border);
  }

  .addresses__card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .addresses__card-type {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--theme-text-secondary);
  }

  .addresses__card-default {
    font-size: 11px;
    padding: 4px 8px;
    background: rgba(16, 185, 129, 0.1);
    color: var(--theme-success);
    border-radius: 4px;
  }

  .addresses__card-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--theme-text);
    margin: 0 0 8px;
  }

  .addresses__card-address {
    font-size: 14px;
    line-height: 1.6;
    color: var(--theme-text-secondary);
    margin: 0 0 8px;
  }

  .addresses__card-phone {
    font-size: 13px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .addresses__card-actions {
    display: flex;
    gap: 16px;
    margin-top: 20px;
    padding-top: 16px;
    border-top: 1px solid var(--theme-border);
  }

  .addresses__card-edit,
  .addresses__card-delete {
    background: none;
    border: none;
    font-size: 13px;
    cursor: pointer;
    padding: 0;
  }

  .addresses__card-edit {
    color: var(--theme-primary);
  }

  .addresses__card-delete {
    color: var(--theme-error);
  }

  .addresses__add-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: var(--theme-surface);
    border: 2px dashed var(--theme-border);
    border-radius: var(--card-radius);
    padding: 40px;
    cursor: pointer;
    transition: border-color 0.2s ease;
    color: var(--theme-text-muted);
  }

  .addresses__add-card:hover {
    border-color: var(--theme-primary);
    color: var(--theme-primary);
  }

  .addresses__add-card span {
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .addresses__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .addresses__header {
      flex-direction: column;
      gap: 20px;
    }

    .addresses__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
