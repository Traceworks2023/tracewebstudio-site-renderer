---
// Fashion Luxe Wishlist Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const wishlistItems = [
  {
    id: '1',
    name: 'Elegant Silk Dress',
    price: 4999,
    compareAtPrice: 7999,
    image: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=400',
    badge: '50% OFF',
    rating: 4.5,
    reviewCount: 128
  },
  {
    id: '3',
    name: 'Classic Watch',
    price: 7999,
    image: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400',
    rating: 4.6,
    reviewCount: 89
  },
  {
    id: '4',
    name: 'Gold Necklace',
    price: 12999,
    image: 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=400',
    rating: 4.9,
    reviewCount: 256
  }
];
---

<BaseLayout title="My Wishlist - LUXE" showHeader={true} showFooter={true}>
  <section class="wishlist" style={cssVars}>
    <div class="wishlist__container">
      <h1 class="wishlist__title">My Wishlist</h1>
      <p class="wishlist__count">{wishlistItems.length} items</p>

      {wishlistItems.length === 0 ? (
        <div class="wishlist__empty">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
          </svg>
          <h2>Your wishlist is empty</h2>
          <p>Save items you love by clicking the heart icon</p>
          <a href="/products" class="wishlist__browse-btn">Start Shopping</a>
        </div>
      ) : (
        <div class="wishlist__grid">
          {wishlistItems.map((item) => (
            <article class="wishlist__item" data-item-id={item.id}>
              <div class="wishlist__item-image">
                <img src={item.image} alt={item.name} />
                {item.badge && <span class="wishlist__item-badge">{item.badge}</span>}
                <button class="wishlist__item-remove" data-remove={item.id} aria-label="Remove from wishlist">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 6 6 18M6 6l12 12"></path>
                  </svg>
                </button>
              </div>
              <div class="wishlist__item-info">
                <div class="wishlist__item-rating">
                  <span class="wishlist__stars">{'★'.repeat(Math.floor(item.rating))}</span>
                  <span class="wishlist__review-count">({item.reviewCount})</span>
                </div>
                <h3 class="wishlist__item-name">{item.name}</h3>
                <div class="wishlist__item-price">
                  <span class="wishlist__price-current">${(item.price / 100).toFixed(2)}</span>
                  {item.compareAtPrice && (
                    <span class="wishlist__price-compare">${(item.compareAtPrice / 100).toFixed(2)}</span>
                  )}
                </div>
                <button class="wishlist__add-to-cart" data-add-cart={item.id}>Add to Cart</button>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .wishlist {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .wishlist__container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .wishlist__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .wishlist__count {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0 0 40px;
  }

  .wishlist__empty {
    text-align: center;
    padding: 80px 20px;
  }

  .wishlist__empty svg {
    color: var(--theme-text-muted);
    opacity: 0.5;
    margin-bottom: 24px;
  }

  .wishlist__empty h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    margin: 0 0 12px;
    color: var(--theme-text);
  }

  .wishlist__empty p {
    color: var(--theme-text-muted);
    margin: 0 0 32px;
  }

  .wishlist__browse-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--theme-primary);
    color: var(--theme-background);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    transition: background 0.2s ease;
  }

  .wishlist__browse-btn:hover {
    background: var(--theme-primary-hover);
  }

  .wishlist__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .wishlist__item {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    overflow: hidden;
    transition: box-shadow 0.3s ease;
  }

  .wishlist__item:hover {
    box-shadow: var(--card-shadow-hover);
  }

  .wishlist__item-image {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
  }

  .wishlist__item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .wishlist__item:hover .wishlist__item-image img {
    transform: scale(1.05);
  }

  .wishlist__item-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: var(--theme-accent);
    color: white;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    padding: 4px 8px;
    border-radius: 2px;
  }

  .wishlist__item-remove {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--theme-background);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s ease, background 0.2s ease;
  }

  .wishlist__item:hover .wishlist__item-remove {
    opacity: 1;
  }

  .wishlist__item-remove:hover {
    background: var(--theme-error);
    color: white;
  }

  .wishlist__item-info {
    padding: 20px;
  }

  .wishlist__item-rating {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 8px;
  }

  .wishlist__stars {
    color: var(--theme-accent);
    font-size: 12px;
  }

  .wishlist__review-count {
    font-size: 12px;
    color: var(--theme-text-muted);
  }

  .wishlist__item-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .wishlist__item-price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
  }

  .wishlist__price-current {
    font-size: 16px;
    font-weight: 600;
    color: var(--theme-text);
  }

  .wishlist__price-compare {
    font-size: 14px;
    color: var(--theme-text-muted);
    text-decoration: line-through;
  }

  .wishlist__add-to-cart {
    width: 100%;
    padding: 12px;
    background: var(--theme-primary);
    color: var(--theme-background);
    border: none;
    border-radius: var(--btn-radius);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .wishlist__add-to-cart:hover {
    background: var(--theme-primary-hover);
  }

  @media (max-width: 1024px) {
    .wishlist__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .wishlist__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
