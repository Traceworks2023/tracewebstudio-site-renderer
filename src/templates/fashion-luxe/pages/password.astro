---
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);
---

<BaseLayout title="Change Password - LUXE Account" showHeader={true} showFooter={true}>
  <section class="password" style={cssVars}>
    <div class="password__container">
      <div class="password__header">
        <h1 class="password__title">Change Password</h1>
        <p class="password__subtitle">Update your password to keep your account secure</p>
      </div>

      <form class="password__form">
        <div class="password__field">
          <label class="password__label" for="current">Current Password</label>
          <div class="password__input-wrapper">
            <input 
              type="password" 
              id="current" 
              name="current" 
              class="password__input" 
              placeholder="Enter your current password"
              autocomplete="current-password"
            />
            <button type="button" class="password__toggle" aria-label="Show password">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>

        <div class="password__field">
          <label class="password__label" for="new">New Password</label>
          <div class="password__input-wrapper">
            <input 
              type="password" 
              id="new" 
              name="new" 
              class="password__input" 
              placeholder="Enter your new password"
              autocomplete="new-password"
            />
            <button type="button" class="password__toggle" aria-label="Show password">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
          <div class="password__requirements">
            <p class="password__requirements-title">Password must contain:</p>
            <ul class="password__requirements-list">
              <li class="password__requirement" data-criteria="length">At least 8 characters</li>
              <li class="password__requirement" data-criteria="uppercase">One uppercase letter</li>
              <li class="password__requirement" data-criteria="lowercase">One lowercase letter</li>
              <li class="password__requirement" data-criteria="number">One number</li>
              <li class="password__requirement" data-criteria="special">One special character</li>
            </ul>
          </div>
        </div>

        <div class="password__field">
          <label class="password__label" for="confirm">Confirm New Password</label>
          <div class="password__input-wrapper">
            <input 
              type="password" 
              id="confirm" 
              name="confirm" 
              class="password__input" 
              placeholder="Re-enter your new password"
              autocomplete="new-password"
            />
            <button type="button" class="password__toggle" aria-label="Show password">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                <circle cx="12" cy="12" r="3"></circle>
              </svg>
            </button>
          </div>
        </div>

        <div class="password__actions">
          <button type="button" class="password__btn password__btn--secondary">Cancel</button>
          <button type="submit" class="password__btn password__btn--primary">Update Password</button>
        </div>
      </form>

      <section class="password__security">
        <div class="password__security-header">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          </svg>
          <h2>Security Tips</h2>
        </div>
        <ul class="password__tips">
          <li>Use a unique password that you don't use elsewhere</li>
          <li>Include a mix of letters, numbers, and special characters</li>
          <li>Avoid using personal information like birthdays or names</li>
          <li>Consider using a password manager to generate and store passwords</li>
          <li>Never share your password with anyone, including LUXE support</li>
        </ul>
      </section>

      <section class="password__twofa">
        <div class="password__twofa-content">
          <div class="password__twofa-info">
            <h3>Two-Factor Authentication</h3>
            <p>Add an extra layer of security to your account by enabling two-factor authentication.</p>
          </div>
          <button class="password__twofa-btn">Enable 2FA</button>
        </div>
      </section>
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .password {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .password__container {
    max-width: 560px;
    margin: 0 auto;
  }

  .password__header {
    margin-bottom: 32px;
  }

  .password__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .password__subtitle {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .password__form {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 32px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .password__field {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .password__label {
    font-size: 14px;
    font-weight: 500;
    color: var(--theme-text);
  }

  .password__input-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .password__input {
    width: 100%;
    padding: 14px 48px 14px 16px;
    border: 1px solid var(--theme-border);
    border-radius: var(--btn-radius);
    font-size: 15px;
    background: var(--theme-background);
    color: var(--theme-text);
    transition: border-color 0.2s ease;
  }

  .password__input:focus {
    outline: none;
    border-color: var(--theme-primary);
  }

  .password__input::placeholder {
    color: var(--theme-text-muted);
  }

  .password__toggle {
    position: absolute;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--theme-text-muted);
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .password__toggle:hover {
    color: var(--theme-text);
  }

  .password__requirements {
    margin-top: 8px;
    padding: 16px;
    background: var(--theme-background);
    border-radius: var(--btn-radius);
  }

  .password__requirements-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--theme-text);
    margin: 0 0 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .password__requirements-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .password__requirement {
    font-size: 13px;
    color: var(--theme-text-muted);
    padding-left: 24px;
    position: relative;
  }

  .password__requirement::before {
    content: '';
    position: absolute;
    left: 0;
    top: 4px;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--theme-border);
    border-radius: 50%;
  }

  .password__requirement--met {
    color: var(--theme-success);
  }

  .password__requirement--met::before {
    background: var(--theme-success);
    border-color: var(--theme-success);
  }

  .password__requirement--met::after {
    content: '✓';
    position: absolute;
    left: 3px;
    top: 1px;
    font-size: 10px;
    color: white;
  }

  .password__actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    padding-top: 8px;
  }

  .password__btn {
    padding: 12px 28px;
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: background 0.2s ease;
    border: none;
  }

  .password__btn--primary {
    background: var(--theme-primary);
    color: var(--theme-background);
  }

  .password__btn--primary:hover {
    background: var(--theme-primary-hover);
  }

  .password__btn--secondary {
    background: transparent;
    color: var(--theme-text);
    border: 1px solid var(--theme-border);
  }

  .password__btn--secondary:hover {
    background: var(--theme-background);
  }

  .password__security {
    margin-top: 40px;
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
  }

  .password__security-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .password__security-header svg {
    color: var(--theme-success);
  }

  .password__security-header h2 {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 600;
    margin: 0;
    color: var(--theme-text);
  }

  .password__tips {
    margin: 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .password__tips li {
    font-size: 14px;
    color: var(--theme-text-secondary);
    line-height: 1.5;
  }

  .password__twofa {
    margin-top: 20px;
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
    border: 1px solid var(--theme-border);
  }

  .password__twofa-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .password__twofa-info h3 {
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 4px;
    color: var(--theme-text);
  }

  .password__twofa-info p {
    font-size: 13px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .password__twofa-btn {
    padding: 10px 20px;
    font-size: 13px;
    font-weight: 500;
    background: transparent;
    color: var(--theme-primary);
    border: 1px solid var(--theme-primary);
    border-radius: var(--btn-radius);
    cursor: pointer;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .password__twofa-btn:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  @media (max-width: 640px) {
    .password__form {
      padding: 24px;
    }

    .password__actions {
      flex-direction: column;
    }

    .password__btn {
      width: 100%;
      text-align: center;
    }

    .password__twofa-content {
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
    }

    .password__twofa-btn {
      width: 100%;
    }
  }
</style>