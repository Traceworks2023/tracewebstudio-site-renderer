---
// Fashion Luxe Account Login Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'login');
const loginContent = pageContent?.content || {};

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);
---

<BaseLayout title="Login - LUXE Account" showHeader={true} showFooter={true}>
  <section class="auth" style={cssVars}>
    <div class="auth__container">
      <div class="auth__card">
        <div class="auth__header">
          <h1 class="auth__title">{loginContent.title || 'Welcome Back'}</h1>
          <p class="auth__subtitle">{loginContent.subtitle || 'Sign in to your LUXE account'}</p>
        </div>

        <form class="auth__form">
          <div class="auth__form-group">
            <label for="email" class="auth__label">Email Address</label>
            <input type="email" id="email" class="auth__input" placeholder="your@email.com" required />
          </div>

          <div class="auth__form-group">
            <label for="password" class="auth__label">Password</label>
            <input type="password" id="password" class="auth__input" placeholder="Enter your password" required />
          </div>

          <div class="auth__options">
            <label class="auth__remember">
              <input type="checkbox" />
              <span>Remember me</span>
            </label>
            <a href="/account/forgot-password" class="auth__forgot">{loginContent.forgot_password_text || 'Forgot password?'}</a>
          </div>

          <button type="submit" class="auth__submit-btn">Sign In</button>
        </form>

        <div class="auth__divider">
          <span>or continue with</span>
        </div>

        <div class="auth__social">
          <button class="auth__social-btn">
            <svg width="20" height="20" viewBox="0 0 24 24">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Google
          </button>
          <button class="auth__social-btn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            GitHub
          </button>
        </div>

        <p class="auth__footer">
          {loginContent.sign_up_link_text || "Don't have an account?"} <a href="/account/register">Create one</a>
        </p>
      </div>

      <div class="auth__image">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=800" alt="Fashion" />
        <div class="auth__image-overlay">
          <h2>New Collection</h2>
          <p>Discover the latest arrivals</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .auth {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 24px;
  }

  .auth__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: 1000px;
    width: 100%;
    background: var(--theme-background);
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: var(--card-shadow);
  }

  .auth__card {
    padding: 60px 48px;
  }

  .auth__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .auth__title {
    font-family: var(--font-heading);
    font-size: 32px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .auth__subtitle {
    font-size: 14px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .auth__form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .auth__form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .auth__label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--theme-text-secondary);
  }

  .auth__input {
    padding: 14px 16px;
    border: 1px solid var(--theme-border);
    border-radius: var(--btn-radius);
    font-size: 14px;
    background: var(--theme-background);
    color: var(--theme-text);
    transition: border-color 0.2s ease;
  }

  .auth__input:focus {
    outline: none;
    border-color: var(--theme-primary);
  }

  .auth__options {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .auth__remember {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--theme-text-secondary);
    cursor: pointer;
  }

  .auth__forgot {
    font-size: 13px;
    color: var(--theme-primary);
    text-decoration: none;
  }

  .auth__forgot:hover {
    text-decoration: underline;
  }

  .auth__submit-btn {
    padding: 16px;
    background: var(--theme-primary);
    color: var(--theme-background);
    border: none;
    border-radius: var(--btn-radius);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .auth__submit-btn:hover {
    background: var(--theme-primary-hover);
  }

  .auth__divider {
    display: flex;
    align-items: center;
    margin: 32px 0;
    color: var(--theme-text-muted);
    font-size: 12px;
  }

  .auth__divider::before,
  .auth__divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--theme-border);
  }

  .auth__divider span {
    padding: 0 16px;
  }

  .auth__social {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .auth__social-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px;
    border: 1px solid var(--theme-border);
    border-radius: var(--btn-radius);
    background: var(--theme-background);
    color: var(--theme-text);
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .auth__social-btn:hover {
    border-color: var(--theme-primary);
    background: var(--theme-surface);
  }

  .auth__footer {
    text-align: center;
    margin-top: 32px;
    font-size: 14px;
    color: var(--theme-text-muted);
  }

  .auth__footer a {
    color: var(--theme-primary);
    font-weight: 500;
    text-decoration: none;
  }

  .auth__footer a:hover {
    text-decoration: underline;
  }

  .auth__image {
    position: relative;
  }

  .auth__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .auth__image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 40px;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    color: white;
  }

  .auth__image-overlay h2 {
    font-family: var(--font-heading);
    font-size: 28px;
    margin: 0 0 8px;
  }

  .auth__image-overlay p {
    margin: 0;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .auth__container {
      grid-template-columns: 1fr;
    }

    .auth__image {
      display: none;
    }

    .auth__card {
      padding: 40px 24px;
    }
  }
</style>
