---
// Fashion Luxe Products Page - Shop all products
import BaseLayout from '../../lib/BaseLayout.astro';
import { getCurrentTheme } from '../../lib/theme-loader';
import { buildThemeCSSVars, isFeatureEnabled } from '../../lib/theme-components';
import { fetchSiteBySlug, fetchProducts } from '../../../lib/api';

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const tenantId = site?.tenant_id || 'default';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const categories = [
  { id: 'all', label: 'All', url: '/products' },
  { id: 'women', label: 'Women', url: '/products?category=women' },
  { id: 'men', label: 'Men', url: '/products?category=men' },
  { id: 'accessories', label: 'Accessories', url: '/products?category=accessories' },
];

const currentCategory = Astro.url.searchParams.get('category') || 'all';

const productsData = await fetchProducts(tenantId, 1, 20, currentCategory !== 'all' ? currentCategory : undefined);

const products = productsData.length > 0 ? productsData : [
  {
    id: '1',
    name: 'Silk Evening Dress',
    price: 6999,
    image: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=400',
    category: 'women',
    rating: 4.8,
    reviews: 124,
  },
  {
    id: '2',
    name: 'Leather Handbag',
    price: 7499,
    image: 'https://images.unsplash.com/photo-1584970365277-6b8209612960?w=400',
    category: 'accessories',
    rating: 4.9,
    reviews: 89,
  },
  {
    id: '3',
    name: 'Designer Watch',
    price: 12499,
    image: 'https://images.unsplash.com/photo-1524592094714-0f0fc841e2b4?w=400',
    category: 'accessories',
    rating: 4.7,
    reviews: 256,
  },
  {
    id: '4',
    name: 'Premium Shirt',
    price: 2499,
    image: 'https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400',
    category: 'men',
    rating: 4.6,
    reviews: 178,
  },
  {
    id: '5',
    name: 'Wool Suit Jacket',
    price: 15999,
    image: 'https://images.unsplash.com/photo-1568702846914-96b30935273e?w=400',
    category: 'men',
    rating: 4.8,
    reviews: 93,
  },
  {
    id: '6',
    name: 'Silk Scarf',
    price: 1999,
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=400',
    category: 'women',
    rating: 4.5,
    reviews: 210,
  },
];

const currentCategory = Astro.url.searchParams.get('category') || 'all';
const filteredProducts = currentCategory === 'all' ? products : products.filter(p => p.category === currentCategory);

const showRatings = isFeatureEnabled('reviews', 'products', theme);
const showCategories = isFeatureEnabled('categories', 'products', theme);
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Products - LUXE</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            theme: {
              primary: 'var(--theme-primary)',
              'primary-hover': 'var(--theme-primary-hover)',
              background: 'var(--theme-background)',
              surface: 'var(--theme-surface)',
              text: 'var(--theme-text)',
              'text-secondary': 'var(--theme-text-secondary)',
              'text-muted': 'var(--theme-text-muted)',
              border: 'var(--theme-border)',
            }
          }
        }
      }
    }
  </script>
</head>
<body class="${cssVars.background} ${cssVars.text}">
  <div class="container mx-auto px-4 py-10">
    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-4xl font-bold mb-2">Shop All Products</h1>
      <p class="text-gray-500">Discover our curated collection of premium fashion and accessories</p>
    </div>

    <!-- Categories Filter -->
    {showCategories && (
      <div class="flex flex-wrap gap-3 mb-10">
        {categories.map((cat) => (
          <a
            href={cat.url}
            class={`px-6 py-3 rounded-full transition-all ${
              currentCategory === cat.id
                ? `${cssVars.primary} text-white`
                : `${cssVars.text} ${cssVars.border} border hover:bg-gray-50`
            }`}
          >
            {cat.label}
          </a>
        ))}
      </div>
    )}

    <!-- Products Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {filteredProducts.map((product) => (
        <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300">
          {/* Product Image */}
          <div class="relative overflow-hidden pb-[100%]">
            <img
              src={product.image}
              alt={product.name}
              class="absolute inset-0 w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
            />
            <div class="absolute top-4 right-4">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-white/90 text-gray-900">
                New
              </span>
            </div>
          </div>

          {/* Product Info */}
          <div class="p-6">
            <div class="flex justify-between items-start mb-3">
              <h3 class="text-lg font-semibold text-gray-900 line-clamp-1">{product.name}</h3>
              <div class="flex items-center gap-1 text-yellow-500">
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
                <span class="text-sm font-medium">{product.rating}</span>
              </div>
            </div>

            {showRatings && (
              <p class="text-sm text-gray-500 mb-4">
                {product.reviews} reviews
              </p>
            )}

            <p class="text-2xl font-bold text-gray-900 mb-5">
              ₹{product.price.toLocaleString('en-IN')}
            </p>

            <a
              href={`/product/${product.id}`}
              class="block w-full py-3 px-6 bg-gray-900 text-white rounded-xl font-semibold hover:bg-orange-600 transition-colors text-center"
            >
              View Product
            </a>
          </div>
        </div>
      ))}
    </div>

    {/* Empty State */}
    {filteredProducts.length === 0 && (
      <div class="text-center py-20">
        <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 11a4 4 0 100-8 4 4 0 000 8z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
        </svg>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">No products found</h3>
        <p class="text-gray-500">Try changing the category filter</p>
        <a href="/products" class="mt-4 inline-block text-orange-600 font-semibold hover:text-orange-700">
          View all products
        </a>
      </div>
    )}
  </div>
</body>
</html>
