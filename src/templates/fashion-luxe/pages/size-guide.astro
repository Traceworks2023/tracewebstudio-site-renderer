---
// Fashion Luxe Size Guide Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars } from '../lib/theme-components';

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const sizeCharts = {
  women: {
    title: "Women's Clothing",
    headers: ['Size', 'Chest (in)', 'Waist (in)', 'Hips (in)'],
    rows: [
      { size: 'XS', chest: '32-33', waist: '24-25', hips: '34-35' },
      { size: 'S', chest: '34-36', waist: '26-27', hips: '36-37' },
      { size: 'M', chest: '37-38', waist: '28-29', hips: '38-39' },
      { size: 'L', chest: '39-41', waist: '30-32', hips: '40-42' },
      { size: 'XL', chest: '42-44', waist: '33-35', hips: '43-45' }
    ]
  },
  men: {
    title: "Men's Clothing",
    headers: ['Size', 'Chest (in)', 'Waist (in)', 'Hips (in)'],
    rows: [
      { size: 'S', chest: '36-38', waist: '29-31', hips: '35-37' },
      { size: 'M', chest: '39-41', waist: '32-34', hips: '38-40' },
      { size: 'L', chest: '42-44', waist: '35-37', hips: '41-43' },
      { size: 'XL', chest: '45-47', waist: '38-40', hips: '44-46' },
      { size: 'XXL', chest: '48-50', waist: '41-43', hips: '47-49' }
    ]
  },
  shoes: {
    title: 'Shoes',
    headers: ['US', 'EU', 'UK', 'Length (in)'],
    rows: [
      { size: '6', eu: '36-37', uk: '4', length: '9.0' },
      { size: '7', eu: '37-38', uk: '5', length: '9.3' },
      { size: '8', eu: '38-39', uk: '6', length: '9.6' },
      { size: '9', eu: '39-40', uk: '7', length: '9.9' },
      { size: '10', eu: '40-41', uk: '8', length: '10.2' },
      { size: '11', eu: '41-42', uk: '9', length: '10.5' }
    ]
  }
};

const measurementTips = [
  { title: 'Bust/Chest', description: 'Measure around the fullest part of your chest, keeping the tape parallel to the floor.' },
  { title: 'Waist', description: 'Measure around your natural waistline, keeping the tape comfortably loose.' },
  { title: 'Hips', description: 'Measure around the fullest part of your hips and buttocks, keeping the tape parallel to the floor.' },
  { title: 'Inseam', description: 'Measure from the crotch seam to the bottom of the leg. For pants, measure along the inner thigh.' }
];
---

<BaseLayout title="Size Guide - LUXE" showHeader={true} showFooter={true}>
  <section class="size-guide" style={cssVars}>
    <div class="size-guide__hero">
      <h1 class="size-guide__title">Size Guide</h1>
      <p class="size-guide__subtitle">Find your perfect fit with our comprehensive size charts</p>
    </div>

    <div class="size-guide__container">
      {/* Measurement Tips */}
      <div class="size-guide__tips">
        <h2 class="size-guide__section-title">How to Measure</h2>
        <div class="size-guide__tips-grid">
          {measurementTips.map((tip) => (
            <div class="size-guide__tip">
              <h3 class="size-guide__tip-title">{tip.title}</h3>
              <p class="size-guide__tip-text">{tip.description}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Size Charts */}
      <div class="size-guide__charts">
        {/* Women's Chart */}
        <div class="size-guide__chart">
          <h2 class="size-guide__chart-title">{sizeCharts.women.title}</h2>
          <div class="size-guide__table-wrapper">
            <table class="size-guide__table">
              <thead>
                <tr>
                  {sizeCharts.women.headers.map((header) => (
                    <th>{header}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {sizeCharts.women.rows.map((row) => (
                  <tr>
                    <td class="size-guide__size">{row.size}</td>
                    <td>{row.chest}</td>
                    <td>{row.waist}</td>
                    <td>{row.hips}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* Men's Chart */}
        <div class="size-guide__chart">
          <h2 class="size-guide__chart-title">{sizeCharts.men.title}</h2>
          <div class="size-guide__table-wrapper">
            <table class="size-guide__table">
              <thead>
                <tr>
                  {sizeCharts.men.headers.map((header) => (
                    <th>{header}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {sizeCharts.men.rows.map((row) => (
                  <tr>
                    <td class="size-guide__size">{row.size}</td>
                    <td>{row.chest}</td>
                    <td>{row.waist}</td>
                    <td>{row.hips}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        {/* Shoes Chart */}
        <div class="size-guide__chart">
          <h2 class="size-guide__chart-title">{sizeCharts.shoes.title}</h2>
          <div class="size-guide__table-wrapper">
            <table class="size-guide__table">
              <thead>
                <tr>
                  {sizeCharts.shoes.headers.map((header) => (
                    <th>{header}</th>
                  ))}
                </tr>
              </thead>
              <tbody>
                {sizeCharts.shoes.rows.map((row) => (
                  <tr>
                    <td class="size-guide__size">{row.size}</td>
                    <td>{row.eu}</td>
                    <td>{row.uk}</td>
                    <td>{row.length}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      {/* Fit Note */}
      <div class="size-guide__note">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M12 16v-4"></path>
          <path d="M12 8h.01"></path>
        </svg>
        <div>
          <h3 class="size-guide__note-title">About Fit</h3>
          <p class="size-guide__note-text">
            Our garments are designed with a contemporary fit. If you prefer a more relaxed fit, we recommend sizing up. 
            Each product page includes specific measurements and fit notes to help you make an informed decision.
          </p>
        </div>
      </div>

      {/* Contact CTA */}
      <div class="size-guide__contact">
        <p>Still unsure about your size? Our stylists are here to help.</p>
        <a href="/contact" class="size-guide__contact-btn">Contact a Stylist</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .size-guide {
    padding-bottom: 0;
  }

  .size-guide__hero {
    background: var(--theme-surface);
    padding: 80px 24px;
    text-align: center;
  }

  .size-guide__title {
    font-family: var(--font-heading);
    font-size: 48px;
    font-weight: 600;
    margin: 0 0 16px;
    color: var(--theme-text);
  }

  .size-guide__subtitle {
    font-size: 18px;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .size-guide__container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 24px;
  }

  .size-guide__tips {
    margin-bottom: 80px;
  }

  .size-guide__section-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: 600;
    margin: 0 0 32px;
    text-align: center;
    color: var(--theme-text);
  }

  .size-guide__tips-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }

  .size-guide__tip {
    background: var(--theme-surface);
    padding: 24px;
    border-radius: var(--card-radius);
    text-align: center;
  }

  .size-guide__tip-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 12px;
    color: var(--theme-primary);
  }

  .size-guide__tip-text {
    font-size: 13px;
    line-height: 1.6;
    color: var(--theme-text-muted);
    margin: 0;
  }

  .size-guide__charts {
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .size-guide__chart {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 32px;
  }

  .size-guide__chart-title {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 600;
    margin: 0 0 24px;
    color: var(--theme-text);
    text-align: center;
  }

  .size-guide__table-wrapper {
    overflow-x: auto;
  }

  .size-guide__table {
    width: 100%;
    border-collapse: collapse;
    min-width: 400px;
  }

  .size-guide__table th {
    padding: 14px 16px;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--theme-text-secondary);
    border-bottom: 2px solid var(--theme-border);
  }

  .size-guide__table td {
    padding: 14px 16px;
    text-align: center;
    font-size: 14px;
    color: var(--theme-text);
    border-bottom: 1px solid var(--theme-border);
  }

  .size-guide__table tr:last-child td {
    border-bottom: none;
  }

  .size-guide__size {
    font-weight: 600;
    color: var(--theme-primary);
  }

  .size-guide__note {
    display: flex;
    gap: 20px;
    align-items: flex-start;
    background: rgba(59, 130, 246, 0.1);
    border-radius: var(--card-radius);
    padding: 24px;
    margin-top: 60px;
  }

  .size-guide__note svg {
    flex-shrink: 0;
    color: var(--theme-info);
    margin-top: 2px;
  }

  .size-guide__note-title {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 8px;
    color: var(--theme-text);
  }

  .size-guide__note-text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--theme-text-secondary);
    margin: 0;
  }

  .size-guide__contact {
    text-align: center;
    margin-top: 60px;
    padding-top: 60px;
    border-top: 1px solid var(--theme-border);
  }

  .size-guide__contact p {
    font-size: 16px;
    color: var(--theme-text-muted);
    margin: 0 0 20px;
  }

  .size-guide__contact-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--theme-primary);
    color: var(--theme-background);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    border-radius: var(--btn-radius);
    transition: background 0.2s ease;
  }

  .size-guide__contact-btn:hover {
    background: var(--theme-primary-hover);
  }

  @media (max-width: 1024px) {
    .size-guide__tips-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .size-guide__hero {
      padding: 60px 24px;
    }

    .size-guide__title {
      font-size: 32px;
    }

    .size-guide__tips-grid {
      grid-template-columns: 1fr;
    }

    .size-guide__chart {
      padding: 20px;
    }
  }
</style>
