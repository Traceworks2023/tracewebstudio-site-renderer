---
// Product Detail Page - Fashion Luxe
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductGallery from '../sections/ProductGallery.astro';
import ProductInfo from '../sections/ProductInfo.astro';
import ProductTabs from '../sections/ProductTabs.astro';
import RelatedProducts from '../sections/RelatedProducts.astro';
import TrustIndicators from '../sections/TrustIndicators.astro';
import NewsletterSection from '../sections/NewsletterSection.astro';
import FooterSection from '../sections/FooterSection.astro';
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

import type { SiteConfig } from '../../lib/site-config';

interface Props {
  siteConfig: SiteConfig;
  product?: {
    id: string;
    name: string;
    price: number;
    original_price?: number;
    images: string[];
    description: string;
    short_description: string;
    sku: string;
    stock: number;
    rating: number;
    review_count: number;
    category: string;
    tags: string[];
  };
}

const { siteConfig, product } = Astro.props;

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'product');
const productContent = pageContent?.content || {};

// Demo product data
const demoProduct = product || {
  id: '1',
  name: 'Elegant Silk Dress',
  price: 4999,
  original_price: 7999,
  images: [
    'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=800',
    'https://images.unsplash.com/photo-1583391733956-3750e0ff4e8b?w=800',
    'https://images.unsplash.com/photo-1594938298603-c8148c4dae35?w=800',
    'https://images.unsplash.com/photo-1572804013309-59a88b7e92f1?w=800'
  ],
  description: `
    <h3>Product Details</h3>
    <p>Experience luxury with our Elegant Silk Dress, crafted from 100% pure mulberry silk. This stunning piece features:</p>
    <ul>
      <li>Premium quality mulberry silk fabric</li>
      <li>Elegant V-neckline with delicate embroidery</li>
      <li>Flattering A-line silhouette</li>
      <li>Fully lined for comfort</li>
      <li>Side zip closure</li>
      <li>Hand wash or dry clean recommended</li>
    </ul>
    <h3>Size & Fit</h3>
    <p>The model is wearing size S. This dress has a regular fit. Available in XS, S, M, L, XL.</p>
  `,
  short_description: 'Premium silk dress with elegant V-neckline and A-line silhouette',
  sku: 'LUXE-SD-001',
  stock: 15,
  rating: 4.5,
  review_count: 128,
  category: 'Women',
  tags: ['dress', 'silk', 'premium', 'formal']
};
---

<BaseLayout siteConfig={siteConfig} title={demoProduct.name}>
  <!-- Breadcrumb -->
  <div class="bg-gray-50 py-4">
    <div class="container mx-auto px-4">
      <nav class="text-sm">
        <a href="/" class="text-gray-500 hover:text-black">Home</a>
        <span class="mx-2 text-gray-400">/</span>
        <a href="/category/women" class="text-gray-500 hover:text-black">{demoProduct.category}</a>
        <span class="mx-2 text-gray-400">/</span>
        <span class="text-gray-900">{demoProduct.name}</span>
      </nav>
    </div>
  </div>
  
  <!-- Product Section -->
  <section class="py-12">
    <div class="container mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Product Gallery -->
        <ProductGallery 
          content={{
            images: demoProduct.images.map((url, i) => ({ 
              id: String(i), 
              url, 
              alt_text: `${demoProduct.name} - Image ${i + 1}` 
            })),
            thumbnail_position: 'bottom',
            show_zoom: true
          }} 
        />
        
        <!-- Product Info -->
        <ProductInfo 
          content={{
            section_id: 'product-info',
            product: demoProduct
          }} 
        />
      </div>
    </div>
  </section>
  
  <!-- Product Tabs -->
  <section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4 max-w-4xl">
      <ProductTabs 
        content={{
          section_id: 'product-tabs',
          tabs: [
            { id: 'description', title: 'Description', content: demoProduct.description, content_type: 'html' },
            { id: 'shipping', title: 'Shipping', content: '<p>Free shipping on orders above ₹999. Standard delivery takes 3-5 business days.</p>', content_type: 'html' },
            { id: 'returns', title: 'Returns', content: '<p>Easy 7-day returns. Items must be unworn with tags attached.</p>', content_type: 'html' }
          ],
          default_tab: 'description'
        }} 
      />
    </div>
  </section>
  
  <!-- Related Products -->
  <section class="py-16">
    <div class="container mx-auto px-4">
      <RelatedProducts 
        content={{
          title: 'You May Also Like',
          section_id: 'related-products',
          products: [
            { id: '2', name: 'Designer Handbag', price: 4999, image: 'https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=400' },
            { id: '3', name: 'Classic Watch', price: 7999, image: 'https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=400' },
            { id: '4', name: 'Gold Necklace', price: 12999, image: 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=400' },
            { id: '5', name: 'Silk Scarf', price: 1999, image: 'https://images.unsplash.com/photo-1601370690183-1c7796ecec61?w=400' }
          ]
        }} 
      />
    </div>
  </section>
  
  <!-- Trust Indicators -->
  <TrustIndicators content={{}} />
  
  <!-- Newsletter -->
  <NewsletterSection content={{}} />
  
  <!-- Footer -->
  <FooterSection siteConfig={siteConfig} />
</BaseLayout>
