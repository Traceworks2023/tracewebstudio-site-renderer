---
// Fashion Luxe Cart Page
import BaseLayout from '../lib/BaseLayout.astro';
import { getCurrentTheme } from '../lib/theme-loader';
import { buildThemeCSSVars, isFeatureEnabled } from '../lib/theme-components';
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

const siteSlug = Astro.url.pathname.split('/')[1] || 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'cart');
const cartContent = pageContent?.content || {};

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const showImages = isFeatureEnabled('images', 'cart', theme);
const showQuantities = isFeatureEnabled('quantities', 'cart', theme);
const showRemove = isFeatureEnabled('remove', 'cart', theme);
const showCoupon = isFeatureEnabled('coupon', 'cart', theme);
const showSummary = isFeatureEnabled('summary', 'cart', theme);

const emptyCartMessage = cartContent.empty_cart_message || 'Your cart is empty';
const continueShoppingText = cartContent.continue_shopping_text || 'Continue Shopping';

const cartItems = [
  {
    id: '1',
    name: 'Elegant Silk Dress',
    price: 4999,
    compareAtPrice: 7999,
    image: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=200',
    quantity: 1,
    size: 'M',
    color: 'Black'
  },
  {
    id: '2',
    name: 'Designer Handbag',
    price: 4999,
    image: 'https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=200',
    quantity: 1,
    size: 'One Size',
    color: 'Tan'
  }
];

const subtotal = cartItems.reduce((sum, item) => sum + item.price * item.quantity, 0);
const shipping = subtotal > 10000 ? 0 : 999;
const total = subtotal + shipping;
---

<BaseLayout title="Shopping Cart - LUXE" showHeader={true} showFooter={true}>
  <section class="cart" style={cssVars}>
    <div class="cart__container">
      <h1 class="cart__title">Shopping Cart</h1>

      {cartItems.length === 0 ? (
        <div class="cart__empty">
          <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
            <path d="M3 6h18"></path>
            <path d="M16 10a4 4 0 0 1-8 0"></path>
          </svg>
          <h2>{emptyCartMessage}</h2>
          <p>Looks like you haven't added any items yet.</p>
          <a href="/products" class="cart__continue-btn">{continueShoppingText}</a>
        </div>
      ) : (
        <div class="cart__content">
          <div class="cart__items">
            <div class="cart__header">
              <span>Product</span>
              <span>Price</span>
              <span>Quantity</span>
              <span>Total</span>
            </div>

            {cartItems.map((item) => (
              <div class="cart__item" data-item-id={item.id}>
                <div class="cart__item-product">
                  {showImages && (
                    <img src={item.image} alt={item.name} class="cart__item-image" />
                  )}
                  <div class="cart__item-details">
                    <h3 class="cart__item-name">{item.name}</h3>
                    <p class="cart__item-meta">{item.color} / {item.size}</p>
                    {showRemove && (
                      <button class="cart__item-remove" data-remove={item.id}>Remove</button>
                    )}
                  </div>
                </div>

                <div class="cart__item-price">
                  <span class="cart__price-current">${(item.price / 100).toFixed(2)}</span>
                  {item.compareAtPrice && (
                    <span class="cart__price-compare">${(item.compareAtPrice / 100).toFixed(2)}</span>
                  )}
                </div>

                {showQuantities && (
                  <div class="cart__item-quantity">
                    <button class="cart__qty-btn" data-action="decrease" data-item={item.id}>-</button>
                    <span class="cart__qty-value">{item.quantity}</span>
                    <button class="cart__qty-btn" data-action="increase" data-item={item.id}>+</button>
                  </div>
                )}

                <div class="cart__item-total">
                  ${((item.price * item.quantity) / 100).toFixed(2)}
                </div>
              </div>
            ))}
          </div>

          <div class="cart__sidebar">
            {showCoupon && (
              <div class="cart__coupon">
                <h3>Coupon Code</h3>
                <div class="cart__coupon-form">
                  <input type="text" placeholder="Enter coupon code" class="cart__coupon-input" />
                  <button class="cart__coupon-btn">Apply</button>
                </div>
              </div>
            )}

            {showSummary && (
              <div class="cart__summary">
                <h3>Order Summary</h3>
                <div class="cart__summary-row">
                  <span>Subtotal</span>
                  <span>${(subtotal / 100).toFixed(2)}</span>
                </div>
                <div class="cart__summary-row">
                  <span>Shipping</span>
                  <span>{shipping === 0 ? 'Free' : `$${(shipping / 100).toFixed(2)}`}</span>
                </div>
                <div class="cart__summary-row cart__summary-row--total">
                  <span>Total</span>
                  <span>${(total / 100).toFixed(2)}</span>
                </div>
                <a href="/checkout" class="cart__checkout-btn">Proceed to Checkout</a>
                <a href="/products" class="cart__continue-link">Continue Shopping</a>
              </div>
            )}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style define:vars={cssVars}>
  .cart {
    padding: 60px 24px;
    min-height: 60vh;
  }

  .cart__container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .cart__title {
    font-family: var(--font-heading);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 40px;
    color: var(--theme-text);
  }

  .cart__empty {
    text-align: center;
    padding: 80px 20px;
    color: var(--theme-text-muted);
  }

  .cart__empty svg {
    margin-bottom: 24px;
    opacity: 0.5;
  }

  .cart__empty h2 {
    font-family: var(--font-heading);
    font-size: 24px;
    margin: 0 0 12px;
    color: var(--theme-text);
  }

  .cart__empty p {
    margin: 0 0 32px;
  }

  .cart__continue-btn {
    display: inline-block;
    padding: 14px 32px;
    background: var(--theme-primary);
    color: var(--theme-background);
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    transition: background 0.2s ease;
  }

  .cart__continue-btn:hover {
    background: var(--theme-primary-hover);
  }

  .cart__content {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 60px;
  }

  .cart__items {
    border: 1px solid var(--theme-border);
    border-radius: var(--card-radius);
  }

  .cart__header {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 20px;
    padding: 16px 24px;
    background: var(--theme-surface);
    border-bottom: 1px solid var(--theme-border);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--theme-text-secondary);
  }

  .cart__item {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 20px;
    padding: 24px;
    border-bottom: 1px solid var(--theme-border);
    align-items: center;
  }

  .cart__item:last-child {
    border-bottom: none;
  }

  .cart__item-product {
    display: flex;
    gap: 20px;
  }

  .cart__item-image {
    width: 100px;
    height: 130px;
    object-fit: cover;
    border-radius: var(--card-radius);
  }

  .cart__item-name {
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 4px;
    color: var(--theme-text);
  }

  .cart__item-meta {
    font-size: 13px;
    color: var(--theme-text-muted);
    margin: 0 0 8px;
  }

  .cart__item-remove {
    background: none;
    border: none;
    color: var(--theme-error);
    font-size: 12px;
    cursor: pointer;
    padding: 0;
  }

  .cart__item-price {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cart__price-current {
    font-weight: 600;
    color: var(--theme-text);
  }

  .cart__price-compare {
    font-size: 13px;
    color: var(--theme-text-muted);
    text-decoration: line-through;
  }

  .cart__item-quantity {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .cart__qty-btn {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--theme-border);
    background: var(--theme-background);
    color: var(--theme-text);
    font-size: 16px;
    cursor: pointer;
    transition: border-color 0.2s ease;
  }

  .cart__qty-btn:hover {
    border-color: var(--theme-primary);
  }

  .cart__qty-value {
    font-size: 14px;
    min-width: 24px;
    text-align: center;
  }

  .cart__item-total {
    font-weight: 600;
    font-size: 16px;
    color: var(--theme-text);
  }

  .cart__sidebar {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .cart__coupon {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
  }

  .cart__coupon h3 {
    font-family: var(--font-heading);
    font-size: 16px;
    margin: 0 0 16px;
    color: var(--theme-text);
  }

  .cart__coupon-form {
    display: flex;
    gap: 8px;
  }

  .cart__coupon-input {
    flex: 1;
    padding: 12px 16px;
    border: 1px solid var(--theme-border);
    border-radius: var(--btn-radius);
    font-size: 14px;
    background: var(--theme-background);
    color: var(--theme-text);
  }

  .cart__coupon-input:focus {
    outline: none;
    border-color: var(--theme-primary);
  }

  .cart__coupon-btn {
    padding: 12px 20px;
    background: var(--theme-secondary);
    color: white;
    border: none;
    border-radius: var(--btn-radius);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .cart__coupon-btn:hover {
    background: var(--theme-primary);
  }

  .cart__summary {
    background: var(--theme-surface);
    border-radius: var(--card-radius);
    padding: 24px;
  }

  .cart__summary h3 {
    font-family: var(--font-heading);
    font-size: 16px;
    margin: 0 0 20px;
    color: var(--theme-text);
  }

  .cart__summary-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 0;
    border-bottom: 1px solid var(--theme-border);
    font-size: 14px;
    color: var(--theme-text-secondary);
  }

  .cart__summary-row--total {
    border-bottom: none;
    padding-top: 16px;
    font-size: 18px;
    font-weight: 600;
    color: var(--theme-text);
  }

  .cart__checkout-btn {
    display: block;
    width: 100%;
    padding: 16px;
    margin-top: 20px;
    background: var(--theme-primary);
    color: var(--theme-background);
    text-align: center;
    text-decoration: none;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 12px;
    letter-spacing: 0.05em;
    border-radius: var(--btn-radius);
    transition: background 0.2s ease;
  }

  .cart__checkout-btn:hover {
    background: var(--theme-primary-hover);
  }

  .cart__continue-link {
    display: block;
    text-align: center;
    margin-top: 16px;
    color: var(--theme-text-secondary);
    font-size: 13px;
  }

  @media (max-width: 1024px) {
    .cart__content {
      grid-template-columns: 1fr;
    }

    .cart__header {
      display: none;
    }

    .cart__item {
      grid-template-columns: 1fr;
      gap: 12px;
    }
  }
</style>
