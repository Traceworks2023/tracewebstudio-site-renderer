---
// Base Layout - wraps all pages
import type { SiteConfig } from '../lib/site-config';
import Header from '../sections/Header.astro';

interface Props {
  siteConfig: SiteConfig;
  title?: string;
  description?: string;
}

const { siteConfig, title, description } = Astro.props;
const pageTitle = title || siteConfig.pages.find(p => p.is_homepage)?.seo.title || siteConfig.site_name || 'Store';
const pageDescription = description || siteConfig.pages.find(p => p.is_homepage)?.seo.description || '';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{pageTitle}</title>
  {pageDescription && <meta name="description" content={pageDescription}>}
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  
  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Playfair Display', 'serif'],
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            primary: '#000000',
            accent: '#FA5014',
          }
        }
      }
    }
  </script>
  
  <!-- Custom Styles -->
  <style is:global>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Inter', sans-serif;
      color: #111827;
      background-color: #ffffff;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    
    h1, h2, h3, h4, h5, h6 {
      font-family: 'Playfair Display', serif;
    }
    
    /* Smooth scrolling */
    html {
      scroll-behavior: smooth;
    }
    
    /* Custom scrollbar */
    ::-webkit-scrollbar {
      width: 8px;
    }
    
    ::-webkit-scrollbar-track {
      background: #f1f1f1;
    }
    
    ::-webkit-scrollbar-thumb {
      background: #888;
      border-radius: 4px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
      background: #555;
    }
    
    /* Image hover effects */
    img {
      transition: transform 0.3s ease;
    }
    
    /* Button hover effects */
    button, a {
      transition: all 0.3s ease;
    }
    
    /* Animation classes */
    .fade-in {
      animation: fadeIn 0.5s ease-in;
    }
    
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    
    .slide-up {
      animation: slideUp 0.5s ease-out;
    }
    
    @keyframes slideUp {
      from { 
        opacity: 0;
        transform: translateY(20px);
      }
      to { 
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
  
  <!-- Custom Head Code -->
  {siteConfig.custom_code?.head && (
    <Fragment set:html={siteConfig.custom_code.head} />
  )}
</head>
<body class="min-h-screen flex flex-col">
  <!-- Header -->
  <Header siteConfig={siteConfig} />
  
  <!-- Main Content -->
  <main class="flex-1">
    <slot />
  </main>
  
  <!-- Custom Body Start Code -->
  {siteConfig.custom_code?.body_start && (
    <Fragment set:html={siteConfig.custom_code.body_start} />
  )}
  
  <!-- Custom Body End Code -->
  {siteConfig.custom_code?.body_end && (
    <Fragment set:html={siteConfig.custom_code.body_end} />
  )}
</body>
</html>
