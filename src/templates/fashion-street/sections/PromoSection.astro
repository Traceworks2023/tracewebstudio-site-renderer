---
// Promo Section - Bold discount callout
interface Props {
  content: {
    heading?: string;
    code?: string;
    discount?: string;
    subtext?: string;
    background_image?: string;
  };
}

const { content } = Astro.props;
const {
  heading = 'USE CODE',
  code = 'STREET20',
  discount = '20% OFF',
  subtext = '',
  background_image = ''
} = content;
---

<section class="relative py-24 overflow-hidden">
  <!-- Background -->
  {background_image && (
    <div 
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${background_image}');`}
    ></div>
  )}
  <div class="absolute inset-0 bg-black/80"></div>
  
  <!-- Content -->
  <div class="relative z-10 container mx-auto px-4 text-center">
    <p class="font-heading text-lg text-gray-400 tracking-widest mb-4">{heading}</p>
    <div class="font-display text-6xl md:text-8xl lg:text-9xl tracking-widest text-neon-glow mb-4">
      {code}
    </div>
    <div class="font-display text-5xl md:text-7xl tracking-widest text-white mb-6">
      {discount}
    </div>
    {subtext && (
      <p class="font-heading text-gray-400 tracking-wider">{subtext}</p>
    )}
  </div>
  
  <!-- Decorative Elements -->
  <div class="absolute top-0 left-0 w-32 h-32 border-l-4 border-t-4 border-accent opacity-50"></div>
  <div class="absolute bottom-0 right-0 w-32 h-32 border-r-4 border-b-4 border-neon opacity-50"></div>
</section>
