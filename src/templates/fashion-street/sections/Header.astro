---
// Street Header - Dark, bold navigation
import type { SiteConfig } from '../../lib/site-config';

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;

const navItems = [
  { label: 'NEW DROPS', url: '/new' },
  { label: 'HOODIES', url: '/category/hoodies' },
  { label: 'TEES', url: '/category/t-shirts' },
  { label: 'SNEAKERS', url: '/category/sneakers' },
  { label: 'ACCESSORIES', url: '/category/accessories' },
  { label: 'SALE', url: '/sale' }
];
---

<header class="sticky top-0 z-50 bg-black/95 backdrop-blur-sm border-b border-gray-800">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="font-display text-3xl md:text-4xl tracking-widest text-white hover:text-accent transition-colors">
        {siteConfig?.site_name || 'URBN'}
      </a>
      
      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center space-x-8">
        {navItems.map((item) => (
          <a 
            href={item.url}
            class="font-heading text-xs tracking-widest text-gray-300 hover:text-white transition-colors relative group"
          >
            {item.label}
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-accent group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </nav>
      
      <!-- Right Actions -->
      <div class="flex items-center space-x-4">
        <!-- Search -->
        <button class="text-gray-300 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </button>
        
        <!-- Account -->
        <a href="/account" class="text-gray-300 hover:text-white transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
        </a>
        
        <!-- Cart -->
        <button class="text-gray-300 hover:text-white transition-colors relative">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
          </svg>
          <span class="absolute -top-2 -right-2 w-5 h-5 bg-accent text-white text-xs font-bold rounded-full flex items-center justify-center">2</span>
        </button>
        
        <!-- Mobile Menu -->
        <button class="lg:hidden text-gray-300">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>
