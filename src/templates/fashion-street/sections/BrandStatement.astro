---
// Brand Statement - Bold typography section
interface Props {
  content: {
    text?: string;
    subtext?: string;
  };
}

const { content } = Astro.props;
const {
  text = 'YOUR BRAND STATEMENT HERE',
  subtext = ''
} = content;
---

<section class="py-20 bg-gradient-to-r from-accent via-purple-600 to-accent">
  <div class="container mx-auto px-4 text-center">
    <h2 class="font-display text-4xl md:text-6xl lg:text-8xl tracking-widest text-white mb-6">
      {text}
    </h2>
    {subtext && (
      <p class="font-heading text-lg md:text-xl text-white/80 tracking-wider">
        {subtext}
      </p>
    )}
  </div>
</section>
