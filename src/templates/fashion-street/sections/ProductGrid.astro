---
// Product Grid - Street style dark grid
interface Product {
  id: string;
  name: string;
  price: number;
  original_price?: number;
  image: string;
  badge?: string;
  rating?: number;
}

interface Props {
  content: {
    products: Product[];
    columns?: number;
    show_prices?: boolean;
    show_ratings?: boolean;
  };
}

const { content } = Astro.props;
const {
  products = [],
  columns = 4,
  show_prices = true,
  show_ratings = true
} = content;

const gridCols = {
  2: 'grid-cols-2',
  3: 'grid-cols-2 md:grid-cols-3',
  4: 'grid-cols-2 md:grid-cols-4'
}[columns] || 'grid-cols-2 md:grid-cols-4';
---

<div class={`grid ${gridCols} gap-4 md:gap-6`}>
  {products.map((product) => (
    <a 
      href={`/product/${product.id}`}
      class="group bg-street rounded-lg overflow-hidden border border-gray-800 hover:border-accent transition-colors"
    >
      <!-- Product Image -->
      <div class="relative aspect-[3/4] overflow-hidden bg-gray-900">
        <img 
          src={product.image}
          alt={product.name}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
        />
        {product.badge && (
          <span class="absolute top-3 left-3 bg-accent text-white text-xs font-bold px-2 py-1 tracking-wider">
            {product.badge}
          </span>
        )}
        
        <!-- Quick Add -->
        <div class="absolute bottom-0 left-0 right-0 p-3 translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <button class="w-full bg-white text-black py-3 font-heading text-xs tracking-widest hover:bg-accent hover:text-white transition-colors">
            QUICK ADD
          </button>
        </div>
      </div>
      
      <!-- Product Info -->
      <div class="p-4">
        <h3 class="font-heading text-sm tracking-wider text-white mb-2 group-hover:text-accent transition-colors line-clamp-1">
          {product.name.toUpperCase()}
        </h3>
        
        {show_prices && (
          <div class="flex items-center gap-2">
            <span class="font-heading font-bold text-white">₹{product.price.toLocaleString()}</span>
            {product.original_price && (
              <span class="text-gray-500 line-through text-sm">₹{product.original_price.toLocaleString()}</span>
            )}
          </div>
        )}
      </div>
    </a>
  ))}
</div>
