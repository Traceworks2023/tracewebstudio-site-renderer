---
// Street Newsletter - Dark, bold
interface Props {
  content: {
    heading?: string;
    description?: string;
    placeholder_text?: string;
    button_text?: string;
    background_color?: string;
  };
}

const { content } = Astro.props;
const {
  heading = 'JOIN THE MOVEMENT',
  description = 'Get early access to drops, exclusive offers, and street style inspiration.',
  placeholder_text = 'Enter your email',
  button_text = 'SUBSCRIBE',
  background_color = '#0a0a0a'
} = content;
---

<section class="py-20 border-y border-gray-800" style={`background-color: ${background_color}`}>
  <div class="container mx-auto px-4">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-display text-4xl md:text-6xl tracking-widest text-white mb-4">{heading}</h2>
      <p class="font-heading text-gray-400 tracking-wider mb-8">{description}</p>
      
      <form class="flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
        <input 
          type="email" 
          placeholder={placeholder_text}
          class="flex-1 bg-transparent border border-gray-700 text-white px-6 py-4 font-heading text-sm tracking-wider focus:outline-none focus:border-accent transition-colors"
          required
        />
        <button 
          type="submit"
          class="bg-accent text-white px-8 py-4 font-heading text-sm tracking-widest hover:bg-white hover:text-black transition-colors"
        >
          {button_text}
        </button>
      </form>
    </div>
  </div>
</section>
