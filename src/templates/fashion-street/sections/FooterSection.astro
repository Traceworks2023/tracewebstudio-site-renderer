---
// Street Footer - Dark, bold
import type { SiteConfig } from '../../lib/site-config';

interface Props {
  siteConfig: SiteConfig;
}

const { siteConfig } = Astro.props;

const columns = [
  {
    title: 'SHOP',
    links: [
      { label: 'New Drops', url: '/new' },
      { label: 'Hoodies', url: '/category/hoodies' },
      { label: 'T-Shirts', url: '/category/t-shirts' },
      { label: 'Sneakers', url: '/category/sneakers' },
      { label: 'Sale', url: '/sale' }
    ]
  },
  {
    title: 'HELP',
    links: [
      { label: 'Contact Us', url: '/contact' },
      { label: 'FAQs', url: '/faq' },
      { label: 'Shipping', url: '/shipping' },
      { label: 'Returns', url: '/returns' },
      { label: 'Size Guide', url: '/size-guide' }
    ]
  },
  {
    title: 'COMPANY',
    links: [
      { label: 'About Us', url: '/about' },
      { label: 'Careers', url: '/careers' },
      { label: 'Stores', url: '/stores' },
      { label: 'Press', url: '/press' }
    ]
  },
  {
    title: 'LEGAL',
    links: [
      { label: 'Privacy Policy', url: '/privacy' },
      { label: 'Terms of Service', url: '/terms' },
      { label: 'Refund Policy', url: '/refund' }
    ]
  }
];

const socialLinks = [
  { platform: 'instagram', url: '#' },
  { platform: 'twitter', url: '#' },
  { platform: 'tiktok', url: '#' },
  { platform: 'youtube', url: '#' }
];
---

<footer class="bg-black text-white border-t border-gray-800">
  <div class="container mx-auto px-4 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2">
        <h3 class="font-display text-4xl tracking-widest mb-4">
          {siteConfig?.site_name || 'URBN'}
        </h3>
        <p class="text-gray-400 text-sm tracking-wider mb-6">
          Streetwear for those who dare to stand out.
        </p>
        <!-- Social Links -->
        <div class="flex space-x-4">
          {socialLinks.map((social) => (
            <a 
              href={social.url}
              class="w-10 h-10 border border-gray-700 rounded-full flex items-center justify-center hover:border-accent hover:text-accent transition-colors"
              aria-label={social.platform}
            >
              <span class="text-xs font-heading tracking-wider">{social.platform.charAt(0).toUpperCase()}</span>
            </a>
          ))}
        </div>
      </div>
      
      <!-- Link Columns -->
      {columns.map((col) => (
        <div>
          <h4 class="font-heading text-xs tracking-widest text-gray-400 mb-4">{col.title}</h4>
          <ul class="space-y-3">
            {col.links.map((link) => (
              <li>
                <a 
                  href={link.url}
                  class="text-sm text-gray-300 hover:text-white transition-colors"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
  
  <!-- Bottom -->
  <div class="border-t border-gray-800">
    <div class="container mx-auto px-4 py-6">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-500 text-sm">
          © {new Date().getFullYear()} {siteConfig?.site_name || 'URBN'}. All rights reserved.
        </p>
        <div class="flex items-center gap-4 text-gray-500 text-sm">
          <span>INDIA</span>
          <span>₹ INR</span>
        </div>
      </div>
    </div>
  </div>
</footer>
