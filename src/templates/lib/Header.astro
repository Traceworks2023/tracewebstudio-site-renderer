---
/**
 * Theme-aware Header Component
 * Renders header based on theme configuration
 */
import { getCurrentTheme } from './theme-loader';
import {
  getColor,
  buildThemeCSSVars,
  isFeatureEnabled
} from './theme-components';

interface Props {
  logoText?: string;
  logoUrl?: string;
  navItems?: Array<{ label: string; url: string }>;
}

const theme = getCurrentTheme();
const colors = theme?.theme?.colors || {};
const fonts = theme?.fonts || {};
const navStyle = theme?.structure?.home?.navigation?.style || 'top-bar';
const isSticky = theme?.structure?.home?.navigation?.sticky || false;
const showSearch = isFeatureEnabled('search', 'home', theme);
const showCart = isFeatureEnabled('cart', 'home', theme);
const showWishlist = isFeatureEnabled('wishlist', 'home', theme);
const showAccount = true;
---

<header
  class={`header header--${navStyle} ${isSticky ? 'header--sticky' : ''}`}
  style={buildThemeCSSVars(theme)}
>
  <div class="header__container">
    {/* Top Bar */}
    {navStyle === 'top-bar' && (
      <div class="header__top-bar">
        <div class="header__announcement">
          Free shipping on orders over $100
        </div>
      </div>
    )}

    {/* Main Header */}
    <div class="header__main">
      {/* Logo */}
      <a href="/" class="header__logo">
        {theme?.metadata?.logo_url ? (
          <img src={theme.metadata.logo_url} alt="Logo" />
        ) : (
          <span class="header__logo-text">{Astro.props.logoText || 'Store Name'}</span>
        )}
      </a>

      {/* Navigation */}
      <nav class="header__nav">
        <ul class="header__nav-list">
          {Astro.props.navItems?.map((item) => (
            <li class="header__nav-item">
              <a href={item.url} class="header__nav-link">{item.label}</a>
            </li>
          )) || (
            <>
              <li class="header__nav-item"><a href="/collections/new" class="header__nav-link">New</a></li>
              <li class="header__nav-item"><a href="/collections" class="header__nav-link">Shop</a></li>
              <li class="header__nav-item"><a href="/collections/sale" class="header__nav-link">Sale</a></li>
              <li class="header__nav-item"><a href="/about" class="header__nav-link">About</a></li>
            </>
          )}
        </ul>
      </nav>

      {/* Actions */}
      <div class="header__actions">
        {showSearch && (
          <button class="header__action" aria-label="Search">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.35-4.35"></path>
            </svg>
          </button>
        )}

        {showAccount && (
          <a href="/account" class="header__action" aria-label="Account">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </a>
        )}

        {showWishlist && (
          <a href="/wishlist" class="header__action" aria-label="Wishlist">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"></path>
            </svg>
          </a>
        )}

        {showCart && (
          <a href="/cart" class="header__action header__cart" aria-label="Cart">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path>
              <path d="M3 6h18"></path>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
            <span class="header__cart-count">0</span>
          </a>
        )}
      </div>
    </div>
  </div>
</header>

<style define:vars={{
  'header-bg': colors.background || '#FFFFFF',
  'header-text': colors.textPrimary || '#111827',
  'header-border': colors.border || '#E5E7EB',
  'header-accent': colors.accent || '#D4AF37',
  'font-heading': fonts.heading?.family || 'Playfair Display',
  'font-body': fonts.body?.family || 'Inter',
  'nav-item-spacing': theme?.components?.navigation?.itemSpacing || '32px',
}}>
  .header {
    background: var(--header-bg);
    border-bottom: 1px solid var(--header-border);
    font-family: var(--font-body);
    position: relative;
  }

  .header--sticky {
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .header__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .header__top-bar {
    background: var(--header-text);
    color: var(--header-bg);
    text-align: center;
    padding: 8px;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .header__main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 0;
    gap: 40px;
  }

  .header__logo {
    text-decoration: none;
    color: var(--header-text);
  }

  .header__logo-text {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .header__nav {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .header__nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: var(--nav-item-spacing);
  }

  .header__nav-link {
    color: var(--header-text);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }

  .header__nav-link:hover {
    color: var(--header-accent);
  }

  .header__actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .header__action {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--header-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .header__action:hover {
    color: var(--header-accent);
  }

  .header__cart {
    position: relative;
  }

  .header__cart-count {
    position: absolute;
    top: -8px;
    right: -8px;
    background: var(--header-accent);
    color: white;
    font-size: 10px;
    font-weight: 600;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Centered logo style */
  .header--centered .header__main {
    flex-direction: column;
    gap: 16px;
  }

  .header--centered .header__nav {
    order: 1;
  }

  .header--centered .header__logo {
    order: 0;
  }

  .header--centered .header__actions {
    order: 2;
  }

  @media (max-width: 768px) {
    .header__nav {
      display: none;
    }
  }
</style>
