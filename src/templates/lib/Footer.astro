---
/**
 * Theme-aware Footer Component
 * Renders footer based on theme configuration
 */
import { getCurrentTheme } from './theme-loader';
import { buildThemeCSSVars, isFeatureEnabled } from './theme-components';

interface FooterColumn {
  title: string;
  links: Array<{ label: string; url: string; isExternal?: boolean }>;
}

interface Props {
  columns?: FooterColumn[];
  showSocial?: boolean;
  showPayment?: boolean;
  copyrightText?: string;
}

const theme = getCurrentTheme();
const cssVars = buildThemeCSSVars(theme);

const colors = theme?.theme?.colors || {};
const fonts = theme?.fonts || {};
const footerStyle = theme?.structure?.home?.footer?.style || 'detailed';
const columnsCount = theme?.structure?.home?.footer?.columns || 4;
const showSocialVal = isFeatureEnabled('social', 'footer', theme) && theme?.structure?.home?.footer?.showSocial;
const showPaymentVal = theme?.structure?.home?.footer?.showPayment !== false;

const socialPlatforms = [
  { name: 'Instagram', url: 'https://instagram.com', icon: 'instagram' },
  { name: 'Facebook', url: 'https://facebook.com', icon: 'facebook' },
  { name: 'Twitter', url: 'https://twitter.com', icon: 'twitter' },
  { name: 'Pinterest', url: 'https://pinterest.com', icon: 'pinterest' },
];

const defaultColumns: FooterColumn[] = [
  {
    title: 'Shop',
    links: [
      { label: 'New Arrivals', url: '/collections/new' },
      { label: 'Best Sellers', url: '/collections/best-sellers' },
      { label: 'Sale', url: '/collections/sale' },
      { label: 'All Products', url: '/products' },
    ],
  },
  {
    title: 'Customer Service',
    links: [
      { label: 'Contact Us', url: '/contact' },
      { label: 'FAQs', url: '/faq' },
      { label: 'Shipping & Returns', url: '/shipping' },
      { label: 'Size Guide', url: '/size-guide' },
    ],
  },
  {
    title: 'About',
    links: [
      { label: 'Our Story', url: '/about' },
      { label: 'Careers', url: '/careers' },
      { label: 'Press', url: '/press' },
      { label: 'Sustainability', url: '/sustainability' },
    ],
  },
  {
    title: 'My Account',
    links: [
      { label: 'Sign In', url: '/account/login' },
      { label: 'Order Tracking', url: '/account/orders' },
      { label: 'Wishlist', url: '/wishlist' },
      { label: 'Rewards', url: '/rewards' },
    ],
  },
];

const columns = Astro.props.columns || defaultColumns;
const copyrightText = Astro.props.copyrightText || `© ${new Date().getFullYear()} Store Name. All rights reserved.`;
---

<footer
  class={`footer footer--${footerStyle}`}
  style={cssVars}
>
  {/* Newsletter Section */}
  <div class="footer__newsletter">
    <div class="footer__newsletter-inner">
      <div class="footer__newsletter-content">
        <h3 class="footer__newsletter-title">Join Our Newsletter</h3>
        <p class="footer__newsletter-text">Subscribe to get special offers, free giveaways, and exclusive deals.</p>
      </div>
      <form class="footer__newsletter-form">
        <input
          type="email"
          placeholder="Enter your email"
          class="footer__newsletter-input"
          required
        />
        <button type="submit" class="footer__newsletter-btn">Subscribe</button>
      </form>
    </div>
  </div>

  {/* Main Footer */}
  <div class="footer__main">
    <div class="footer__container">
      {/* Brand Column */}
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="footer__logo-text">Store Name</span>
        </a>
        <p class="footer__brand-text">
          Premium fashion for those who appreciate quality craftsmanship and timeless style.
        </p>
        {showSocialVal && (
          <div class="footer__social">
            {socialPlatforms.map((platform) => (
              <a
                href={platform.url}
                class="footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label={platform.name}
              >
                {platform.icon === 'instagram' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
                  </svg>
                )}
                {platform.icon === 'facebook' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                  </svg>
                )}
                {platform.icon === 'twitter' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"></path>
                  </svg>
                )}
                {platform.icon === 'pinterest' && (
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" x2="12" y1="17" y2="22"></line>
                    <path d="M5 17c2 2 5 2 5 0"></path>
                    <path d="M12 13a5 5 0 0 1 5 5c0 2-1 4-3 5s-4 1-4 2-1 2-1 4"></path>
                    <circle cx="12" cy="8" r="5"></circle>
                  </svg>
                )}
              </a>
            ))}
          </div>
        )}
      </div>

      {/* Link Columns */}
      <div class={`footer__links footer__links--${columns.length > 0 ? columns.length : 4}`}>
        {columns.slice(0, 4).map((column) => (
          <div class="footer__column">
            <h4 class="footer__column-title">{column.title}</h4>
            <ul class="footer__column-list">
              {column.links.map((link) => (
                <li>
                  <a href={link.url} class="footer__link" target={link.isExternal ? '_blank' : undefined}>
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Footer Bottom */}
  <div class="footer__bottom">
    <div class="footer__container">
      <div class="footer__bottom-content">
        <p class="footer__copyright">{copyrightText}</p>

        {showPaymentVal && (
          <div class="footer__payment">
            <span class="footer__payment-label">We Accept:</span>
            <div class="footer__payment-icons">
              <span class="footer__payment-icon">VISA</span>
              <span class="footer__payment-icon">MC</span>
              <span class="footer__payment-icon">AMEX</span>
              <span class="footer__payment-icon">PayPal</span>
            </div>
          </div>
        )}

        <div class="footer__legal">
          <a href="/privacy" class="footer__legal-link">Privacy Policy</a>
          <a href="/terms" class="footer__legal-link">Terms of Service</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style define:vars={{
  'footer-bg': colors.background || '#FFFFFF',
  'footer-bg-alt': colors.surface || '#F9FAFB',
  'footer-text': colors.textPrimary || '#111827',
  'footer-text-muted': colors.textSecondary || '#6B7280',
  'footer-border': colors.border || '#E5E7EB',
  'footer-accent': colors.accent || '#D4AF37',
  'font-heading': fonts.heading?.family || 'Playfair Display',
  'font-body': fonts.body?.family || 'Inter',
}}>
  .footer {
    background: var(--footer-bg);
    border-top: 1px solid var(--footer-border);
    font-family: var(--font-body);
  }

  .footer__newsletter {
    background: var(--footer-text);
    color: var(--footer-bg);
    padding: 60px 24px;
  }

  .footer__newsletter-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
  }

  .footer__newsletter-title {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .footer__newsletter-text {
    font-size: 14px;
    opacity: 0.8;
    margin: 0;
  }

  .footer__newsletter-form {
    display: flex;
    gap: 12px;
    flex: 1;
    max-width: 480px;
  }

  .footer__newsletter-input {
    flex: 1;
    padding: 14px 20px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: white;
    font-size: 14px;
  }

  .footer__newsletter-input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }

  .footer__newsletter-input:focus {
    outline: none;
    border-color: var(--footer-accent);
  }

  .footer__newsletter-btn {
    padding: 14px 28px;
    background: var(--footer-accent);
    color: white;
    border: none;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .footer__newsletter-btn:hover {
    opacity: 0.9;
  }

  .footer__main {
    padding: 80px 24px;
  }

  .footer__container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer__brand {
    max-width: 300px;
  }

  .footer__logo {
    display: inline-block;
    text-decoration: none;
    margin-bottom: 16px;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 600;
    color: var(--footer-text);
  }

  .footer__brand-text {
    font-size: 14px;
    color: var(--footer-text-muted);
    line-height: 1.6;
    margin: 0 0 24px;
  }

  .footer__social {
    display: flex;
    gap: 16px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid var(--footer-border);
    color: var(--footer-text);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .footer__social-link:hover {
    border-color: var(--footer-accent);
    color: var(--footer-accent);
  }

  .footer__links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .footer__links--3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .footer__links--2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer__column-title {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--footer-text);
    margin: 0 0 20px;
  }

  .footer__column-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer__column-list li {
    margin-bottom: 12px;
  }

  .footer__link {
    color: var(--footer-text-muted);
    text-decoration: none;
    font-size: 14px;
    transition: color 0.2s ease;
  }

  .footer__link:hover {
    color: var(--footer-accent);
  }

  .footer__bottom {
    border-top: 1px solid var(--footer-border);
    padding: 24px;
  }

  .footer__bottom-content {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer__copyright {
    font-size: 13px;
    color: var(--footer-text-muted);
    margin: 0;
  }

  .footer__payment {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer__payment-label {
    font-size: 12px;
    color: var(--footer-text-muted);
  }

  .footer__payment-icons {
    display: flex;
    gap: 8px;
  }

  .footer__payment-icon {
    padding: 4px 8px;
    background: var(--footer-border);
    font-size: 10px;
    font-weight: 600;
    border-radius: 2px;
  }

  .footer__legal {
    display: flex;
    gap: 24px;
  }

  .footer__legal-link {
    font-size: 13px;
    color: var(--footer-text-muted);
    text-decoration: none;
  }

  .footer__legal-link:hover {
    color: var(--footer-text);
  }

  /* Minimal Footer Style */
  .footer--minimal .footer__main {
    padding: 40px 24px;
  }

  .footer--minimal .footer__links {
    grid-template-columns: repeat(2, 1fr);
  }

  .footer--minimal .footer__newsletter {
    display: none;
  }

  /* Centered Footer Style */
  .footer--centered .footer__main {
    text-align: center;
  }

  .footer--centered .footer__brand {
    max-width: none;
    margin: 0 auto 40px;
  }

  .footer--centered .footer__social {
    justify-content: center;
  }

  @media (max-width: 768px) {
    .footer__newsletter-inner {
      flex-direction: column;
      text-align: center;
    }

    .footer__newsletter-form {
      flex-direction: column;
      width: 100%;
    }

    .footer__links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer__bottom-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
