---
// Dynamic Blog Post Page
// Route: /blog/[slug]

import { getBlogPostBySlug, mockBlogPosts, mockAuthors } from '../../lib/entities/store';
import type { BlogPost } from '../../lib/entities/types';

export const prerender = true;

export async function getStaticPaths() {
  return mockBlogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: BlogPost };

if (!post) {
  return Astro.redirect('/404');
}

const postJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt,
  image: post.featuredImage,
  author: {
    '@type': 'Person',
    name: post.author.name
  },
  datePublished: post.publishedAt,
  dateModified: post.updatedAt
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.title} - Blog</title>
  <meta name="description" content={post.excerpt}>
  <script type="application/ld+json" set:html={JSON.stringify(postJsonLd)}></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-primary: #000032;
      --color-accent: #FA5014;
      --color-text: #333333;
    }
    body { font-family: 'Inter', sans-serif; margin: 0; background: #fff; color: var(--color-text); line-height: 1.6; }
    * { box-sizing: border-box; }
    .blog-post { max-width: 800px; margin: 0 auto; padding: 60px 24px; }
    .post-header { text-align: center; margin-bottom: 48px; }
    .post-category { display: inline-block; background: var(--color-accent); color: white; padding: 6px 16px; border-radius: 20px; font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 16px; }
    .post-title { font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 700; color: #000; margin: 0 0 24px; line-height: 1.2; }
    @media (max-width: 768px) { .post-title { font-size: 32px; } }
    .post-meta { display: flex; align-items: center; justify-content: center; gap: 24px; color: #666; font-size: 14px; }
    .post-author { display: flex; align-items: center; gap: 12px; }
    .author-avatar { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
    .author-info { text-align: left; }
    .author-name { font-weight: 600; color: #000; }
    .post-date { color: #999; }
    .reading-time { display: flex; align-items: center; gap: 4px; }
    .featured-image { width: 100%; max-height: 500px; object-fit: cover; border-radius: 16px; margin-bottom: 48px; }
    .post-content { font-size: 18px; line-height: 1.8; color: #444; }
    .post-content h2 { font-family: 'Playfair Display', serif; font-size: 28px; color: #000; margin: 48px 0 24px; }
    .post-content p { margin-bottom: 24px; }
    .post-content img { width: 100%; border-radius: 8px; margin: 32px 0; }
    .post-content blockquote { border-left: 4px solid var(--color-accent); padding-left: 24px; margin: 32px 0; font-style: italic; color: #666; }
    .post-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 48px; padding-top: 32px; border-top: 1px solid #eee; }
    .tag { background: #f5f5f5; padding: 6px 16px; border-radius: 20px; font-size: 13px; color: #666; text-decoration: none; transition: background 0.2s; }
    .tag:hover { background: #eee; }
    .share-buttons { display: flex; gap: 12px; margin-top: 32px; }
    .share-btn { width: 44px; height: 44px; border-radius: 50%; background: #f5f5f5; display: flex; align-items: center; justify-content: center; color: #333; text-decoration: none; transition: all 0.2s; }
    .share-btn:hover { background: var(--color-primary); color: white; }
    .author-box { display: flex; gap: 20px; padding: 32px; background: #f9f9f9; border-radius: 16px; margin-top: 64px; }
    .author-box-avatar { width: 80px; height: 80px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }
    .author-box-name { font-weight: 700; font-size: 18px; color: #000; margin-bottom: 4px; }
    .author-box-bio { font-size: 14px; color: #666; margin-bottom: 12px; }
    .related-posts { margin-top: 80px; padding-top: 48px; border-top: 1px solid #eee; }
    .related-title { font-size: 24px; font-weight: 700; margin-bottom: 24px; }
    .related-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    @media (max-width: 768px) { .related-grid { grid-template-columns: 1fr; } }
    .related-card { border-radius: 12px; overflow: hidden; background: #f9f9f9; }
    .related-card img { width: 100%; aspect-ratio: 16/10; object-fit: cover; }
    .related-card-content { padding: 16px; }
    .related-card-title { font-weight: 600; color: #000; text-decoration: none; display: block; margin-bottom: 8px; }
    .related-card-date { font-size: 12px; color: #999; }
    .back-link { display: inline-flex; align-items: center; gap: 8px; color: var(--color-accent); text-decoration: none; font-weight: 500; margin-bottom: 24px; }
    .back-link:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <article class="blog-post">
    <a href="/blog" class="back-link">← Back to Blog</a>

    <header class="post-header">
      {post.category && <span class="post-category">{post.category}</span>}
      <h1 class="post-title">{post.title}</h1>
      <div class="post-meta">
        <div class="post-author">
          <img src={post.author.image} alt={post.author.name} class="author-avatar" />
          <div class="author-info">
            <p class="author-name">{post.author.name}</p>
            <p class="post-date">{new Date(post.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
          </div>
        </div>
        {post.readingTime && (
          <span class="reading-time">
            <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
            </svg>
            {post.readingTime} min read
          </span>
        )}
      </div>
    </header>

    {post.featuredImage && (
      <img src={post.featuredImage} alt={post.title} class="featured-image" />
    )}

    <div class="post-content" set:html={post.content}></div>

    {post.tags && post.tags.length > 0 && (
      <div class="post-tags">
        {post.tags.map((tag) => (
          <a href={`/blog?tag=${tag}`} class="tag">{tag}</a>
        ))}
      </div>
    )}

    <div class="share-buttons">
      <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}`} class="share-btn" title="Share on Twitter">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
      </a>
      <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.toString())}`} class="share-btn" title="Share on Facebook">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href={`https://www.linkedin.com/shareArticle?mini=true&url=${encodeURIComponent(Astro.url.toString())}`} class="share-btn" title="Share on LinkedIn">
        <svg width="18" height="18" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>

    <div class="author-box">
      <img src={post.author.image} alt={post.author.name} class="author-box-avatar" />
      <div>
        <p class="author-box-name">{post.author.name}</p>
        {post.author.bio && <p class="author-box-bio">{post.author.bio}</p>}
        {post.author.socialLinks?.twitter && (
          <a href={post.author.socialLinks.twitter} class="share-btn" style="display:inline-flex;width:36px;height:36px;border-radius:50%;background:#f5f5f5;align-items:center;justify-content:center;color:#333;text-decoration:none;">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
        )}
      </div>
    </div>

    <div class="related-posts">
      <h2 class="related-title">Related Articles</h2>
      <div class="related-grid">
        {[1, 2, 3].map((i) => (
          <a href="#" class="related-card">
            <img src={`https://picsum.photos/seed/related${i}/400/250`} alt="Related post" />
            <div class="related-card-content">
              <p class="related-card-title">Related Article Title That Could Be Long</p>
              <p class="related-card-date">March {10 + i}, 2026</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </article>
</body>
</html>