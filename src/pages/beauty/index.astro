---
const siteConfig = {
  site_name: 'Beauty Salon',
  site_tagline: 'Hair & Beauty Studio',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Montserrat', sans-serif; }
    h1, h2, h3 { font-family: 'Cormorant Garamond', serif; }
  </style>
</head>
<body class="min-h-screen bg-pink-50">
  <!-- Header -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        <div class="text-center">
          <h1 class="text-2xl font-serif font-bold text-pink-900">GLAMOUR</h1>
          <span class="text-xs text-pink-600 tracking-widest">BEAUTY STUDIO</span>
        </div>
        <nav class="hidden md:flex items-center gap-8">
          <a href="#services" class="text-pink-800 hover:text-pink-500 transition text-sm">Services</a>
          <a href="#about" class="text-pink-800 hover:text-pink-500 transition text-sm">About</a>
          <a href="#gallery" class="text-pink-800 hover:text-pink-500 transition text-sm">Gallery</a>
          <a href="#contact" class="text-pink-800 hover:text-pink-500 transition text-sm">Contact</a>
        </nav>
        <a href="#book" class="bg-pink-600 text-white px-6 py-2 rounded-full hover:bg-pink-700 transition text-sm font-medium">Book Now</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative bg-pink-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=1920" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 md:py-48 text-center">
      <span class="text-pink-300 text-sm tracking-widest">BENGALURU'S PREMIER BEAUTY DESTINATION</span>
      <h1 class="text-5xl md:text-7xl font-serif mt-4 mb-6">Reveal Your<br/><span class="text-pink-400">Inner Glow</span></h1>
      <p class="text-lg text-pink-100 max-w-2xl mx-auto mb-10">Expert stylists, premium products, and a luxurious experience that transforms you from the inside out.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#book" class="bg-pink-500 text-white px-8 py-4 rounded-full font-medium hover:bg-pink-400 transition">Book Appointment</a>
        <a href="#services" class="border-2 border-white px-8 py-4 rounded-full font-medium hover:bg-white hover:text-pink-900 transition">View Services</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section id="services" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-pink-500 text-sm tracking-widest">WHAT WE OFFER</span>
        <h2 class="text-4xl font-serif mt-2 text-pink-900">Our Services</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">💇</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Hair Styling</h3>
          <p class="text-pink-700 mb-4">Cuts, coloring, keratin treatments, and styling for all occasions.</p>
          <span class="text-pink-500 font-bold">From ₹499</span>
        </div>
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">💆</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Spa & Wellness</h3>
          <p class="text-pink-700 mb-4">Rejuvenating facials, body massages, and aromatherapy.</p>
          <span class="text-pink-500 font-bold">From ₹999</span>
        </div>
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">💅</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Nail Art</h3>
          <p class="text-pink-700 mb-4">Manicure, pedicure, gel nails, and custom nail art designs.</p>
          <span class="text-pink-500 font-bold">From ₹299</span>
        </div>
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">👰</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Bridal</h3>
          <p class="text-pink-700 mb-4">Complete bridal makeup, hair, and pre-wedding packages.</p>
          <span class="text-pink-500 font-bold">From ₹5,999</span>
        </div>
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">🧴</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Skin Care</h3>
          <p class="text-pink-700 mb-4">Advanced facials, chemical peels, and skin rejuvenation.</p>
          <span class="text-pink-500 font-bold">From ₹799</span>
        </div>
        <div class="bg-pink-50 rounded-2xl p-8 text-center hover:shadow-xl transition">
          <div class="w-16 h-16 bg-pink-200 rounded-full flex items-center justify-center mx-auto mb-6 text-3xl">👁️</div>
          <h3 class="text-xl font-serif font-bold text-pink-900 mb-3">Makeup</h3>
          <p class="text-pink-700 mb-4">Party makeup, editorial looks, and special occasion styling.</p>
          <span class="text-pink-500 font-bold">From ₹1,499</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="py-20 bg-pink-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-pink-500 text-sm tracking-widest">OUR WORK</span>
        <h2 class="text-4xl font-serif mt-2 text-pink-900">Gallery</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <img src="https://images.unsplash.com/photo-1562322140-8baeececf3df?w=400" class="rounded-lg w-full h-64 object-cover" />
        <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=400" class="rounded-lg w-full h-64 object-cover" />
        <img src="https://images.unsplash.com/photo-1519699047748-de8e457a634e?w=400" class="rounded-lg w-full h-64 object-cover" />
        <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=400" class="rounded-lg w-full h-64 object-cover" />
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <span class="text-pink-500 text-sm tracking-widest">TESTIMONIALS</span>
      <h2 class="text-4xl font-serif mt-2 text-pink-900 mb-12">What Our Clients Say</h2>
      <div class="bg-pink-50 rounded-2xl p-8">
        <p class="text-xl text-pink-800 italic mb-6">"Absolutely amazing experience! The team at Glamour transformed my look completely. I've never felt more confident. The ambiance is so relaxing and the staff is incredibly professional."</p>
        <div class="flex items-center justify-center gap-4">
          <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100" class="w-12 h-12 rounded-full object-cover" />
          <div class="text-left">
            <span class="font-bold text-pink-900">Priya Sharma</span>
            <p class="text-pink-600 text-sm">Regular Client</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 bg-pink-900 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-serif mb-6">Visit Us</h2>
      <p class="text-pink-200 mb-8">45 Indiranagar, 100 Feet Road, Bengaluru, Karnataka 560038</p>
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div>
          <span class="text-3xl mb-4 block">📞</span>
          <p class="text-pink-200">+91 98765 43211</p>
        </div>
        <div>
          <span class="text-3xl mb-4 block">⏰</span>
          <p class="text-pink-200">Mon-Sat: 10AM - 8PM</p>
        </div>
        <div>
          <span class="text-3xl mb-4 block">✉️</span>
          <p class="text-pink-200">book@glamour.in</p>
        </div>
      </div>
      <a href="#book" class="inline-block bg-pink-500 text-white px-8 py-4 rounded-full font-medium hover:bg-pink-400 transition">Book Your Appointment</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-pink-950 text-pink-200 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="mb-4">&copy; 2024 Glamour Beauty Studio. All rights reserved.</p>
      <div class="flex justify-center gap-6 text-sm">
        <a href="#" class="hover:text-white">Privacy</a>
        <a href="#" class="hover:text-white">Terms</a>
        <a href="#" class="hover:text-white">Instagram</a>
      </div>
    </div>
  </footer>
</body>
</html>