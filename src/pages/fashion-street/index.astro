---
const siteConfig = {
  site_name: 'Fashion Street',
  site_tagline: 'Urban Streetwear & Casual',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Space Grotesk', sans-serif; }
    .font-display { font-family: 'Bebas Neue', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-stone-100">
  <!-- Header -->
  <header class="bg-black text-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-3">
        <div class="font-display text-3xl tracking-widest">STREET<span class="text-lime-400">KICKS</span></div>
        <nav class="hidden md:flex items-center gap-6 text-sm">
          <a href="#" class="hover:text-lime-400 transition">NEW</a>
          <a href="#" class="hover:text-lime-400 transition">HOODIES</a>
          <a href="#" class="hover:text-lime-400 transition">TEES</a>
          <a href="#" class="hover:text-lime-400 transition">SNEAKERS</a>
          <a href="#" class="hover:text-lime-400 transition">SALE</a>
        </nav>
        <div class="flex items-center gap-3">
          <button class="p-2 hover:text-lime-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></button>
          <button class="p-2 hover:text-lime-400"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative bg-black text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1523398002811-999ca8dec234?w=1920" class="w-full h-full object-cover opacity-70" />
      <div class="absolute inset-0 bg-gradient-to-r from-black via-black/50 to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-24 md:py-40">
      <div class="max-w-xl">
        <span class="text-lime-400 text-sm font-bold tracking-widest">SS24 COLLECTION</span>
        <h1 class="font-display text-6xl md:text-8xl mt-2 mb-4 leading-none">STREET<br/><span class="text-lime-400">STYLE</span></h1>
        <p class="text-gray-300 mb-8">Bold designs for those who dare to stand out. Authentic streetwear for the urban culture.</p>
        <div class="flex gap-4">
          <a href="#" class="bg-lime-400 text-black font-bold px-8 py-4 hover:bg-lime-300 transition">SHOP COLLECTION</a>
          <a href="#" class="border-2 border-lime-400 text-lime-400 font-bold px-8 py-4 hover:bg-lime-400 hover:text-black transition">LOOKBOOK</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Grid -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-display text-4xl mb-8">SHOP BY STYLE</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="#" class="group relative aspect-[3/4] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1556821840-3a63f15732ce?w=600" class="w-full h-full object-cover group-hover:scale-110 transition duration-500 grayscale group-hover:grayscale-0" />
          <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
            <span class="font-display text-3xl text-white">GRAPHIC TEES</span>
          </div>
        </a>
        <a href="#" class="group relative aspect-[3/4] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?w=600" class="w-full h-full object-cover group-hover:scale-110 transition duration-500 grayscale group-hover:grayscale-0" />
          <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
            <span class="font-display text-3xl text-white">HOODIES</span>
          </div>
        </a>
        <a href="#" class="group relative aspect-[3/4] overflow-hidden">
          <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=600" class="w-full h-full object-cover group-hover:scale-110 transition duration-500 grayscale group-hover:grayscale-0" />
          <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
            <span class="font-display text-3xl text-white">SNEAKERS</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="py-16 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-display text-4xl">TRENDING NOW</h2>
        <a href="#" class="text-lime-600 hover:underline">View All →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1618354691373-d851c5c3a990?w=400" class="w-full h-full object-cover group-hover:scale-105 transition" />
            <button class="absolute bottom-4 right-4 bg-black text-white p-3 rounded-full hover:bg-lime-400 hover:text-black transition">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></button>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-1">Oversized Logo Tee</h3>
            <p class="text-stone-500 text-sm mb-2">Black / White</p>
            <span class="font-bold">₹1,299</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1556821840-3a63f15732ce?w=400" class="w-full h-full object-cover group-hover:scale-105 transition" />
            <span class="absolute top-3 left-3 bg-lime-400 text-black text-xs font-bold px-2 py-1">NEW</span>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-1">Essential Hoodie</h3>
            <p class="text-stone-500 text-sm mb-2">Charcoal</p>
            <span class="font-bold">₹2,799</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=400" class="w-full h-full object-cover group-hover:scale-105 transition" />
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-1">Urban Runner V2</h3>
            <p class="text-stone-500 text-sm mb-2">White/Black</p>
            <span class="font-bold">₹4,599</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative aspect-square overflow-hidden">
            <img src="https://images.unsplash.com/photo-1627225924765-552d49cf47ad?w=400" class="w-full h-full object-cover group-hover:scale-105 transition" />
            <span class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-2 py-1">-20%</span>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-1">Cargo Joggers</h3>
            <p class="text-stone-500 text-sm mb-2">Olive</p>
            <span class="font-bold">₹1,799</span>
            <span class="text-stone-400 line-through text-sm ml-2">₹2,199</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Instagram Section -->
  <section class="py-16 bg-black text-white">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <span class="text-lime-400 text-sm font-bold tracking-widest">@STREETKICKS</span>
      <h2 class="font-display text-4xl mt-2 mb-8">FOLLOW THE MOVEMENT</h2>
      <div class="grid grid-cols-3 md:grid-cols-6 gap-2">
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1523398002811-999ca8dec234?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1556821840-3a63f15732ce?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1595950653106-6c9ebd614d3a?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1618354691373-d851c5c3a990?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
        <div class="aspect-square overflow-hidden"><img src="https://images.unsplash.com/photo-1627225924765-552d49cf47ad?w=300" class="w-full h-full object-cover hover:scale-110 transition" /></div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-stone-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <div>
          <h4 class="font-display text-xl mb-4">STREETKICKS</h4>
          <p class="text-stone-400 text-sm">Authentic streetwear for the urban generation.</p>
        </div>
        <div>
          <h5 class="font-bold mb-3">Shop</h5>
          <ul class="space-y-2 text-stone-400 text-sm">
            <li><a href="#" class="hover:text-lime-400">New Arrivals</a></li>
            <li><a href="#" class="hover:text-lime-400">Hoodies</a></li>
            <li><a href="#" class="hover:text-lime-400">T-Shirts</a></li>
            <li><a href="#" class="hover:text-lime-400">Sale</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-bold mb-3">Help</h5>
          <ul class="space-y-2 text-stone-400 text-sm">
            <li><a href="#" class="hover:text-lime-400">Shipping</a></li>
            <li><a href="#" class="hover:text-lime-400">Returns</a></li>
            <li><a href="#" class="hover:text-lime-400">Size Guide</a></li>
            <li><a href="#" class="hover:text-lime-400">Contact</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-bold mb-3">Connect</h5>
          <div class="flex gap-4">
            <a href="#" class="text-stone-400 hover:text-lime-400">IG</a>
            <a href="#" class="text-stone-400 hover:text-lime-400">TW</a>
            <a href="#" class="text-stone-400 hover:text-lime-400">FB</a>
          </div>
        </div>
      </div>
      <div class="border-t border-stone-800 pt-8 text-center text-stone-500 text-sm">
        <p>&copy; 2024 StreetKicks. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>