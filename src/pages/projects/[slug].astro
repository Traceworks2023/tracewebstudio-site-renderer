---
// Dynamic Project/Case Study Page
// Route: /projects/[slug]

import { getProjectBySlug, mockProjects } from '../../lib/entities/store';
import type { Project } from '../../lib/entities/types';

export const prerender = true;

export async function getStaticPaths() {
  return mockProjects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props as { project: Project };

if (!project) {
  return Astro.redirect('/404');
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{project.title} - Our Work</title>
  <meta name="description" content={project.excerpt}>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-primary: #000032;
      --color-accent: #FA5014;
      --color-text: #333333;
    }
    body { font-family: 'Inter', sans-serif; margin: 0; background: #fff; color: var(--color-text); }
    * { box-sizing: border-box; }
    .project-hero { position: relative; height: 70vh; min-height: 500px; overflow: hidden; }
    .project-hero img { width: 100%; height: 100%; object-fit: cover; }
    .project-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7)); display: flex; align-items: flex-end; padding: 60px; }
    .project-hero-content { max-width: 800px; }
    .project-client { color: var(--color-accent); font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
    .project-title { font-family: 'Playfair Display', serif; font-size: 56px; font-weight: 700; color: white; margin: 0 0 16px; line-height: 1.1; }
    @media (max-width: 768px) { .project-title { font-size: 36px; } .project-hero { height: 50vh; } .project-hero-overlay { padding: 24px; } }
    .project-services { display: flex; gap: 12px; flex-wrap: wrap; }
    .service-tag { background: rgba(255,255,255,0.2); backdrop-filter: blur(10px); padding: 8px 16px; border-radius: 20px; color: white; font-size: 13px; }
    .project-content { max-width: 1200px; margin: 0 auto; padding: 80px 24px; }
    .project-grid { display: grid; grid-template-columns: 2fr 1fr; gap: 60px; }
    @media (max-width: 768px) { .project-grid { grid-template-columns: 1fr; } }
    .project-main-content { font-size: 18px; line-height: 1.8; color: #444; }
    .project-main-content h2 { font-family: 'Playfair Display', serif; font-size: 28px; color: #000; margin: 48px 0 24px; }
    .project-main-content p { margin-bottom: 24px; }
    .project-sidebar { position: sticky; top: 40px; }
    .project-meta { background: #f9f9f9; border-radius: 16px; padding: 32px; }
    .meta-title { font-size: 14px; font-weight: 600; color: #999; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .meta-value { font-size: 16px; font-weight: 600; color: #000; margin-bottom: 24px; }
    .project-testimonial { margin-top: 48px; padding: 32px; background: var(--color-primary); border-radius: 16px; color: white; }
    .testimonial-quote { font-size: 20px; font-style: italic; line-height: 1.6; margin-bottom: 16px; }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .testimonial-author img { width: 48px; height: 48px; border-radius: 50%; object-fit: cover; }
    .author-name { font-weight: 600; }
    .author-role { font-size: 13px; opacity: 0.8; }
    .results-section { margin-top: 80px; padding-top: 48px; border-top: 1px solid #eee; }
    .results-title { font-size: 32px; font-weight: 700; margin-bottom: 32px; }
    .results-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    @media (max-width: 768px) { .results-grid { grid-template-columns: 1fr; } }
    .result-card { background: #f9f9f9; padding: 32px; border-radius: 16px; text-align: center; }
    .result-value { font-size: 48px; font-weight: 700; color: var(--color-accent); margin-bottom: 8px; }
    .result-metric { font-size: 14px; font-weight: 600; color: #000; margin-bottom: 4px; }
    .result-description { font-size: 13px; color: #666; }
    .gallery-section { margin-top: 80px; padding-top: 48px; border-top: 1px solid #eee; }
    .gallery-title { font-size: 32px; font-weight: 700; margin-bottom: 32px; }
    .gallery-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    @media (max-width: 768px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
    .gallery-item { aspect-ratio: 4/3; border-radius: 12px; overflow: hidden; }
    .gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
    .gallery-item:hover img { transform: scale(1.05); }
    .cta-section { margin-top: 80px; padding: 80px 40px; background: var(--color-primary); border-radius: 24px; text-align: center; color: white; }
    .cta-title { font-family: 'Playfair Display', serif; font-size: 36px; margin-bottom: 16px; }
    .cta-text { opacity: 0.8; margin-bottom: 32px; }
    .cta-btn { display: inline-block; padding: 16px 40px; background: var(--color-accent); color: white; text-decoration: none; font-weight: 600; border-radius: 30px; transition: transform 0.2s; }
    .cta-btn:hover { transform: scale(1.05); }
  </style>
</head>
<body>
  {/* Hero */}
  <section class="project-hero">
    <img src={project.featuredImage || 'https://picsum.photos/1600/900'} alt={project.title} />
    <div class="project-hero-overlay">
      <div class="project-hero-content">
        {project.client && <p class="project-client">{project.client}</p>}
        <h1 class="project-title">{project.title}</h1>
        <div class="project-services">
          {project.services?.map((service) => (
            <span class="service-tag">{service}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  {/* Content */}
  <section class="project-content">
    <div class="project-grid">
      <div class="project-main-content">
        <p><strong>{project.excerpt}</strong></p>
        <div set:html={project.content}></div>

        {project.testimonial && (
          <div class="project-testimonial">
            <p class="testimonial-quote">"{project.testimonial.quote}"</p>
            <div class="testimonial-author">
              {project.testimonial.image && <img src={project.testimonial.image} alt={project.testimonial.author} />}
              <div>
                <p class="author-name">{project.testimonial.author}</p>
                {project.testimonial.role && <p class="author-role">{project.testimonial.role}{project.testimonial.company ? `, ${project.testimonial.company}` : ''}</p>}
              </div>
            </div>
          </div>
        )}
      </div>

      <aside class="project-sidebar">
        <div class="project-meta">
          {project.industry && (
            <>
              <p class="meta-title">Industry</p>
              <p class="meta-value">{project.industry}</p>
            </>
          )}
          {project.timeline && (
            <>
              <p class="meta-title">Timeline</p>
              <p class="meta-value">{project.timeline.duration || `${project.timeline.start} - ${project.timeline.end || 'Present'}`}</p>
            </>
          )}
          {project.budget && (
            <>
              <p class="meta-title">Project Value</p>
              <p class="meta-value">{project.budget}</p>
            </>
          )}
          <p class="meta-title">Services</p>
          <div class="project-services" style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:24px;">
            {project.services?.map((service) => (
              <span class="service-tag" style="background:#eee;color:#333;">{service}</span>
            ))}
          </div>
        </div>
      </aside>
    </div>

    {/* Results */}
    {project.results && project.results.length > 0 && (
      <div class="results-section">
        <h2 class="results-title">The Results</h2>
        <div class="results-grid">
          {project.results.map((result) => (
            <div class="result-card">
              <p class="result-value">{result.value}</p>
              <p class="result-metric">{result.metric}</p>
              {result.description && <p class="result-description">{result.description}</p>}
            </div>
          ))}
        </div>
      </div>
    )}

    {/* Gallery */}
    {project.gallery && project.gallery.length > 0 && (
      <div class="gallery-section">
        <h2 class="gallery-title">Project Gallery</h2>
        <div class="gallery-grid">
          {project.gallery.map((img, i) => (
            <div class="gallery-item">
              <img src={img || `https://picsum.photos/seed/proj${i}/600/450`} alt={`Gallery image ${i + 1}`} loading="lazy" />
            </div>
          ))}
        </div>
      </div>
    )}

    {/* CTA */}
    <div class="cta-section">
      <h2 class="cta-title">Like What You See?</h2>
      <p class="cta-text">Let's discuss how we can help you achieve similar results.</p>
      <a href="/contact" class="cta-btn">Start a Project</a>
    </div>
  </section>
</body>
</html>