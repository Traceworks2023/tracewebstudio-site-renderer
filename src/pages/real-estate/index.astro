---
const siteConfig = { site_name: 'Real Estate', site_tagline: 'Premium Property Solutions' };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-gray-50">
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-serif font-bold text-gray-900">HOMES<span class="text-blue-600">PRO</span></h1>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="#properties" class="text-gray-700 hover:text-blue-600">Buy</a>
        <a href="#properties" class="text-gray-700 hover:text-blue-600">Rent</a>
        <a href="#properties" class="text-gray-700 hover:text-blue-600">Sell</a>
        <a href="#" class="text-gray-700 hover:text-blue-600">Agents</a>
        <a href="#" class="text-gray-700 hover:text-blue-600">About</a>
      </nav>
      <div class="flex items-center gap-3">
        <button class="text-sm text-gray-700 hover:text-blue-600">Sign In</button>
        <button class="bg-blue-600 text-white px-4 py-2 rounded text-sm hover:bg-blue-700 transition">List Property</button>
      </div>
    </div>
  </header>

  <section class="relative bg-gray-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1582407947304-fd86f028f716?w=1920" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 text-center">
      <h1 class="text-5xl md:text-6xl font-serif mb-6">Find Your<br/><span class="text-blue-400">Dream Home</span></h1>
      <p class="text-lg text-gray-300 max-w-2xl mx-auto mb-10">Discover premium properties across India's top locations. Trusted by 50,000+ happy homeowners.</p>
      <div class="bg-white rounded-lg p-4 flex flex-col md:flex-row gap-4 max-w-3xl mx-auto">
        <input type="text" placeholder="Search by location, project, or keyword" class="flex-1 px-4 py-3 rounded text-gray-900 text-sm" />
        <select class="px-4 py-3 rounded text-gray-700 text-sm">
          <option>Buy</option><option>Rent</option>
        </select>
        <select class="px-4 py-3 rounded text-gray-700 text-sm">
          <option>Any Type</option><option>Apartment</option><option>Villa</option><option>Plot</option>
        </select>
        <button class="bg-blue-600 text-white px-8 py-3 rounded font-medium hover:bg-blue-700 transition">Search</button>
      </div>
    </div>
  </section>

  <section id="properties" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl font-serif">Featured Properties</h2>
        <a href="#" class="text-blue-600 hover:underline text-sm">View All →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=600" class="w-full h-56 object-cover" />
            <span class="absolute top-4 left-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded">FOR SALE</span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2">4 BHK Luxury Villa</h3>
            <p class="text-gray-600 text-sm mb-3">Whitefield, Bangalore</p>
            <div class="flex gap-4 text-sm text-gray-500 mb-4">
              <span>4 Beds</span><span>3 Baths</span><span>2800 sq.ft</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-blue-600">₹2.5 Cr</span>
              <button class="text-blue-600 text-sm hover:underline">View Details</button>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=600" class="w-full h-56 object-cover" />
            <span class="absolute top-4 left-4 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded">FOR RENT</span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2">3 BHK Modern Apartment</h3>
            <p class="text-gray-600 text-sm mb-3">Koramangala, Bangalore</p>
            <div class="flex gap-4 text-sm text-gray-500 mb-4">
              <span>3 Beds</span><span>2 Baths</span><span>1800 sq.ft</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-blue-600">₹65,000/mo</span>
              <button class="text-blue-600 text-sm hover:underline">View Details</button>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1600607687939-ce8a6c25118c?w=600" class="w-full h-56 object-cover" />
            <span class="absolute top-4 left-4 bg-blue-600 text-white text-xs font-bold px-3 py-1 rounded">FOR SALE</span>
          </div>
          <div class="p-6">
            <h3 class="text-lg font-bold mb-2">5 BHK Premium Penthouse</h3>
            <p class="text-gray-600 text-sm mb-3">MG Road, Bangalore</p>
            <div class="flex gap-4 text-sm text-gray-500 mb-4">
              <span>5 Beds</span><span>4 Baths</span><span>4000 sq.ft</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-blue-600">₹4.8 Cr</span>
              <button class="text-blue-600 text-sm hover:underline">View Details</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-blue-900 text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-8 text-center">
        <div><span class="text-4xl font-bold block mb-2">500+</span><span class="text-blue-200">Properties</span></div>
        <div><span class="text-4xl font-bold block mb-2">200+</span><span class="text-blue-200">Agents</span></div>
        <div><span class="text-4xl font-bold block mb-2">50K+</span><span class="text-blue-200">Happy Clients</span></div>
        <div><span class="text-4xl font-bold block mb-2">10+</span><span class="text-blue-200">Years</span></div>
      </div>
    </div>
  </section>

  <footer class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-gray-400 text-sm">
      <p>&copy; 2024 HomesPro. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>