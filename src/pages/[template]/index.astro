// Customer-facing pages
import ProductPage from '../../components/pages/ProductPage.astro';
import CartPage from '../../components/pages/CartPage.astro';
import CheckoutPage from '../../components/pages/CheckoutPage.astro';
import WishlistPage from '../../components/pages/WishlistPage.astro';
import AccountPage from '../../components/pages/AccountPage.astro';
import SearchPage from '../../components/pages/SearchPage.astro';
import AboutPage from '../../components/pages/AboutPage.astro';
import ContactPage from '../../components/pages/ContactPage.astro';
import FAQPage from '../../components/pages/FAQPage.astro';
import TrackOrderPage from '../../components/pages/TrackOrderPage.astro';

// Admin pages
import DashboardPage from '../../components/pages/admin/DashboardPage.astro';
import OrdersPage from '../../components/pages/admin/OrdersPage.astro';
import ProductsPage from '../../components/pages/admin/ProductsPage.astro';
import CustomersPage from '../../components/pages/admin/CustomersPage.astro';
import AnalyticsPage from '../../components/pages/admin/AnalyticsPage.astro';
import MarketingPage from '../../components/pages/admin/MarketingPage.astro';
import SettingsPage from '../../components/pages/admin/SettingsPage.astro';

// Business pages
import MenuPage from '../../components/pages/MenuPage.astro';
import ServicesPage from '../../components/pages/ServicesPage.astro';
import BookingPage from '../../components/pages/BookingPage.astro';
import TeamPage from '../../components/pages/TeamPage.astro';
import ProgramsPage from '../../components/pages/ProgramsPage.astro';
import TrainersPage from '../../components/pages/TrainersPage.astro';
import MembershipPage from '../../components/pages/MembershipPage.astro';
import SchedulePage from '../../components/pages/SchedulePage.astro';
import ReservationsPage from '../../components/pages/ReservationsPage.astro';
import OffersPage from '../../components/pages/OffersPage.astro';
import ProcessPage from '../../components/pages/ProcessPage.astro';
import TestimonialsPage from '../../components/pages/TestimonialsPage.astro';
import LookbookPage from '../../components/pages/LookbookPage.astro';
import RoomCollectionsPage from '../../components/pages/RoomCollectionsPage.astro';
import RoomsPage from '../../components/pages/RoomsPage.astro';
import DoctorsPage from '../../components/pages/DoctorsPage.astro';
import DestinationsPage from '../../components/pages/DestinationsPage.astro';
import HelpCenterPage from '../../components/pages/HelpCenterPage.astro';
import SupportPortalPage from '../../components/pages/SupportPortalPage.astro';
import QuoteRequestPage from '../../components/pages/QuoteRequestPage.astro';
import FormBuilderPage from '../../components/pages/FormBuilderPage.astro';

// Portfolio pages
import GalleryPage from '../../components/pages/GalleryPage.astro';

const { template } = Astro.params;
const url = new URL(Astro.request.url);
const pageId = url.searchParams.get('page') || 'home';

const templateConfig = await loadTemplate(template || '');
const pageConfig = templateConfig ? getPageById(templateConfig, pageId) : null;
const templateSections = pageConfig ? getVisibleSections(pageConfig) : [];

// Extract theme configuration first
const theme = templateConfig?.theme || {};
const fonts = theme.fonts || { heading: 'Playfair Display', body: 'Inter' };
const colors = theme.colors || {};

// Generate unique content for this template
const contentCategory = templateConfig?.category || 'business';
const generatedContent = generateUniqueContent(template || '', contentCategory);

// Apply generated content to sections with index for bg style variation
const sections = templateSections.map((section, index) =>
  applyGeneratedContentToSection(section, generatedContent, section.type, index, colors)
);

// Build Google Fonts URL with proper weight ranges
function getGoogleFontsUrl(heading: string, body: string): string {
  const fontWeights = '300;400;500;600;700';
  const headingParam = heading.replace(/ /g, '+');
  const bodyParam = body.replace(/ /g, '+');
  return `https://fonts.googleapis.com/css2?family=${headingParam}:wght@${fontWeights}&family=${bodyParam}:wght@${fontWeights}&display=swap`;
}

const googleFontsUrl = getGoogleFontsUrl(fonts.heading, fonts.body);

// Build CSS variables from theme
const cssVariables = `
  --color-primary: ${colors.primary || '#000032'};
  --color-secondary: ${colors.secondary || '#333333'};
  --color-accent: ${colors.accent || '#FA5014'};
  --color-background: ${colors.background || '#ffffff'};
  --color-surface: ${colors.surface || '#f5f5f5'};
  --color-text: ${colors.text || '#1a1a1a'};
  --color-text-muted: ${colors.textMuted || '#666666'};
  --color-border: ${colors.border || '#e5e5e5'};
  --color-error: ${colors.error || '#dc2626'};
  --color-success: ${colors.success || '#16a34a'};
  --font-heading: '${fonts.heading}', serif;
  --font-body: '${fonts.body}', sans-serif;
  --radius-sm: ${theme.borderRadius?.sm || '4px'};
  --radius-md: ${theme.borderRadius?.md || '8px'};
  --radius-lg: ${theme.borderRadius?.lg || '16px'};
  --radius-xl: ${theme.borderRadius?.xl || '24px'};
  --spacing-section: ${theme.spacing?.section || '80px'};
  --spacing-container: ${theme.spacing?.container || '1200px'};
`;

// Define navigation pages based on template category
const templateCategory = templateConfig.category || 'ecommerce';

