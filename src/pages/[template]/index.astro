  'contactform': ContactForm,
  // Motion section
  'motion-section': MotionSection,
  // Features horizontal
  'features-horizontal': FeaturesHorizontal,
};

// Map page types to full-page components (ecommerce uses SearchPage for category)
const pageComponents: Record<string, any> = {
  'product': ProductPage,
  'cart': CartPage,
  'checkout': CheckoutPage,
  'wishlist': WishlistPage,
  'account': AccountPage,
  'search': SearchPage,
  'about': AboutPage,
  'contact': ContactPage,
  'faq': FAQPage,
  'track-order': TrackOrderPage,
