// Build Google Fonts URL with proper weight ranges
function getGoogleFontsUrl(heading: string, body: string): string {
  const fontWeights = '300;400;500;600;700';
  const headingParam = heading.replace(/ /g, '+');
  const bodyParam = body.replace(/ /g, '+');
  return `https://fonts.googleapis.com/css2?family=${headingParam}:wght@${fontWeights}&family=${bodyParam}:wght@${fontWeights}&display=swap`;
}

