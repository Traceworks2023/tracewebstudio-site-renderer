  'herotypographic': getCategoryHero(templateSlug),
  'herosplit': HeroSplit,
  'heroeditorial': getCategoryHero(templateSlug),
  'herocinematic': getCategoryHero(templateSlug),
  'herosection': getCategoryHero(templateSlug),
  'hero-typographic': getCategoryHero(templateSlug),
  // Content sections - shared but with good variety
  'category-grid': CategoryGrid,
  'categorygrid': CategoryGrid,
  'product-carousel': ProductCarousel,
  'productcarousel': ProductCarousel,
  'product-grid': ProductGrid,
  'productgrid': ProductGrid,
  'collection-grid': CollectionGrid,
  'collectiongrid': CollectionGrid,
  'advanced-carousel': AdvancedCarousel,
  'advancedcarousel': AdvancedCarousel,
  'split-media': SplitMedia,
  'splitmedia': SplitMedia,
  'gallery-grid': GalleryGrid,
  'gallerygrid': GalleryGrid,
  'features': Features,
  'featureshorizontal': FeaturesHorizontal,
  'faq': FAQ,
  'stats': StatsSection,
  'statsection': StatsSection,
  'logo-strip': LogoStrip,
  'logostrip': LogoStrip,
  // Social/conversion sections
  'cta-banner': CTABanner,
  'cta-vapor': CTAVapor,
  'ctavapor': CTAVapor,
  'testimonials-slider': TestimonialsSlider,
  'testimonialsslider': TestimonialsSlider,
  'testimonials': Testimonials,
  'testimonials-marquee': TestimonialsMarquee,
  'testimonialsmarquee': TestimonialsMarquee,
  'newsletter': Newsletter,
  'contact-form': ContactForm,
  'contactform': ContactForm,
  // Motion section
  'motion-section': MotionSection,
  // Features horizontal
  'features-horizontal': FeaturesHorizontal,

  // Premium 2026 Components - Portfolio
  'parallax-hero': ParallaxHero,
  'bento-grid': BentoGrid,
  'horizontal-scroll': HorizontalScrollGallery,
  'before-after': BeforeAfterSlider,
  'animated-stats': AnimatedStats,
  'testimonial-masonry': TestimonialMasonry,
  'cta-split': CTASplit,
  'cta-center': CTACenter,
  'minimal-hero': MinimalHero,
  'minimal-footer': MinimalFooter,
  'split-hero': SplitHero,
  'timeline': Timeline,
  'pricing-cards': PricingCards,
  'contact-split': ContactSplit,
  'masonry-gallery': MasonryGallery,
  
  // Portfolio Masterpiece Components
  'contact-cards': ContactCards,
  'wedding-contact': WeddingContact,
  'mehndi-contact': MehndiContact,
  'food-contact': FoodContact,
  'tattoo-contact': TattooContact,
  'about-centered': AboutCentered,
  'service-cards': ServiceCards,
  'pattern-grid': PatternGrid,
  'process-timeline': ProcessTimeline,
  'portfolio-contact-split': PortfolioContactSplit,
  'wedding-hero': WeddingHero,
  'mehndi-hero': MehndiHero,
  'food-hero': FoodHero,
  'tattoo-hero': TattooHero,
};

// Map page types to full-page components (ecommerce uses SearchPage for category)
const pageComponents: Record<string, any> = {
  'product': ProductPage,
  'cart': CartPage,
  'checkout': CheckoutPage,
  'wishlist': WishlistPage,
  'account': AccountPage,
  'search': SearchPage,
  'about': AboutPage,
  'contact': ContactPage,
  'faq': FAQPage,
  'track-order': TrackOrderPage,
  /* Admin pages - lazily loaded to avoid prisma dependency
  'admin-dashboard': DashboardPage,
  'admin-orders': OrdersPage,
  'admin-products': ProductsPage,
  'admin-customers': CustomersPage,
  'admin-analytics': AnalyticsPage,
  'admin-marketing': MarketingPage,
  'admin-settings': SettingsPage,
  'admin-templates': TemplatesPage,
  */
  'menu': MenuPage,
  'services': ServicesPage,
  'booking': BookingPage,
  'team': TeamPage,
  'gallery': GalleryPage,
  'programs': ProgramsPage,
  'trainers': TrainersPage,
  'membership': MembershipPage,
  'schedule': SchedulePage,
  'reservations': ReservationsPage,
  'offers': OffersPage,
  'process': ProcessPage,
  'testimonials-page': TestimonialsPage,
  'lookbook': LookbookPage,
  'room-collections': RoomCollectionsPage,
  'rooms': RoomsPage,
  'doctors': DoctorsPage,
  'destinations': DestinationsPage,
  'help-center': HelpCenterPage,
  'support': SupportPortalPage,
  'quote': QuoteRequestPage,
  'forms': FormBuilderPage
};

// NEVER use generic page components - ALWAYS render the template's own sections
// Generic page components (AboutPage, ContactPage, etc.) are ONLY used as fallback
// for pages that the template doesn't define - but since we're removing fallbacks,
// we will NEVER use them. Templates must define ALL pages they want to show.
// If a page isn't defined in template config, it will show "Page Not Found"
const PageComponent = null;
---

{!templateConfig ? (
  <div class="min-h-screen flex items-center justify-center">
    <div class="text-center">
      <h1 class="text-2xl font-bold mb-4">Template Not Found</h1>
      <p class="text-gray-600 mb-4">The template could not be loaded.</p>
      <a href="/" class="text-blue-600">Go Home</a>
    </div>
  </div>
) : (
  <html lang="en">
    <head>
      <meta charset="UTF-8" />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>{pageConfig?.name || templateConfig.name} - Built with Tracewebstudio</title>
      <link href={googleFontsUrl} rel="stylesheet" />
      <style is:global set:html={cssVariables}></style>
    </head>
    <body class="min-h-screen" style={`background-color: ${colors.background || '#ffffff'};`}>
      {pageId?.startsWith('admin-') && templateConfig?.category === 'ecommerce' ? (
        <div class="flex min-h-screen bg-gray-100" style={`--admin-primary: ${colors.primary || '#000032'}; --admin-accent: ${colors.accent || '#FA5014'};`}>
          {/* Admin Sidebar */}
          <aside class="w-64 text-white flex flex-col" style="background: linear-gradient(180deg, var(--admin-primary) 0%, color-mix(in srgb, var(--admin-primary) 80%, black) 100%);">
            <div class="p-6 border-b border-white/10">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 rounded-xl flex items-center justify-center text-white font-bold text-lg" style="background: var(--admin-accent);">{templateConfig.name.charAt(0)}</div>
                <div>
                  <h1 class="text-lg font-bold">{templateConfig.name}</h1>
                  <p class="text-xs text-white/60">Admin Panel</p>
                </div>
              </div>
            </div>
            <nav class="flex-1 p-4 space-y-1">
              <a href={`/${template}?page=admin-dashboard`} style={pageId === 'admin-dashboard' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
                Dashboard
              </a>
              <a href={`/${template}?page=admin-orders`} style={pageId === 'admin-orders' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
                Orders
              </a>
              <a href={`/${template}?page=admin-products`} style={pageId === 'admin-products' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                Products
              </a>
              <a href={`/${template}?page=admin-customers`} style={pageId === 'admin-customers' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
                Customers
              </a>
              <a href={`/${template}?page=admin-analytics`} style={pageId === 'admin-analytics' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
                Analytics
              </a>
              <a href={`/${template}?page=admin-marketing`} style={pageId === 'admin-marketing' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
                Marketing
              </a>
              <div class="border-t border-white/10 my-4"></div>
              <a href={`/${template}?page=admin-settings`} style={pageId === 'admin-settings' ? `background: var(--admin-accent)` : ''} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Settings
              </a>
              <a href={`/${template}`} class="flex items-center gap-3 px-4 py-3 rounded-lg transition-colors text-white/90 hover:bg-white/10">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                View Store
              </a>
            </nav>
            <div class="p-4 border-t border-white/10">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold" style="background: var(--admin-accent);">A</div>
                <div>
                  <p class="text-sm font-medium">Admin User</p>
                  <p class="text-xs text-white/60">admin@store.com</p>
                </div>
              </div>
            </div>
          </aside>
          {/* Admin Content */}
          <main class="flex-1 overflow-auto">
            {PageComponent ? (
              <PageComponent template={templateConfig} page={pageConfig} />
            ) : (
              <div class="p-8">
                <h1 class="text-2xl font-bold text-gray-900 mb-4">Page: {pageId}</h1>
                <p class="text-gray-600">This page component is being built.</p>
              </div>
            )}
          </main>
        </div>
      ) : (
        <>
          <PremiumNav
            content={{
              logo: templateConfig?.name || generatedContent.brand.name,
              ctaText: 'Contact',
              ctaUrl: `#contact`,
              navItems: templateNavigation.length > 0
                ? templateNavigation.map(n => ({ label: n.label, href: n.href }))
                : generatedContent.navigation
                    .filter(n => templatePageIds.includes(n.href.replace('/', '')))
                    .map(n => ({ label: n.label, href: n.href })),
            }}
            settings={{ variant: navVariant, position: 'fixed', showCart: false, showSearch: false, showAccount: false, templateSlug: template }}
          />

          <main class={editMode ? 'edit-mode' : ''}>
            {PageComponent ? (
              <PageComponent template={templateConfig} page={pageConfig} tenantId={Astro.locals.tenant?.tenantId || '00000000-0000-0000-0000-000000000000'} />
            ) : pageConfig ? (
sections.map((section, index) => {
                const SectionComponent = sectionComponents[section.type];
                if (!SectionComponent) return null;
                if (editMode) {
                  return (
                    <div
                      class="edit-section"
                      data-section-id={section.id}
                      data-section-type={section.type}
                      data-section-index={index}
                      data-section-name={section.type.replace(/-/g, ' ').replace(/\b\w/g, l => l.toUpperCase())}
                      data-section-title={section.content?.title || section.content?.name || ''}
                      data-section-subtitle={section.content?.subtitle || ''}
                      data-section-description={section.content?.description || ''}
                      data-section-image={section.content?.image || section.content?.images?.[0] || ''}
                      data-section-visible={section.visible !== false}
                    >
                      <SectionComponent
                        content={section.content}
                        settings={{ ...section.settings, templateSlug: template }}
                      />
                    </div>
                  );
                }
                return <SectionComponent
                  content={section.content}
                  settings={{ ...section.settings, templateSlug: template }}
                />;
              })
            ) : (
              <div class="min-h-[60vh] flex items-center justify-center">
                <div class="text-center">
                  <h1 class="text-4xl font-bold mb-4" style="color: var(--color-text);">Page Not Found</h1>
                  <p class="text-lg mb-8" style="color: var(--color-text-muted);">This page doesn't exist in this template.</p>
                  <a href={`/${template}`} class="px-6 py-3 rounded-full font-semibold text-white" style="background: var(--color-primary);">
                    Go to Home
                  </a>
                </div>
              </div>
            )}
          </main>

          <PremiumFooter
            content={{
              logo: templateFooter?.logo || templateConfig?.name || generatedContent.brand.name,
              description: templateFooter?.tagline || templateConfig?.description || generatedContent.brand.description,
            }}
            settings={{ variant: 'dark', showNewsletter: false, showSocial: true }}
          />

          {/* Floating Page Switcher */}
          {!pageId?.startsWith('admin-') && (
            <div class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-1 bg-white/95 backdrop-blur-xl rounded-full shadow-2xl border border-gray-200 p-2 max-w-[95vw] overflow-x-auto">
              <span class="px-3 text-sm font-medium text-gray-500 whitespace-nowrap">Pages:</span>
              {navPages.map(p => (
                <a
                  href={`/${template}?page=${p.id}`}
                  class={`px-3 py-2 rounded-full text-sm font-medium whitespace-nowrap transition-all ${
                    pageId === p.id
                      ? 'text-white'
                      : 'text-gray-600 hover:bg-gray-100'
                  }`}
                  style={pageId === p.id ? `background: var(--color-primary);` : ''}
                >
                  {p.label}
                </a>
              ))}
            </div>
          )}
        </>
      )}

      {editMode && (
        <style>
          .edit-section {
            position: relative;
            cursor: pointer;
            outline: 2px dashed transparent;
            outline-offset: -2px;
            transition: outline-color 0.2s;
          }
          .edit-section:hover {
            outline-color: #f97316;
          }
          .edit-section.selected {
            outline-color: #f97316;
            outline-width: 3px;
          }
          .edit-section::before {
            content: attr(data-section-name);
            position: absolute;
            top: 0;
            left: 0;
            background: #f97316;
            color: white;
            padding: 4px 12px;
            font-size: 12px;
            font-weight: 600;
            border-radius: 0 0 8px 0;
            z-index: 1000;
            opacity: 0;
            transition: opacity 0.2s;
            pointer-events: none;
          }
          .edit-section:hover::before {
            opacity: 1;
          }
        </style>
        <script define:vars={{ editMode: true }}>
          document.addEventListener('DOMContentLoaded', () => {
            const sections = document.querySelectorAll('.edit-section');

            sections.forEach(section => {
              section.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();

                // Remove selected class from all sections
                sections.forEach(s => s.classList.remove('selected'));
                // Add selected class to clicked section
                section.classList.add('selected');

                // Send section data to parent
                const sectionData = {
                  type: 'section-selected',
                  sectionId: section.dataset.sectionId,
                  sectionType: section.dataset.sectionType,
                  sectionName: section.dataset.sectionName,
                  sectionData: {
                    name: section.dataset.sectionName,
                    title: section.dataset.sectionTitle,
                    subtitle: section.dataset.sectionSubtitle,
                    description: section.dataset.sectionDescription,
                    image: section.dataset.sectionImage,
                    bgColor: section.style.backgroundColor || '#0a0a1a',
                    textColor: getComputedStyle(section).color || '#ffffff',
                    visible: section.dataset.sectionVisible !== 'false'
                  }
                };

                window.parent.postMessage(sectionData, '*');
              });
            });

            // Listen for update messages from parent
            window.addEventListener('message', (event) => {
              if (event.data.type === 'update-section') {
                const { sectionId, data } = event.data;
                const section = document.querySelector(`[data-section-id="${sectionId}"]`);
                if (section && data) {
                  // Update section content based on data
                  // This would need more sophisticated handling based on section type
                  if (data.bgColor) {
                    section.style.backgroundColor = data.bgColor;
                  }
                  // Update child elements with data attributes
                  section.dataset.sectionTitle = data.title || '';
                  section.dataset.sectionSubtitle = data.subtitle || '';
                  section.dataset.sectionDescription = data.description || '';
                  section.dataset.sectionImage = data.image || '';
                  section.dataset.sectionVisible = data.visible;

                  if (data.visible === false) {
                    section.style.display = 'none';
                  } else {
                    section.style.display = '';
                  }
                }
              }
            });
          });
        </script>
      )}
    </body>
  </html>
)}