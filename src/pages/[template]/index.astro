  { id: 'forms', label: 'Forms', icon: 'M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z' },
];

const navPages = templateCategory === 'ecommerce' ? ecommercePages : templateCategory === 'portfolio' ? portfolioPages : businessPages;

// Determine template family for category-specific components
const templateSlug = template || '';

// Category-specific hero components - each category has its own unique design
function getCategoryHero(slug: string): any {
  const s = slug.toLowerCase();
  if (s.includes('restaurant') || s.includes('cafe') || s.includes('food')) return HeroRestaurant;
  if (s.includes('beauty') || s.includes('makeup')) return HeroBeauty;
  if (s.includes('fitness') || s.includes('gym')) return HeroFitness;
  if (s.includes('hotel') || s.includes('resort') || s.includes('travel')) return HeroHotel;
  if (s.includes('photographer') || s.includes('photo') || s.includes('video')) return HeroPhotographer;
  if (s.includes('agency') || s.includes('portfolio') || s.includes('designer') || s.includes('developer') || s.includes('freelancer')) return HeroAgency;
  // Default to premium cinematic hero
  return HeroCinematic;
}

// Map section types to components - using category-specific heroes for uniqueness
const sectionComponents: Record<string, any> = {
  // Hero sections - category-specific for truly unique designs
  'hero-cinematic': getCategoryHero(templateSlug),
  'hero-editorial': getCategoryHero(templateSlug),
  'hero-section': getCategoryHero(templateSlug),
  'hero-typographic': getCategoryHero(templateSlug),
  'hero-split': HeroSplit,
  'herotypographic': getCategoryHero(templateSlug),
  'herosplit': HeroSplit,
  'heroeditorial': getCategoryHero(templateSlug),
  'herocinematic': getCategoryHero(templateSlug),
  'herosection': getCategoryHero(templateSlug),
  'hero-typographic': getCategoryHero(templateSlug),
  // Content sections - shared but with good variety
  'category-grid': CategoryGrid,
  'categorygrid': CategoryGrid,
  'product-carousel': ProductCarousel,
