  'programs': ProgramsPage,
  'trainers': TrainersPage,
  'membership': MembershipPage,
  'schedule': SchedulePage,
  'reservations': ReservationsPage,
  'offers': OffersPage,
  'process': ProcessPage,
  'testimonials-page': TestimonialsPage,
  'lookbook': LookbookPage,
  'room-collections': RoomCollectionsPage,
  'rooms': RoomsPage,
  'doctors': DoctorsPage,
  'destinations': DestinationsPage,
  'help-center': HelpCenterPage,
  'support': SupportPortalPage,
  'quote': QuoteRequestPage,
  'forms': FormBuilderPage
