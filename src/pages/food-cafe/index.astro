---
const siteConfig = {
  site_name: 'Food Cafe',
  site_tagline: 'Artisan Coffee & Fresh Bites',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Lato:wght@300;400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailcss.com"></script>
  <style>
    body { font-family: 'Lato', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-amber-50">
  <!-- Header -->
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        <h1 class="text-2xl font-serif font-bold text-amber-900">☕ The Daily Grind</h1>
        <nav class="hidden md:flex items-center gap-8">
          <a href="#menu" class="text-amber-800 hover:text-amber-600 transition">Menu</a>
          <a href="#about" class="text-amber-800 hover:text-amber-600 transition">About</a>
          <a href="#gallery" class="text-amber-800 hover:text-amber-600 transition">Gallery</a>
          <a href="#contact" class="text-amber-800 hover:text-amber-600 transition">Contact</a>
        </nav>
        <a href="#book" class="bg-amber-800 text-white px-5 py-2 rounded-full hover:bg-amber-700 transition text-sm font-medium">Book a Table</a>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="relative bg-amber-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1920" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-24 md:py-40 text-center">
      <span class="text-amber-300 text-sm tracking-widest">EST. 2018 • BENGALURU</span>
      <h1 class="text-5xl md:text-6xl font-serif mt-4 mb-6">Where Every Cup<br/>Tells a Story</h1>
      <p class="text-xl text-amber-100 max-w-2xl mx-auto mb-10">Artisan coffee roasted in-house, fresh bakes daily, and a warm ambiance that feels like home.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#menu" class="bg-amber-500 text-white px-8 py-4 rounded-full font-medium hover:bg-amber-400 transition">Explore Our Menu</a>
        <a href="#book" class="border-2 border-white px-8 py-4 rounded-full font-medium hover:bg-white hover:text-amber-900 transition">Reserve a Table</a>
      </div>
    </div>
  </section>

  <!-- Hours Banner -->
  <section class="bg-amber-800 text-white py-4">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-center gap-6 text-center">
      <div><strong>Mon-Fri:</strong> 7:00 AM - 10:00 PM</div>
      <div><strong>Sat-Sun:</strong> 8:00 AM - 11:00 PM</div>
      <div class="text-amber-300">📍 MG Road, Bengaluru</div>
    </div>
  </section>

  <!-- Menu Section -->
  <section id="menu" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-amber-600 text-sm tracking-widest">CURATED FOR YOU</span>
        <h2 class="text-4xl font-serif mt-2 text-amber-900">Our Menu</h2>
      </div>

      <!-- Coffee -->
      <div class="mb-16">
        <h3 class="text-2xl font-serif text-amber-900 mb-6 border-b-2 border-amber-200 pb-2">☕ Signature Coffees</h3>
        <div class="space-y-4">
          <div class="flex justify-between items-center py-3 border-b border-amber-100">
            <div>
              <span class="font-medium text-lg">Classic Espresso</span>
              <p class="text-amber-600 text-sm">Rich, bold, and aromatic</p>
            </div>
            <span class="font-bold text-amber-800">₹149</span>
          </div>
          <div class="flex justify-between items-center py-3 border-b border-amber-100">
            <div>
              <span class="font-medium text-lg">Caramel Macchiato</span>
              <p class="text-amber-600 text-sm">Espresso with vanilla and caramel</p>
            </div>
            <span class="font-bold text-amber-800">₹229</span>
          </div>
          <div class="flex justify-between items-center py-3 border-b border-amber-100">
            <div>
              <span class="font-medium text-lg">Cold Brew Classic</span>
              <p class="text-amber-600 text-sm">Steeped for 20 hours</p>
            </div>
            <span class="font-bold text-amber-800">₹199</span>
          </div>
          <div class="flex justify-between items-center py-3">
            <div>
              <span class="font-medium text-lg">Mocha Delight</span>
              <p class="text-amber-600 text-sm">Espresso, chocolate, and steamed milk</p>
            </div>
            <span class="font-bold text-amber-800">₹249</span>
          </div>
        </div>
      </div>

      <!-- Food -->
      <div>
        <h3 class="text-2xl font-serif text-amber-900 mb-6 border-b-2 border-amber-200 pb-2">🥐 Fresh Bakes</h3>
        <div class="space-y-4">
          <div class="flex justify-between items-center py-3 border-b border-amber-100">
            <div>
              <span class="font-medium text-lg">Croissant</span>
              <p class="text-amber-600 text-sm">Buttery, flaky, freshly baked</p>
            </div>
            <span class="font-bold text-amber-800">₹179</span>
          </div>
          <div class="flex justify-between items-center py-3 border-b border-amber-100">
            <div>
              <span class="font-medium text-lg">Blueberry Muffin</span>
              <p class="text-amber-600 text-sm">Soft muffin with fresh blueberries</p>
            </div>
            <span class="font-bold text-amber-800">₹159</span>
          </div>
          <div class="flex justify-between items-center py-3">
            <div>
              <span class="font-medium text-lg">Avocado Toast</span>
              <p class="text-amber-600 text-sm">Sourdough, avocado, poached eggs</p>
            </div>
            <span class="font-bold text-amber-800">₹299</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-20 bg-amber-50">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=800" class="rounded-lg shadow-lg" />
        </div>
        <div>
          <span class="text-amber-600 text-sm tracking-widest">OUR STORY</span>
          <h2 class="text-4xl font-serif mt-2 mb-6 text-amber-900">More Than Just Coffee</h2>
          <p class="text-amber-800 mb-4 leading-relaxed">Founded in 2018, The Daily Grind started with a simple mission: to create a space where people can slow down, connect, and enjoy exceptional coffee.</p>
          <p class="text-amber-800 mb-6 leading-relaxed">We source our beans directly from farmers in Coorg and Chikmagalur, roast them in-house, and brew every cup with love and precision.</p>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-white p-4 rounded-lg">
              <span class="text-3xl font-bold text-amber-800">50+</span>
              <p class="text-amber-600 text-sm">Coffee Origins</p>
            </div>
            <div class="bg-white p-4 rounded-lg">
              <span class="text-3xl font-bold text-amber-800">6</span>
              <p class="text-amber-600 text-sm">Years Serving</p>
            </div>
            <div class="bg-white p-4 rounded-lg">
              <span class="text-3xl font-bold text-amber-800">100K+</span>
              <p class="text-amber-600 text-sm">Happy Customers</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery -->
  <section id="gallery" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-amber-600 text-sm tracking-widest">OUR SPACE</span>
        <h2 class="text-4xl font-serif mt-2 text-amber-900">Gallery</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <img src="https://images.unsplash.com/photo-1559925393-8be0ec4767c8?w=400" class="rounded-lg w-full h-48 object-cover" />
        <img src="https://images.unsplash.com/photo-1442512595331-e89e73853f31?w=400" class="rounded-lg w-full h-48 object-cover" />
        <img src="https://images.unsplash.com/photo-1509042239860-f550ce710b93?w=400" class="rounded-lg w-full h-48 object-cover" />
        <img src="https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?w=400" class="rounded-lg w-full h-48 object-cover" />
      </div>
    </div>
  </section>

  <!-- Contact / Book -->
  <section id="contact" class="py-20 bg-amber-900 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-serif mb-6">Visit Us</h2>
      <p class="text-amber-200 mb-8 text-lg">123 MG Road, Brigade Road Area, Bengaluru, Karnataka 560001</p>
      <div class="grid md:grid-cols-3 gap-8 mb-12">
        <div>
          <span class="text-3xl mb-4 block">📞</span>
          <h4 class="font-bold mb-2">Call</h4>
          <p class="text-amber-200">+91 98765 43210</p>
        </div>
        <div>
          <span class="text-3xl mb-4 block">✉️</span>
          <h4 class="font-bold mb-2">Email</h4>
          <p class="text-amber-200">hello@thedailygrind.in</p>
        </div>
        <div>
          <span class="text-3xl mb-4 block">💬</span>
          <h4 class="font-bold mb-2">WhatsApp</h4>
          <p class="text-amber-200">+91 98765 43210</p>
        </div>
      </div>
      <a href="#book" class="inline-block bg-amber-500 text-white px-8 py-4 rounded-full font-medium hover:bg-amber-400 transition">Reserve a Table</a>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-amber-950 text-amber-200 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="mb-4">&copy; 2024 The Daily Grind. All rights reserved.</p>
      <div class="flex justify-center gap-6 text-sm">
        <a href="#" class="hover:text-white">Privacy</a>
        <a href="#" class="hover:text-white">Terms</a>
        <a href="#" class="hover:text-white">Instagram</a>
        <a href="#" class="hover:text-white">Facebook</a>
      </div>
    </div>
  </footer>
</body>
</html>