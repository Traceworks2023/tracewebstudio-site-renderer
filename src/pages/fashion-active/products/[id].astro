---
const product = {
  id: '1',
  name: 'Performance Tank Top',
  price: 1499,
  originalPrice: 2199,
  badge: 'SALE',
  rating: 4.5,
  reviews: 128,
  description: 'High-performance tank top designed for intense workouts. Features moisture-wicking fabric, breathable mesh panels, and a comfortable fit that moves with you.',
  features: [
    'Moisture-wicking fabric keeps you dry',
    '4-way stretch for maximum mobility',
    'Mesh ventilation panels',
    'Reflective details for night runs',
    'Machine washable'
  ],
  sizes: ['XS', 'S', 'M', 'L', 'XL', 'XXL'],
  colors: [
    { name: 'Black', hex: '#000000' },
    { name: 'Navy', hex: '#000032' },
    { name: 'Orange', hex: '#FA5014' },
    { name: 'White', hex: '#FFFFFF' }
  ],
  images: [
    'https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=800',
    'https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800',
    'https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=800'
  ]
};

const relatedProducts = [
  { id: '2', name: 'Running Shoes Pro', price: 4999, image: 'https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400' },
  { id: '3', name: 'Training Leggings', price: 2299, image: 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400' },
  { id: '4', name: 'Sports Hoodie', price: 1999, originalPrice: 2899, image: 'https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=400' },
  { id: '5', name: 'CrossFit Shorts', price: 1299, image: 'https://images.unsplash.com/photo-1591195853828-11db59a44f6b?w=400' }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{product.name} - Fashion Active</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Roboto', sans-serif; }
    h1, h2, h3, h4 { font-family: 'Oswald', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-white">
  <!-- Header -->
  <header class="bg-black text-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        <a href="/" class="text-2xl font-bold tracking-wider">FASHION ACTIVE</a>
        <nav class="hidden md:flex items-center gap-8">
          <a href="/" class="text-sm font-medium hover:text-orange-500 transition">Home</a>
          <a href="/#categories" class="text-sm font-medium hover:text-orange-500 transition">Categories</a>
          <a href="/#products" class="text-sm font-medium hover:text-orange-500 transition">Products</a>
          <a href="/#about" class="text-sm font-medium hover:text-orange-500 transition">About</a>
        </nav>
        <div class="flex items-center gap-4">
          <button class="p-2 hover:text-orange-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></button>
          <button class="p-2 hover:text-orange-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
        </div>
      </div>
    </div>
  </header>

  <!-- Breadcrumb -->
  <nav class="bg-gray-100 py-3">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center gap-2 text-sm text-gray-600">
        <a href="/" class="hover:text-orange-500">Home</a>
        <span>/</span>
        <a href="/#products" class="hover:text-orange-500">Products</a>
        <span>/</span>
        <span class="text-gray-900">{product.name}</span>
      </div>
    </div>
  </nav>

  <!-- Product Section -->
  <section class="py-12">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Product Images -->
        <div>
          <div class="relative mb-4">
            <img id="main-image" src={product.images[0]} alt={product.name} class="w-full h-[500px] object-cover rounded-lg" />
            <span class="absolute top-4 left-4 bg-orange-500 text-white text-sm font-bold px-3 py-1 rounded">{product.badge}</span>
          </div>
          <div class="grid grid-cols-4 gap-2">
            {product.images.map((img, i) => (
              <button
                onclick={`document.getElementById('main-image').src='${img}'`}
                class={`border-2 rounded-lg overflow-hidden ${i === 0 ? 'border-orange-500' : 'border-transparent'}`}
              >
                <img src={img} alt="" class="w-full h-24 object-cover" />
              </button>
            ))}
          </div>
        </div>

        <!-- Product Info -->
        <div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{product.name}</h1>
          
          <!-- Rating -->
          <div class="flex items-center gap-2 mb-4">
            <div class="flex text-yellow-400">
              {Array(Math.floor(product.rating)).fill('★').map(s => <span>{s}</span>)}
              {product.rating % 1 !== 0 && <span class="text-yellow-400">½</span>}
            </div>
            <span class="text-gray-600">({product.reviews} reviews)</span>
          </div>

          <!-- Price -->
          <div class="flex items-center gap-4 mb-6">
            <span class="text-3xl font-bold text-orange-500">₹{product.price.toLocaleString()}</span>
            <span class="text-xl text-gray-400 line-through">₹{product.originalPrice.toLocaleString()}</span>
            <span class="bg-red-100 text-red-600 text-sm font-bold px-2 py-1 rounded">-{Math.round((1 - product.price/product.originalPrice) * 100)}% OFF</span>
          </div>

          <p class="text-gray-600 mb-6 leading-relaxed">{product.description}</p>

          <!-- Size Selection -->
          <div class="mb-6">
            <h3 class="font-bold mb-3">Select Size</h3>
            <div class="flex flex-wrap gap-2">
              {product.sizes.map((size, i) => (
                <button class={`px-4 py-2 border-2 rounded-lg font-medium transition ${i === 1 ? 'border-orange-500 text-orange-500' : 'border-gray-200 hover:border-gray-300'}`}>
                  {size}
                </button>
              ))}
            </div>
            <a href="#" class="text-orange-500 text-sm mt-2 inline-block hover:underline">Size Guide</a>
          </div>

          <!-- Color Selection -->
          <div class="mb-8">
            <h3 class="font-bold mb-3">Color: <span class="font-normal">Black</span></h3>
            <div class="flex gap-3">
                {product.colors.map((color, i) => (
                <button
                  class={`w-10 h-10 rounded-full border-2 ${i === 0 ? 'border-orange-500' : 'border-gray-200'} hover:scale-110 transition`}
                  data-color={color.hex}
                  title={color.name}
                />
              ))}
            </div>
          </div>

          <!-- Add to Cart -->
          <div class="flex gap-4 mb-8">
            <div class="flex items-center border-2 border-gray-200 rounded-lg">
              <button class="px-4 py-3 text-xl font-bold hover:bg-gray-100">-</button>
              <span class="px-4 py-3 font-bold">1</span>
              <button class="px-4 py-3 text-xl font-bold hover:bg-gray-100">+</button>
            </div>
            <button class="flex-1 bg-orange-500 text-white font-bold py-3 px-8 rounded-lg hover:bg-orange-600 transition flex items-center justify-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
              ADD TO CART
            </button>
          </div>

          <!-- Features -->
          <div class="border-t pt-6">
            <h3 class="font-bold mb-4">Key Features</h3>
            <ul class="space-y-2">
              {product.features.map(f => (
                <li class="flex items-center gap-2 text-gray-600">
                  <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>

          <!-- Trust Badges -->
          <div class="flex gap-6 mt-8 pt-6 border-t text-sm text-gray-600">
            <div class="flex items-center gap-2">
              <span>🚚</span> Free Shipping
            </div>
            <div class="flex items-center gap-2">
              <span>↩️</span> Easy Returns
            </div>
            <div class="flex items-center gap-2">
              <span>🔒</span> Secure Payment
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  <section class="py-16 bg-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-8">You May Also Like</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {relatedProducts.map(p => (
          <div class="bg-white rounded-lg overflow-hidden group">
            <div class="relative">
              <img src={p.image} alt={p.name} class="w-full h-48 object-cover" />
              {p.originalPrice && <span class="absolute top-2 left-2 bg-red-500 text-white text-xs font-bold px-2 py-1 rounded">SALE</span>}
            </div>
            <div class="p-4">
              <h3 class="font-medium mb-1">{p.name}</h3>
              <div class="flex items-center gap-2">
                <span class="font-bold text-orange-500">₹{p.price.toLocaleString()}</span>
                {p.originalPrice && <span class="text-gray-400 line-through text-sm">₹{p.originalPrice.toLocaleString()}</span>}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-black text-white py-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-gray-400 text-sm">
      <p>&copy; 2024 Fashion Active. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>