---
const siteConfig = {
  site_name: 'Fashion Active',
  site_tagline: 'Premium Sportswear & Activewear',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            display: ['Oswald', 'sans-serif'],
            body: ['Roboto', 'sans-serif'],
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Roboto', sans-serif; }
    h1, h2, h3, h4, h5, h6 { font-family: 'Oswald', sans-serif; }
    html { scroll-behavior: smooth; }
  </style>
</head>
<body class="min-h-screen bg-white">
  <!-- Header -->
  <header class="bg-black text-white sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between py-4">
        <a href="#top" class="text-2xl font-bold tracking-wider">FASHION ACTIVE</a>
        <nav class="hidden md:flex items-center gap-8">
          <a href="#home" class="text-sm font-medium hover:text-orange-500 transition">Home</a>
          <a href="#categories" class="text-sm font-medium hover:text-orange-500 transition">Categories</a>
          <a href="#products" class="text-sm font-medium hover:text-orange-500 transition">Products</a>
          <a href="#about" class="text-sm font-medium hover:text-orange-500 transition">About</a>
          <a href="#contact" class="text-sm font-medium hover:text-orange-500 transition">Contact</a>
        </nav>
        <div class="flex items-center gap-4">
          <button class="p-2 hover:text-orange-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></button>
          <button class="p-2 hover:text-orange-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></button>
          <button class="p-2 hover:text-orange-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero Section -->
  <section id="home" class="relative bg-gray-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1483721310020-03333e577078?w=1920" class="w-full h-full object-cover opacity-60" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 md:py-48">
      <div class="max-w-2xl">
        <span class="inline-block bg-orange-500 text-white text-xs font-bold px-3 py-1 mb-4">NEW COLLECTION</span>
        <h1 class="text-5xl md:text-7xl font-bold uppercase mb-6 leading-none">Push Your<br/><span class="text-orange-500">Limits</span></h1>
        <p class="text-lg text-gray-300 mb-8">High-performance activewear designed for athletes who demand more. Breathable, durable, and built for peak performance.</p>
        <div class="flex gap-4">
          <a href="#products" class="bg-orange-500 text-white font-bold px-8 py-4 hover:bg-orange-600 transition">SHOP NOW</a>
          <a href="#categories" class="border-2 border-white text-white font-bold px-8 py-4 hover:bg-white hover:text-black transition">VIEW LOOKBOOK</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section id="categories" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12 uppercase">Shop by Sport</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <a href="#products" class="group relative overflow-hidden rounded-lg cursor-pointer">
          <img src="https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=600" class="w-full h-64 object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-bold text-lg uppercase">Running</span>
          </div>
        </a>
        <a href="#products" class="group relative overflow-hidden rounded-lg cursor-pointer">
          <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600" class="w-full h-64 object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-bold text-lg uppercase">Gym</span>
          </div>
        </a>
        <a href="#products" class="group relative overflow-hidden rounded-lg cursor-pointer">
          <img src="https://images.unsplash.com/photo-1571019614242-c5c5dee9f50b?w=600" class="w-full h-64 object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-bold text-lg uppercase">Yoga</span>
          </div>
        </a>
        <a href="#products" class="group relative overflow-hidden rounded-lg cursor-pointer">
          <img src="https://images.unsplash.com/photo-1579952363873-27f3bade9f55?w=600" class="w-full h-64 object-cover group-hover:scale-110 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-bold text-lg uppercase">Cycling</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Products Section -->
  <section id="products" class="py-16 bg-gray-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center justify-between mb-12">
        <h2 class="text-3xl font-bold uppercase">Bestsellers</h2>
        <a href="#" class="text-orange-500 font-medium hover:underline">View All →</a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1515886657613-9f3515b0c78f?w=400" class="w-full h-72 object-cover" />
            <span class="absolute top-3 left-3 bg-orange-500 text-white text-xs font-bold px-2 py-1">SALE</span>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-2">Performance Tank</h3>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-orange-500 font-bold">₹1,499</span>
              <span class="text-gray-400 line-through text-sm">₹2,199</span>
            </div>
            <div class="flex items-center gap-1 mb-3">
              <span class="text-yellow-400">★★★★</span><span class="text-gray-300">★</span>
              <span class="text-gray-500 text-sm ml-1">(128)</span>
            </div>
            <a href="/fashion-active/products/1" class="block w-full bg-black text-white py-2 rounded hover:bg-orange-500 transition text-center">View Product</a>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1542291026-7eec264c27ff?w=400" class="w-full h-72 object-cover" />
            <span class="absolute top-3 left-3 bg-black text-white text-xs font-bold px-2 py-1">NEW</span>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-2">Running Shoes Pro</h3>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-orange-500 font-bold">₹4,999</span>
            </div>
            <div class="flex items-center gap-1 mb-3">
              <span class="text-yellow-400">★★★★</span><span class="text-gray-300">★</span>
              <span class="text-gray-500 text-sm ml-1">(256)</span>
            </div>
            <button class="w-full bg-black text-white py-2 rounded hover:bg-orange-500 transition">Add to Cart</button>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=400" class="w-full h-72 object-cover" />
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-2">Training Leggings</h3>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-orange-500 font-bold">₹2,299</span>
            </div>
            <div class="flex items-center gap-1 mb-3">
              <span class="text-yellow-400">★★★★★</span>
              <span class="text-gray-500 text-sm ml-1">(89)</span>
            </div>
            <button class="w-full bg-black text-white py-2 rounded hover:bg-orange-500 transition">Add to Cart</button>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden group">
          <div class="relative">
            <img src="https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=400" class="w-full h-72 object-cover" />
            <span class="absolute top-3 left-3 bg-red-500 text-white text-xs font-bold px-2 py-1">-30%</span>
          </div>
          <div class="p-4">
            <h3 class="font-medium mb-2">Sports Hoodie</h3>
            <div class="flex items-center gap-2 mb-2">
              <span class="text-orange-500 font-bold">₹1,999</span>
              <span class="text-gray-400 line-through text-sm">₹2,899</span>
            </div>
            <div class="flex items-center gap-1 mb-3">
              <span class="text-yellow-400">★★★★</span><span class="text-gray-300">★</span>
              <span class="text-gray-500 text-sm ml-1">(167)</span>
            </div>
            <button class="w-full bg-black text-white py-2 rounded hover:bg-orange-500 transition">Add to Cart</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Promo Banner -->
  <section class="bg-orange-500 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-bold mb-4">MEMBERS GET 20% OFF</h2>
      <p class="text-xl mb-8 opacity-90">Join our fitness community and unlock exclusive benefits</p>
      <a href="#" class="inline-block bg-black text-white font-bold px-8 py-4 hover:bg-gray-900 transition">JOIN NOW</a>
    </div>
  </section>

  <!-- Features -->
  <section class="py-16 bg-black text-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div>
          <div class="text-4xl mb-4">🏃</div>
          <h3 class="font-bold mb-2">Free Shipping</h3>
          <p class="text-gray-400 text-sm">On orders above ₹999</p>
        </div>
        <div>
          <div class="text-4xl mb-4">↩️</div>
          <h3 class="font-bold mb-2">Easy Returns</h3>
          <p class="text-gray-400 text-sm">30-day return policy</p>
        </div>
        <div>
          <div class="text-4xl mb-4">🔒</div>
          <h3 class="font-bold mb-2">Secure Payment</h3>
          <p class="text-gray-400 text-sm">100% secure checkout</p>
        </div>
        <div>
          <div class="text-4xl mb-4">💬</div>
          <h3 class="font-bold mb-2">24/7 Support</h3>
          <p class="text-gray-400 text-sm">Dedicated customer care</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <img src="https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=800" class="rounded-lg shadow-lg" />
        </div>
        <div>
          <span class="text-orange-500 text-sm tracking-widest font-bold">OUR STORY</span>
          <h2 class="text-4xl font-bold mt-2 mb-6">Built for Athletes,<br/>By Athletes</h2>
          <p class="text-gray-600 mb-4 leading-relaxed">Founded by former professional athletes, Fashion Active was born from a simple belief: every athlete deserves high-quality, affordable gear that performs as hard as they do.</p>
          <p class="text-gray-600 mb-6 leading-relaxed">We partner with world-class manufacturers and use cutting-edge fabrics to create activewear that moves with you, not against you.</p>
          <div class="grid grid-cols-3 gap-4 text-center">
            <div class="bg-gray-100 p-4 rounded-lg">
              <span class="text-3xl font-bold text-orange-500">50+</span>
              <p class="text-gray-600 text-sm">Countries</p>
            </div>
            <div class="bg-gray-100 p-4 rounded-lg">
              <span class="text-3xl font-bold text-orange-500">1M+</span>
              <p class="text-gray-600 text-sm">Customers</p>
            </div>
            <div class="bg-gray-100 p-4 rounded-lg">
              <span class="text-3xl font-bold text-orange-500">500+</span>
              <p class="text-gray-600 text-sm">Products</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter -->
  <section class="py-16 bg-gray-900 text-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Stay in the Loop</h2>
      <p class="text-gray-400 mb-8">Subscribe to get exclusive offers, new arrivals, and fitness tips.</p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-xl mx-auto">
        <input type="email" placeholder="Enter your email" class="flex-1 px-6 py-4 rounded-lg bg-white/10 border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:border-orange-500" />
        <button type="submit" class="bg-orange-500 text-white font-bold px-8 py-4 rounded-lg hover:bg-orange-600 transition">SUBSCRIBE</button>
      </form>
    </div>
  </section>

  <!-- Contact Section -->
  <section id="contact" class="py-20 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-12">
        <span class="text-orange-500 text-sm tracking-widest font-bold">GET IN TOUCH</span>
        <h2 class="text-4xl font-bold mt-2">Contact Us</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h3 class="font-bold text-xl mb-4">Send us a message</h3>
          <form class="space-y-4">
            <input type="text" placeholder="Your Name" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:border-orange-500" />
            <input type="email" placeholder="Your Email" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:border-orange-500" />
            <textarea placeholder="Your Message" rows="4" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:border-orange-500"></textarea>
            <button type="submit" class="w-full bg-orange-500 text-white font-bold py-3 rounded-lg hover:bg-orange-600 transition">SEND MESSAGE</button>
          </form>
        </div>
        <div>
          <h3 class="font-bold text-xl mb-4">Visit our store</h3>
          <div class="space-y-4 text-gray-600">
            <div class="flex items-start gap-3">
              <span class="text-orange-500 text-xl">📍</span>
              <div>
                <strong>Address</strong><br/>
                123 Fitness Street, Indiranagar<br/>
                Bangalore, Karnataka 560038
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-orange-500 text-xl">📞</span>
              <div>
                <strong>Phone</strong><br/>
                +91 98765 43210
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-orange-500 text-xl">✉️</span>
              <div>
                <strong>Email</strong><br/>
                support@fashionactive.in
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-orange-500 text-xl">⏰</span>
              <div>
                <strong>Hours</strong><br/>
                Mon-Sat: 10AM - 9PM<br/>
                Sun: 11AM - 6PM
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <div>
          <h4 class="font-bold mb-4">Shop</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href="#products" class="hover:text-orange-500">New Arrivals</a></li>
            <li><a href="#products" class="hover:text-orange-500">Men</a></li>
            <li><a href="#products" class="hover:text-orange-500">Women</a></li>
            <li><a href="#products" class="hover:text-orange-500">Sale</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">Help</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href="#contact" class="hover:text-orange-500">Contact Us</a></li>
            <li><a href="#" class="hover:text-orange-500">Shipping Info</a></li>
            <li><a href="#" class="hover:text-orange-500">Returns</a></li>
            <li><a href="#" class="hover:text-orange-500">Size Guide</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">About</h4>
          <ul class="space-y-2 text-gray-400">
            <li><a href="#about" class="hover:text-orange-500">Our Story</a></li>
            <li><a href="#" class="hover:text-orange-500">Sustainability</a></li>
            <li><a href="#" class="hover:text-orange-500">Careers</a></li>
            <li><a href="#" class="hover:text-orange-500">Press</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-bold mb-4">Connect</h4>
          <div class="flex gap-4 mb-4">
            <a href="#" class="hover:text-orange-500">IG</a>
            <a href="#" class="hover:text-orange-500">FB</a>
            <a href="#" class="hover:text-orange-500">TW</a>
            <a href="#" class="hover:text-orange-500">YT</a>
          </div>
          <h4 class="font-bold mb-4 mt-6">Download App</h4>
          <div class="space-y-2 text-gray-400 text-sm">
            <a href="#" class="block hover:text-orange-500">App Store</a>
            <a href="#" class="block hover:text-orange-500">Google Play</a>
          </div>
        </div>
      </div>
      <div class="border-t border-gray-800 pt-8 text-center text-gray-400 text-sm">
        <p>&copy; 2024 Fashion Active. All rights reserved. | <a href="#" class="hover:text-orange-500">Privacy</a> | <a href="#" class="hover:text-orange-500">Terms</a></p>
      </div>
    </div>
  </footer>
</body>
</html>