---
// Template Preview Index Page - Showcase all templates
export const prerender = false;

import fs from 'fs';
import path from 'path';

interface TemplateInfo {
  slug: string;
  name: string;
  category: string;
  tier: string;
  description: string;
  colors: {
    primary: string;
    accent: string;
    background: string;
  };
  fonts: {
    heading: string;
    body: string;
  };
}

function loadAllTemplates(): TemplateInfo[] {
  const templatesDir = path.join(process.cwd(), 'src', 'templates');
  const categories = fs.readdirSync(templatesDir);
  const templates: TemplateInfo[] = [];

  for (const category of categories) {
    const categoryPath = path.join(templatesDir, category);
    if (!fs.statSync(categoryPath).isDirectory()) continue;

    const configPath = path.join(categoryPath, 'config.json');
    if (!fs.existsSync(configPath)) continue;

    try {
      const config = JSON.parse(fs.readFileSync(configPath, 'utf8'));
      templates.push({
        slug: config.slug || category,
        name: config.name || config.slug,
        category: config.category || 'business',
        tier: config.tier || 'basic',
        description: config.description || '',
        colors: {
          primary: config.theme?.colors?.primary || '#000032',
          accent: config.theme?.colors?.accent || '#FA5014',
          background: config.theme?.colors?.background || '#ffffff',
        },
        fonts: {
          heading: config.theme?.fonts?.heading || 'Playfair Display',
          body: config.theme?.fonts?.body || 'Inter',
        },
      });
    } catch (e) {
      console.error(`Error loading ${configPath}:`, e);
    }
  }

  return templates.sort((a, b) => a.name.localeCompare(b.name));
}

const templates = loadAllTemplates();

const categories = [...new Set(templates.map(t => t.category))];
const tiers = [...new Set(templates.map(t => t.tier))];

const tierLabels: Record<string, string> = {
  'starter': 'Starter',
  'basic': 'Basic',
  'growth': 'Growth',
  'medium': 'Growth',
  'advanced': 'Advanced',
  'premium': 'Advanced',
  'signature': 'Signature',
};

const categoryLabels: Record<string, string> = {
  'business': 'Business',
  'ecommerce': 'E-Commerce',
  'portfolio': 'Portfolio',
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Template Gallery - Tracewebstudio</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
    .template-card {
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .template-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    }
    .tier-badge {
      font-size: 10px;
      letter-spacing: 0.05em;
    }
    .category-filter.active {
      background: #000032;
      color: white;
    }
    .tier-filter.active {
      background: #FA5014;
      color: white;
    }
  </style>
</head>
<body class="bg-gray-100 min-h-screen">
  <!-- Header -->
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-6 py-4">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 bg-gradient-to-br from-orange-500 to-blue-900 rounded-xl flex items-center justify-center text-white font-bold text-xl">
            T
          </div>
          <span class="text-xl font-bold text-gray-900">Tracewebstudio</span>
        </div>
        <div class="flex items-center gap-4">
          <span class="text-sm text-gray-500">{templates.length} Templates</span>
          <a href="http://localhost:8080" target="_blank" class="px-4 py-2 bg-orange-500 text-white text-sm font-semibold rounded-full hover:bg-orange-600 transition-colors">
            Create Your Own
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Hero -->
  <section class="bg-gradient-to-br from-blue-900 via-blue-800 to-orange-500 text-white py-20">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h1 class="text-5xl md:text-6xl font-bold mb-6">Premium Website Templates</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto mb-8">
        Explore our collection of beautifully designed templates for every industry.
        Each template is fully customizable and powered by Tracewebstudio.
      </p>
      <div class="flex items-center justify-center gap-4 text-sm">
        <span class="px-3 py-1 bg-white/20 rounded-full">{templates.length} Templates</span>
        <span class="px-3 py-1 bg-white/20 rounded-full">{categories.length} Categories</span>
        <span class="px-3 py-1 bg-white/20 rounded-full">3 Tiers</span>
      </div>
    </div>
  </section>

  <!-- Filters -->
  <section class="bg-white border-b border-gray-200 py-6 sticky top-[73px] z-40">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-wrap items-center gap-6">
        <!-- Category Filter -->
        <div>
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block mb-2">Category</span>
          <div class="flex gap-2" id="category-filters">
            <button class="category-filter active px-4 py-2 text-sm font-medium rounded-full border border-gray-300 hover:border-gray-400 transition-colors" data-category="all">
              All
            </button>
            {categories.map(cat => (
              <button class="category-filter px-4 py-2 text-sm font-medium rounded-full border border-gray-300 hover:border-gray-400 transition-colors" data-category={cat}>
                {categoryLabels[cat] || cat}
              </button>
            ))}
          </div>
        </div>

        <!-- Tier Filter -->
        <div>
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block mb-2">Tier</span>
          <div class="flex gap-2" id="tier-filters">
            <button class="tier-filter active px-4 py-2 text-sm font-medium rounded-full border border-gray-300 hover:border-gray-400 transition-colors" data-tier="all">
              All
            </button>
            {['starter', 'growth', 'advanced', 'signature'].map(tier => (
              <button class="tier-filter px-4 py-2 text-sm font-medium rounded-full border border-gray-300 hover:border-gray-400 transition-colors" data-tier={tier}>
                {tierLabels[tier]}
              </button>
            ))}
          </div>
        </div>

        <!-- Search -->
        <div class="flex-1 max-w-xs">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider block mb-2">Search</span>
          <input
            type="text"
            id="search-input"
            placeholder="Search templates..."
            class="w-full px-4 py-2 text-sm border border-gray-300 rounded-full focus:outline-none focus:ring-2 focus:ring-orange-500 focus:border-transparent"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Template Grid -->
  <main class="max-w-7xl mx-auto px-6 py-12">
    <div id="template-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {templates.map((template) => (
        <a
          href={`/${template.slug}`}
          class="template-card block bg-white rounded-2xl overflow-hidden shadow-md"
          data-category={template.category}
          data-tier={template.tier}
          data-name={template.name.toLowerCase()}
        >
          <!-- Preview Area -->
          <div class="aspect-[4/3] relative overflow-hidden" style={`background: ${template.colors.background};`}>
            <!-- Mock Preview -->
            <div class="absolute inset-0 p-4">
              <div class="h-6 w-20 rounded mb-2" style={`background: ${template.colors.primary}; opacity: 0.8;`}></div>
              <div class="h-3 w-full rounded mb-1" style={`background: ${template.colors.primary}; opacity: 0.3;`}></div>
              <div class="h-3 w-3/4 rounded mb-4" style={`background: ${template.colors.primary}; opacity: 0.2;`}></div>
              <div class="flex gap-2 mb-3">
                <div class="w-12 h-12 rounded-lg" style={`background: ${template.colors.accent}; opacity: 0.6;`}></div>
                <div class="w-12 h-12 rounded-lg" style={`background: ${template.colors.primary}; opacity: 0.4;`}></div>
                <div class="w-12 h-12 rounded-lg" style={`background: ${template.colors.accent}; opacity: 0.3;`}></div>
              </div>
              <div class="h-16 rounded-lg" style={`background: linear-gradient(135deg, ${template.colors.primary}40, ${template.colors.accent}40);`}></div>
            </div>
            <!-- Tier Badge -->
            <div class="absolute top-3 right-3">
              <span class="tier-badge px-2 py-1 bg-black/70 text-white rounded-full uppercase font-semibold">
                {tierLabels[template.tier] || template.tier}
              </span>
            </div>
          </div>

          <!-- Info -->
          <div class="p-4">
            <h3 class="font-semibold text-gray-900 mb-1 truncate">{template.name}</h3>
            <p class="text-sm text-gray-500 mb-3 capitalize">{categoryLabels[template.category] || template.category}</p>
            <div class="flex items-center gap-2">
              <span class="text-xs text-gray-400 capitalize">{template.fonts.heading}</span>
              <span class="w-1 h-1 bg-gray-300 rounded-full"></span>
              <span class="text-xs text-gray-400 capitalize">{template.fonts.body}</span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- No Results -->
    <div id="no-results" class="hidden text-center py-20">
      <div class="text-6xl mb-4">🔍</div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">No templates found</h3>
      <p class="text-gray-500">Try adjusting your filters or search terms</p>
    </div>
  </main>

  <!-- Footer -->
  <footer class="bg-gray-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <p class="text-gray-400">© 2024 Tracewebstudio. All templates powered by Tracewebstudio.</p>
    </div>
  </footer>

  <script>
    const categoryFilters = document.querySelectorAll('.category-filter');
    const tierFilters = document.querySelectorAll('.tier-filter');
    const searchInput = document.getElementById('search-input');
    const templateCards = document.querySelectorAll('.template-card');
    const noResults = document.getElementById('no-results');

    let activeCategory = 'all';
    let activeTier = 'all';
    let searchTerm = '';

    function filterTemplates() {
      let visibleCount = 0;

      templateCards.forEach((card) => {
        const el = card as HTMLElement;
        const category = el.dataset.category || '';
        const tier = el.dataset.tier || '';
        const name = el.dataset.name || '';

        const matchesCategory = activeCategory === 'all' || category === activeCategory;
        const matchesTier = activeTier === 'all' || tier === activeTier;
        const matchesSearch = searchTerm === '' || name.includes(searchTerm.toLowerCase());

        if (matchesCategory && matchesTier && matchesSearch) {
          el.style.display = 'block';
          visibleCount++;
        } else {
          el.style.display = 'none';
        }
      });

      noResults?.classList.toggle('hidden', visibleCount > 0);
    }

    categoryFilters.forEach(btn => {
      btn.addEventListener('click', () => {
        categoryFilters.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeCategory = (btn as HTMLElement).dataset.category || 'all';
        filterTemplates();
      });
    });

    tierFilters.forEach(btn => {
      btn.addEventListener('click', () => {
        tierFilters.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        activeTier = (btn as HTMLElement).dataset.tier || 'all';
        filterTemplates();
      });
    });

    searchInput?.addEventListener('input', (e) => {
      searchTerm = (e.target as HTMLInputElement).value;
      filterTemplates();
    });
  </script>
</body>
</html>