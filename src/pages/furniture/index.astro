---
const siteConfig = { site_name: 'Furniture', site_tagline: 'Modern Home & Office Furniture' };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'DM Sans', sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-stone-50">
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-serif font-bold text-stone-800">HAVEN</h1>
      <nav class="hidden md:flex items-center gap-8 text-sm">
        <a href="#" class="text-stone-700 hover:text-stone-500">Living</a>
        <a href="#" class="text-stone-700 hover:text-stone-500">Bedroom</a>
        <a href="#" class="text-stone-700 hover:text-stone-500">Office</a>
        <a href="#" class="text-stone-700 hover:text-stone-500">Dining</a>
        <a href="#" class="text-stone-700 hover:text-stone-500">Sale</a>
      </nav>
      <div class="flex items-center gap-4">
        <button class="p-2 hover:text-stone-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></button>
        <button class="p-2 hover:text-stone-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></button>
        <button class="p-2 hover:text-stone-500"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
      </div>
    </div>
  </header>

  <section class="relative bg-stone-800 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=1920" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 text-center">
      <h1 class="text-5xl md:text-6xl font-serif mb-6">Create Your<br/><span class="text-amber-400">Perfect Space</span></h1>
      <p class="text-lg text-stone-300 max-w-2xl mx-auto mb-10">Premium furniture for home and office. Timeless designs, exceptional quality.</p>
      <a href="#" class="bg-amber-500 text-white px-8 py-4 font-medium rounded hover:bg-amber-400 transition">Shop Collection</a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-serif text-center mb-12">Shop by Room</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
            <span class="text-white font-medium text-lg">Living Room</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1616594039964-ae9021a400a0?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
            <span class="text-white font-medium text-lg">Bedroom</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
            <span class="text-white font-medium text-lg">Office</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1617806118233-18e1de247200?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
            <span class="text-white font-medium text-lg">Dining</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-stone-100">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-serif text-center mb-12">Bestsellers</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Modern Sofa Set</h3>
            <p class="text-stone-500 text-sm mb-2">3+1+1 Seater</p>
            <span class="font-bold text-lg">₹45,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1506439773649-6e0eb8cfb237?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Wooden Bed Frame</h3>
            <p class="text-stone-500 text-sm mb-2">Queen Size</p>
            <span class="font-bold text-lg">₹32,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1595428774223-ef52624120d2?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Ergonomic Chair</h3>
            <p class="text-stone-500 text-sm mb-2">Office Use</p>
            <span class="font-bold text-lg">₹12,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1617806118233-18e1de247200?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Dining Table Set</h3>
            <p class="text-stone-500 text-sm mb-2">6 Seater</p>
            <span class="font-bold text-lg">₹28,999</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-stone-800 text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-4xl font-serif mb-6">Free Delivery & Assembly</h2>
      <p class="text-stone-300 mb-8">On all orders above ₹25,000. Professional installation included.</p>
      <a href="#" class="bg-amber-500 text-white px-8 py-4 font-medium rounded hover:bg-amber-400 transition">Shop Now</a>
    </div>
  </section>

  <footer class="bg-stone-900 text-white py-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-stone-400 text-sm">
      <p>&copy; 2024 Haven Furniture. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>