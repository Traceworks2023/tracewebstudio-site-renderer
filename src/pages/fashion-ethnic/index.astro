---
const siteConfig = { site_name: 'Fashion Ethnic', site_tagline: 'Traditional Indian Fashion' };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Hindi:ital@0;1&family=Inter:wght@400;500;600&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
    .hindi { font-family: 'Tiro Devanagari Hindi', serif; }
  </style>
</head>
<body class="min-h-screen bg-amber-50">
  <header class="bg-maroon text-white">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <div class="flex items-center justify-between">
        <h1 class="text-2xl font-serif font-bold">VARANG</h1>
        <nav class="hidden md:flex items-center gap-8 text-sm">
          <a href="#" class="hover:text-amber-300 transition">New Arrivals</a>
          <a href="#" class="hover:text-amber-300 transition">Sarees</a>
          <a href="#" class="hover:text-amber-300 transition">Lehengas</a>
          <a href="#" class="hover:text-amber-300 transition">Kurtis</a>
          <a href="#" class="hover:text-amber-300 transition">Sale</a>
        </nav>
        <div class="flex items-center gap-4">
          <button class="p-2 hover:text-amber-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg></button>
          <button class="p-2 hover:text-amber-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg></button>
          <button class="p-2 hover:text-amber-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg></button>
        </div>
      </div>
    </div>
  </header>

  <section class="relative bg-maroon text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=1920" class="w-full h-full object-cover opacity-50" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 text-center">
      <span class="text-amber-300 text-sm tracking-widest">CELEBRATING INDIAN HERITAGE</span>
      <h1 class="text-5xl md:text-7xl font-serif mt-4 mb-6">Timeless<br/><span class="text-amber-300">Elegance</span></h1>
      <p class="text-lg text-white/80 max-w-2xl mx-auto mb-10">Exquisite handcrafted pieces that celebrate the rich heritage of Indian craftsmanship. Each saree, lehenga, and kurta tells a story.</p>
      <a href="#" class="bg-amber-500 text-white px-8 py-4 rounded font-medium hover:bg-amber-400 transition">Explore Collection</a>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-serif text-center mb-12">Shop by Category</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-medium text-lg">Sarees</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-medium text-lg">Lehengas</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1590548784585-643d2b05f9c1?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-medium text-lg">Kurtis</span>
          </div>
        </a>
        <a href="#" class="group relative overflow-hidden rounded-lg">
          <img src="https://images.unsplash.com/photo-1602173574767-37ac01994b2a?w=600" class="w-full h-72 object-cover group-hover:scale-105 transition duration-500" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 to-transparent flex items-end p-4">
            <span class="text-white font-medium text-lg">Dupattas</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-amber-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-serif text-center mb-12">Bestsellers</h2>
      <div class="grid md:grid-cols-4 gap-6">
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1610030469983-98e550d6193c?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Kanjeevaram Silk Saree</h3>
            <p class="text-amber-600 text-sm mb-2">Handwoven in Kanchipuram</p>
            <span class="font-bold text-lg">₹24,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1594463750939-ebb28c3f7f75?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Bridal Lehenga Set</h3>
            <p class="text-amber-600 text-sm mb-2">Zardozi embroidery</p>
            <span class="font-bold text-lg">₹65,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1590548784585-643d2b05f9c1?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Chikankari Kurti</h3>
            <p class="text-amber-600 text-sm mb-2">Lucknowi hand embroidery</p>
            <span class="font-bold text-lg">₹3,999</span>
          </div>
        </div>
        <div class="bg-white rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1602173574767-37ac01994b2a?w=400" class="w-full h-64 object-cover" />
          <div class="p-4">
            <h3 class="font-medium mb-1">Bandhani Dupatta</h3>
            <p class="text-amber-600 text-sm mb-2">Tie-dye art from Gujarat</p>
            <span class="font-bold text-lg">₹2,499</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-maroon text-white text-center">
    <div class="max-w-4xl mx-auto px-4">
      <span class="text-amber-300 text-sm tracking-widest">ARTISAN CRAFTSMANSHIP</span>
      <h2 class="text-4xl font-serif mt-4 mb-6">Handpicked by Heritage</h2>
      <p class="text-white/80 mb-8">Each piece in our collection is handcrafted by skilled artisans using traditional techniques passed down through generations.</p>
      <a href="#" class="inline-block bg-amber-500 text-white px-8 py-4 rounded font-medium hover:bg-amber-400 transition">Shop the Collection</a>
    </div>
  </section>

  <footer class="bg-amber-900 text-amber-100 py-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2024 Varang. Celebrating Indian Heritage.</p>
    </div>
  </footer>

  <style>
    .bg-maroon { background-color: #800020; }
  </style>
</body>
</html>