---
// Fashion Luxe About Page
import { fetchSiteBySlug, fetchPageContent } from '../../lib/api';

const siteSlug = 'demo';
const site = await fetchSiteBySlug(siteSlug);
const siteId = site?.id || 'demo-site';

const pageContent = await fetchPageContent(siteId, 'about');
const aboutContent = pageContent?.content || {};

const team = [
  { name: 'Sarah Mitchell', role: 'Founder & CEO', image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400' },
  { name: 'James Chen', role: 'Creative Director', image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=400' },
  { name: 'Elena Rodriguez', role: 'Head of Design', image: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=400' }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>About Us - LUXE</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>{`
    :root {
      --theme-primary: #000032;
      --theme-accent: #FA5014;
      --theme-background: #FFFFFF;
      --theme-surface: #F9FAFB;
      --theme-text: #111827;
      --theme-text-secondary: #6B7280;
      --theme-border: #E5E7EB;
      --font-heading: 'Playfair Display', serif;
      --font-body: 'Inter', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: var(--font-body); }
    h1, h2, h3 { font-family: var(--font-heading); }
  `}</style>
</head>
<body class="min-h-screen">

  <section class="about">
    <div class="about__hero">
      <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920" alt="About LUXE" class="about__hero-image" />
      <div class="about__hero-overlay">
        <h1 class="about__hero-title">{aboutContent.hero_title || 'Our Story'}</h1>
        <p class="about__hero-subtitle">{aboutContent.mission_statement || 'Crafting elegance since 2010'}</p>
      </div>
    </div>

    <div class="about__story">
      <div class="about__container">
        <div class="about__story-content">
          <h2 class="about__section-title">Redefining Luxury Fashion</h2>
          <p class="about__text">
            LUXE was founded with a singular vision: to make premium fashion accessible without compromising on quality or ethics. What started as a small boutique in New York City has grown into a global brand, serving fashion-forward individuals who appreciate timeless elegance.
          </p>
          <p class="about__text">
            Our curated collections bring together the finest materials, skilled craftsmanship, and contemporary design. Every piece in our collection is thoughtfully selected to ensure it meets our exacting standards for quality, sustainability, and style.
          </p>
        </div>
        <div class="about__story-image">
          <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?w=800" alt="Our Store" />
        </div>
      </div>
    </div>

    <div class="about__values">
      <div class="about__container">
        <h2 class="about__section-title about__section-title--center">Our Values</h2>
        <div class="about__values-grid">
          <div class="about__value">
            <div class="about__value-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              </svg>
            </div>
            <h3 class="about__value-title">Quality First</h3>
            <p class="about__value-text">Every item undergoes rigorous quality checks to ensure it meets our exacting standards.</p>
          </div>
          <div class="about__value">
            <div class="about__value-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"></path>
              </svg>
            </div>
            <h3 class="about__value-title">Sustainable Practices</h3>
            <p class="about__value-text">We're committed to reducing our environmental footprint through responsible sourcing.</p>
          </div>
          <div class="about__value">
            <div class="about__value-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 16v-4M12 8h.01"></path>
              </svg>
            </div>
            <h3 class="about__value-title">Transparent Pricing</h3>
            <p class="about__value-text">No hidden costs or markups. Fair pricing for both customers and artisans.</p>
          </div>
          <div class="about__value">
            <div class="about__value-icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75"></path>
              </svg>
            </div>
            <h3 class="about__value-title">Community Focus</h3>
            <p class="about__value-text">We give back through charitable partnerships and community initiatives.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="about__team">
      <div class="about__container">
        <h2 class="about__section-title about__section-title--center">{aboutContent.team_title || 'Meet Our Leadership'}</h2>
        <p class="about__team-intro">The passionate individuals driving LUXE forward</p>
        <div class="about__team-grid">
          {team.map((member) => (
            <div class="about__team-member">
              <img src={member.image} alt={member.name} class="about__team-image" />
              <h3 class="about__team-name">{member.name}</h3>
              <p class="about__team-role">{member.role}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <div class="about__cta">
      <div class="about__container about__container--narrow">
        <h2 class="about__cta-title">Ready to Experience LUXE?</h2>
        <p class="about__cta-text">Explore our latest collection and discover pieces that speak to your unique style.</p>
        <div class="about__cta-buttons">
          <a href="/fashion-luxe/products" class="about__cta-btn about__cta-btn--primary">Shop Now</a>
          <a href="/fashion-luxe/contact" class="about__cta-btn about__cta-btn--outline">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

  <style>{`
    .about { padding-bottom: 0; }
    .about__container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
    .about__container--narrow { max-width: 800px; text-align: center; }
    .about__hero { position: relative; height: 500px; overflow: hidden; }
    .about__hero-image { width: 100%; height: 100%; object-fit: cover; }
    .about__hero-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; background: rgba(0, 0, 0, 0.5); color: white; text-align: center; }
    .about__hero-title { font-family: var(--font-heading); font-size: 56px; font-weight: 600; margin: 0 0 16px; }
    .about__hero-subtitle { font-size: 18px; margin: 0; opacity: 0.9; }
    .about__story { padding: 100px 0; }
    .about__story .about__container { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }
    .about__section-title { font-family: var(--font-heading); font-size: 36px; font-weight: 600; margin: 0 0 24px; color: var(--theme-text); }
    .about__section-title--center { text-align: center; }
    .about__text { font-size: 16px; line-height: 1.8; color: var(--theme-text-secondary); margin: 0 0 20px; }
    .about__story-image img { width: 100%; border-radius: 8px; }
    .about__values { padding: 100px 0; background: var(--theme-surface); }
    .about__values-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 40px; margin-top: 60px; }
    .about__value { text-align: center; }
    .about__value-icon { width: 72px; height: 72px; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; background: var(--theme-background); border-radius: 50%; color: var(--theme-primary); }
    .about__value-title { font-family: var(--font-heading); font-size: 18px; font-weight: 600; margin: 0 0 12px; color: var(--theme-text); }
    .about__value-text { font-size: 14px; line-height: 1.6; color: var(--theme-text-secondary); margin: 0; }
    .about__team { padding: 100px 0; }
    .about__team-intro { text-align: center; font-size: 16px; color: var(--theme-text-secondary); margin: 0 0 60px; }
    .about__team-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 48px; }
    .about__team-member { text-align: center; }
    .about__team-image { width: 200px; height: 200px; border-radius: 50%; object-fit: cover; margin-bottom: 24px; }
    .about__team-name { font-family: var(--font-heading); font-size: 20px; font-weight: 600; margin: 0 0 8px; color: var(--theme-text); }
    .about__team-role { font-size: 14px; color: var(--theme-text-secondary); margin: 0; }
    .about__cta { padding: 100px 0; background: var(--theme-primary); color: var(--theme-background); }
    .about__cta-title { font-family: var(--font-heading); font-size: 40px; font-weight: 600; margin: 0 0 16px; }
    .about__cta-text { font-size: 18px; margin: 0 0 40px; opacity: 0.9; }
    .about__cta-buttons { display: flex; justify-content: center; gap: 16px; }
    .about__cta-btn { padding: 16px 40px; font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; text-decoration: none; border-radius: 4px; transition: background 0.2s ease; }
    .about__cta-btn--primary { background: var(--theme-background); color: var(--theme-primary); }
    .about__cta-btn--primary:hover { background: white; }
    .about__cta-btn--outline { background: transparent; border: 2px solid var(--theme-background); color: var(--theme-background); }
    .about__cta-btn--outline:hover { background: var(--theme-background); color: var(--theme-primary); }
    @media (max-width: 1024px) {
      .about__story .about__container { grid-template-columns: 1fr; gap: 48px; }
      .about__values-grid { grid-template-columns: repeat(2, 1fr); }
      .about__team-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 640px) {
      .about__hero { height: 400px; }
      .about__hero-title { font-size: 36px; }
      .about__section-title { font-size: 28px; }
      .about__values-grid { grid-template-columns: 1fr; }
      .about__cta-buttons { flex-direction: column; }
    }
  `}</style>
</body>
</html>
