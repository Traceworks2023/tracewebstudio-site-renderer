---
const siteConfig = { site_name: 'Automotive', site_tagline: 'Premium Vehicles & Services' };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Roboto', sans-serif; }
    h1, h2, h3 { font-family: 'Rajdhani', sans-serif; }
  </style>
</head>
<body class="min-h-screen bg-gray-100">
  <header class="bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold tracking-wider">MOTORS<span class="text-red-500">PRO</span></h1>
      <nav class="hidden md:flex items-center gap-6 text-sm">
        <a href="#inventory" class="hover:text-red-400">INVENTORY</a>
        <a href="#services" class="hover:text-red-400">SERVICES</a>
        <a href="#about" class="hover:text-red-400">ABOUT</a>
        <a href="#contact" class="hover:text-red-400">CONTACT</a>
      </nav>
      <a href="#contact" class="bg-red-600 px-4 py-2 rounded text-sm hover:bg-red-500">GET QUOTE</a>
    </div>
  </header>

  <section class="relative bg-gray-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1486262715619-67b85e0b08d3?w=1920" class="w-full h-full object-cover opacity-40" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 text-center">
      <span class="text-red-400 font-bold tracking-widest text-sm">PREMIUM AUTOMOTIVE</span>
      <h1 class="text-5xl md:text-7xl font-bold mt-4 mb-6">DRIVE YOUR<br/><span class="text-red-500">DREAMS</span></h1>
      <p class="text-gray-300 text-lg mb-10 max-w-2xl mx-auto">Experience excellence with our curated collection of premium vehicles. Quality service, unmatched expertise.</p>
      <a href="#inventory" class="bg-red-600 text-white px-8 py-4 font-bold hover:bg-red-500 transition">VIEW INVENTORY</a>
    </div>
  </section>

  <section id="inventory" class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">FEATURED VEHICLES</h2>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1555215695-3004980ad54e?w=600" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">BMW 5 Series</h3>
            <p class="text-gray-600 mb-4 text-sm">2023 • Petrol • 25000 km</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-red-600">₹65,00,000</span>
              <button class="bg-gray-900 text-white px-4 py-2 text-sm rounded hover:bg-red-600 transition">View Details</button>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1503376780353-7e6692767b70?w=600" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Mercedes C-Class</h3>
            <p class="text-gray-600 mb-4 text-sm">2023 • Diesel • 15000 km</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-red-600">₹55,00,000</span>
              <button class="bg-gray-900 text-white px-4 py-2 text-sm rounded hover:bg-red-600 transition">View Details</button>
            </div>
          </div>
        </div>
        <div class="bg-gray-50 rounded-lg overflow-hidden">
          <img src="https://images.unsplash.com/photo-1617531653332-bd46c24f2068?w=600" class="w-full h-48 object-cover" />
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Audi A4</h3>
            <p class="text-gray-600 mb-4 text-sm">2022 • Petrol • 30000 km</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-red-600">₹45,00,000</span>
              <button class="bg-gray-900 text-white px-4 py-2 text-sm rounded hover:bg-red-600 transition">View Details</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="services" class="py-16 bg-gray-900 text-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-12">OUR SERVICES</h2>
      <div class="grid md:grid-cols-4 gap-6 text-center">
        <div class="p-6">
          <div class="text-4xl mb-4">🔧</div>
          <h3 class="font-bold mb-2">Scheduled Service</h3>
          <p class="text-gray-400 text-sm">Expert maintenance for your vehicle</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-4">🚗</div>
          <h3 class="font-bold mb-2">Car Finance</h3>
          <p class="text-gray-400 text-sm">Flexible payment options</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-4">🔄</div>
          <h3 class="font-bold mb-2">Exchange</h3>
          <p class="text-gray-400 text-sm">Trade in your old vehicle</p>
        </div>
        <div class="p-6">
          <div class="text-4xl mb-4">🛡️</div>
          <h3 class="font-bold mb-2">Extended Warranty</h3>
          <p class="text-gray-400 text-sm">Protection plans available</p>
        </div>
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Contact Us</h2>
      <p class="text-gray-600 mb-8">MotorsPro Showroom, Whitefield Road, Bengaluru</p>
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div><strong>Sales:</strong> +91 98765 43212</div>
        <div><strong>Service:</strong> +91 98765 43213</div>
        <div><strong>Email:</strong> info@motorspro.in</div>
      </div>
      <a href="#" class="inline-block bg-red-600 text-white px-8 py-4 font-bold rounded hover:bg-red-500 transition">Schedule a Visit</a>
    </div>
  </section>

  <footer class="bg-gray-900 text-white py-8 text-center text-gray-400 text-sm">
    <p>&copy; 2024 MotorsPro. All rights reserved.</p>
  </footer>
</body>
</html>