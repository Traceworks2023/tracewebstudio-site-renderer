---
const siteConfig = { site_name: 'Consulting', site_tagline: 'Strategic Business Solutions' };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{siteConfig.site_name} - {siteConfig.site_tagline}</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <style>
    body { font-family: 'Inter', sans-serif; }
    h1, h2, h3 { font-family: 'Playfair Display', serif; }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <header class="bg-white shadow-sm sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4 flex items-center justify-between">
      <h1 class="text-2xl font-serif font-bold text-slate-900">APEX<span class="text-orange-600">ADVISORS</span></h1>
      <nav class="hidden md:flex items-center gap-8 text-sm">
        <a href="#services" class="text-slate-700 hover:text-orange-600 transition">Services</a>
        <a href="#case-studies" class="text-slate-700 hover:text-orange-600 transition">Case Studies</a>
        <a href="#about" class="text-slate-700 hover:text-orange-600 transition">About</a>
        <a href="#contact" class="text-slate-700 hover:text-orange-600 transition">Contact</a>
      </nav>
      <a href="#contact" class="bg-slate-900 text-white px-5 py-2 rounded text-sm hover:bg-orange-600 transition">Get Consultation</a>
    </div>
  </header>

  <section class="relative bg-slate-900 text-white">
    <div class="absolute inset-0">
      <img src="https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1920" class="w-full h-full object-cover opacity-30" />
    </div>
    <div class="relative max-w-7xl mx-auto px-4 py-32 text-center">
      <span class="text-orange-400 text-sm tracking-widest font-medium">STRATEGIC CONSULTING</span>
      <h1 class="text-5xl md:text-6xl font-serif mt-4 mb-6">Transform Your<br/><span class="text-orange-400">Business</span></h1>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto mb-10">Expert guidance to navigate complexity, drive growth, and achieve sustainable success in today's dynamic market.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="#contact" class="bg-orange-600 text-white px-8 py-4 rounded font-medium hover:bg-orange-500 transition">Schedule Consultation</a>
        <a href="#case-studies" class="border-2 border-white px-8 py-4 rounded font-medium hover:bg-white hover:text-slate-900 transition">View Case Studies</a>
      </div>
    </div>
  </section>

  <section id="services" class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-orange-600 text-sm tracking-widest">WHAT WE DO</span>
        <h2 class="text-4xl font-serif mt-2 text-slate-900">Our Services</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">📊</div>
          <h3 class="text-xl font-bold mb-3">Strategy & Growth</h3>
          <p class="text-slate-600 mb-4">Comprehensive strategic planning, market analysis, and growth roadmaps tailored to your business.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">💼</div>
          <h3 class="text-xl font-bold mb-3">Operations Excellence</h3>
          <p class="text-slate-600 mb-4">Streamline operations, reduce costs, and improve efficiency across your organization.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">🎯</div>
          <h3 class="text-xl font-bold mb-3">Digital Transformation</h3>
          <p class="text-slate-600 mb-4">Leverage technology to modernize your business and stay ahead of the competition.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">💰</div>
          <h3 class="text-xl font-bold mb-3">Financial Advisory</h3>
          <p class="text-slate-600 mb-4">Expert financial planning, risk management, and investment strategy services.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">👥</div>
          <h3 class="text-xl font-bold mb-3">Leadership Development</h3>
          <p class="text-slate-600 mb-4">Build high-performing teams and develop next-generation leaders.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
        <div class="bg-slate-50 rounded-xl p-8 hover:shadow-xl transition">
          <div class="w-14 h-14 bg-orange-100 rounded-lg flex items-center justify-center mb-6 text-2xl">🌐</div>
          <h3 class="text-xl font-bold mb-3">Market Expansion</h3>
          <p class="text-slate-600 mb-4">Strategic guidance for entering new markets and expanding your global footprint.</p>
          <a href="#" class="text-orange-600 font-medium hover:underline">Learn More →</a>
        </div>
      </div>
    </div>
  </section>

  <section id="case-studies" class="py-20 bg-slate-100">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <span class="text-orange-600 text-sm tracking-widest">SUCCESS STORIES</span>
        <h2 class="text-4xl font-serif mt-2 text-slate-900">Case Studies</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8">
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800" class="w-full h-48 object-cover" />
          <div class="p-6">
            <span class="text-orange-600 text-xs font-bold">STRATEGY</span>
            <h3 class="text-xl font-bold mt-2 mb-3">Scaling a D2C Brand from ₹10Cr to ₹100Cr</h3>
            <p class="text-slate-600 text-sm mb-4">How we helped a direct-to-consumer brand transform their growth strategy and achieve 10x revenue.</p>
            <a href="#" class="text-slate-900 font-medium hover:text-orange-600 transition">Read Case Study →</a>
          </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden shadow-sm">
          <img src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=800" class="w-full h-48 object-cover" />
          <div class="p-6">
            <span class="text-orange-600 text-xs font-bold">OPERATIONS</span>
            <h3 class="text-xl font-bold mt-2 mb-3">Optimizing Supply Chain for 40% Cost Reduction</h3>
            <p class="text-slate-600 text-sm mb-4">Streamlined operations and supply chain management resulted in significant cost savings.</p>
            <a href="#" class="text-slate-900 font-medium hover:text-orange-600 transition">Read Case Study →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-900 text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-4xl font-serif mb-6">Trusted by Industry Leaders</h2>
      <p class="text-slate-300 mb-12">We've partnered with forward-thinking organizations across industries</p>
      <div class="grid grid-cols-4 gap-8 opacity-70">
        <div class="flex items-center justify-center font-bold text-xl">TATA</div>
        <div class="flex items-center justify-center font-bold text-xl">INFOSYS</div>
        <div class="flex items-center justify-center font-bold text-xl">WIPRO</div>
        <div class="flex items-center justify-center font-bold text-xl">RELIANCE</div>
      </div>
    </div>
  </section>

  <section id="contact" class="py-20 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <h2 class="text-4xl font-serif text-slate-900">Let's Talk</h2>
        <p class="text-slate-600 mt-2">Schedule a consultation to discuss your business challenges</p>
      </div>
      <form class="bg-slate-50 rounded-xl p-8 grid md:grid-cols-2 gap-4">
        <input type="text" placeholder="Your Name" class="px-4 py-3 rounded border border-slate-200 w-full" />
        <input type="email" placeholder="Work Email" class="px-4 py-3 rounded border border-slate-200 w-full" />
        <input type="tel" placeholder="Phone" class="px-4 py-3 rounded border border-slate-200 w-full" />
        <select class="px-4 py-3 rounded border border-slate-200 w-full">
          <option>Area of Interest</option>
          <option>Strategy</option>
          <option>Operations</option>
          <option>Digital Transformation</option>
          <option>Financial Advisory</option>
        </select>
        <textarea placeholder="Tell us about your challenge" class="md:col-span-2 px-4 py-3 rounded border border-slate-200 w-full h-32"></textarea>
        <button type="submit" class="md:col-span-2 bg-slate-900 text-white py-3 rounded font-medium hover:bg-orange-600 transition">Submit</button>
      </form>
    </div>
  </section>

  <footer class="bg-slate-950 text-slate-400 py-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2024 Apex Advisors. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>