---
// Dynamic Product Detail Page
// Route: /products/[slug]

import { getProductBySlug, getRelatedProducts, mockProducts } from '../../lib/entities/store';
import type { Product } from '../../lib/entities/types';

export const prerender = true;

export async function getStaticPaths() {
  return mockProducts.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props as { product: Product };

if (!product) {
  return Astro.redirect('/404');
}

const relatedProducts = getRelatedProducts(product.id, 4);

const productJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.description,
  image: product.images[0]?.url,
  sku: product.sku,
  brand: {
    '@type': 'Brand',
    name: product.vendor || 'Store'
  },
  aggregateRating: product.rating ? {
    '@type': 'AggregateRating',
    ratingValue: product.rating.average,
    reviewCount: product.rating.count
  } : undefined,
  offers: {
    '@type': 'Offer',
    price: product.price,
    priceCurrency: 'USD',
    availability: product.inventory.quantity > 0
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock'
  }
};
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{product.name} - Store</title>
  <meta name="description" content={product.shortDescription || product.description.substring(0, 160)}>
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)}></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style>
    :root {
      --color-primary: #000032;
      --color-accent: #FA5014;
      --color-text: #333333;
      --color-background: #ffffff;
    }
    body { font-family: 'Inter', sans-serif; margin: 0; background: var(--color-background); color: var(--color-text); }
    * { box-sizing: border-box; }
    .product-detail { max-width: 1280px; margin: 0 auto; padding: 40px 20px; }
    .product-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
    @media (max-width: 768px) { .product-grid { grid-template-columns: 1fr; gap: 30px; } }
    .product-gallery { position: relative; }
    .main-image { width: 100%; aspect-ratio: 1; object-fit: cover; border-radius: 16px; background: #f5f5f5; }
    .thumbnails { display: flex; gap: 12px; margin-top: 16px; }
    .thumbnail { width: 80px; height: 80px; object-fit: cover; border-radius: 8px; cursor: pointer; opacity: 0.6; transition: opacity 0.2s; }
    .thumbnail:hover, .thumbnail.active { opacity: 1; }
    .product-info { padding-top: 20px; }
    .product-category { font-size: 14px; color: var(--color-accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .product-title { font-size: 36px; font-weight: 700; margin: 0 0 16px; color: #000; line-height: 1.2; }
    .product-rating { display: flex; align-items: center; gap: 8px; margin-bottom: 16px; }
    .stars { display: flex; gap: 2px; }
    .star { width: 18px; height: 18px; fill: #FBB03B; }
    .rating-text { font-size: 14px; color: #666; }
    .product-price { display: flex; align-items: baseline; gap: 12px; margin-bottom: 24px; }
    .current-price { font-size: 32px; font-weight: 700; color: #000; }
    .original-price { font-size: 20px; color: #999; text-decoration: line-through; }
    .discount-badge { background: #E23D28; color: white; padding: 4px 10px; border-radius: 4px; font-size: 12px; font-weight: 600; }
    .product-description { font-size: 16px; line-height: 1.7; color: #555; margin-bottom: 32px; }
    .options { margin-bottom: 32px; }
    .option-label { font-size: 14px; font-weight: 600; margin-bottom: 12px; color: #000; }
    .option-values { display: flex; gap: 10px; flex-wrap: wrap; }
    .option-btn { padding: 10px 20px; border: 2px solid #e0e0e0; border-radius: 8px; background: white; cursor: pointer; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .option-btn:hover { border-color: var(--color-primary); }
    .option-btn.selected { border-color: var(--color-primary); background: var(--color-primary); color: white; }
    .quantity-selector { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
    .qty-btn { width: 40px; height: 40px; border: 2px solid #e0e0e0; border-radius: 8px; background: white; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; }
    .qty-btn:hover { border-color: var(--color-primary); }
    .qty-value { font-size: 18px; font-weight: 600; min-width: 40px; text-align: center; }
    .add-to-cart-btn { width: 100%; padding: 18px 32px; background: var(--color-primary); color: white; border: none; border-radius: 12px; font-size: 16px; font-weight: 600; cursor: pointer; transition: background 0.2s; }
    .add-to-cart-btn:hover { background: var(--color-accent); }
    .product-meta { margin-top: 32px; padding-top: 32px; border-top: 1px solid #eee; }
    .meta-item { display: flex; gap: 8px; margin-bottom: 12px; font-size: 14px; color: #666; }
    .meta-item strong { color: #000; }
    .related-products { margin-top: 80px; padding-top: 40px; border-top: 1px solid #eee; }
    .related-title { font-size: 24px; font-weight: 700; margin-bottom: 24px; }
    .related-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
    @media (max-width: 768px) { .related-grid { grid-template-columns: repeat(2, 1fr); } }
    .related-card { border-radius: 12px; overflow: hidden; background: #f9f9f9; }
    .related-card img { width: 100%; aspect-ratio: 1; object-fit: cover; }
    .related-card-info { padding: 12px; }
    .related-card-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; }
    .related-card-price { font-size: 14px; color: var(--color-accent); font-weight: 600; }
  </style>
</head>
<body>
  <div class="product-detail">
    <div class="product-grid">
      {/* Gallery */}
      <div class="product-gallery">
        <img src={product.images[0]?.url || 'https://picsum.photos/800/800'} alt={product.name} class="main-image" id="mainImage" />
        {product.images.length > 1 && (
          <div class="thumbnails">
            {product.images.map((img, i) => (
              <img
                src={img.url}
                alt={img.alt}
                class={`thumbnail ${i === 0 ? 'active' : ''}`}
                onclick={`document.getElementById('mainImage').src=this.src;document.querySelectorAll('.thumbnail').forEach(t=>t.classList.remove('active'));this.classList.add('active')`}
              />
            ))}
          </div>
        )}
      </div>

      {/* Info */}
      <div class="product-info">
        <p class="product-category">{(product.collections || [])[0]?.replace('coll-', '').replace(/-/g, ' ') || 'Product'}</p>
        <h1 class="product-title">{product.name}</h1>

        {/* Rating */}
        {product.rating && (
          <div class="product-rating">
            <div class="stars">
              {[1, 2, 3, 4, 5].map((i) => (
                <svg class="star" viewBox="0 0 20 20" fill={i <= Math.floor(product.rating!.average) ? '#FBB03B' : '#ddd'}>
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>
            <span class="rating-text">{product.rating.average} ({product.rating.count} reviews)</span>
          </div>
        )}

        {/* Price */}
        <div class="product-price">
          <span class="current-price">${product.price}</span>
          {product.compareAtPrice && (
            <>
              <span class="original-price">${product.compareAtPrice}</span>
              <span class="discount-badge">Save ${product.compareAtPrice - product.price}</span>
            </>
          )}
        </div>

        {/* Description */}
        <p class="product-description">{product.description}</p>

        {/* Options */}
        {product.options.map((option) => (
          <div class="options">
            <p class="option-label">{option.name}: <span id={`selected-${option.id}`}>Select {option.name}</span></p>
            <div class="option-values">
              {option.values.map((value) => (
                <button class="option-btn" onclick={`selectOption('${option.id}', '${value}')`}>{value}</button>
              ))}
            </div>
          </div>
        ))}

        {/* Quantity */}
        <div class="quantity-selector">
          <span class="option-label">Quantity:</span>
          <button class="qty-btn" onclick="updateQty(-1)">-</button>
          <span class="qty-value" id="qtyValue">1</span>
          <button class="qty-btn" onclick="updateQty(1)">+</button>
        </div>

        {/* Add to Cart */}
        <button class="add-to-cart-btn" onclick="addToCart()">Add to Cart</button>

        {/* Meta */}
        <div class="product-meta">
          {product.sku && <p class="meta-item"><strong>SKU:</strong> {product.sku}</p>}
          {product.vendor && <p class="meta-item"><strong>Brand:</strong> {product.vendor}</p>}
          <p class="meta-item">
            <strong>Availability:</strong>
            {product.inventory.quantity > 0 ? `${product.inventory.quantity} in stock` : 'Out of stock'}
          </p>
        </div>
      </div>
    </div>

    {/* Related Products */}
    {relatedProducts.length > 0 && (
      <div class="related-products">
        <h2 class="related-title">You May Also Like</h2>
        <div class="related-grid">
          {relatedProducts.map((rp) => (
            <a href={`/products/${rp.slug}`} class="related-card">
              <img src={rp.images[0]?.url || 'https://picsum.photos/400/400'} alt={rp.name} />
              <div class="related-card-info">
                <p class="related-card-name">{rp.name}</p>
                <p class="related-card-price">${rp.price}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  <script is:inline>
    let qty = 1;
    const maxQty = 99;

    function updateQty(delta) {
      qty = Math.max(1, Math.min(qty + delta, maxQty));
      document.getElementById('qtyValue').textContent = qty;
    }

    function selectOption(optionId, value) {
      document.querySelectorAll('[onclick^="selectOption(\'' + optionId + '\')]').forEach(btn => {
        btn.classList.toggle('selected', btn.textContent.trim() === value);
      });
      document.getElementById('selected-' + optionId).textContent = value;
    }

    function addToCart() {
      alert('Added to cart! Quantity: ' + qty);
    }
  </script>
</body>
</html>