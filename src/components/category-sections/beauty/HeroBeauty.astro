---
// Beauty Hero - Editorial magazine style with soft tones
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Radiant Beauty',
  subtitle = 'Discover your natural glow with our curated collection',
  ctaText = 'Shop Now',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=1200',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="beauty-hero relative min-h-screen bg-[#FDF8F5] overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-20 left-10 w-64 h-64 bg-[#E8D5C4] rounded-full opacity-50 blur-3xl"></div>
  <div class="absolute bottom-20 right-20 w-96 h-96 bg-[#F5E6D3] rounded-full opacity-60 blur-3xl"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-12 gap-12 items-center min-h-[80vh]">
      <!-- Left: Image Stack -->
      <div class="lg:col-span-7 relative">
        <!-- Main Image -->
        <div class="relative z-10 rounded-2xl overflow-hidden shadow-2xl">
          <img src={image} alt={title} class="w-full h-[500px] object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
        </div>

        <!-- Floating Badge -->
        <div class="absolute -bottom-6 -right-6 bg-white rounded-xl shadow-xl p-4 z-20">
          <div class="text-3xl font-serif text-[#8B4513] mb-1">25%</div>
          <div class="text-xs text-gray-500 uppercase tracking-wider">First Order</div>
        </div>

        <!-- Second Image (offset) -->
        <div class="absolute -top-8 -left-8 w-48 h-64 rounded-xl overflow-hidden shadow-xl z-0 hidden lg:block">
          <img src="https://images.unsplash.com/photo-1570194065650-d99fb4bedf0a?w=300" alt="Beauty product" class="w-full h-full object-cover" />
        </div>
      </div>

      <!-- Right: Content -->
      <div class="lg:col-span-5 space-y-8">
        <div class="inline-block px-4 py-1 bg-[#8B4513]/10 text-[#8B4513] text-xs tracking-[0.2em] uppercase rounded-full">
          New Collection
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif text-[#2C1810] leading-[0.95]">
          {title}
        </h1>

        <p class="text-lg text-[#6B4423] leading-relaxed max-w-md">
          {subtitle}
        </p>

        <div class="flex items-center gap-4">
          <a
            href={ctaUrl}
            class="inline-flex items-center gap-2 px-8 py-4 bg-[#2C1810] text-white font-medium rounded-full hover:bg-[#4A2C1A] transition-colors"
          >
            {ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

        <!-- Trust indicators -->
        <div class="flex items-center gap-8 pt-8 border-t border-[#E8D5C4]">
          <div class="text-center">
            <div class="text-2xl font-serif text-[#8B4513]">15K+</div>
            <div class="text-xs text-gray-500">Happy Customers</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-serif text-[#8B4513]">4.9</div>
            <div class="text-xs text-gray-500">Average Rating</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-serif text-[#8B4513]">100%</div>
            <div class="text-xs text-gray-500">Natural</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>