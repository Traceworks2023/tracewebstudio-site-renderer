---
// Hotel Hero - Luxurious, elegant with large imagery
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'A World of Luxury Awaits',
  subtitle = 'Experience unparalleled elegance and comfort',
  ctaText = 'Book Your Stay',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1566073771259-6a8506099945?w=1200',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="hotel-hero relative min-h-screen">
  <!-- Fullscreen Background -->
  <div class="absolute inset-0">
    <img src={image} alt={title} class="w-full h-full object-cover" />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 min-h-screen flex flex-col justify-end pb-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="max-w-3xl">
        <!-- Small badge -->
        <div class="flex items-center gap-3 mb-6">
          <div class="flex gap-1">
            {[1,2,3,4,5].map(() => (
              <svg class="w-5 h-5 text-[#d4af37]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <span class="text-white/80 text-sm tracking-wider uppercase">5 Star Luxury</span>
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif text-white mb-6 leading-tight">
          {title}
        </h1>

        <!-- Subtitle -->
        <p class="text-xl text-white/70 mb-8 max-w-xl">
          {subtitle}
        </p>

        <!-- CTA and Price -->
        <div class="flex flex-wrap items-center gap-6">
          <a
            href={ctaUrl}
            class="inline-flex items-center gap-3 px-8 py-4 bg-[#d4af37] text-[#1a1a1a] font-semibold rounded hover:bg-[#c4a030] transition-colors"
          >
            {ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <div class="text-white">
            <span class="text-3xl font-serif">$299</span>
            <span class="text-white/60 text-sm"> / night</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Booking Widget -->
  <div class="absolute bottom-0 left-0 right-0 bg-white/95 backdrop-blur shadow-2xl">
    <div class="max-w-5xl mx-auto px-6 py-6">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div>
          <label class="block text-xs text-gray-500 uppercase tracking-wider mb-2">Check In</label>
          <div class="flex items-center gap-2 px-4 py-3 bg-gray-50 rounded-lg">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-gray-800">Jun 15, 2025</span>
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 uppercase tracking-wider mb-2">Check Out</label>
          <div class="flex items-center gap-2 px-4 py-3 bg-gray-50 rounded-lg">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            <span class="text-gray-800">Jun 18, 2025</span>
          </div>
        </div>
        <div>
          <label class="block text-xs text-gray-500 uppercase tracking-wider mb-2">Guests</label>
          <div class="flex items-center gap-2 px-4 py-3 bg-gray-50 rounded-lg">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            <span class="text-gray-800">2 Adults</span>
          </div>
        </div>
        <div class="flex items-end">
          <button class="w-full px-6 py-3 bg-[#1a1a1a] text-white font-semibold rounded-lg hover:bg-[#2a2a2a] transition-colors">
            Check Availability
          </button>
        </div>
      </div>
    </div>
  </div>
</section>