---
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Canvas of Creation',
  subtitle = 'Original paintings and artistic commissions',
  ctaText = 'View Gallery',
  ctaUrl = '#',
  image = '',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="artist-hero relative min-h-screen flex items-center overflow-hidden" style="background: var(--color-background, #1a1a1a);">
  <div class="absolute inset-0">
    {image && <img src={image} alt={title} class="w-full h-full object-cover" style="opacity: 0.4;" />}
    <div class="absolute inset-0" style="background: linear-gradient(to top, var(--color-background, #1a1a1a), var(--color-background, rgba(26,26,26,0.6)), var(--color-background, #1a1a1a));"></div>
  </div>

  <div class="absolute top-20 left-20 w-64 h-64 rounded-full opacity-10 blur-3xl" style="background: var(--color-primary, #E07B39);"></div>
  <div class="absolute bottom-40 right-40 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: var(--color-secondary, #7B68EE);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
    <div class="max-w-3xl">
      <div class="inline-flex items-center gap-2 text-sm tracking-[0.3em] uppercase mb-6" style="color: var(--color-primary, #E07B39);">
        <span class="w-8 h-px" style="background: var(--color-primary, #E07B39);"></span>
        Fine Art
        <span class="w-8 h-px" style="background: var(--color-primary, #E07B39);"></span>
      </div>

      <h1 class="text-5xl md:text-6xl lg:text-7xl font-serif leading-tight mb-6" style="color: var(--color-text, #ffffff);">
        {title}
      </h1>

      <p class="text-xl max-w-lg leading-relaxed mb-8" style="color: var(--color-text-muted, rgba(255,255,255,0.7));">
        {subtitle}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href={ctaUrl}
          class="inline-flex items-center gap-3 px-8 py-4 font-semibold rounded transition-opacity"
          style="background: var(--color-primary, #E07B39); color: var(--color-text, #ffffff);"
        >
          {ctaText}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded transition-colors" style="border: 1px solid rgba(255,255,255,0.3); color: var(--color-text, #ffffff);">
          Commission Work
        </a>
      </div>

      <div class="flex items-center gap-8 pt-12 border-t mt-12" style="border-color: var(--color-border, rgba(255,255,255,0.1));">
        <div class="text-center">
          <div class="text-3xl font-serif" style="color: var(--color-primary, #E07B39);">500+</div>
          <div class="text-sm" style="color: var(--color-text-muted, #999999);">Artworks</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-serif" style="color: var(--color-text, #ffffff);">50+</div>
          <div class="text-sm" style="color: var(--color-text-muted, #999999);">Exhibitions</div>
        </div>
        <div class="text-center">
          <div class="text-3xl font-serif" style="color: var(--color-text, #ffffff);">15+</div>
          <div class="text-sm" style="color: var(--color-text-muted, #999999);">Years</div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 py-4 border-t" style="background: var(--color-primary, rgba(224,123,57,0.2)); border-color: var(--color-primary, rgba(224,123,57,0.3));">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between text-sm" style="color: var(--color-text-muted, rgba(255,255,255,0.6));">
      <div class="flex items-center gap-6">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Original Works
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Commissions Open
        </span>
      </div>
      <span class="font-medium">Available for private viewings</span>
    </div>
  </div>
</section>