---
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Style Your Space',
  subtitle = 'Transforming environments with creative flair',
  ctaText = 'See Our Work',
  ctaUrl = '#',
  image = '',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="decor-stylist-hero relative min-h-screen flex items-center overflow-hidden" style="background: var(--color-surface, #f5f5f5);">
  <div class="absolute top-20 right-20 w-96 h-96 rounded-full opacity-20 blur-3xl" style="background: var(--color-secondary, #f4a7b9);"></div>
  <div class="absolute bottom-20 left-10 w-64 h-64 rounded-full opacity-15 blur-3xl" style="background: var(--color-primary, #c4a484);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="inline-block px-4 py-1 text-xs tracking-[0.2em] uppercase rounded-full" style="background: var(--color-primary, rgba(232,121,160,0.1)); color: var(--color-primary, #e879a0);">
          Decor & Styling
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif leading-tight" style="color: var(--color-text, #1a1a1a);">
          {title}
        </h1>

        <p class="text-lg max-w-md leading-relaxed" style="color: var(--color-text-muted, #666666);">
          {subtitle}
        </p>

        <div class="flex items-center gap-4">
          <a
            href={ctaUrl}
            class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded-full transition-opacity"
            style="background: var(--color-primary, #e879a0); color: var(--color-text, #ffffff);"
          >
            {ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="#" class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded-full transition-colors" style="border: 1px solid var(--color-primary, rgba(232,121,160,0.3)); color: var(--color-primary, #e879a0);">
            Consult Now
          </a>
        </div>

        <div class="flex items-center gap-8 pt-8 border-t" style="border-color: var(--color-border, #e0e0e0);">
          <div class="text-center">
            <div class="text-2xl font-serif" style="color: var(--color-primary, #e879a0);">200+</div>
            <div class="text-xs" style="color: var(--color-text-muted, #666666);">Projects</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-serif" style="color: var(--color-primary, #e879a0);">100%</div>
            <div class="text-xs" style="color: var(--color-text-muted, #666666);">Satisfaction</div>
          </div>
        </div>
      </div>

      <div class="hidden lg:block relative">
        <div class="relative">
          {image && (
            <>
              <div class="absolute -inset-4 rounded-3xl blur-xl" style="background: var(--color-secondary, #f4a7b9); opacity: 0.3;"></div>
              <div class="relative rounded-2xl overflow-hidden shadow-2xl">
                <img src={image} alt={title} class="w-full h-[500px] object-cover" />
              </div>
            </>
          )}
          {!image && (
            <div class="w-full h-[500px] rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-primary, #e879a0), var(--color-secondary, #f4a7b9));">
              <span class="text-8xl font-serif" style="color: var(--color-text, #ffffff); opacity: 0.5;">{title.charAt(0)}</span>
            </div>
          )}
          <div class="absolute -top-6 -right-6 rounded-xl shadow-xl p-4 z-20" style="background: var(--color-surface, #ffffff);">
            <div class="text-3xl font-serif mb-1" style="color: var(--color-primary, #e879a0);">New</div>
            <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted, #666666);">Collection</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>