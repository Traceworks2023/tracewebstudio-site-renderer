---
// Fitness Hero - Bold, high energy, dark theme with accent colors
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Unleash Your Power',
  subtitle = 'Transform your body. Transform your life.',
  ctaText = 'Start Free Trial',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=1200',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="fitness-hero relative min-h-screen flex items-center bg-[#0a0a0a] overflow-hidden">
  <!-- Background with gradient overlay -->
  <div class="absolute inset-0">
    <img src={image} alt={title} class="w-full h-full object-cover opacity-40" />
    <div class="absolute inset-0 bg-gradient-to-br from-[#0a0a0a] via-[#0a0a0a]/90 to-[#1a1a1a]"></div>
    <!-- Diagonal accent stripe -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[#FF4500]/20 to-transparent transform skew-x-12"></div>
  </div>

  <!-- Grid overlay -->
  <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.05) 1px, transparent 1px); background-size: 50px 50px;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Left: Content -->
      <div class="space-y-8">
        <!-- Badge -->
        <div class="inline-flex items-center gap-3 px-4 py-2 bg-[#FF4500]/20 border border-[#FF4500]/30 rounded-lg">
          <span class="w-2 h-2 bg-[#FF4500] rounded-full animate-pulse"></span>
          <span class="text-[#FF4500] text-sm font-medium tracking-wider uppercase">New Training Program</span>
        </div>

        <!-- Title -->
        <h1 class="text-5xl md:text-6xl lg:text-8xl font-black text-white leading-[0.9] tracking-tight">
          {title}
        </h1>

        <!-- Subtitle -->
        <p class="text-xl text-gray-400 max-w-lg leading-relaxed">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap gap-4">
          <a
            href={ctaUrl}
            class="group relative inline-flex items-center gap-3 px-8 py-4 bg-[#FF4500] text-white font-bold rounded-lg overflow-hidden transition-transform hover:scale-105"
          >
            <span class="relative z-10">{ctaText}</span>
            <svg class="relative z-10 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-[#FF6B00] to-[#FF4500] opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-bold rounded-lg hover:bg-white/10 transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z"/>
            </svg>
            Watch Video
          </a>
        </div>

        <!-- Stats Row -->
        <div class="flex gap-8 pt-8 border-t border-white/10">
          <div>
            <div class="text-4xl font-black text-[#FF4500]">50+</div>
            <div class="text-gray-500 text-sm uppercase tracking-wider">Trainers</div>
          </div>
          <div>
            <div class="text-4xl font-black text-white">100+</div>
            <div class="text-gray-500 text-sm uppercase tracking-wider">Classes</div>
          </div>
          <div>
            <div class="text-4xl font-black text-white">24/7</div>
            <div class="text-gray-500 text-sm uppercase tracking-wider">Access</div>
          </div>
        </div>
      </div>

      <!-- Right: Feature Cards -->
      <div class="hidden lg:grid grid-cols-2 gap-4">
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
          <div class="text-3xl mb-3">💪</div>
          <h3 class="text-white font-bold mb-1">Strength</h3>
          <p class="text-gray-500 text-sm">Build muscle, build confidence</p>
        </div>
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors mt-8">
          <div class="text-3xl mb-3">🔥</div>
          <h3 class="text-white font-bold mb-1">Cardio</h3>
          <p class="text-gray-500 text-sm">Burn fat, boost endurance</p>
        </div>
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors">
          <div class="text-3xl mb-3">🧘</div>
          <h3 class="text-white font-bold mb-1">Recovery</h3>
          <p class="text-gray-500 text-sm">Rest, stretch, grow</p>
        </div>
        <div class="bg-white/5 backdrop-blur border border-white/10 rounded-2xl p-6 hover:bg-white/10 transition-colors mt-8">
          <div class="text-3xl mb-3">🏆</div>
          <h3 class="text-white font-bold mb-1">Coaching</h3>
          <p class="text-gray-500 text-sm">Expert guidance daily</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="absolute bottom-0 left-0 right-0 bg-[#FF4500] py-3">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between text-white text-sm font-medium">
      <div class="flex items-center gap-6">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          No Contract
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Cancel Anytime
        </span>
      </div>
      <span class="font-bold">FIRST MONTH FREE →</span>
    </div>
  </div>
</section>