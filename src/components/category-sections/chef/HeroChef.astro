---
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Culinary Excellence',
  subtitle = 'Farm-to-table cuisine crafted with passion',
  ctaText = 'View Menu',
  ctaUrl = '#',
  image = '',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="chef-hero relative min-h-screen flex items-center overflow-hidden" style="background: var(--color-background, #1a1a1a);">
  <div class="absolute inset-0">
    {image && <img src={image} alt={title} class="w-full h-full object-cover" style="opacity: 0.5;" />}
    <div class="absolute inset-0" style="background: linear-gradient(to right, var(--color-background, #1a1a1a), var(--color-background, rgba(26,26,26,0.7)), transparent);"></div>
  </div>

  <div class="absolute top-20 right-20 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: var(--color-accent, #d4af37);"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 text-sm tracking-[0.3em] uppercase" style="color: var(--color-accent, #d4af37);">
          <span class="w-8 h-px" style="background: var(--color-accent, #d4af37);"></span>
          Professional Chef
          <span class="w-8 h-px" style="background: var(--color-accent, #d4af37);"></span>
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif leading-tight" style="color: var(--color-text, #ffffff);">
          {title}
        </h1>

        <p class="text-xl max-w-md leading-relaxed" style="color: var(--color-text-muted, rgba(255,255,255,0.7));">
          {subtitle}
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={ctaUrl}
            class="inline-flex items-center gap-3 px-8 py-4 font-semibold rounded transition-opacity"
            style="background: var(--color-accent, #d4af37); color: var(--color-background, #1a1a1a);"
          >
            {ctaText}
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="#" class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded transition-colors" style="border: 1px solid rgba(255,255,255,0.3); color: var(--color-text, #ffffff);">
            Book Chef
          </a>
        </div>

        <div class="flex items-center gap-8 pt-8 border-t" style="border-color: var(--color-border, rgba(255,255,255,0.1));">
          <div class="text-center">
            <div class="text-2xl font-serif" style="color: var(--color-accent, #d4af37);">15+</div>
            <div class="text-sm" style="color: var(--color-text-muted, #999999);">Years Experience</div>
          </div>
          <div class="text-center">
            <div class="text-2xl font-serif" style="color: var(--color-accent, #d4af37);">Michelin</div>
            <div class="text-sm" style="color: var(--color-text-muted, #999999);">Trained</div>
          </div>
        </div>
      </div>

      <div class="hidden lg:block relative">
        <div class="relative">
          {image && (
            <>
              <div class="absolute -inset-4 rounded-3xl blur-xl" style="background: var(--color-accent, #d4af37); opacity: 0.2;"></div>
              <div class="relative rounded-2xl overflow-hidden shadow-2xl">
                <img src={image} alt={title} class="w-full h-[500px] object-cover" />
              </div>
            </>
          )}
          {!image && (
            <div class="w-full h-[500px] rounded-2xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-accent, #d4af37), var(--color-primary, #B22A2A));">
              <span class="text-8xl font-serif" style="color: var(--color-text, #ffffff); opacity: 0.5;">{title.charAt(0)}</span>
            </div>
          )}
          <div class="absolute -top-6 -right-6 rounded-xl shadow-xl p-4 z-20" style="background: var(--color-surface, #ffffff);">
            <div class="text-3xl font-serif mb-1" style="color: var(--color-accent, #d4af37);">5</div>
            <div class="text-xs uppercase tracking-wider" style="color: var(--color-text-muted, #666666);">Star Rating</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 py-4" style="background: var(--color-accent, #d4af37);">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between text-sm font-medium" style="color: var(--color-background, #1a1a1a);">
      <div class="flex items-center gap-6">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Private Dining
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Catering Available
        </span>
      </div>
      <span class="font-bold">BOOK NOW →</span>
    </div>
  </div>
</section>