---
// Restaurant Hero - Elegant dark theme with food imagery and menu preview
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Welcome',
  subtitle = 'Experience culinary excellence',
  ctaText = 'View Menu',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1200',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="restaurant-hero relative min-h-screen flex items-center bg-[#1a1a1a]">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0">
    <img src={image} alt={title} class="w-full h-full object-cover opacity-60" />
    <div class="absolute inset-0 bg-gradient-to-r from-[#1a1a1a] via-[#1a1a1a]/80 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Text Content -->
      <div class="space-y-8">
        <div class="inline-flex items-center gap-2 text-[#d4af37] text-sm tracking-[0.3em] uppercase">
          <span class="w-8 h-px bg-[#d4af37]"></span>
          Fine Dining
          <span class="w-8 h-px bg-[#d4af37]"></span>
        </div>

        <h1 class="text-5xl md:text-7xl font-serif text-white leading-tight">
          {title}
        </h1>

        <p class="text-xl text-white/70 max-w-md leading-relaxed">
          {subtitle}
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={ctaUrl}
            class="inline-flex items-center gap-3 px-8 py-4 bg-[#d4af37] text-[#1a1a1a] font-semibold rounded hover:bg-[#c4a030] transition-colors"
          >
            <span>{ctaText}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-8 py-4 border border-white/30 text-white font-medium rounded hover:bg-white/10 transition-colors"
          >
            Reserve a Table
          </a>
        </div>

        <!-- Award Badge -->
        <div class="flex items-center gap-4 pt-8 border-t border-white/10">
          <div class="flex -space-x-3">
            <div class="w-10 h-10 rounded-full bg-[#d4af37] flex items-center justify-center text-[#1a1a1a] font-bold text-lg">★</div>
            <div class="w-10 h-10 rounded-full bg-[#d4af37] flex items-center justify-center text-[#1a1a1a] font-bold text-lg">★</div>
            <div class="w-10 h-10 rounded-full bg-[#d4af37] flex items-center justify-center text-[#1a1a1a] font-bold text-lg">★</div>
          </div>
          <div class="text-white/60 text-sm">
            <span class="text-[#d4af37] font-semibold">4.9</span> rating from 2,000+ reviews
          </div>
        </div>
      </div>

      <!-- Right: Menu Preview Card -->
      <div class="hidden lg:block">
        <div class="relative">
          <div class="absolute -inset-4 bg-[#d4af37]/20 rounded-3xl blur-xl"></div>
          <div class="relative bg-[#2a2a2a] rounded-2xl p-8 border border-white/10">
            <div class="text-center mb-6">
              <h3 class="text-2xl font-serif text-[#d4af37] mb-2">Tonight's Special</h3>
              <p class="text-white/50 text-sm">Chef's Selection</p>
            </div>

            <div class="space-y-4">
              <div class="flex justify-between items-start border-b border-white/10 pb-4">
                <div>
                  <div class="text-white font-medium">Grilled Salmon</div>
                  <div class="text-white/50 text-sm">Lemon butter sauce, asparagus</div>
                </div>
                <div class="text-[#d4af37] font-semibold">$42</div>
              </div>
              <div class="flex justify-between items-start border-b border-white/10 pb-4">
                <div>
                  <div class="text-white font-medium">Filet Mignon</div>
                  <div class="text-white/50 text-sm">8oz, truffle mash</div>
                </div>
                <div class="text-[#d4af37] font-semibold">$58</div>
              </div>
              <div class="flex justify-between items-start">
                <div>
                  <div class="text-white font-medium">Lobster Risotto</div>
                  <div class="text-white/50 text-sm">Arborio rice, mascarpone</div>
                </div>
                <div class="text-[#d4af37] font-semibold">$48</div>
              </div>
            </div>

            <div class="mt-6 text-center">
              <a href="#" class="text-[#d4af37] text-sm font-medium hover:underline">
                View Full Menu →
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Info Bar -->
  <div class="absolute bottom-0 left-0 right-0 bg-[#d4af37] py-4">
    <div class="max-w-7xl mx-auto px-6 flex justify-between items-center text-[#1a1a1a] text-sm">
      <div class="flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        <span>123 Main Street, Downtown</span>
      </div>
      <div class="flex items-center gap-6">
        <span>Open Daily: 11AM - 11PM</span>
        <span class="font-semibold">Call: (555) 123-4567</span>
      </div>
    </div>
  </div>
</section>