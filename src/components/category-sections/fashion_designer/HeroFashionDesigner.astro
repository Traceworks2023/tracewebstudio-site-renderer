---
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Wear Art',
  subtitle = 'Bespoke fashion designed for the bold',
  ctaText = 'Explore Collection',
  ctaUrl = '#',
  image = '',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="fashion-designer-hero relative min-h-screen flex items-center overflow-hidden" style="background: var(--color-background, #1a1a1a);">
  <div class="absolute inset-0">
    {image && <img src={image} alt={title} class="w-full h-full object-cover" style="opacity: 0.4;" />}
    <div class="absolute inset-0" style="background: linear-gradient(to right, var(--color-background, #1a1a1a), var(--color-background, #1a1a1a) 70%, transparent);"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 py-20 w-full">
    <div class="max-w-2xl">
      <div class="inline-flex items-center gap-2 text-sm tracking-[0.3em] uppercase mb-6" style="color: var(--color-accent, #A581D5);">
        <span class="w-8 h-px" style="background: var(--color-accent, #A581D5);"></span>
        Couture Fashion
        <span class="w-8 h-px" style="background: var(--color-accent, #A581D5);"></span>
      </div>

      <h1 class="text-5xl md:text-7xl font-serif leading-tight mb-6" style="color: var(--color-text, #ffffff);">
        {title}
      </h1>

      <p class="text-xl max-w-md leading-relaxed mb-8" style="color: var(--color-text-muted, rgba(255,255,255,0.7));">
        {subtitle}
      </p>

      <div class="flex flex-wrap gap-4">
        <a
          href={ctaUrl}
          class="inline-flex items-center gap-3 px-8 py-4 font-semibold rounded transition-opacity"
          style="background: var(--color-accent, #A581D5); color: var(--color-background, #1a1a1a);"
        >
          {ctaText}
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="#" class="inline-flex items-center gap-2 px-8 py-4 font-medium rounded transition-colors" style="border: 1px solid rgba(255,255,255,0.3); color: var(--color-text, #ffffff);">
          Private Consultation
        </a>
      </div>

      <div class="flex items-center gap-8 pt-12 border-t mt-12" style="border-color: var(--color-border, rgba(255,255,255,0.1));">
        <div class="flex -space-x-3">
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg" style="background: var(--color-accent, #A581D5); color: var(--color-background, #1a1a1a);">A</div>
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg" style="background: var(--color-accent, #A581D5); color: var(--color-background, #1a1a1a);">V</div>
          <div class="w-10 h-10 rounded-full flex items-center justify-center font-bold text-lg" style="background: var(--color-accent, #A581D5); color: var(--color-background, #1a1a1a);">M</div>
        </div>
        <div class="text-sm" style="color: var(--color-text-muted, rgba(255,255,255,0.6));">
          <span style="color: var(--color-accent, #A581D5); font-weight: 600;">500+</span> designs created
        </div>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 py-4 border-t" style="background: rgba(255,255,255,0.05); border-color: var(--color-border, rgba(255,255,255,0.1));">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between text-sm" style="color: var(--color-text-muted, rgba(255,255,255,0.4));">
      <div class="flex items-center gap-8">
        <span>RUNWAY</span>
        <span style="color: var(--color-accent, #A581D5);">•</span>
        <span>COUTURE</span>
        <span style="color: var(--color-accent, #A581D5);">•</span>
        <span>BESPOKE</span>
        <span style="color: var(--color-accent, #A581D5);">•</span>
        <span>EDITORIAL</span>
      </div>
      <span class="font-medium" style="color: var(--color-text, rgba(255,255,255,0.6));">SS 2026 Collection</span>
    </div>
  </div>
</section>