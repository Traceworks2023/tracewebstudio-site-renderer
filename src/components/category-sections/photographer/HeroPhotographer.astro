---
// Photographer Hero - Artistic, gallery-style with masonry images
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Capturing Moments',
  subtitle = 'Wedding, Portrait & Editorial Photography',
  ctaText = 'View Portfolio',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1452587925148-ce544e77e70d?w=1200',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="photographer-hero relative min-h-screen bg-[#1a1a1a] overflow-hidden">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#1a1a1a] via-[#2a2a2a] to-[#1a1a1a]"></div>

  <div class="relative z-10 min-h-screen flex items-center py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <!-- Left: Content -->
        <div class="lg:col-span-5 space-y-8">
          <div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 leading-tight">
              {title}
            </h1>
            <p class="text-xl text-gray-400">{subtitle}</p>
          </div>

          <!-- Stats -->
          <div class="flex gap-8 py-6 border-y border-white/10">
            <div>
              <div class="text-3xl font-bold text-white">500+</div>
              <div class="text-gray-500 text-sm">Projects</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white">10+</div>
              <div class="text-gray-500 text-sm">Years</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-white">50+</div>
              <div class="text-gray-500 text-sm">Awards</div>
            </div>
          </div>

          <!-- CTA -->
          <div class="flex flex-wrap gap-4">
            <a
              href={ctaUrl}
              class="group inline-flex items-center gap-3 px-8 py-4 bg-white text-[#1a1a1a] font-semibold rounded hover:bg-gray-100 transition-colors"
            >
              {ctaText}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href="#"
              class="inline-flex items-center gap-2 px-6 py-4 text-white/70 hover:text-white transition-colors"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M8 5v14l11-7z"/>
              </svg>
              Watch Showreel
            </a>
          </div>
        </div>

        <!-- Right: Masonry Image Grid -->
        <div class="lg:col-span-7">
          <div class="relative">
            <!-- Large main image -->
            <div class="absolute top-0 right-0 w-3/4 rounded-lg overflow-hidden shadow-2xl">
              <img src={image} alt={title} class="w-full h-80 object-cover" />
            </div>

            <!-- Smaller overlapping images -->
            <div class="absolute top-20 left-0 w-2/5 rounded-lg overflow-hidden shadow-2xl">
              <img src="https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=400" alt="Portrait" class="w-full h-48 object-cover" />
            </div>

            <div class="absolute bottom-0 left-10 w-1/3 rounded-lg overflow-hidden shadow-2xl">
              <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=300" alt="Wedding" class="w-full h-36 object-cover" />
            </div>

            <!-- Floating quote -->
            <div class="absolute bottom-8 right-8 bg-white/10 backdrop-blur border border-white/20 rounded-lg p-4 max-w-xs">
              <p class="text-white/80 text-sm italic mb-2">
                "Every love story deserves to be beautifully told."
              </p>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-[#E8D5C4] to-[#D4AF37]"></div>
                <span class="text-white text-sm font-medium">Sarah & John</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom strip with services -->
  <div class="absolute bottom-0 left-0 right-0 bg-white/5 border-t border-white/10">
    <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between text-white/60 text-sm overflow-x-auto">
      <span class="flex items-center gap-6">
        <span class="whitespace-nowrap">Wedding Photography</span>
        <span class="text-white/30">•</span>
        <span class="whitespace-nowrap">Portrait Sessions</span>
        <span class="text-white/30">•</span>
        <span class="whitespace-nowrap">Editorial</span>
        <span class="text-white/30">•</span>
        <span class="whitespace-nowrap">Commercial</span>
      </span>
      <a href="#" class="text-[#d4af37] hover:underline whitespace-nowrap">Book a Session →</a>
    </div>
  </div>
</section>