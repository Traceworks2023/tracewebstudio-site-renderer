---
// Photographer Hero - Artistic, gallery-style
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
    description?: string;
    services?: string[];
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Capturing Moments',
  subtitle = 'Wedding, Portrait & Editorial Photography',
  ctaText = 'View Portfolio',
  ctaUrl = '#',
  image = '',
  description = '',
  services = [],
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="photographer-hero relative min-h-screen overflow-hidden" style="background: var(--color-background, #1a1a1a);">
  <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-background, #1a1a1a), var(--color-surface, #2a2a2a), var(--color-background, #1a1a1a));"></div>

  <div class="relative z-10 min-h-screen flex items-center py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 w-full">
      <div class="grid lg:grid-cols-12 gap-8 items-center">
        <!-- Left: Content -->
        <div class="lg:col-span-5 space-y-8">
          <div>
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4 leading-tight" style="color: var(--color-text, #ffffff);">
              {title}
            </h1>
            <p class="text-xl" style="color: var(--color-text-muted, #999999);">{subtitle}</p>
          </div>

          {description && (
            <p class="text-lg leading-relaxed" style="color: var(--color-text-muted, #aaaaaa);">{description}</p>
          )}

          <!-- CTA -->
          <div class="flex flex-wrap gap-4">
            <a
              href={ctaUrl}
              class="group inline-flex items-center gap-3 px-8 py-4 font-semibold rounded transition-colors"
              style="background: var(--color-text, #ffffff); color: var(--color-background, #1a1a1a);"
            >
              {ctaText}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Right: Main Image -->
        <div class="lg:col-span-7">
          <div class="relative">
            <div class="rounded-lg overflow-hidden shadow-2xl">
              {image ? (
                <img src={image} alt={title} class="w-full h-96 object-cover" loading="eager" />
              ) : (
                <div class="w-full h-96 flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-surface, #2a2a2a), var(--color-background, #1a1a1a));">
                  <span class="text-6xl font-light" style="color: var(--color-text-muted, #666666);">{title.charAt(0)}</span>
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {services.length > 0 && (
    <!-- Bottom strip with services -->
    <div class="absolute bottom-0 left-0 right-0" style="background: rgba(255,255,255,0.05); border-top: 1px solid rgba(255,255,255,0.1);">
      <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between text-sm overflow-x-auto" style="color: var(--color-text-muted, rgba(255,255,255,0.6));">
        <span class="flex items-center gap-6">
          {services.map((svc, i) => (
            <>
              {i > 0 && <span style="opacity: 0.3;">•</span>}
              <span class="whitespace-nowrap">{svc}</span>
            </>
          ))}
        </span>
      </div>
    </div>
  )}
</section>