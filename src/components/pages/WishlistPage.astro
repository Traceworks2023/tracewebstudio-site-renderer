---
// Wishlist Page - Tailwind version
interface Props {
  template?: any;
  page?: any;
}

const { template, page } = Astro.props;

const wishlistItems = [
  { id: '1', name: 'Premium Silk Dress', price: 4999, image: 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?w=400', inStock: true },
  { id: '2', name: 'Designer Handbag', price: 12999, image: 'https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=400', inStock: true },
  { id: '3', name: 'Gold Necklace', price: 8999, image: 'https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?w=400', inStock: false }
];
---

<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-6xl mx-auto">
    <h1 class="text-2xl font-bold text-gray-900 mb-2">My Wishlist ({wishlistItems.length} items)</h1>
    <p class="text-gray-600 mb-8">Save your favorite items for later</p>

    {wishlistItems.length === 0 ? (
      <div class="text-center py-16 bg-white rounded-lg">
        <div class="text-6xl mb-4">♡</div>
        <h2 class="text-xl font-semibold mb-2">Your wishlist is empty</h2>
        <p class="text-gray-500 mb-6">Save items you love to your wishlist.</p>
        <a href="/" class="inline-block px-6 py-3 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition">
          Browse Products
        </a>
      </div>
    ) : (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {wishlistItems.map((item) => (
          <div class="bg-white rounded-lg overflow-hidden shadow-sm group">
            <button class="absolute top-3 right-3 z-10 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow hover:bg-red-50 hover:text-red-500 transition" aria-label="Remove from wishlist">
              ×
            </button>
            
            <div class="aspect-[3/4] overflow-hidden bg-gray-100">
              <img src={item.image} alt={item.name} class="w-full h-full object-cover group-hover:scale-105 transition duration-500" />
            </div>
            
            <div class="p-4">
              <h3 class="font-medium text-gray-900 mb-1">{item.name}</h3>
              <p class="font-semibold text-gray-900 mb-2">₹{item.price}</p>
              <p class={`text-sm mb-3 ${item.inStock ? 'text-green-600' : 'text-red-500'}`}>
                {item.inStock ? 'In Stock' : 'Out of Stock'}
              </p>
              <button 
                class="w-full py-2 font-semibold rounded-lg transition"
                class:list={item.inStock ? 'bg-gray-900 text-white hover:bg-gray-800' : 'bg-gray-200 text-gray-400 cursor-not-allowed'}
                disabled={!item.inStock}
              >
                {item.inStock ? 'Add to Cart' : 'Notify When Available'}
              </button>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</div>
