---
// Hotel Rooms Page
interface Room {
  id: string;
  name: string;
  description: string;
  price: number;
  image: string;
  images?: string[];
  size?: string;
  capacity?: number;
  bedType?: string;
  view?: string;
  amenities?: string[];
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    rooms?: Room[];
  };
}

const { content = {} } = Astro.props;
const {
  title = 'Our Rooms & Suites',
  subtitle = 'Experience luxury accommodations designed for your comfort',
  rooms = [
    {
      id: 'deluxe-king',
      name: 'Deluxe King Room',
      description: 'Spacious comfort with modern amenities and city views.',
      price: 299,
      image: 'https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=800',
      size: '35 m²',
      capacity: 2,
      bedType: 'King Bed',
      view: 'City View',
      amenities: ['Free WiFi', 'Mini Bar', 'Room Service', 'Smart TV', 'Coffee Maker']
    },
    {
      id: 'premium-suite',
      name: 'Premium Suite',
      description: 'Elegant suite with separate living area and premium amenities.',
      price: 499,
      image: 'https://images.unsplash.com/photo-1590490360182-c33d57733427?w=800',
      size: '55 m²',
      capacity: 3,
      bedType: 'King Bed + Sofa',
      view: 'Panoramic View',
      amenities: ['Free WiFi', 'Mini Bar', 'Room Service', 'Smart TV', 'Coffee Maker', 'Bathtub', 'Balcony']
    },
    {
      id: 'family-room',
      name: 'Family Room',
      description: 'Perfect for families with connecting rooms and kid-friendly amenities.',
      price: 399,
      image: 'https://images.unsplash.com/photo-1566665797739-1674de7a421a?w=800',
      size: '45 m²',
      capacity: 4,
      bedType: 'Two Queen Beds',
      view: 'Garden View',
      amenities: ['Free WiFi', 'Mini Bar', 'Room Service', 'Smart TV', 'Coffee Maker', 'Kids Amenities']
    },
    {
      id: 'presidential-suite',
      name: 'Presidential Suite',
      description: 'The ultimate in luxury with exclusive amenities and butler service.',
      price: 1299,
      image: 'https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?w=800',
      size: '120 m²',
      capacity: 4,
      bedType: 'King Bed',
      view: '360° Panoramic',
      amenities: ['Free WiFi', 'Private Bar', '24/7 Butler', 'Smart TV', 'Nespresso', 'Jacuzzi', 'Private Terrace', 'Dining Room']
    }
  ]
} = content;
---

<div class="rooms-page py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Accommodations
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="space-y-12">
      {rooms.map((room, index) => (
        <article class={`room-card grid lg:grid-cols-2 gap-8 items-center ${index % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
          <div class={`relative aspect-video lg:aspect-auto ${index % 2 === 1 ? 'lg:order-2' : ''}`}>
            <img
              src={room.image}
              alt={room.name}
              class="w-full h-full object-cover rounded-2xl"
              loading="lazy"
            />
          </div>
          <div class={`space-y-6 ${index % 2 === 1 ? 'lg:order-1' : ''}`}>
            <div>
              <h2 class="text-3xl font-bold text-gray-900 mb-2">{room.name}</h2>
              <p class="text-gray-600 text-lg">{room.description}</p>
            </div>

            <div class="grid grid-cols-3 gap-4">
              {room.size && (
                <div class="text-center p-4 bg-gray-50 rounded-xl">
                  <p class="text-2xl font-bold text-[var(--color-primary)]">{room.size}</p>
                  <p class="text-sm text-gray-500">Room Size</p>
                </div>
              )}
              {room.capacity && (
                <div class="text-center p-4 bg-gray-50 rounded-xl">
                  <p class="text-2xl font-bold text-[var(--color-primary)]">{room.capacity}</p>
                  <p class="text-sm text-gray-500">Guests</p>
                </div>
              )}
              {room.bedType && (
                <div class="text-center p-4 bg-gray-50 rounded-xl">
                  <p class="text-lg font-bold text-[var(--color-primary)]">{room.bedType}</p>
                  <p class="text-sm text-gray-500">Bed Type</p>
                </div>
              )}
            </div>

            <div>
              <h3 class="font-semibold text-gray-900 mb-3">Amenities</h3>
              <div class="flex flex-wrap gap-2">
                {room.amenities?.map((amenity) => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 text-sm rounded-full">
                    {amenity}
                  </span>
                ))}
              </div>
            </div>

            <div class="flex items-center justify-between pt-4 border-t border-gray-200">
              <div>
                <span class="text-3xl font-bold text-[var(--color-primary)]">${room.price}</span>
                <span class="text-gray-500">/night</span>
              </div>
              <a
                href={`/book?room=${room.id}`}
                class="px-8 py-3 bg-[var(--color-primary)] text-white font-semibold rounded-lg hover:bg-[var(--color-accent)] transition-colors"
              >
                Book Now
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>