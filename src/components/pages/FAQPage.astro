---
// FAQ Page - Tailwind version
interface Props {
  template?: any;
  page?: any;
}

const { template, page } = Astro.props;

const faqs = [
  {
    category: 'Orders & Shipping',
    questions: [
      { q: 'How do I track my order?', a: 'Once your order ships, you will receive an email with a tracking number. You can also track your order by logging into your account and visiting the "Orders" section.' },
      { q: 'What are the shipping options?', a: 'We offer standard shipping (5-7 business days), express shipping (2-3 business days), and same-day delivery in select cities.' },
      { q: 'Do you ship internationally?', a: 'Yes, we ship to over 100 countries worldwide. International shipping rates and delivery times vary by location.' }
    ]
  },
  {
    category: 'Returns & Refunds',
    questions: [
      { q: 'What is your return policy?', a: 'We accept returns within 30 days of delivery. Items must be unused, in original packaging, and with all tags attached.' },
      { q: 'How do I initiate a return?', a: 'Log into your account, go to "Orders," select the order you want to return, and click "Return Items." Follow the instructions to complete your return.' },
      { q: 'When will I receive my refund?', a: 'Refunds are processed within 5-7 business days after we receive your return. The amount will be credited to your original payment method.' }
    ]
  },
  {
    category: 'Products',
    questions: [
      { q: 'How do I find my size?', a: 'Each product page has a size guide specific to that item. You can also refer to our general size chart for measurements.' },
      { q: 'Are your products authentic?', a: 'Yes, all products sold on our platform are 100% authentic. We source directly from brands and authorized distributors.' },
      { q: 'How do I care for my items?', a: 'Care instructions are included on the product label and listed on the product page under "Product Care" section.' }
    ]
  },
  {
    category: 'Account',
    questions: [
      { q: 'How do I create an account?', a: 'Click the "Sign Up" button at the top right, enter your email and password, and verify your email to complete registration.' },
      { q: 'How do I reset my password?', a: 'Click "Forgot Password" on the login page, enter your email, and we will send you a password reset link.' },
      { q: 'Can I change my email address?', a: 'Yes, go to Account Settings > Profile and click "Edit" next to your email address.' }
    ]
  }
];

const popularQuestions = [
  'How do I track my order?',
  'What is your return policy?',
  'How do I find my size?',
  'Do you offer international shipping?'
];
---

<div class="min-h-screen bg-gray-50 py-8 px-4 sm:px-6 lg:px-8">
  <div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold text-gray-900 mb-4">Frequently Asked Questions</h1>
      <p class="text-gray-600 mb-8">Find answers to common questions about our products, orders, shipping, and more.</p>
      
      <!-- Search -->
      <div class="max-w-xl mx-auto relative">
        <input 
          type="text" 
          placeholder="Search for answers..."
          class="w-full px-4 py-3 pl-12 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gray-900 focus:border-transparent"
        />
        <svg class="w-5 h-5 text-gray-400 absolute left-4 top-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </div>
    </div>

    <!-- Popular Questions -->
    <div class="mb-12">
      <h2 class="text-sm font-semibold text-gray-900 uppercase tracking-wide mb-4">Popular Questions</h2>
      <div class="flex flex-wrap gap-2">
        {popularQuestions.map((q) => (
          <button class="px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-600 hover:border-gray-400 transition">
            {q}
          </button>
        ))}
      </div>
    </div>

    <!-- FAQ Categories -->
    <div class="space-y-8">
      {faqs.map((category) => (
        <div class="bg-white rounded-lg shadow-sm overflow-hidden">
          <div class="px-6 py-4 bg-gray-50 border-b border-gray-200">
            <h2 class="font-semibold text-gray-900">{category.category}</h2>
          </div>
          
          <div class="divide-y divide-gray-200">
            {category.questions.map((qa) => (
              <details class="group">
                <summary class="px-6 py-4 cursor-pointer flex items-center justify-between hover:bg-gray-50 transition list-none">
                  <span class="font-medium text-gray-900">{qa.q}</span>
                  <svg class="w-5 h-5 text-gray-400 group-open:rotate-180 transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-gray-600">
                  {qa.a}
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Contact CTA -->
    <div class="mt-12 text-center bg-gray-900 rounded-lg p-8">
      <h2 class="text-xl font-semibold text-white mb-2">Still have questions?</h2>
      <p class="text-gray-300 mb-6">Our support team is here to help you.</p>
      <div class="flex justify-center gap-4">
        <a href="/contact" class="px-6 py-3 bg-white text-gray-900 font-semibold rounded-lg hover:bg-gray-100 transition">
          Contact Us
        </a>
        <a href="/support" class="px-6 py-3 border border-white text-white font-semibold rounded-lg hover:bg-white/10 transition">
          Live Chat
        </a>
      </div>
    </div>
  </div>
</div>
