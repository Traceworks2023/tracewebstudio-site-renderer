---
// Services Page - Dynamic content based on template
import { generateUniqueContent } from '../../lib/content-generator';

interface Props {
  template?: any;
  page?: any;
  tenantId?: string;
}

const { template, page, tenantId = '00000000-0000-0000-0000-000000000000' } = Astro.props;

const templateCategory = template?.category || 'business';
const templateSlug = template?.slug || 'store';
const theme = template?.theme || {};
const colors = theme.colors || {};
const fonts = theme.fonts || { heading: 'Playfair Display', body: 'Inter' };

// Generate unique content based on template
const generatedContent = generateUniqueContent(templateSlug, templateCategory);
const { brand, services, navigation, ctas } = generatedContent;

// Use generated services, or map from content generator
const displayServices = services.slice(0, 6).map((svc, i) => ({
  id: svc.id,
  name: svc.name,
  description: svc.description,
  duration: ['30 min', '60 min', '90 min', '45 min', '2 hours', '1 hour'][i % 6],
  price: [999, 1499, 2499, 1999, 3499, 1299][i % 6],
  image: `https://picsum.photos/seed/${svc.id}/600/400`,
  featured: i === 0
}));

const benefits = [
  { icon: '✓', title: 'Expert Team', description: `${brand.name} professionals with years of experience` },
  { icon: '✓', title: 'Quality First', description: 'Premium materials and attention to detail' },
  { icon: '✓', title: 'Customer Focus', description: 'Your satisfaction is our top priority' },
  { icon: '✓', title: 'Flexible Options', description: 'Services tailored to your schedule' }
];

const icons = ['📋', '💎', '🎯', '⏰', '🌟', '✨'];
---

<div class="min-h-screen" style={`background-color: ${colors.background || '#ffffff'}; color: ${colors.text || '#1a1a1a'};`}>
  {/* Hero */}
  <section class="py-20 px-4" style={`background: linear-gradient(135deg, ${colors.primary || '#000032'}, ${colors.secondary || '#333333'});`}>
    <div class="max-w-4xl mx-auto text-center text-white">
      <h1 class="text-4xl md:text-5xl font-bold mb-4" style={`font-family: '${fonts.heading}', serif;`}>{brand.name}</h1>
      <p class="text-xl opacity-90 max-w-2xl mx-auto">
        {brand.tagline}
      </p>
    </div>
  </section>

  {/* Benefits */}
  <section class="py-16 px-4" style={`background-color: ${colors.surface || '#f9fafb'};`}>
    <div class="max-w-6xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {benefits.map((benefit, i) => (
          <div class="text-center">
            <div class="text-3xl mb-2">{icons[i % icons.length]}</div>
            <h3 class="font-semibold mb-1" style={`color: ${colors.text};`}>{benefit.title}</h3>
            <p class="text-sm" style={`color: ${colors.textMuted || '#6b7280'};`}>{benefit.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Services Grid */}
  <section class="py-16 px-4">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-4" style={`color: ${colors.text}; font-family: '${fonts.heading}', serif;`}>What We Offer</h2>
      <p class="text-center mb-12" style={`color: ${colors.textMuted || '#6b7280'};`}>Professional services tailored to your needs</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {displayServices.map((service, i) => (
          <div class={`rounded-2xl overflow-hidden shadow-lg transition-transform hover:scale-105 ${service.featured ? 'ring-2' : ''}`}
               style={`background: ${colors.surface || '#ffffff'}; ${service.featured ? `ring-color: ${colors.primary || '#000032'};` : ''}`}>
            <div class="relative">
              <img src={service.image} alt={service.name} class="w-full h-48 object-cover" />
              {service.featured && (
                <span class="absolute top-2 left-2 px-3 py-1 text-white text-xs font-bold rounded-full" style={`background: ${colors.accent || '#FA5014'};`}>POPULAR</span>
              )}
            </div>

            <div class="p-6">
              <div class="flex items-start justify-between mb-2">
                <h3 class="text-xl font-bold" style={`color: ${colors.text};`}>{service.name}</h3>
              </div>
              <p class="mb-4" style={`color: ${colors.textMuted || '#6b7280'};`}>{service.description}</p>
              <div class="flex items-center justify-between">
                <div class="text-sm" style={`color: ${colors.textMuted || '#6b7280'};`}>
                  <span class="font-semibold" style={`color: ${colors.primary || '#000032'};`}>₹{service.price.toLocaleString()}</span> • {service.duration}
                </div>
                <button class="px-4 py-2 text-white text-sm font-semibold rounded-lg transition hover:opacity-90" style={`background: ${colors.primary || '#000032'};`}>
                  Book Now
                </button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="py-16 px-4" style={`background: linear-gradient(135deg, ${colors.primary || '#000032'}, ${colors.accent || '#FA5014'});`}>
    <div class="max-w-2xl mx-auto text-center text-white">
      <h2 class="text-3xl font-bold mb-4" style={`font-family: '${fonts.heading}', serif;`}>Ready to Get Started?</h2>
      <p class="opacity-90 mb-8">Contact us today and experience the difference with {brand.name}.</p>
      <a href={`/${templateSlug}?page=contact`} class="inline-block px-8 py-3 text-white font-semibold rounded-lg transition hover:opacity-90" style={`background: ${colors.accent || '#FA5014'};`}>
        Schedule Appointment
      </a>
    </div>
  </section>
</div>