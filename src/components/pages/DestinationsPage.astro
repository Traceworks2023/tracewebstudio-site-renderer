---
// Destinations Page - Travel Agency
interface Destination {
  id: string;
  name: string;
  country: string;
  description: string;
  image: string;
  price: number;
  duration?: string;
  rating?: number;
  reviews?: number;
  highlights?: string[];
  bestTime?: string;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    destinations?: Destination[];
  };
}

const { content = {} } = Astro.props;
const {
  title = 'Explore Destinations',
  subtitle = 'Discover breathtaking locations and unforgettable experiences around the world',
  destinations = [
    {
      id: 'maldives',
      name: 'Maldives',
      country: 'Maldives',
      description: 'Crystal clear waters, overwater villas, and pristine beaches await in this tropical paradise.',
      image: 'https://images.unsplash.com/photo-1514282401047-d79a71a590e8?w=800',
      price: 2499,
      duration: '7 nights',
      rating: 4.9,
      reviews: 1247,
      highlights: ['Overwater Bungalow', 'Snorkeling', 'Spa', 'Private Dining'],
      bestTime: 'Nov - Apr'
    },
    {
      id: 'santorini',
      name: 'Santorini',
      country: 'Greece',
      description: 'Iconic white-washed buildings, stunning sunsets, and Mediterranean charm in the Greek islands.',
      image: 'https://images.unsplash.com/photo-1613395877344-13d4a8e0d49e?w=800',
      price: 1899,
      duration: '5 nights',
      rating: 4.8,
      reviews: 892,
      highlights: ['Caldera View', 'Wine Tasting', 'Sunset Cruise', 'Village Tour'],
      bestTime: 'May - Oct'
    },
    {
      id: 'bali',
      name: 'Bali',
      country: 'Indonesia',
      description: 'Ancient temples, lush rice terraces, and vibrant culture blend in this Indonesian gem.',
      image: 'https://images.unsplash.com/photo-1537996194471-e657df975ab4?w=800',
      price: 1599,
      duration: '6 nights',
      rating: 4.7,
      reviews: 1563,
      highlights: ['Temple Tours', 'Rice Terraces', 'Beach Clubs', 'Yoga Retreat'],
      bestTime: 'Apr - Oct'
    },
    {
      id: 'swiss-alps',
      name: 'Swiss Alps',
      country: 'Switzerland',
      description: 'Majestic mountain scenery, world-class skiing, and cozy alpine villages.',
      image: 'https://images.unsplash.com/photo-1531366936337-7c912a4589a7?w=800',
      price: 3299,
      duration: '7 nights',
      rating: 4.9,
      reviews: 654,
      highlights: ['Skiing', 'Mountain Views', 'Train Ride', 'Fondue Experience'],
      bestTime: 'Dec - Mar'
    },
    {
      id: 'dubai',
      name: 'Dubai',
      country: 'UAE',
      description: 'Futuristic skyscrapers, luxury shopping, and desert adventures in the Middle East.',
      image: 'https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=800',
      price: 2199,
      duration: '5 nights',
      rating: 4.6,
      reviews: 2103,
      highlights: ['Burj Khalifa', 'Desert Safari', 'Shopping', 'Fine Dining'],
      bestTime: 'Nov - Mar'
    },
    {
      id: 'machu-picchu',
      name: 'Machu Picchu',
      country: 'Peru',
      description: 'Ancient Incan citadel set high in the Andes Mountains, a wonder of the world.',
      image: 'https://images.unsplash.com/photo-1587595431973-160d0d94add1?w=800',
      price: 2799,
      duration: '8 nights',
      rating: 4.9,
      reviews: 876,
      highlights: ['Inca Trail', 'Sacred Valley', 'Cusco Tour', 'Local Cuisine'],
      bestTime: 'May - Sep'
    }
  ]
} = content;
---

<div class="destinations-page py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Travel Destinations
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {destinations.map((dest) => (
        <article class="destination-card group bg-white rounded-2xl overflow-hidden shadow-sm border border-gray-100 hover:shadow-xl transition-all duration-300">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img
              src={dest.image}
              alt={dest.name}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
            />
            <div class="absolute top-4 left-4">
              <span class="px-3 py-1 bg-white/90 backdrop-blur-sm rounded-full text-sm font-medium text-gray-700">
                {dest.country}
              </span>
            </div>
            {dest.bestTime && (
              <div class="absolute top-4 right-4">
                <span class="px-3 py-1 bg-[var(--color-accent)]/90 text-white rounded-full text-xs font-medium">
                  Best: {dest.bestTime}
                </span>
              </div>
            )}
            <div class="absolute bottom-0 inset-x-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent p-6">
              <h2 class="text-2xl font-bold text-white mb-1">{dest.name}</h2>
              {dest.duration && (
                <p class="text-white/80 text-sm">{dest.duration}</p>
              )}
            </div>
          </div>

          <div class="p-6">
            <p class="text-gray-600 text-sm mb-4 line-clamp-2">{dest.description}</p>

            {dest.highlights && dest.highlights.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {dest.highlights.slice(0, 3).map((highlight) => (
                  <span class="px-2 py-1 bg-gray-100 text-gray-600 text-xs rounded">
                    {highlight}
                  </span>
                ))}
                {dest.highlights.length > 3 && (
                  <span class="px-2 py-1 bg-gray-100 text-gray-500 text-xs rounded">
                    +{dest.highlights.length - 3} more
                  </span>
                )}
              </div>
            )}

            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <div>
                <div class="flex items-baseline gap-1">
                  <span class="text-2xl font-bold text-[var(--color-primary)]">${dest.price}</span>
                  <span class="text-sm text-gray-500">/person</span>
                </div>
              </div>
              {dest.rating && (
                <div class="flex items-center gap-1">
                  <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  <span class="font-semibold text-gray-900">{dest.rating}</span>
                  <span class="text-sm text-gray-500">({dest.reviews})</span>
                </div>
              )}
            </div>

            <a
              href={`/packages/${dest.id}`}
              class="mt-4 w-full py-3 bg-[var(--color-primary)] text-white text-center font-semibold rounded-lg hover:bg-[var(--color-accent)] transition-colors block"
            >
              View Package
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</div>