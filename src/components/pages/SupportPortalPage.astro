---
// Support Portal Page
interface TicketCategory {
  id: string;
  name: string;
  description: string;
  icon: string;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
  };
  tenantId?: string;
}

const { content = {}, tenantId = '00000000-0000-0000-0000-000000000000' } = Astro.props;
const {
  title = 'Support Portal',
  subtitle = 'We\'re here to help. Submit a ticket and our team will get back to you within 24 hours.',
} = content;

const categories = [
  { id: 'technical', name: 'Technical Issue', description: 'Report a bug or technical problem', icon: '🔧' },
  { id: 'billing', name: 'Billing & Payments', description: 'Questions about invoices or payments', icon: '💳' },
  { id: 'product', name: 'Product Inquiry', description: 'Questions about our products or services', icon: '📦' },
  { id: 'account', name: 'Account Assistance', description: 'Help with your account settings', icon: '👤' },
  { id: 'feedback', name: 'Feedback & Suggestions', description: 'Share your ideas to improve our service', icon: '💡' },
  { id: 'other', name: 'Other', description: 'Anything else we can help with', icon: '❓' }
];

const priorityLevels = [
  { id: 'low', name: 'Low', description: 'General questions, no urgency', color: 'green' },
  { id: 'medium', name: 'Medium', description: 'Some impact on my work', color: 'yellow' },
  { id: 'high', name: 'High', description: 'Significant impact, needs quick response', color: 'orange' },
  { id: 'urgent', name: 'Urgent', description: 'System down or critical issue', color: 'red' }
];
---

<div class="support-portal-page py-20 bg-gray-50">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Support
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <form id="ticket-form" class="bg-white rounded-2xl shadow-sm p-8" data-tenant-id={tenantId}>
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-3">What do you need help with?</label>
              <div class="grid grid-cols-2 gap-3">
                {categories.map((cat) => (
                  <label class="category-option flex items-start gap-3 p-4 border border-gray-200 rounded-xl cursor-pointer hover:border-[var(--color-accent)] transition-colors has-[:checked]:border-[var(--color-accent)] has-[:checked]:bg-[var(--color-accent)]/5">
                    <input type="radio" name="category" value={cat.id} class="mt-1" />
                    <div>
                      <span class="text-lg">{cat.icon}</span>
                      <p class="font-medium text-gray-900">{cat.name}</p>
                    </div>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Subject</label>
              <input
                type="text"
                name="subject"
                placeholder="Brief description of your issue"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent"
                required
              />
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-3">Priority Level</label>
              <div class="flex flex-wrap gap-3">
                {priorityLevels.map((priority) => (
                  <label class="flex items-center gap-2 px-4 py-2 border border-gray-200 rounded-full cursor-pointer hover:border-[var(--color-accent)] transition-colors has-[:checked]:border-[var(--color-accent)] has-[:checked]:bg-[var(--color-accent)]/5">
                    <input type="radio" name="priority" value={priority.id} class="sr-only" />
                    <span class={`w-3 h-3 rounded-full ${
                      priority.color === 'green' ? 'bg-green-500' :
                      priority.color === 'yellow' ? 'bg-yellow-500' :
                      priority.color === 'orange' ? 'bg-orange-500' :
                      'bg-red-500'
                    }`}></span>
                    <span class="font-medium text-gray-700">{priority.name}</span>
                  </label>
                ))}
              </div>
            </div>

            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Description</label>
              <textarea
                name="description"
                rows={5}
                placeholder="Please provide as much detail as possible about your issue or question..."
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent resize-none"
                required
              ></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Your Name</label>
                <input
                  type="text"
                  name="customer_name"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
                  required
                />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
                <input
                  type="email"
                  name="customer_email"
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]"
                  required
                />
              </div>
            </div>

            <button
              type="submit"
              class="w-full py-4 bg-[var(--color-primary)] text-white font-semibold rounded-lg hover:bg-[var(--color-accent)] transition-colors"
            >
              Submit Ticket
            </button>
          </div>
        </form>

        <div id="ticket-success" class="hidden bg-white rounded-2xl shadow-sm p-8 text-center">
          <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Ticket Submitted!</h2>
          <p class="text-gray-600 mb-6">We'll get back to you within 24 hours.</p>
          <a href="/" class="px-6 py-3 bg-gray-900 text-white font-semibold rounded-lg hover:bg-gray-800 transition">
            Back to Home
          </a>
        </div>
      </div>

      <div class="space-y-6">
        <div class="bg-white rounded-2xl shadow-sm p-6">
          <h3 class="font-bold text-gray-900 mb-4">Quick Answers</h3>
          <ul class="space-y-3">
            <li>
              <a href="/help/how-to-track-order" class="flex items-center gap-2 text-[var(--color-accent)] hover:underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                How to track my order
              </a>
            </li>
            <li>
              <a href="/help/return-policy" class="flex items-center gap-2 text-[var(--color-accent)] hover:underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Return policy info
              </a>
            </li>
            <li>
              <a href="/help/payment-methods" class="flex items-center gap-2 text-[var(--color-accent)] hover:underline">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
                Accepted payment methods
              </a>
            </li>
          </ul>
          <a href="/help" class="block mt-4 text-center text-sm text-gray-600 hover:text-[var(--color-accent)]">
            Browse all articles →
          </a>
        </div>

        <div class="bg-[var(--color-primary)] rounded-2xl p-6 text-white">
          <h3 class="font-bold mb-4">Need Immediate Help?</h3>
          <p class="text-white/80 text-sm mb-4">Our support team is available 24/7</p>
          <div class="space-y-3">
            <a href="tel:1-800-SUPPORT" class="flex items-center gap-3 text-white hover:text-[var(--color-accent)]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              1-800-SUPPORT
            </a>
            <a href="mailto:support@example.com" class="flex items-center gap-3 text-white hover:text-[var(--color-accent)]">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              support@example.com
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('ticket-form') as HTMLFormElement;
    const successDiv = document.getElementById('ticket-success');
    const tenantId = form?.dataset.tenantId || '00000000-0000-0000-0000-000000000000';

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);

      const data = {
        subject: formData.get('subject'),
        description: formData.get('description'),
        category: formData.get('category'),
        priority: formData.get('priority') || 'medium',
        customer_name: formData.get('customer_name'),
        customer_email: formData.get('customer_email'),
        tenant_id: tenantId,
      };

      try {
        const res = await fetch('http://localhost:8084/api/v1 addon/tickets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.classList.add('hidden');
          successDiv?.classList.remove('hidden');
        } else {
          alert('Failed to submit ticket. Please try again.');
        }
      } catch (err) {
        alert('Failed to submit ticket. Please try again.');
      }
    });
  });
</script>