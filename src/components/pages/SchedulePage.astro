---
interface Class {
  id: string;
  name: string;
  time: string;
  duration: string;
  trainer: string;
  trainerImage?: string;
  location?: string;
  intensity?: 'low' | 'medium' | 'high';
  spotsLeft?: number;
  maxSpots?: number;
  booked?: boolean;
}

interface DaySchedule {
  date: string;
  dayName: string;
  classes: Class[];
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    schedule?: DaySchedule[];
    weekStart?: string;
    weekEnd?: string;
    showFilters?: boolean;
    showAvailability?: boolean;
    ctaText?: string;
  };
  settings?: {
    motionLevel?: 1 | 2 | 3 | 4;
    view?: 'week' | 'day' | 'list';
  };
}

const { content = {}, settings = {} } = Astro.props;

const today = new Date();
const weekDates = Array.from({ length: 7 }, (_, i) => {
  const date = new Date(today);
  date.setDate(today.getDate() + i - today.getDay());
  return date;
});

const {
  title = 'Class Schedule',
  subtitle = 'Find the perfect class to fit your routine',
  schedule = weekDates.map((date, dayIndex) => ({
    date: date.toISOString().split('T')[0],
    dayName: date.toLocaleDateString('en-US', { weekday: 'long' }),
    classes: dayIndex === 0 ? [
      { id: 'c1', name: 'Morning Yoga', time: '06:00', duration: '60 min', trainer: 'Emily Chen', intensity: 'low', spotsLeft: 8, maxSpots: 15 },
      { id: 'c2', name: 'HIIT Blast', time: '07:30', duration: '45 min', trainer: 'Sarah Mitchell', intensity: 'high', spotsLeft: 3, maxSpots: 12 },
      { id: 'c3', name: 'Spin & Cycle', time: '12:00', duration: '45 min', trainer: 'Marcus Johnson', intensity: 'medium', spotsLeft: 10, maxSpots: 20 },
      { id: 'c4', name: 'Strength Training', time: '18:00', duration: '60 min', trainer: 'David Rodriguez', intensity: 'high', spotsLeft: 5, maxSpots: 10 },
      { id: 'c5', name: 'Evening Pilates', time: '19:30', duration: '45 min', trainer: 'Jessica Park', intensity: 'low', spotsLeft: 12, maxSpots: 15 },
    ] : dayIndex === 1 ? [
      { id: 'c6', name: 'CrossFit WOD', time: '06:00', duration: '60 min', trainer: 'Marcus Johnson', intensity: 'high', spotsLeft: 0, maxSpots: 10 },
      { id: 'c7', name: 'Cardio Kickboxing', time: '09:00', duration: '45 min', trainer: 'Michael Thompson', intensity: 'high', spotsLeft: 6, maxSpots: 15 },
      { id: 'c8', name: 'Yoga Flow', time: '12:30', duration: '60 min', trainer: 'Emily Chen', intensity: 'medium', spotsLeft: 14, maxSpots: 20 },
      { id: 'c9', name: 'Boxing Basics', time: '18:00', duration: '60 min', trainer: 'Michael Thompson', intensity: 'medium', spotsLeft: 4, maxSpots: 12 },
    ] : [
      { id: 'c10', name: 'Morning Stretch', time: '07:00', duration: '30 min', trainer: 'Jessica Park', intensity: 'low', spotsLeft: 15, maxSpots: 20 },
      { id: 'c11', name: 'Power Lifting', time: '10:00', duration: '75 min', trainer: 'David Rodriguez', intensity: 'high', spotsLeft: 2, maxSpots: 8 },
      { id: 'c12', name: 'Zumba Dance', time: '17:30', duration: '45 min', trainer: 'Sarah Mitchell', intensity: 'medium', spotsLeft: 9, maxSpots: 25 },
      { id: 'c13', name: 'Meditation', time: '20:00', duration: '30 min', trainer: 'Emily Chen', intensity: 'low', spotsLeft: 20, maxSpots: 30 },
    ]
  })),
  showFilters = true,
  showAvailability = true,
  ctaText = 'Book Class',
} = content;

const {
  motionLevel = 2,
  view = 'week',
} = settings;

const intensityColors = {
  low: 'bg-green-100 text-green-700',
  medium: 'bg-yellow-100 text-yellow-700',
  high: 'bg-red-100 text-red-700',
};
---

<div class="schedule-page py-20 bg-gray-50" data-view={view} data-motion-level={motionLevel}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-12">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Weekly Schedule
      </span>
      {title && <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>}
      {subtitle && <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>}
    </div>

    {/* Filters */}
    {showFilters && (
      <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div class="flex flex-wrap gap-3">
          <button class="filter-btn px-4 py-2 bg-[var(--color-primary)] text-white rounded-full text-sm font-medium" data-filter="all">
            All Classes
          </button>
          <button class="filter-btn px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-[var(--color-primary)]" data-filter="yoga">
            Yoga
          </button>
          <button class="filter-btn px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-[var(--color-primary)]" data-filter="hiit">
            HIIT
          </button>
          <button class="filter-btn px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-[var(--color-primary)]" data-filter="strength">
            Strength
          </button>
          <button class="filter-btn px-4 py-2 bg-white border border-gray-300 text-gray-700 rounded-full text-sm font-medium hover:border-[var(--color-primary)]" data-filter="cardio">
            Cardio
          </button>
        </div>

        <div class="flex items-center gap-3">
          <select class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]">
            <option>This Week</option>
            <option>Next Week</option>
            <option>This Month</option>
          </select>
        </div>
      </div>
    )}

    {/* Week View - Day Cards */}
    <div class="grid grid-cols-1 md:grid-cols-7 gap-4 mb-8">
      {schedule.map((day) => {
        const isToday = day.date === today.toISOString().split('T')[0];
        return (
          <div
            class={`day-card bg-white rounded-xl overflow-hidden shadow-sm ${
              isToday ? 'ring-2 ring-[var(--color-accent)]' : ''
            }`}
            data-day={day.date}
          >
            {/* Day Header */}
            <div class={`p-4 text-center ${isToday ? 'bg-[var(--color-accent)] text-white' : 'bg-gray-100'}`}>
              <p class="text-sm font-medium">{day.dayName}</p>
              <p class="text-2xl font-bold">{new Date(day.date).getDate()}</p>
            </div>

            {/* Classes */}
            <div class="p-2 space-y-2 max-h-[400px] overflow-y-auto">
              {day.classes.map((cls) => (
                <div
                  class="class-item p-2 rounded-lg bg-gray-50 hover:bg-gray-100 transition-colors cursor-pointer"
                  data-class-id={cls.id}
                >
                  <p class="text-xs font-semibold text-[var(--color-accent)]">{cls.time}</p>
                  <p class="text-sm font-medium text-gray-900 truncate">{cls.name}</p>
                  <p class="text-xs text-gray-500">{cls.trainer}</p>
                  {showAvailability && cls.spotsLeft !== undefined && (
                    <p class={`text-xs mt-1 ${cls.spotsLeft === 0 ? 'text-red-500 font-semibold' : 'text-gray-500'}`}>
                      {cls.spotsLeft === 0 ? 'Full' : `${cls.spotsLeft} spots left`}
                    </p>
                  )}
                </div>
              ))}
            </div>
          </div>
        );
      })}
    </div>

    {/* Class List Detail View */}
    <div class="bg-white rounded-2xl shadow-sm overflow-hidden">
      <div class="p-6 border-b border-gray-200">
        <h2 class="text-xl font-bold text-gray-900">All Classes This Week</h2>
      </div>

      <div class="divide-y divide-gray-100">
        {schedule.map((day) => (
          <div class="day-section">
            <div class="px-6 py-3 bg-gray-50">
              <h3 class="font-semibold text-gray-900">{day.dayName}, {new Date(day.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</h3>
            </div>

            {day.classes.map((cls) => (
              <div
                class="class-row flex items-center justify-between px-6 py-4 hover:bg-gray-50 transition-colors cursor-pointer"
                data-class-id={cls.id}
              >
                <div class="flex items-center gap-4">
                  <div class="text-center min-w-[60px]">
                    <p class="text-lg font-bold text-gray-900">{cls.time}</p>
                    <p class="text-xs text-gray-500">{cls.duration}</p>
                  </div>

                  <div>
                    <div class="flex items-center gap-2">
                      <h4 class="font-semibold text-gray-900">{cls.name}</h4>
                      <span class={`px-2 py-0.5 rounded-full text-xs font-medium ${intensityColors[cls.intensity as keyof typeof intensityColors]}`}>
                        {cls.intensity}
                      </span>
                    </div>
                    <p class="text-sm text-gray-600">{cls.trainer}</p>
                  </div>
                </div>

                <div class="flex items-center gap-4">
                  {showAvailability && cls.spotsLeft !== undefined && (
                    <div class="text-right">
                      {cls.spotsLeft === 0 ? (
                        <span class="text-sm font-semibold text-red-500">Class Full</span>
                      ) : (
                        <p class="text-sm text-gray-500">{cls.spotsLeft} / {cls.maxSpots} available</p>
                      )}
                    </div>
                  )}

                  <button
                    class={`px-4 py-2 rounded-lg font-medium text-sm transition-colors ${
                      cls.spotsLeft === 0
                        ? 'bg-gray-100 text-gray-400 cursor-not-allowed'
                        : 'bg-[var(--color-primary)] text-white hover:bg-[var(--color-accent)]'
                    }`}
                    disabled={cls.spotsLeft === 0}
                  >
                    {cls.booked ? 'Booked' : ctaText}
                  </button>
                </div>
              </div>
            ))}
          </div>
        ))}
      </div>
    </div>

    {/* CTA */}
    <div class="text-center mt-12 p-8 bg-[var(--color-primary)] rounded-2xl">
      <h3 class="text-2xl font-bold text-white mb-4">Can't find the right class?</h3>
      <p class="text-white/80 mb-6 max-w-lg mx-auto">Book a private session with one of our expert trainers for personalized attention.</p>
      <a
        href="/book"
        class="inline-flex items-center gap-2 px-8 py-3 bg-white text-[var(--color-primary)] font-semibold rounded-full hover:bg-gray-100 transition-colors"
      >
        Book Private Session
      </a>
    </div>
  </div>
</div>

<style>
  .day-card,
  .class-item {
    opacity: 0;
    transform: translateY(20px);
    animation: schedule-reveal 0.5s ease-out forwards;
  }

  @keyframes schedule-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .filter-btn.active {
    @apply bg-[var(--color-primary)] text-white border-[var(--color-primary)];
  }
</style>