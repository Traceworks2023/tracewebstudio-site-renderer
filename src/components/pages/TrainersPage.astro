---
interface Trainer {
  id: string;
  name: string;
  role: string;
  bio: string;
  image: string;
  specialties?: string[];
  certifications?: string[];
  experience?: string;
  rating?: number;
  reviews?: number;
  socialLinks?: {
    instagram?: string;
    twitter?: string;
    linkedin?: string;
  };
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    trainers?: Trainer[];
    layout?: 'grid' | 'list' | 'carousel';
    columns?: 2 | 3 | 4;
    showBio?: boolean;
    showSpecialties?: boolean;
    showCertifications?: boolean;
    showStats?: boolean;
  };
  settings?: {
    motionLevel?: 1 | 2 | 3 | 4;
    style?: 'minimal' | 'bold' | 'elegant';
  };
}

const { content = {}, settings = {} } = Astro.props;

const {
  title = 'Our Expert Trainers',
  subtitle = 'Meet the certified professionals who will guide your fitness journey',
  trainers = [
    {
      id: 'trainer-1',
      name: 'Sarah Mitchell',
      role: 'Head Fitness Coach',
      bio: 'With over 15 years of experience in personal training and group fitness instruction, Sarah specializes in strength training and weight loss programs.',
      image: 'https://images.unsplash.com/photo-1594381898411-846e7d193883?w=400',
      specialties: ['Strength Training', 'Weight Loss', 'HIIT', 'Nutrition'],
      certifications: ['NASM-CPT', 'CrossFit L3', 'Precision Nutrition'],
      experience: '15 years',
      rating: 4.9,
      reviews: 248
    },
    {
      id: 'trainer-2',
      name: 'Marcus Johnson',
      role: 'CrossFit Specialist',
      bio: 'Former competitive CrossFit athlete turned coach, Marcus brings intensity and expertise to every session.',
      image: 'https://images.unsplash.com/photo-1567013127542-490d757e51fc?w=400',
      specialties: ['CrossFit', 'Olympic Lifting', 'Functional Fitness', 'Mobility'],
      certifications: ['CrossFit L2', 'USAW', 'FMS'],
      experience: '10 years',
      rating: 4.8,
      reviews: 192
    },
    {
      id: 'trainer-3',
      name: 'Emily Chen',
      role: 'Yoga & Mindfulness',
      bio: 'Emily combines traditional yoga practices with modern science to create balanced wellness programs.',
      image: 'https://images.unsplash.com/photo-1603336208422-53f0b83c3fb3?w=400',
      specialties: ['Vinyasa', 'Hatha Yoga', 'Meditation', 'Breathwork'],
      certifications: ['RYT-500', 'E-RYT 200', 'Yoga Alliance'],
      experience: '12 years',
      rating: 5.0,
      reviews: 176
    },
    {
      id: 'trainer-4',
      name: 'David Rodriguez',
      role: 'Sports Performance Coach',
      bio: 'Former college athlete dedicated to helping clients achieve peak athletic performance.',
      image: 'https://images.unsplash.com/photo-1583468982228-19f19164aee2?w=400',
      specialties: ['Athletic Training', 'Speed & Agility', 'Sports Specific', 'Recovery'],
      certifications: ['CSCS', 'USA Track & Field', 'Titleist Performance'],
      experience: '8 years',
      rating: 4.7,
      reviews: 143
    },
    {
      id: 'trainer-5',
      name: 'Jessica Park',
      role: 'Pilates Instructor',
      bio: 'Certified Pilates instructor focusing on core strength, posture correction, and injury prevention.',
      image: 'https://images.unsplash.com/photo-1548690312-e3b507d8c110?w=400',
      specialties: ['Pilates', 'Posture Correction', 'Core Strength', 'Prenatal'],
      certifications: ['PMA-CPT', 'Balanced Body', 'STOTT Pilates'],
      experience: '9 years',
      rating: 4.9,
      reviews: 201
    },
    {
      id: 'trainer-6',
      name: 'Michael Thompson',
      role: 'Boxing & MMA Coach',
      bio: 'Professional boxer turned trainer, Michael brings fight-ready conditioning to your fitness routine.',
      image: 'https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=400',
      specialties: ['Boxing', 'MMA', 'Cardio Kickboxing', 'Self Defense'],
      certifications: ['USA Boxing', 'NASM-CPT', 'AFAA'],
      experience: '11 years',
      rating: 4.8,
      reviews: 167
    }
  ],
  layout = 'grid',
  columns = 3,
  showBio = true,
  showSpecialties = true,
  showCertifications = false,
  showStats = true,
} = content;

const {
  motionLevel = 2,
  style = 'modern',
} = settings;

const gridColsClass = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4',
}[columns] || 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3';
---

<div class="trainers-page py-20 bg-gray-50" data-layout={layout} data-motion-level={motionLevel}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Our Team
      </span>
      {title && <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>}
      {subtitle && <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>}
    </div>

    {/* Trainers Grid */}
    <div class={`trainers-grid ${gridColsClass} gap-8`}>
      {trainers.map((trainer, index) => (
        <div
          class="trainer-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300"
          data-trainer-id={trainer.id}
        >
          {/* Image */}
          <div class="relative aspect-[4/5] overflow-hidden">
            <img
              src={trainer.image || `https://i.pravatar.cc/400?u=${trainer.id}`}
              alt={trainer.name}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />

            {/* Overlay with Social Links */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity">
              <div class="absolute bottom-0 left-0 right-0 p-6">
                <div class="flex gap-3 justify-center">
                  {trainer.socialLinks?.instagram && (
                    <a href={trainer.socialLinks.instagram} class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white hover:text-pink-500 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                      </svg>
                    </a>
                  )}
                  {trainer.socialLinks?.linkedin && (
                    <a href={trainer.socialLinks.linkedin} class="w-10 h-10 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center text-white hover:bg-white hover:text-blue-600 transition-colors">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* Content */}
          <div class="p-6 text-center">
            {/* Rating */}
            {showStats && trainer.rating && (
              <div class="flex items-center justify-center gap-2 mb-3">
                <div class="flex">
                  {[1, 2, 3, 4, 5].map((i) => (
                    <svg class={`w-4 h-4 ${i <= Math.floor(trainer.rating!) ? 'text-yellow-400' : 'text-gray-300'} fill-current`} viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                  ))}
                </div>
                <span class="text-sm text-gray-500">({trainer.reviews})</span>
              </div>
            )}

            {/* Name & Role */}
            <h3 class="text-xl font-bold text-gray-900 mb-1">{trainer.name}</h3>
            <p class="text-sm text-[var(--color-accent)] font-medium mb-3">{trainer.role}</p>

            {/* Bio */}
            {showBio && trainer.bio && (
              <p class="text-gray-600 text-sm mb-4 line-clamp-3">{trainer.bio}</p>
            )}

            {/* Specialties */}
            {showSpecialties && trainer.specialties && trainer.specialties.length > 0 && (
              <div class="flex flex-wrap gap-2 justify-center">
                {trainer.specialties.slice(0, 3).map((specialty) => (
                  <span class="px-3 py-1 bg-gray-100 text-gray-600 text-xs font-medium rounded-full">
                    {specialty}
                  </span>
                ))}
              </div>
            )}

            {/* Book Button */}
            <a
              href={`/book?trainer=${trainer.id}`}
              class="inline-flex items-center gap-2 mt-6 px-6 py-2.5 bg-[var(--color-primary)] text-white text-sm font-semibold rounded-full hover:bg-[var(--color-accent)] transition-colors"
            >
              Book Session
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .trainer-card {
    opacity: 0;
    transform: translateY(30px);
    animation: trainer-reveal 0.6s ease-out forwards;
  }

  @keyframes trainer-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .trainer-card:nth-child(1) { animation-delay: 0ms; }
  .trainer-card:nth-child(2) { animation-delay: 100ms; }
  .trainer-card:nth-child(3) { animation-delay: 200ms; }
  .trainer-card:nth-child(4) { animation-delay: 300ms; }
  .trainer-card:nth-child(5) { animation-delay: 400ms; }
  .trainer-card:nth-child(6) { animation-delay: 500ms; }

  /* Hover Effects */
  [data-motion-level="4"] .trainer-card:hover {
    transform: translateY(-8px);
  }
</style>