---
interface Offer {
  id: string;
  title: string;
  description: string;
  code?: string;
  discount?: string;
  badge?: string;
  image?: string;
  validUntil?: string;
  ctaText?: string;
  link?: string;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    offers?: Offer[];
    layout?: 'grid' | 'featured' | 'list';
    showCountdown?: boolean;
    ctaText?: string;
  };
  settings?: {
    motionLevel?: 1 | 2 | 3 | 4;
    style?: 'bold' | 'minimal' | 'elegant';
  };
}

const { content = {}, settings = {} } = Astro.props;

const {
  title = 'Special Offers',
  subtitle = 'Discover exclusive deals and limited-time promotions',
  offers = [
    {
      id: 'offer-1',
      title: 'Summer Savings Event',
      description: 'Get up to 50% off on selected items across all categories. Perfect time to refresh your wardrobe!',
      code: 'SUMMER50',
      discount: '50% OFF',
      badge: 'Best Seller',
      image: 'https://images.unsplash.com/photo-1607083206869-4c7672e72a8a?w=600',
      validUntil: '2026-08-31',
      ctaText: 'Shop Now'
    },
    {
      id: 'offer-2',
      title: 'First Order Discount',
      description: 'New to our store? Enjoy 20% off your first purchase with this exclusive code.',
      code: 'WELCOME20',
      discount: '20% OFF',
      badge: 'New',
      image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600',
      validUntil: '2026-12-31',
      ctaText: 'Claim Offer'
    },
    {
      id: 'offer-3',
      title: 'Flash Sale - Today Only',
      description: '24 hours only! Extra 30% off already reduced items. No code needed.',
      discount: '30% OFF',
      badge: 'Limited Time',
      image: 'https://images.unsplash.com/photo-1607082349566-187342175e2f?w=600',
      ctaText: 'Grab Deal'
    },
    {
      id: 'offer-4',
      title: 'Bundle & Save',
      description: 'Buy 3 items and get the 4th free. Mix and match any styles you love.',
      code: 'BUNDLE4FREE',
      discount: 'FREE ITEM',
      image: 'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600',
      validUntil: '2026-06-30',
      ctaText: 'Build Bundle'
    },
    {
      id: 'offer-5',
      title: 'Membership Rewards',
      description: 'Members get early access to sales and exclusive discounts. Join free today!',
      discount: 'MEMBER ONLY',
      badge: 'Exclusive',
      image: 'https://images.unsplash.com/photo-1483275394625-0f9235d1e8f4?w=600',
      ctaText: 'Join Now'
    },
    {
      id: 'offer-6',
      title: 'Holiday Gift Guide',
      description: 'Find the perfect gift for everyone on your list. Free shipping on orders over $75.',
      code: 'FREESHIP75',
      discount: 'FREE SHIP',
      image: 'https://images.unsplash.com/photo-1512909006721-3d6018887383?w=600',
      validUntil: '2026-12-25',
      ctaText: 'Browse Gifts'
    }
  ],
  layout = 'grid',
  showCountdown = true,
  ctaText = 'View Offer',
} = content;

const {
  motionLevel = 2,
  style = 'modern',
} = settings;
---

<div class="offers-page py-20 bg-gray-50" data-layout={layout} data-motion-level={motionLevel}>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Special Offers
      </span>
      {title && <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>}
      {subtitle && <p class="text-xl text-gray-600 max-w-2xl mx-auto">{subtitle}</p>}
    </div>

    {/* Offers Grid */}
    <div class={`offers-grid grid gap-8 ${layout === 'featured' ? 'md:grid-cols-2' : 'md:grid-cols-2 lg:grid-cols-3'}`}>
      {offers.map((offer, index) => (
        <div
          class={`offer-card group bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 ${
            layout === 'featured' && index === 0 ? 'md:col-span-2 md:row-span-2' : ''
          }`}
          data-offer-id={offer.id}
        >
          {/* Image */}
          <div class={`relative overflow-hidden ${layout === 'featured' && index === 0 ? 'aspect-[16/9]' : 'aspect-[4/3]'}`}>
            <img
              src={offer.image || `https://picsum.photos/seed/${offer.id}/600/400`}
              alt={offer.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
            />

            {/* Discount Badge */}
            {offer.discount && (
              <div class="absolute top-4 right-4">
                <span class="inline-block px-4 py-2 bg-red-500 text-white text-xl font-bold rounded-lg shadow-lg">
                  {offer.discount}
                </span>
              </div>
            )}

            {/* Status Badge */}
            {offer.badge && (
              <div class="absolute top-4 left-4">
                <span class={`inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider rounded-full ${
                  offer.badge === 'Best Seller' ? 'bg-yellow-400 text-gray-900' :
                  offer.badge === 'New' ? 'bg-green-500 text-white' :
                  offer.badge === 'Limited Time' ? 'bg-red-500 text-white' :
                  'bg-gray-900 text-white'
                }`}>
                  {offer.badge}
                </span>
              </div>
            )}

            {/* Overlay */}
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          {/* Content */}
          <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-2 group-hover:text-[var(--color-accent)] transition-colors">
              {offer.title}
            </h3>
            <p class="text-gray-600 mb-4">{offer.description}</p>

            {/* Code */}
            {offer.code && (
              <div class="flex items-center gap-2 mb-4">
                <code class="px-4 py-2 bg-gray-100 text-gray-900 font-mono font-bold rounded-lg">
                  {offer.code}
                </code>
                <button class="copy-btn text-sm text-[var(--color-accent)] font-medium hover:underline" data-code={offer.code}>
                  Copy
                </button>
              </div>
            )}

            {/* Valid Until */}
            {showCountdown && offer.validUntil && (
              <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Valid until {new Date(offer.validUntil).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
              </div>
            )}

            {/* CTA */}
            <a
              href={offer.link || `/offers/${offer.id}`}
              class="inline-flex items-center gap-2 px-6 py-3 bg-[var(--color-primary)] text-white font-semibold rounded-lg hover:bg-[var(--color-accent)] transition-colors"
            >
              {offer.ctaText || ctaText}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>

    {/* Newsletter CTA */}
    <div class="mt-16 p-8 bg-[var(--color-primary)] rounded-2xl text-center">
      <h3 class="text-2xl font-bold text-white mb-4">Don't Miss Out</h3>
      <p class="text-white/80 mb-6 max-w-lg mx-auto">Subscribe to get exclusive offers, early access to sales, and more delivered straight to your inbox.</p>
      <form class="flex flex-col sm:flex-row gap-4 max-w-md mx-auto">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 px-4 py-3 rounded-lg focus:outline-none focus:ring-2 focus:ring-white"
        />
        <button
          type="submit"
          class="px-6 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-lg hover:bg-white hover:text-[var(--color-accent)] transition-colors"
        >
          Subscribe
        </button>
      </form>
    </div>
  </div>
</div>

<style>
  .offer-card {
    opacity: 0;
    transform: translateY(30px);
    animation: offer-reveal 0.6s ease-out forwards;
  }

  @keyframes offer-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .offer-card:nth-child(1) { animation-delay: 0ms; }
  .offer-card:nth-child(2) { animation-delay: 100ms; }
  .offer-card:nth-child(3) { animation-delay: 200ms; }
  .offer-card:nth-child(4) { animation-delay: 300ms; }
  .offer-card:nth-child(5) { animation-delay: 400ms; }
  .offer-card:nth-child(6) { animation-delay: 500ms; }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = (btn as HTMLElement).dataset.code;
      if (code) {
        navigator.clipboard.writeText(code);
        btn.textContent = 'Copied!';
        setTimeout(() => {
          btn.textContent = 'Copy';
        }, 2000);
      }
    });
  });
</script>