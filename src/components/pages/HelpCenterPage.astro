---
// Help Center / Knowledge Base
interface Category {
  id: string;
  name: string;
  description: string;
  slug: string;
  articles_count?: number;
}

interface Article {
  id: string;
  title: string;
  slug: string;
  excerpt?: string;
  content?: string;
  status: string;
  updated_at: string;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
  };
  tenantId?: string;
}

const { content = {}, tenantId = '00000000-0000-0000-0000-000000000000' } = Astro.props;
const { title = 'Help Center', subtitle = 'Find answers to common questions and learn how to get the most out of our services' } = content;

import { addonApi } from '../../lib/addon-api';

let categories: Category[] = [];
let articles: Article[] = [];

try {
  const [catsRes, artsRes] = await Promise.all([
    addonApi.knowledgeBase.categories.list(tenantId),
    addonApi.knowledgeBase.articles.list(tenantId, 'published'),
  ]);
  categories = catsRes || [];
  articles = artsRes || [];
} catch (e) {
  console.error('Failed to fetch KB data:', e);
}

if (categories.length === 0) {
  categories = [
    { id: 'getting-started', name: 'Getting Started', description: 'New to our platform? Start here', slug: 'getting-started', articles_count: 12 },
    { id: 'account', name: 'Account & Billing', description: 'Manage your account settings', slug: 'account', articles_count: 18 },
    { id: 'products', name: 'Products & Orders', description: 'Questions about your purchases', slug: 'products', articles_count: 24 },
    { id: 'shipping', name: 'Shipping & Delivery', description: 'Track orders and delivery info', slug: 'shipping', articles_count: 15 },
    { id: 'returns', name: 'Returns & Refunds', description: 'Our return policy and process', slug: 'returns', articles_count: 10 },
    { id: 'technical', name: 'Technical Support', description: 'Troubleshooting and help', slug: 'technical', articles_count: 20 },
  ];
}

if (articles.length === 0) {
  articles = [
    { id: 'art-1', title: 'How to track your order', slug: 'how-to-track-order', excerpt: 'Learn how to monitor your shipment in real-time...', status: 'published', updated_at: '2026-03-15' },
    { id: 'art-2', title: 'Setting up your account', slug: 'setting-up-account', excerpt: 'A step-by-step guide to configuring your profile...', status: 'published', updated_at: '2026-03-10' },
    { id: 'art-3', title: 'Understanding our return policy', slug: 'return-policy', excerpt: 'Everything you need to know about returns...', status: 'published', updated_at: '2026-03-08' },
    { id: 'art-4', title: 'Payment methods accepted', slug: 'payment-methods', excerpt: 'We accept all major credit cards and PayPal...', status: 'published', updated_at: '2026-03-01' },
  ];
}

const categoryIcons: Record<string, string> = {
  'getting-started': '🚀',
  'account': '💳',
  'products': '📦',
  'shipping': '🚚',
  'returns': '↩️',
  'technical': '🔧',
};
---

<div class="help-center-page py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Help Center
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">{title}</h1>
      <p class="text-xl text-gray-600 max-w-2xl mx-auto mb-8">{subtitle}</p>

      <div class="max-w-xl mx-auto relative">
        <input
          type="search"
          id="kb-search"
          placeholder="Search for answers..."
          class="w-full px-6 py-4 pl-12 bg-white border border-gray-200 rounded-full shadow-sm focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent"
        />
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <div id="search-results" class="max-w-xl mx-auto mt-4 hidden"></div>
    </div>

    <section class="mb-16">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Browse by Topic</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {categories.map((cat) => (
          <a
            href={`/help/${cat.slug}`}
            class="category-card p-6 bg-white rounded-xl border border-gray-100 hover:border-[var(--color-accent)] hover:shadow-lg transition-all group"
          >
            <div class="w-12 h-12 rounded-xl bg-[var(--color-accent)]/10 flex items-center justify-center text-2xl mb-4 group-hover:bg-[var(--color-accent)] group-hover:text-white transition-colors">
              {categoryIcons[cat.id] || '📄'}
            </div>
            <h3 class="text-lg font-bold text-gray-900 mb-1">{cat.name}</h3>
            <p class="text-gray-600 text-sm mb-3">{cat.description}</p>
            <span class="text-sm text-[var(--color-accent)] font-medium">{cat.articles_count || 0} articles</span>
          </a>
        ))}
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Popular Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {articles.map((article) => (
          <a
            href={`/help/article/${article.slug}`}
            class="article-card flex items-start gap-4 p-4 bg-white rounded-xl border border-gray-100 hover:border-[var(--color-accent)] hover:shadow-md transition-all"
          >
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900 mb-1">{article.title}</h3>
              <p class="text-gray-600 text-sm line-clamp-1">{article.excerpt}</p>
              <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                <span>Updated {new Date(article.updated_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              </div>
            </div>
            <svg class="w-5 h-5 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>
        ))}
      </div>
    </section>

    <div class="mt-16 p-8 bg-[var(--color-primary)] rounded-2xl text-center">
      <h3 class="text-2xl font-bold text-white mb-4">Can't find what you're looking for?</h3>
      <p class="text-white/80 mb-6 max-w-lg mx-auto">Our support team is here to help you with any questions.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact"
          class="px-6 py-3 bg-white text-[var(--color-primary)] font-semibold rounded-lg hover:bg-gray-100 transition-colors"
        >
          Contact Support
        </a>
        <a
          href="/support"
          class="px-6 py-3 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors"
        >
          Open a Ticket
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const searchInput = document.getElementById('kb-search') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');

  searchInput?.addEventListener('keypress', async (e) => {
    if (e.key === 'Enter') {
      const query = searchInput.value.trim();
      if (!query) return;

      try {
        const res = await fetch(`http://localhost:8084/api/v1 addon/knowledge-base/search?tenant_id=00000000-0000-0000-0000-000000000000&q=${encodeURIComponent(query)}`);
        const articles = await res.json();

        if (searchResults) {
          if (articles.length === 0) {
            searchResults.innerHTML = '<p class="text-gray-500">No articles found.</p>';
          } else {
            searchResults.innerHTML = articles.map((a: any) => `
              <a href="/help/article/${a.slug}" class="block p-4 bg-white border border-gray-200 rounded-lg mb-2 hover:border-[var(--color-accent)]">
                <h4 class="font-medium text-gray-900">${a.title}</h4>
                <p class="text-sm text-gray-600">${a.excerpt || ''}</p>
              </a>
            `).join('');
          }
          searchResults.classList.remove('hidden');
        }
      } catch (err) {
        console.error('Search failed:', err);
      }
    }
  });
</script>