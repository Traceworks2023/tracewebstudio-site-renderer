---
// Admin Customers Page
interface Props {
  template?: any;
  page?: any;
}

const { template, page } = Astro.props;

const customers = [
  { id: 'CUST-001', name: 'John Doe', email: 'john@example.com', orders: 12, spent: '₹45,678', lastOrder: 'Jan 20, 2024', status: 'active' },
  { id: 'CUST-002', name: 'Jane Smith', email: 'jane@example.com', orders: 8, spent: '₹23,456', lastOrder: 'Jan 19, 2024', status: 'active' },
  { id: 'CUST-003', name: 'Mike Johnson', email: 'mike@example.com', orders: 3, spent: '₹8,999', lastOrder: 'Jan 15, 2024', status: 'inactive' },
  { id: 'CUST-004', name: 'Sarah Williams', email: 'sarah@example.com', orders: 24, spent: '₹89,234', lastOrder: 'Jan 18, 2024', status: 'vip' }
];
---

<div class="min-h-screen bg-gray-50">
  <header class="bg-white shadow-sm border-b border-gray-200 sticky top-0 z-30">
    <div class="px-6 py-4 flex items-center justify-between">
      <h1 class="text-xl font-bold text-gray-900">Customers</h1>
      <button class="px-4 py-2 bg-gray-900 text-white text-sm font-medium rounded-lg hover:bg-gray-800">
        Export Customers
      </button>
    </div>
  </header>

  <div class="p-6">
    <div class="bg-white rounded-lg shadow-sm p-4 mb-6 flex flex-wrap gap-4 items-center">
      <input type="text" placeholder="Search customers..." class="px-4 py-2 border border-gray-300 rounded-lg text-sm w-64" />
      <select class="px-4 py-2 border border-gray-300 rounded-lg text-sm">
        <option>All Status</option>
        <option>Active</option>
        <option>Inactive</option>
        <option>VIP</option>
      </select>
    </div>

    <div class="bg-white rounded-lg shadow-sm overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Customer</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Orders</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Total Spent</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Last Order</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          {customers.map((customer) => (
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div>
                  <p class="font-medium text-gray-900">{customer.name}</p>
                  <p class="text-sm text-gray-500">{customer.email}</p>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{customer.orders}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">{customer.spent}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{customer.lastOrder}</td>
              <td class="px-6 py-4 whitespace-nowrap">
                <span class={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${
                  customer.status === 'active' ? 'bg-green-100 text-green-800' :
                  customer.status === 'vip' ? 'bg-purple-100 text-purple-800' :
                  'bg-gray-100 text-gray-800'
                }`}>
                  {customer.status}
                </span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <button class="text-blue-600 hover:text-blue-900">View</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</div>
