---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { prisma } from '../../../lib/prisma';

const templates = await prisma.template.findMany({
  orderBy: [
    { isFeatured: 'desc' },
    { name: 'asc' }
  ]
});

const tiers = ['basic', 'medium', 'premium'];
const categories = ['portfolio', 'business', 'ecommerce'];
---

<AdminLayout title="Template Management" activePage="templates">
  <div class="p-6">
    <!-- Header -->
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold text-white">Template Management</h1>
        <p class="text-white/60 text-sm mt-1">Manage website templates for the platform</p>
      </div>
      <button id="add-template-btn" class="flex items-center gap-2 px-4 py-2 bg-orange text-white rounded-lg hover:bg-orange/80 transition-all">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        Add Template
      </button>
    </div>

    <!-- Filters -->
    <div class="flex items-center gap-4 mb-6">
      <div class="relative">
        <select id="filter-category" class="appearance-none bg-white/5 border border-white/10 rounded-lg px-4 py-2 pr-10 text-white text-sm focus:outline-none focus:border-orange/50">
          <option value="">All Categories</option>
          {categories.map(cat => (
            <option value={cat}>{cat.charAt(0).toUpperCase() + cat.slice(1)}</option>
          ))}
        </select>
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
      <div class="relative">
        <select id="filter-tier" class="appearance-none bg-white/5 border border-white/10 rounded-lg px-4 py-2 pr-10 text-white text-sm focus:outline-none focus:border-orange/50">
          <option value="">All Tiers</option>
          {tiers.map(tier => (
            <option value={tier}>{tier.charAt(0).toUpperCase() + tier.slice(1)}</option>
          ))}
        </select>
        <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-white/40 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </div>
    </div>

    <!-- Templates Grid -->
    <div id="templates-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {templates.map(template => (
        <div class="template-card bg-white/5 border border-white/10 rounded-2xl overflow-hidden hover:border-white/20 transition-all" data-category={template.category} data-tier={template.tier}>
          <div class="aspect-video bg-gradient-to-br from-navy to-black relative">
            {template.thumbnailUrl ? (
              <img src={template.thumbnailUrl} alt={template.name} class="w-full h-full object-cover opacity-80" />
            ) : (
              <div class="w-full h-full flex items-center justify-center">
                <span class="text-4xl font-bold text-white/20">{template.name.charAt(0)}</span>
              </div>
            )}
            {template.isFeatured && (
              <span class="absolute top-3 right-3 px-2 py-1 bg-gradient-to-r from-amber-400 to-orange-500 text-white text-xs font-semibold rounded">Featured</span>
            )}
            <span class={`absolute top-3 left-3 px-2 py-1 text-white text-xs font-medium rounded ${
              template.category === 'portfolio' ? 'bg-purple-500/80' :
              template.category === 'business' ? 'bg-blue-500/80' : 'bg-green-500/80'
            }`}>
              {template.category}
            </span>
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between mb-2">
              <h3 class="text-lg font-semibold text-white">{template.name}</h3>
              <span class={`px-2 py-0.5 text-xs rounded ${
                template.tier === 'premium' ? 'bg-amber-500/20 text-amber-400' :
                template.tier === 'medium' ? 'bg-blue-500/20 text-blue-400' :
                'bg-white/10 text-white/60'
              }`}>
                {template.tier}
              </span>
            </div>
            <p class="text-white/40 text-sm mb-4 line-clamp-2">{template.description || 'No description'}</p>
            <div class="flex items-center justify-between">
              <span class={`px-2 py-1 rounded text-xs font-medium ${
                template.isPublished ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'
              }`}>
                {template.isPublished ? 'Published' : 'Draft'}
              </span>
              <div class="flex items-center gap-2">
                <button class="edit-template-btn p-2 hover:bg-white/10 rounded-lg transition-all" data-id={template.id} title="Edit">
                  <svg class="w-4 h-4 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                  </svg>
                </button>
                <button class="delete-template-btn p-2 hover:bg-red-500/10 rounded-lg transition-all" data-id={template.id} title="Delete">
                  <svg class="w-4 h-4 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                  </svg>
                </button>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    {templates.length === 0 && (
      <div class="text-center py-20">
        <svg class="w-16 h-16 mx-auto text-white/20 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        <p class="text-white/50 text-lg mb-4">No templates found</p>
        <button id="add-template-btn-empty" class="px-6 py-2 bg-orange text-white rounded-lg hover:bg-orange/80 transition-all">
          Create your first template
        </button>
      </div>
    )}
  </div>

  <!-- Modal -->
  <div id="template-modal" class="fixed inset-0 bg-black/80 backdrop-blur-sm z-50 hidden">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-2xl max-h-[90vh] overflow-y-auto bg-navy border border-white/10 rounded-2xl">
      <div class="sticky top-0 bg-navy border-b border-white/10 p-6 flex items-center justify-between">
        <h2 id="modal-title" class="text-xl font-semibold text-white">Add Template</h2>
        <button id="close-modal" class="p-2 hover:bg-white/10 rounded-lg transition-all">
          <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <form id="template-form" class="p-6 space-y-6">
        <input type="hidden" id="template-id" name="id" />

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm text-white/60 mb-2">Template Name</label>
            <input type="text" id="template-name" name="name" required class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-orange/50" />
          </div>
          <div>
            <label class="block text-sm text-white/60 mb-2">Slug</label>
            <input type="text" id="template-slug" name="slug" required class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-orange/50" />
          </div>
        </div>

        <div>
          <label class="block text-sm text-white/60 mb-2">Description</label>
          <textarea id="template-description" name="description" rows="2" class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-orange/50"></textarea>
        </div>

        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm text-white/60 mb-2">Category</label>
            <select id="template-category" name="category" required class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:border-orange/50">
              <option value="portfolio">Portfolio</option>
              <option value="business">Business</option>
              <option value="ecommerce">E-Commerce</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-white/60 mb-2">Tier</label>
            <select id="template-tier" name="tier" required class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white focus:outline-none focus:border-orange/50">
              <option value="basic">Basic</option>
              <option value="medium">Medium</option>
              <option value="premium">Premium</option>
            </select>
          </div>
          <div>
            <label class="block text-sm text-white/60 mb-2">Thumbnail URL</label>
            <input type="url" id="template-thumbnail" name="thumbnailUrl" class="w-full px-4 py-2 bg-white/5 border border-white/10 rounded-lg text-white placeholder-white/40 focus:outline-none focus:border-orange/50" />
          </div>
        </div>

        <div class="flex items-center gap-6">
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="template-published" name="isPublished" class="w-4 h-4 rounded border-white/20 bg-white/5 text-orange focus:ring-orange" />
            <span class="text-sm text-white">Published</span>
          </label>
          <label class="flex items-center gap-3 cursor-pointer">
            <input type="checkbox" id="template-featured" name="isFeatured" class="w-4 h-4 rounded border-white/20 bg-white/5 text-orange focus:ring-orange" />
            <span class="text-sm text-white">Featured</span>
          </label>
        </div>

        <div class="flex items-center justify-end gap-3 pt-4 border-t border-white/10">
          <button type="button" id="cancel-btn" class="px-6 py-2 bg-white/5 text-white rounded-lg hover:bg-white/10 transition-all">Cancel</button>
          <button type="submit" class="px-6 py-2 bg-orange text-white rounded-lg hover:bg-orange/80 transition-all">Save Template</button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  const API_BASE = '/api/admin/templates';
  let templates = {templates};

  // Modal elements
  const modal = document.getElementById('template-modal');
  const form = document.getElementById('template-form') as HTMLFormElement;
  const modalTitle = document.getElementById('modal-title');

  // Form fields
  const idField = document.getElementById('template-id') as HTMLInputElement;
  const nameField = document.getElementById('template-name') as HTMLInputElement;
  const slugField = document.getElementById('template-slug') as HTMLInputElement;
  const descField = document.getElementById('template-description') as HTMLTextAreaElement;
  const categoryField = document.getElementById('template-category') as HTMLSelectElement;
  const tierField = document.getElementById('template-tier') as HTMLSelectElement;
  const thumbnailField = document.getElementById('template-thumbnail') as HTMLInputElement;
  const publishedField = document.getElementById('template-published') as HTMLInputElement;
  const featuredField = document.getElementById('template-featured') as HTMLInputElement;

  // Open modal for add
  document.getElementById('add-template-btn')?.addEventListener('click', openAddModal);
  document.getElementById('add-template-btn-empty')?.addEventListener('click', openAddModal);

  function openAddModal() {
    modalTitle!.textContent = 'Add Template';
    form.reset();
    idField.value = '';
    modal!.classList.remove('hidden');
  }

  // Edit buttons
  document.querySelectorAll('.edit-template-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.id;
      const template = templates.find(t => t.id === id);
      if (template) {
        openEditModal(template);
      }
    });
  });

  function openEditModal(t: any) {
    modalTitle!.textContent = 'Edit Template';
    idField.value = t.id;
    nameField.value = t.name;
    slugField.value = t.slug;
    descField.value = t.description || '';
    categoryField.value = t.category;
    tierField.value = t.tier;
    thumbnailField.value = t.thumbnailUrl || '';
    publishedField.checked = t.isPublished;
    featuredField.checked = t.isFeatured;
    modal!.classList.remove('hidden');
  }

  // Close modal
  document.getElementById('close-modal')?.addEventListener('click', closeModal);
  document.getElementById('cancel-btn')?.addEventListener('click', closeModal);

  function closeModal() {
    modal!.classList.add('hidden');
  }

  // Close on backdrop click
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Form submit
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const data = {
      name: nameField.value,
      slug: slugField.value,
      description: descField.value,
      category: categoryField.value,
      tier: tierField.value,
      thumbnailUrl: thumbnailField.value || null,
      isPublished: publishedField.checked,
      isFeatured: featuredField.checked
    };

    const isEdit = !!idField.value;
    const url = isEdit ? `${API_BASE}/${idField.value}` : API_BASE;
    const method = isEdit ? 'PUT' : 'POST';

    try {
      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      if (res.ok) {
        window.location.reload();
      } else {
        alert('Failed to save template');
      }
    } catch (err) {
      alert('Error saving template');
    }
  });

  // Delete buttons
  document.querySelectorAll('.delete-template-btn').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      const id = (e.currentTarget as HTMLElement).dataset.id;
      if (confirm('Are you sure you want to delete this template?')) {
        try {
          const res = await fetch(`${API_BASE}/${id}`, { method: 'DELETE' });
          if (res.ok) {
            window.location.reload();
          } else {
            alert('Failed to delete template');
          }
        } catch (err) {
          alert('Error deleting template');
        }
      }
    });
  });

  // Filters
  document.getElementById('filter-category')?.addEventListener('change', applyFilters);
  document.getElementById('filter-tier')?.addEventListener('change', applyFilters);

  function applyFilters() {
    const category = (document.getElementById('filter-category') as HTMLSelectElement).value;
    const tier = (document.getElementById('filter-tier') as HTMLSelectElement).value;

    document.querySelectorAll('.template-card').forEach(card => {
      const el = card as HTMLElement;
      const matchCategory = !category || el.dataset.category === category;
      const matchTier = !tier || el.dataset.tier === tier;
      el.style.display = matchCategory && matchTier ? '' : 'none';
    });
  }
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
