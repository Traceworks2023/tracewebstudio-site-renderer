---
interface Props {
  template?: any;
  page?: any;
}

const { template, page } = Astro.props;
const colors = template?.theme?.colors || {};
---

<div class="min-h-screen bg-gray-50 p-6">
  {/* Header */}
  <header class="mb-8">
    <h1 class="text-2xl font-bold" style="color: var(--color-text, #1a1a1a);">Analytics</h1>
    <p class="text-gray-500 mt-1">Track your store performance and customer insights</p>
  </header>

  {/* Stats Overview */}
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <span class="text-gray-500 text-sm">Total Revenue</span>
        <span class="text-green-500 text-xs font-medium bg-green-50 px-2 py-1 rounded-full">+12.5%</span>
      </div>
      <p class="text-3xl font-bold" style="color: var(--color-primary, #000032);">₹8,45,230</p>
      <p class="text-gray-400 text-sm mt-1">This month</p>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <span class="text-gray-500 text-sm">Orders</span>
        <span class="text-green-500 text-xs font-medium bg-green-50 px-2 py-1 rounded-full">+8.2%</span>
      </div>
      <p class="text-3xl font-bold" style="color: var(--color-primary, #000032);">1,234</p>
      <p class="text-gray-400 text-sm mt-1">This month</p>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <span class="text-gray-500 text-sm">Customers</span>
        <span class="text-green-500 text-xs font-medium bg-green-50 px-2 py-1 rounded-full">+15.3%</span>
      </div>
      <p class="text-3xl font-bold" style="color: var(--color-primary, #000032);">5,678</p>
      <p class="text-gray-400 text-sm mt-1">Total registered</p>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <div class="flex items-center justify-between mb-4">
        <span class="text-gray-500 text-sm">Conversion Rate</span>
        <span class="text-red-500 text-xs font-medium bg-red-50 px-2 py-1 rounded-full">-2.1%</span>
      </div>
      <p class="text-3xl font-bold" style="color: var(--color-primary, #000032);">3.24%</p>
      <p class="text-gray-400 text-sm mt-1">Visitor to purchase</p>
    </div>
  </div>

  {/* Charts Section */}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">Revenue Overview</h2>
      <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
        <p class="text-gray-400">Chart visualization</p>
      </div>
    </div>
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">Traffic Sources</h2>
      <div class="h-64 flex items-center justify-center bg-gray-50 rounded-lg">
        <p class="text-gray-400">Traffic chart</p>
      </div>
    </div>
  </div>

  {/* Top Products */}
  <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
    <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">Top Selling Products</h2>
    <table class="w-full">
      <thead>
        <tr class="text-left text-gray-500 text-sm border-b">
          <th class="pb-3 font-medium">Product</th>
          <th class="pb-3 font-medium">Sales</th>
          <th class="pb-3 font-medium">Revenue</th>
          <th class="pb-3 font-medium">Trend</th>
        </tr>
      </thead>
      <tbody class="divide-y">
        <tr>
          <td class="py-4 flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348?w=50" class="w-10 h-10 rounded-lg object-cover" />
            <span class="font-medium">Hydrating Serum</span>
          </td>
          <td class="py-4">245</td>
          <td class="py-4">₹11,76,605</td>
          <td class="py-4"><span class="text-green-500">↑ 12%</span></td>
        </tr>
        <tr>
          <td class="py-4 flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1586495777744-4413f21062fa?w=50" class="w-10 h-10 rounded-lg object-cover" />
            <span class="font-medium">Velvet Matte Lipstick</span>
          </td>
          <td class="py-4">189</td>
          <td class="py-4">₹6,04,811</td>
          <td class="py-4"><span class="text-green-500">↑ 8%</span></td>
        </tr>
        <tr>
          <td class="py-4 flex items-center gap-3">
            <img src="https://images.unsplash.com/photo-1608248597279-f99d160bfcbc?w=50" class="w-10 h-10 rounded-lg object-cover" />
            <span class="font-medium">Rose Face Oil</span>
          </td>
          <td class="py-4">156</td>
          <td class="py-4">₹8,73,936</td>
          <td class="py-4"><span class="text-green-500">↑ 15%</span></td>
        </tr>
      </tbody>
    </table>
  </div>
</div>