---
interface Props {
  template?: any;
  page?: any;
}

const { template, page } = Astro.props;
---

<div class="min-h-screen bg-gray-50 p-6">
  {/* Header */}
  <header class="mb-8">
    <h1 class="text-2xl font-bold" style="color: var(--color-text, #1a1a1a);">Marketing</h1>
    <p class="text-gray-500 mt-1">Promote your store and engage customers</p>
  </header>

  {/* Quick Actions */}
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <button class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-left hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      </div>
      <h3 class="font-semibold mb-1" style="color: var(--color-text, #1a1a1a);">Email Campaign</h3>
      <p class="text-gray-500 text-sm">Send newsletters to your customers</p>
    </button>

    <button class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-left hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #4ECDC4 0%, #45B7AF 100%);">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
      </div>
      <h3 class="font-semibold mb-1" style="color: var(--color-text, #1a1a1a);">Discount Codes</h3>
      <p class="text-gray-500 text-sm">Create promotional codes</p>
    </button>

    <button class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-left hover:shadow-md transition-shadow">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-4" style="background: linear-gradient(135deg, #667EEA 0%, #764BA2 100%);">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/></svg>
      </div>
      <h3 class="font-semibold mb-1" style="color: var(--color-text, #1a1a1a);">Push Notifications</h3>
      <p class="text-gray-500 text-sm">Send browser notifications</p>
    </button>
  </div>

  {/* Active Campaigns */}
  <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 mb-8">
    <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">Active Campaigns</h2>
    <div class="space-y-4">
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-orange-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="font-medium">Summer Sale - 20% Off</p>
            <p class="text-sm text-gray-500">Ends in 3 days • 1,234 emails sent</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span class="px-3 py-1 bg-green-100 text-green-700 text-xs font-medium rounded-full">Active</span>
          <span class="text-gray-500 text-sm">4.2% CTR</span>
        </div>
      </div>
      <div class="flex items-center justify-between p-4 bg-gray-50 rounded-lg">
        <div class="flex items-center gap-4">
          <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <p class="font-medium">New Product Launch</p>
            <p class="text-sm text-gray-500">Starts tomorrow • 5,678 subscribers</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <span class="px-3 py-1 bg-yellow-100 text-yellow-700 text-xs font-medium rounded-full">Scheduled</span>
          <span class="text-gray-500 text-sm">Ready to send</span>
        </div>
      </div>
    </div>
  </div>

  {/* SEO & Social */}
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">SEO Score</h2>
      <div class="flex items-center justify-center py-8">
        <div class="relative w-32 h-32">
          <svg class="w-32 h-32 transform -rotate-90">
            <circle cx="64" cy="64" r="56" stroke="#E5E7EB" stroke-width="12" fill="none" />
            <circle cx="64" cy="64" r="56" stroke="#10B981" stroke-width="12" fill="none" stroke-dasharray="351.86" stroke-dashoffset="70" stroke-linecap="round" />
          </svg>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-3xl font-bold" style="color: var(--color-primary, #000032);">80</span>
          </div>
        </div>
      </div>
      <p class="text-center text-gray-500 text-sm mt-2">Your SEO score is good! Continue optimizing.</p>
    </div>

    <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
      <h2 class="text-lg font-semibold mb-4" style="color: var(--color-text, #1a1a1a);">Social Media</h2>
      <div class="space-y-4">
        <div class="flex items-center justify-between p-4 bg-gradient-to-r from-pink-500 via-red-500 to-yellow-500 rounded-lg text-white">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            <span class="font-medium">Instagram</span>
          </div>
          <div class="text-right">
            <p class="font-bold">12.5K</p>
            <p class="text-xs opacity-80">Followers</p>
          </div>
        </div>
        <div class="flex items-center justify-between p-4 bg-blue-600 rounded-lg text-white">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/></svg>
            <span class="font-medium">Twitter</span>
          </div>
          <div class="text-right">
            <p class="font-bold">8.3K</p>
            <p class="text-xs opacity-80">Followers</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>