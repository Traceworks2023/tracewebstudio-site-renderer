---
// Color Palette Swapper Component
interface ColorPalette {
  id: string;
  name: string;
  colors: {
    primary: string;
    secondary: string;
    accent: string;
    background: string;
    surface: string;
  };
}

interface Props {
  currentPalette?: string;
  palettes?: ColorPalette[];
}

const {
  currentPalette = 'default',
  palettes = [
    { id: 'midnight-gold', name: 'Midnight Gold', colors: { primary: '#000032', secondary: '#333333', accent: '#FA5014', background: '#ffffff', surface: '#f5f5f5' } },
    { id: 'emerald-stone', name: 'Emerald Stone', colors: { primary: '#1a4d3e', secondary: '#2d5a4a', accent: '#c9a227', background: '#faf9f7', surface: '#f0efed' } },
    { id: 'ink-copper', name: 'Ink Copper', colors: { primary: '#1c2431', secondary: '#374151', accent: '#b87333', background: '#ffffff', surface: '#f9fafb' } },
    { id: 'royal-plum', name: 'Royal Plum', colors: { primary: '#4a1942', secondary: '#6b2d5c', accent: '#d4af37', background: '#fdfcff', surface: '#f5f0f7' } },
    { id: 'ocean-slate', name: 'Ocean Slate', colors: { primary: '#1e3a5f', secondary: '#2d4a6f', accent: '#4ecdc4', background: '#f8fafc', surface: '#e2e8f0' } },
    { id: 'sand-terracotta', name: 'Sand Terracotta', colors: { primary: '#8b4513', secondary: '#a0522d', accent: '#cd853f', background: '#faf8f5', surface: '#f5ebe0' } },
    { id: 'graphite-electric', name: 'Graphite Electric', colors: { primary: '#1a1a2e', secondary: '#2d2d44', accent: '#00d4ff', background: '#ffffff', surface: '#f0f0f5' } },
    { id: 'ivory-mocha', name: 'Ivory Mocha', colors: { primary: '#3d2b1f', secondary: '#5c4033', accent: '#8b7355', background: '#fefef9', surface: '#f5f0e6' } }
  ]
} = Astro.props;
---

<div class="color-swapper" data-current={currentPalette}>
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
    {palettes.map((palette) => (
      <button
        type="button"
        class={`palette-btn p-3 rounded-xl border-2 transition-all ${
          currentPalette === palette.id
            ? 'border-[var(--color-accent)] ring-2 ring-[var(--color-accent)]/20'
            : 'border-transparent hover:border-gray-200'
        }`}
        data-palette-id={palette.id}
        title={palette.name}
      >
        <div class="flex gap-1 mb-2">
          <div class="w-6 h-6 rounded-full" style={`background-color: ${palette.colors.primary}`}></div>
          <div class="w-6 h-6 rounded-full" style={`background-color: ${palette.colors.accent}`}></div>
          <div class="w-6 h-6 rounded-full" style={`background-color: ${palette.colors.background}`}></div>
        </div>
        <p class="text-xs font-medium text-gray-700 truncate">{palette.name}</p>
      </button>
    ))}
  </div>

  {/* Preview */}
  <div class="preview-section mt-6 p-4 bg-gray-50 rounded-xl" id="palette-preview">
    <p class="text-sm font-semibold text-gray-700 mb-3">Preview</p>
    <div class="flex gap-2">
      <div class="preview-primary w-12 h-12 rounded-lg flex items-center justify-center text-white text-xs font-bold" data-color="primary">Pri</div>
      <div class="preview-secondary w-12 h-12 rounded-lg flex items-center justify-center text-white text-xs font-bold" data-color="secondary">Sec</div>
      <div class="preview-accent w-12 h-12 rounded-lg flex items-center justify-center text-white text-xs font-bold" data-color="accent">Acc</div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('.palette-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const paletteId = (btn as HTMLElement).dataset.paletteId;
      const swapper = btn.closest('.color-swapper');
      const preview = swapper?.querySelector('#palette-preview');

      if (paletteId && preview) {
        // Update preview colors
        console.log('Selected palette:', paletteId);
        // Would dispatch event to update template colors
        window.dispatchEvent(new CustomEvent('palette:change', { detail: { paletteId } }));
      }
    });
  });
</script>