---
// CTA Vapor - Large centered CTA with animated background
interface Props {
  content?: {
    title?: string;
    ctaText?: string;
    secondaryCtaText?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Ready to transform your business?',
  ctaText = 'Get Started',
  secondaryCtaText = 'Learn More',
} = content;
---

<section class="cta-vapor py-32 relative overflow-hidden">
  {/* Animated gradient background */}
  <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-primary)] via-[var(--color-secondary)] to-[var(--color-accent)]">
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-0 left-1/4 w-96 h-96 bg-white rounded-full blur-3xl animate-pulse"></div>
      <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-[var(--color-accent)] rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>
    </div>
  </div>

  {/* Grid pattern overlay */}
  <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 50px 50px;"></div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8 relative z-10 text-center">
    <div class="space-y-8">
      <h2 class="text-4xl md:text-6xl lg:text-7xl font-bold text-white leading-tight">
        {title}
      </h2>

      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Join thousands of satisfied customers and start your journey today.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <a
          href="#"
          class="group inline-flex items-center gap-3 px-10 py-5 bg-white text-[var(--color-primary)] font-bold text-lg rounded-full hover:shadow-2xl transition-all duration-300 hover:-translate-y-1"
        >
          <span>{ctaText}</span>
          <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a
          href="#"
          class="inline-flex items-center gap-2 px-10 py-5 border-2 border-white/50 text-white font-semibold text-lg rounded-full hover:bg-white/10 transition-all"
        >
          {secondaryCtaText}
        </a>
      </div>

      {/* Trust badges */}
      <div class="flex items-center justify-center gap-8 pt-8 text-white/60 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Free 14-day trial
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          No credit card required
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          Cancel anytime
        </div>
      </div>
    </div>
  </div>
</section>