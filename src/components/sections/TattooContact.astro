---
// TattooContact — Minimal wireframe card stack on deep black
interface Props {
  content?: {
    title?: string;
    phone?: string;
    whatsapp?: string;
    email?: string;
    instagram?: string;
    location?: string;
    availability?: string;
  };
  settings?: {
    templateSlug?: string;
    motionLevel?: number;
  };
}
const { content = {}, settings = {} } = Astro.props;
const { title = 'Book a Session', phone = '+91 98765 43210', whatsapp = '+91 98765 43210', email = 'hello@studio.in', instagram = '@studio', location = 'Mumbai \u00b7 Pune', availability = 'Booking by appointment only' } = content;
const items = [
  { label: 'Phone',    value: phone,     href: `tel:${phone.replace(/\s/g,'')}`, icon: 'phone' },
  { label: 'WhatsApp', value: whatsapp,  href: `https://wa.me/${whatsapp.replace(/\D/g,'')}`, icon: 'whatsapp' },
  { label: 'Email',    value: email,     href: `mailto:${email}`, icon: 'email' },
  { label: 'Instagram',value: instagram, href: `https://instagram.com/${instagram.replace('@','')}`, icon: 'instagram' },
];
---
<section id="contact" class="tattoo-contact">
  <div class="inner">
    <div class="top-line"></div>
    <h2 class="title">{title}</h2>
    <p class="avail">{availability}</p>
    <div class="cards">
      {items.map((it,i)=>(
        <a href={it.href} target={it.href?.startsWith('http')?'_blank':undefined} rel="noopener" class="card" key={i}>
          <span class="dot"></span>
          <div class="body">
            <span class="label">{it.label}</span>
            <span class="val">{it.value}</span>
          </div>
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      ))}
    </div>
    <p class="loc">{location}</p>
  </div>
</section>
<style>
  .tattoo-contact { padding:120px 24px; background:var(--color-background,#0a0a0a); }
  .inner { max-width:560px; margin:0 auto; text-align:center; }
  .top-line { width:80px; height:1px; background:var(--color-accent,#aaaaaa); opacity:0.4; margin:0 auto 48px; }
  .title { font-family:var(--font-heading,'Cormorant Garamond',serif); font-size:clamp(2rem,4vw,3rem); font-weight:300; color:var(--color-text,#f5f5f5); margin-bottom:8px; }
  .avail { font-family:var(--font-body,'Inter',sans-serif); font-size:0.85rem; color:var(--color-text-muted,#888888); margin-bottom:48px; }
  .cards { display:flex; flex-direction:column; gap:12px; }
  .card { display:flex; align-items:center; gap:18px; padding:24px 28px; text-decoration:none; color:inherit; border:1px solid var(--color-border,#222); border-radius:var(--radius-md,12px); background:var(--color-surface,#111); transition:all .35s cubic-bezier(.16,1,.3,1); }
  .card:hover { transform:translateX(6px); border-color:var(--color-accent,#aaa); box-shadow:0 8px 28px -8px rgba(170,170,170,0.08); }
  .dot { width:6px; height:6px; border-radius:2px; background:var(--color-accent,#aaaaaa); flex-shrink:0; opacity:0.5; }
  .body { flex:1; display:flex; flex-direction:column; gap:2px; text-align:left; }
  .label { font-family:var(--font-heading); font-style:italic; font-size:0.8rem; color:var(--color-text-muted,#888); letter-spacing:0.04em; }
  .val { font-family:var(--font-body); font-size:1rem; font-weight:500; color:var(--color-text,#f5f5f5); }
  .arrow { width:16px; height:16px; color:var(--color-text-muted,#888); opacity:0; transform:translateX(-8px); transition:all .3s ease; }
  .card:hover .arrow { opacity:1; transform:translateX(0); color:var(--color-accent,#aaa); }
  .loc { margin-top:48px; font-family:var(--font-heading); font-style:italic; font-size:1rem; color:var(--color-text-muted,#888); }
  @media(max-width:640px){ .tattoo-contact{padding:80px 16px;} .card{padding:20px 22px;} }
</style>
