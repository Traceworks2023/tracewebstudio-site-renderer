---
// Hero Editorial - Premium typography-focused hero with parallax
interface Props {
  content?: {
    badge?: string;
    title?: string;
    subtitle?: string;
    description?: string;
    ctaText?: string;
    ctaUrl?: string;
    secondaryCtaText?: string;
    secondaryCtaUrl?: string;
    image?: string;
    imageAlt?: string;
  };
  settings?: {
    variant?: 'centered' | 'left' | 'split' | 'editorial';
    parallaxPreset?: 'softBackgroundDrift' | 'layeredDepth' | 'foregroundFloat' | 'textOverMedia';
    motionLevel?: 1 | 2 | 3 | 4;
    height?: 'full' | 'large' | 'medium' | 'auto';
    showImage?: boolean;
    showDecoration?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  badge = 'Featured',
  title = 'Elevate Your Digital Presence',
  subtitle = 'Premium Design System',
  description = 'Create stunning, conversion-focused websites with our collection of hand-crafted templates. Every detail is optimized for performance and aesthetics.',
  ctaText = 'Explore Templates',
  ctaUrl = '#',
  secondaryCtaText = 'View Demo',
  secondaryCtaUrl = '#',
  image = 'https://images.unsplash.com/photo-1618005182384-a83a8bd57fbe?w=1200',
  imageAlt = 'Hero image',
} = content;

const {
  variant = 'editorial',
  parallaxPreset = 'layeredDepth',
  motionLevel = 4,
  height = 'full',
  showImage = true,
  showDecoration = true,
  templateSlug = '',
} = settings;

const getTemplateLink = (link: string) => {
  if (!link || link === '#') return '#';
  if (link.startsWith('http')) return link;
  return `/${templateSlug}${link.startsWith('/') ? link : `/${link}`}`;
};

const heightClass = height === 'full' ? 'min-h-screen' : height === 'large' ? 'min-h-[90vh]' : height === 'medium' ? 'min-h-[70vh]' : '';
---

<section
  class={`hero-editorial relative overflow-hidden ${heightClass} ${variant === 'dark' ? 'bg-navy text-white' : 'bg-white'}`}
  data-variant={variant}
  data-parallax={parallaxPreset}
  data-motion-level={motionLevel}
>
  {/* Background Pattern */}
  {showDecoration && (
    <div class="hero-pattern absolute inset-0 opacity-[0.03] pointer-events-none">
      <svg class="w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <defs>
          <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
            <path d="M 10 0 L 0 0 0 10" fill="none" stroke="currentColor" stroke-width="0.5"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>
  )}

  {/* Floating Elements */}
  {motionLevel >= 4 && (
    <div class="floating-elements absolute inset-0 pointer-events-none overflow-hidden">
      <div class="float-shape absolute w-2 h-2 bg-[var(--color-accent)] rounded-full top-1/4 left-1/4 animate-float" />
      <div class="float-shape absolute w-4 h-4 border border-[var(--color-accent)]/50 rounded-full top-1/3 right-1/4 animate-float-delayed" />
      <div class="float-shape absolute w-3 h-3 bg-navy/20 rounded-full bottom-1/4 left-1/3 animate-float" />
      <div class="float-shape absolute w-6 h-6 border border-navy/20 rounded-full bottom-1/3 right-1/3 animate-float-delayed" />
    </div>
  )}

  <div class="relative z-10 max-w-7xl mx-auto px-6 py-20 md:py-32">
    {variant === 'editorial' && showImage ? (
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        {/* Content */}
        <div class="hero-content">
          {badge && (
<span class="hero-badge inline-flex items-center gap-2 px-4 py-2 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-8">
                <span class="w-2 h-2 bg-[var(--color-accent)] rounded-full animate-pulse" />
              {badge}
            </span>
          )}

          <h1 class="hero-title text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
            {title}
          </h1>

          <p class="hero-subtitle text-xl md:text-2xl text-gray-600 mb-4 font-medium">
            {subtitle}
          </p>

          <p class="hero-description text-lg text-gray-500 mb-10 max-w-lg leading-relaxed">
            {description}
          </p>

          <div class="hero-actions flex flex-wrap gap-4">
            <a href={getTemplateLink(ctaUrl)} class="group inline-flex items-center gap-3 px-8 py-4 bg-[var(--color-primary)] text-white font-semibold rounded-full hover:bg-[var(--color-accent)] transition-all hover:scale-105 shadow-xl">
              {ctaText}
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href={getTemplateLink(secondaryCtaUrl)} class="inline-flex items-center gap-2 px-8 py-4 border-2 border-gray-200 text-gray-700 font-semibold rounded-full hover:border-navy hover:text-navy transition-all">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              {secondaryCtaText}
            </a>
          </div>


        </div>

        {/* Image */}
        <div class="hero-image-wrapper relative">
          <div class="relative">
            {/* Decorative frame */}
            <div class="absolute -inset-4 border-2 border-navy/10 rounded-3xl transform rotate-3" />
            <div class="absolute -inset-4 border border-[var(--color-accent)]/20 rounded-3xl transform -rotate-2" />

            {/* Main image */}
            <div class="relative rounded-2xl overflow-hidden shadow-2xl">
              <img
                src={image}
                alt={imageAlt}
                class="w-full aspect-[4/3] object-cover"
                loading="eager"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy/20 to-transparent" />
            </div>
          </div>
        </div>
      </div>
    ) : variant === 'centered' ? (
      <div class="text-center max-w-4xl mx-auto">
        {badge && (
          <span class="hero-badge inline-block px-6 py-2 bg-navy/5 text-navy rounded-full text-sm font-semibold mb-8">
            {badge}
          </span>
        )}

        <h1 class="hero-title text-5xl md:text-6xl lg:text-8xl font-bold leading-[1.05] tracking-tight mb-8">
          {title}
        </h1>

        <p class="hero-description text-xl md:text-2xl text-gray-500 mb-12 max-w-2xl mx-auto leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-wrap justify-center gap-4">
          <a href={getTemplateLink(ctaUrl)} class="group inline-flex items-center gap-3 px-10 py-5 bg-[var(--color-primary)] text-white text-lg font-semibold rounded-full hover:bg-[var(--color-accent)] transition-all hover:scale-105 shadow-2xl">
            {ctaText}
            <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href={getTemplateLink(secondaryCtaUrl)} class="inline-flex items-center gap-2 px-10 py-5 border-2 border-gray-200 text-gray-700 text-lg font-semibold rounded-full hover:border-navy hover:text-navy transition-all">
            {secondaryCtaText}
          </a>
        </div>
      </div>
    ) : (
      <div class="max-w-3xl">
        {badge && (
          <span class="hero-badge inline-block px-4 py-2 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-6">
            {badge}
          </span>
        )}

        <h1 class="hero-title text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight mb-6">
          {title}
        </h1>

        <p class="hero-description text-xl text-gray-500 mb-10 leading-relaxed">
          {description}
        </p>

        <div class="hero-actions flex flex-wrap gap-4">
          <a href={getTemplateLink(ctaUrl)} class="inline-flex items-center gap-2 px-8 py-4 bg-[var(--color-primary)] text-white font-semibold rounded-full hover:bg-[var(--color-accent)] transition-all">
            {ctaText}
          </a>
          <a href={getTemplateLink(secondaryCtaUrl)} class="inline-flex items-center gap-2 px-8 py-4 border border-gray-200 text-gray-700 font-semibold rounded-full hover:border-navy transition-all">
            {secondaryCtaText}
          </a>
        </div>
      </div>
    )}
  </div>

  {/* Scroll Indicator */}
  {height === 'full' && (
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 scroll-indicator">
      <div class="flex flex-col items-center gap-2 animate-bounce">
        <span class="text-xs uppercase tracking-widest text-gray-400">Scroll</span>
        <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  )}
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-5deg); }
  }

  .float-shape {
    will-change: transform;
  }

  .float-shape:nth-child(1) { animation: float 4s ease-in-out infinite; }
  .float-shape:nth-child(2) { animation: float-delayed 5s ease-in-out infinite 1s; }
  .float-shape:nth-child(3) { animation: float 3s ease-in-out infinite 0.5s; }
  .float-shape:nth-child(4) { animation: float-delayed 6s ease-in-out infinite 2s; }

  .animate-float-slow { animation: float 6s ease-in-out infinite; }
  .animate-float-delayed { animation: float-delayed 5s ease-in-out infinite 1s; }

  @keyframes title-reveal {
    from {
      opacity: 0;
      transform: translateY(60px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes subtitle-reveal {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes description-reveal {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes actions-reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-title {
    animation: title-reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .hero-subtitle {
    animation: subtitle-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
  }

  .hero-description {
    animation: description-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s forwards;
    opacity: 0;
  }

  .hero-actions {
    animation: actions-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    opacity: 0;
  }

  .hero-badge {
    animation: description-reveal 0.6s ease-out 0.1s forwards;
    opacity: 0;
  }

  .hero-image-wrapper img {
    will-change: transform;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-motion-level="4"] .hero-image-wrapper:hover img {
    transform: scale(1.03);
  }

  @media (max-width: 768px) {
    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector('.hero-editorial') as HTMLElement;
    if (!hero) return;

    const imageWrapper = hero.querySelector('.hero-image-wrapper');
    const parallaxPreset = hero.dataset.parallax;
    const motionLevel = parseInt(hero.dataset.motionLevel || '4');

    // Parallax effect
    if (motionLevel >= 3 && parallaxPreset && imageWrapper) {
      const img = imageWrapper.querySelector('img');

      ScrollTrigger.create({
        trigger: hero,
        start: 'top top',
        end: 'bottom top',
        scrub: true,
        onUpdate: (self) => {
          if (img) {
            const progress = self.progress;
            switch (parallaxPreset) {
              case 'layeredDepth':
                gsap.set(img, { yPercent: progress * 20, scale: 1 + progress * 0.05 });
                break;
              case 'softBackgroundDrift':
                gsap.set(img, { yPercent: progress * 15 });
                break;
            }
          }
        },
      });
    }

    // Staggered reveal for stats
    if (motionLevel >= 3) {
      gsap.from('.stat', {
        opacity: 0,
        y: 30,
        duration: 0.6,
        stagger: 0.15,
        ease: 'power3.out',
        delay: 0.6,
      });
    }
  });
</script>