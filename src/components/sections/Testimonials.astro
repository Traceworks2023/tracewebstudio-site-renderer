---
// Testimonials Section - Multiple variants with theme integration
// Supports variants: grid, cards, slider, featured, minimal

interface Testimonial {
  name: string;
  role?: string;
  company?: string;
  avatar?: string;
  image?: string;
  quote: string;
  rating?: number;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    testimonials?: Testimonial[];
  };
  settings?: {
    variant?: 'grid' | 'cards' | 'slider' | 'featured' | 'minimal';
    backgroundStyle?: 'light' | 'dark' | 'gradient' | 'surface';
    columns?: number;
    motionLevel?: 1 | 2 | 3 | 4;
    autoplay?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'What Our Clients Say',
  subtitle = 'Join thousands of satisfied customers',
  testimonials = [
    { name: 'Sarah Johnson', role: 'Small Business Owner', company: 'Sarah\'s Crafts', quote: 'This platform transformed my business! I was able to launch my online store in just a few hours.', rating: 5 },
    { name: 'Michael Chen', role: 'Marketing Director', company: 'TechStart Inc', quote: 'The best website builder we\'ve used. Intuitive interface, great features, and the SEO tools helped us rank #1 on Google.', rating: 5 },
    { name: 'Emily Rodriguez', role: 'Entrepreneur', quote: 'I switched from another platform and never looked back. The performance is outstanding and the pricing is unbeatable.', rating: 5 },
  ],
} = content;

const {
  variant = 'cards',
  backgroundStyle = 'light',
  columns = 3,
  motionLevel = 2,
  autoplay = true,
} = settings;

const sectionId = `testimonials-${Math.random().toString(36).slice(2, 9)}`;

const bgClasses = {
  light: 'bg-gray-50',
  dark: 'bg-gray-900 text-white',
  gradient: 'bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] text-white',
  surface: 'bg-white',
};
---

<section
  id={sectionId}
  class={`testimonials-section testimonials-variant-${variant} ${bgClasses[backgroundStyle]}`}
  data-variant={variant}
  data-motion-level={motionLevel}
  data-autoplay={autoplay}
>
  <div class="testimonials-container max-w-7xl mx-auto px-6 py-20">
    {(title || subtitle) && (
      <div class="testimonials-header text-center mb-16">
        {title && <h2 class="testimonials-title text-4xl md:text-5xl font-bold mb-4">{title}</h2>}
        {subtitle && <p class="testimonials-subtitle text-lg opacity-80">{subtitle}</p>}
      </div>
    )}

    {/* Grid Variant */}
    {variant === 'grid' && (
      <div class={`testimonials-grid grid-cols-1 md:grid-cols-${Math.min(columns, 3)} gap-8`}>
        {testimonials.map((testimonial, index) => (
          <div class="testimonial-card bg-white rounded-2xl p-8 shadow-sm" data-testimonial-index={index}>
            <div class="testimonial-rating mb-4">
              {Array(testimonial.rating || 5).fill(null).map(() => (
                <span class="star text-[var(--color-accent)]">★</span>
              ))}
            </div>
            <blockquote class="testimonial-quote text-gray-700 mb-6">"{testimonial.quote}"</blockquote>
            <div class="testimonial-author flex items-center gap-4">
              <div class="testimonial-avatar w-12 h-12 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white font-bold">
                {testimonial.avatar || testimonial.name.charAt(0)}
              </div>
              <div>
                <div class="testimonial-name font-semibold text-gray-900">{testimonial.name}</div>
                {(testimonial.role || testimonial.company) && (
                  <div class="testimonial-role text-sm text-gray-500">{testimonial.role}{testimonial.role && testimonial.company && ' at '}{testimonial.company}</div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Cards Variant */}
    {(variant === 'cards' || !variant) && (
      <div class={`testimonials-grid grid-cols-1 md:grid-cols-${Math.min(columns, 3)} gap-8`}>
        {testimonials.map((testimonial, index) => (
          <div class="testimonial-card bg-white rounded-2xl p-8 shadow-sm hover:shadow-xl transition-all duration-300" data-testimonial-index={index}>
            <div class="testimonial-rating mb-4">
              {Array(testimonial.rating || 5).fill(null).map(() => (
                <span class="star text-[var(--color-accent)]">★</span>
              ))}
            </div>
            <blockquote class="testimonial-quote text-gray-700 mb-6 leading-relaxed">"{testimonial.quote}"</blockquote>
            <div class="testimonial-author flex items-center gap-4">
              {testimonial.image ? (
                <img src={testimonial.image} alt={testimonial.name} class="w-12 h-12 rounded-full object-cover" />
              ) : (
                <div class="testimonial-avatar w-12 h-12 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white font-bold">
                  {testimonial.name.charAt(0)}
                </div>
              )}
              <div>
                <div class="testimonial-name font-semibold text-gray-900">{testimonial.name}</div>
                {(testimonial.role || testimonial.company) && (
                  <div class="testimonial-role text-sm text-gray-500">{testimonial.role}{testimonial.role && testimonial.company && ' at '}{testimonial.company}</div>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Slider Variant */}
    {variant === 'slider' && (
      <div class="testimonials-slider relative">
        <div class="testimonials-track flex gap-6 overflow-x-auto pb-4 snap-x snap-mandatory" data-slider-track>
          {testimonials.map((testimonial, index) => (
            <div class="testimonial-slide flex-shrink-0 w-full md:w-[calc(50%-1rem)] lg:w-[calc(33.333%-1.5rem)] snap-start" data-testimonial-index={index}>
              <div class="testimonial-card bg-white rounded-2xl p-8 h-full">
                <div class="testimonial-rating mb-4">
                  {Array(testimonial.rating || 5).fill(null).map(() => (
                    <span class="star text-[var(--color-accent)]">★</span>
                  ))}
                </div>
                <blockquote class="testimonial-quote text-gray-700 mb-6 leading-relaxed">"{testimonial.quote}"</blockquote>
                <div class="testimonial-author flex items-center gap-4">
                  <div class="testimonial-avatar w-12 h-12 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white font-bold">
                    {testimonial.name.charAt(0)}
                  </div>
                  <div>
                    <div class="testimonial-name font-semibold text-gray-900">{testimonial.name}</div>
                    {(testimonial.role || testimonial.company) && (
                      <div class="testimonial-role text-sm text-gray-500">{testimonial.role}{testimonial.role && testimonial.company && ' at '}{testimonial.company}</div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="testimonials-nav flex justify-center gap-4 mt-8">
          <button class="slider-prev w-12 h-12 rounded-full border border-gray-300 flex items-center justify-center hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors" aria-label="Previous">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
          </button>
          <button class="slider-next w-12 h-12 rounded-full border border-gray-300 flex items-center justify-center hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] transition-colors" aria-label="Next">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </button>
        </div>
      </div>
    )}

    {/* Featured Variant */}
    {variant === 'featured' && (
      <div class="testimonials-featured">
        {testimonials.slice(0, 2).map((testimonial, index) => (
          <div class="testimonial-featured-item grid md:grid-cols-2 gap-12 items-center mb-16 last:mb-0" data-testimonial-index={index}>
            <div class={index % 2 === 1 ? 'md:order-2' : ''}>
              <div class="testimonial-featured-avatar w-24 h-24 mx-auto md:mx-0 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white text-3xl font-bold mb-6">
                {testimonial.name.charAt(0)}
              </div>
            </div>
            <div class={index % 2 === 1 ? 'md:order-1' : ''}>
              <div class="testimonial-rating mb-4">
                {Array(testimonial.rating || 5).fill(null).map(() => (
                  <span class="star text-[var(--color-accent)] text-xl">★</span>
                ))}
              </div>
              <blockquote class="testimonial-quote text-2xl font-medium leading-relaxed mb-6">"{testimonial.quote}"</blockquote>
              <div class="testimonial-name font-bold text-lg">{testimonial.name}</div>
              {(testimonial.role || testimonial.company) && (
                <div class="testimonial-role text-gray-500">{testimonial.role}{testimonial.role && testimonial.company && ' at '}{testimonial.company}</div>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    {/* Minimal Variant */}
    {variant === 'minimal' && (
      <div class="testimonials-minimal space-y-8">
        {testimonials.map((testimonial, index) => (
          <div class="testimonial-minimal-item flex items-start gap-6" data-testimonial-index={index}>
            <div class="testimonial-minimal-avatar w-10 h-10 flex-shrink-0 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center text-[var(--color-primary)] font-bold">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="testimonial-minimal-rating mb-2">
                {Array(testimonial.rating || 5).fill(null).map(() => (
                  <span class="star text-[var(--color-accent)] text-sm">★</span>
                ))}
              </div>
              <blockquote class="testimonial-quote text-gray-700 mb-2">"{testimonial.quote}"</blockquote>
              <div class="testimonial-meta text-sm">
                <span class="testimonial-name font-semibold text-gray-900">{testimonial.name}</span>
                {(testimonial.role || testimonial.company) && (
                  <span class="text-gray-500"> — {testimonial.role}{testimonial.role && testimonial.company && ' at '}{testimonial.company}</span>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .testimonials-section {
    position: relative;
  }

  .testimonials-title {
    font-family: var(--font-heading);
    color: inherit;
  }

  .testimonials-subtitle {
    font-family: var(--font-body);
  }

  .testimonial-name {
    font-family: var(--font-heading);
  }

  .testimonial-role {
    font-family: var(--font-body);
  }

  .testimonial-quote {
    font-family: var(--font-body);
  }

  .star {
    display: inline-block;
  }

  /* Cards hover effect */
  .testimonials-variant-cards .testimonial-card:hover {
    transform: translateY(-5px);
  }

  /* Motion */
  [data-motion-level="3"] .testimonial-card,
  [data-motion-level="4"] .testimonial-card {
    opacity: 0;
    transform: translateY(20px);
    animation: testimonial-stagger 0.5s ease-out forwards;
  }

  [data-motion-level="3"] .testimonial-card:nth-child(1),
  [data-motion-level="4"] .testimonial-card:nth-child(1) { animation-delay: 0.1s; }
  [data-motion-level="3"] .testimonial-card:nth-child(2),
  [data-motion-level="4"] .testimonial-card:nth-child(2) { animation-delay: 0.2s; }
  [data-motion-level="3"] .testimonial-card:nth-child(3),
  [data-motion-level="4"] .testimonial-card:nth-child(3) { animation-delay: 0.3s; }

  @keyframes testimonial-stagger {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Slider styles */
  .testimonials-track {
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .testimonials-track::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.testimonials-slider').forEach((slider) => {
      const el = slider as HTMLElement;
      const track = el.querySelector('[data-slider-track]') as HTMLElement;
      const prevBtn = el.querySelector('.slider-prev');
      const nextBtn = el.querySelector('.slider-next');

      if (!track) return;

      const scrollAmount = track.offsetWidth * 0.8;

      nextBtn?.addEventListener('click', () => {
        track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });

      prevBtn?.addEventListener('click', () => {
        track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });
    });
  });
</script>