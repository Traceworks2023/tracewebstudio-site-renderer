---
interface Plan {
  name: string;
  price: string;
  period?: string;
  description: string;
  features: string[];
  highlighted?: boolean;
  buttonText?: string;
  buttonUrl?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  plans?: Plan[];
  settings?: {
    templateSlug?: string;
  };
}

const {
  title = "Our Pricing",
  subtitle = "Choose the plan that works for you",
  plans = [
    {
      name: "Starter",
      price: "$0",
      period: "forever",
      description: "Perfect for getting started",
      features: ["3 pages", "1GB storage", "Basic analytics", "Email support"],
      buttonText: "Get Started",
      buttonUrl: "/signup",
    },
    {
      name: "Professional",
      price: "$29",
      period: "per month",
      description: "Best for growing businesses",
      features: ["Unlimited pages", "10GB storage", "Advanced analytics", "Priority support", "Custom domain", "No ads"],
      highlighted: true,
      buttonText: "Start Free Trial",
      buttonUrl: "/signup?plan=professional",
    },
    {
      name: "Enterprise",
      price: "$99",
      period: "per month",
      description: "For large organizations",
      features: ["Everything in Pro", "Unlimited storage", "SSO & SAML", "Dedicated support", "SLA guarantee", "Custom integrations"],
      buttonText: "Contact Sales",
      buttonUrl: "/contact",
    },
  ],
} = Astro.props;

const settings = Astro.props.settings || {};
const templateSlug = settings.templateSlug || '';

const getTemplateLink = (link: string) => {
  if (!link || link === '#') return '#';
  if (link.startsWith('http')) return link;
  return `/${templateSlug}${link.startsWith('/') ? link : `/${link}`}`;
};
---

<section class="pricing">
  <div class="pricing-container">
    <div class="pricing-header">
      <h2 class="pricing-title">{title}</h2>
      {subtitle && <p class="pricing-subtitle">{subtitle}</p>}
    </div>
    <div class="pricing-grid">
      {plans.map((plan) => (
        <div class={`pricing-card ${plan.highlighted ? 'highlighted' : ''}`}>
          {plan.highlighted && <div class="popular-badge">Most Popular</div>}
          <h3 class="plan-name">{plan.name}</h3>
          <div class="plan-price">
            <span class="price">{plan.price}</span>
            {plan.period && <span class="period">/{plan.period}</span>}
          </div>
          <p class="plan-description">{plan.description}</p>
          <ul class="plan-features">
            {plan.features.map((feature) => (
              <li class="feature-item">
                <span class="check-icon">✓</span>
                {feature}
              </li>
            ))}
          </ul>
          <a href={getTemplateLink(plan.buttonUrl)} class={`btn ${plan.highlighted ? 'btn-primary' : 'btn-secondary'}`}>
            {plan.buttonText}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    padding: 5rem 2rem;
    background-color: white;
  }

  .pricing-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .pricing-title {
    font-family: 'Exo 2', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #000032;
    margin: 0 0 1rem 0;
  }

  .pricing-subtitle {
    font-size: 1.125rem;
    color: #6B7280;
    margin: 0;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    align-items: start;
  }

  .pricing-card {
    background: #F9FAFB;
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid #E5E7EB;
    position: relative;
    transition: all 0.3s ease;
  }

  .pricing-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0,0,0,0.1);
  }

  .pricing-card.highlighted {
    background: #000032;
    border-color: #000032;
    transform: scale(1.05);
    z-index: 1;
  }

  .pricing-card.highlighted:hover {
    transform: scale(1.05) translateY(-5px);
  }

  .popular-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #FA5014;
    color: white;
    padding: 0.25rem 1rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  .plan-name {
    font-family: 'Exo 2', sans-serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #111827;
    margin: 0 0 1rem 0;
    text-align: center;
  }

  .pricing-card.highlighted .plan-name {
    color: white;
  }

  .plan-price {
    text-align: center;
    margin-bottom: 1rem;
  }

  .price {
    font-family: 'Exo 2', sans-serif;
    font-size: 3rem;
    font-weight: 700;
    color: #000032;
  }

  .pricing-card.highlighted .price {
    color: #FA5014;
  }

  .period {
    font-size: 1rem;
    color: #6B7280;
  }

  .pricing-card.highlighted .period {
    color: rgba(255,255,255,0.7);
  }

  .plan-description {
    text-align: center;
    color: #6B7280;
    margin: 0 0 1.5rem 0;
  }

  .pricing-card.highlighted .plan-description {
    color: rgba(255,255,255,0.8);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem 0;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    color: #111827;
  }

  .pricing-card.highlighted .feature-item {
    color: white;
  }

  .check-icon {
    color: #FA5014;
    font-weight: bold;
  }

  .pricing-card.highlighted .check-icon {
    color: #FA5014;
  }

  .btn {
    display: block;
    width: 100%;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-family: 'Exo 2', sans-serif;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
    transition: all 0.3s ease;
  }

  .btn-primary {
    background-color: #FA5014;
    color: white;
    border: 2px solid #FA5014;
  }

  .btn-primary:hover {
    background-color: #e04a12;
    border-color: #e04a12;
  }

  .btn-secondary {
    background-color: transparent;
    color: #000032;
    border: 2px solid #000032;
  }

  .btn-secondary:hover {
    background-color: #000032;
    color: white;
  }

  @media (max-width: 768px) {
    .pricing-card.highlighted {
      transform: none;
    }

    .pricing-card.highlighted:hover {
      transform: translateY(-5px);
    }
  }
</style>