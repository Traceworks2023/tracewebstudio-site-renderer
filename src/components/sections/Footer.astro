---
interface Link {
  label: string;
  url: string;
}

interface Column {
  title: string;
  links: Link[];
}

interface Props {
  columns?: Column[];
  companyName?: string;
  copyright?: string;
}

const {
  columns = [
    {
      title: "Product",
      links: [
        { label: "Features", url: "/features" },
        { label: "Pricing", url: "/pricing" },
        { label: "Templates", url: "/templates" },
        { label: "Integrations", url: "/integrations" },
      ],
    },
    {
      title: "Company",
      links: [
        { label: "About Us", url: "/about" },
        { label: "Careers", url: "/careers" },
        { label: "Press", url: "/press" },
        { label: "Contact", url: "/contact" },
      ],
    },
    {
      title: "Resources",
      links: [
        { label: "Help Center", url: "/help" },
        { label: "Blog", url: "/blog" },
        { label: "Community", url: "/community" },
        { label: "API Docs", url: "/api" },
      ],
    },
    {
      title: "Legal",
      links: [
        { label: "Privacy Policy", url: "/privacy" },
        { label: "Terms of Service", url: "/terms" },
        { label: "Cookie Policy", url: "/cookies" },
        { label: "GDPR", url: "/gdpr" },
      ],
    },
  ],
  companyName = "Tracewebstudio",
  copyright = `© ${new Date().getFullYear()} ${companyName}. All rights reserved.`,
} = Astro.props;
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-main">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-text">{companyName}</span>
        </a>
        <p class="footer-tagline">
          Build beautiful websites without code. The modern platform for creators and businesses.
        </p>
        <div class="social-links">
          <a href="https://twitter.com" class="social-link" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
            </svg>
          </a>
          <a href="https://facebook.com" class="social-link" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
          <a href="https://linkedin.com" class="social-link" aria-label="LinkedIn">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>
      <div class="footer-links">
        {columns.map((column) => (
          <div class="footer-column">
            <h4 class="footer-column-title">{column.title}</h4>
            <ul class="footer-list">
              {column.links.map((link) => (
                <li>
                  <a href={link.url} class="footer-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
    <div class="footer-bottom">
      <p class="copyright">{copyright}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #111827;
    color: white;
    padding: 4rem 2rem 2rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 1.5fr 3fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-logo {
    text-decoration: none;
  }

  .logo-text {
    font-family: 'Exo 2', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #FA5014;
  }

  .footer-tagline {
    color: rgba(255,255,255,0.7);
    margin: 1rem 0 1.5rem 0;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: #FA5014;
    transform: translateY(-3px);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .footer-column-title {
    font-family: 'Exo 2', sans-serif;
    font-size: 1rem;
    font-weight: 600;
    margin: 0 0 1rem 0;
    color: white;
  }

  .footer-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-list li {
    margin-bottom: 0.75rem;
  }

  .footer-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: #FA5014;
  }

  .footer-bottom {
    padding-top: 2rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    text-align: center;
  }

  .copyright {
    color: rgba(255,255,255,0.5);
    margin: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 968px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 576px) {
    .footer {
      padding: 3rem 1rem 1.5rem;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>