---
// CTA Banner - Call to Action with Level 4 Motion Effects
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    secondaryCtaText?: string;
    secondaryCtaUrl?: string;
    backgroundImage?: string;
    backgroundVideo?: string;
  };
  settings?: {
    variant?: 'centered' | 'left' | 'split' | 'floating';
    parallaxPreset?: 'none' | 'softBackgroundDrift' | 'foregroundFloat' | 'textOverMedia';
    motionLevel?: 1 | 2 | 3 | 4;
    showDecoration?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Ready to Get Started?',
  subtitle = 'Join thousands of satisfied customers and transform your business today.',
  ctaText = 'Start Free Trial',
  ctaUrl = '#',
  secondaryCtaText = 'Learn More',
  secondaryCtaUrl = '#',
  backgroundImage = 'https://images.unsplash.com/photo-1557804506-669a67965ba0?w=1920&q=80',
} = content;

const {
  variant = 'centered',
  parallaxPreset = 'foregroundFloat',
  motionLevel = 3,
  showDecoration = true,
  templateSlug = '',
} = settings;

const getTemplateLink = (link: string) => {
  if (!link || link === '#') return '#';
  if (link.startsWith('http')) return link;
  return `/${templateSlug}${link.startsWith('/') ? link : `/${link}`}`;
};
---

<section
  class={`cta-banner relative overflow-hidden py-24 md:py-32 ${variant === 'split' ? 'lg:min-h-[600px]' : ''}`}
  data-variant={variant}
  data-parallax={parallaxPreset}
  data-motion-level={motionLevel}
>
  {/* Background Layer */}
  <div class="cta-bg-layer absolute inset-0 will-change-transform">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${backgroundImage}')`}
    />
    <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-primary)] via-[var(--color-primary)]/95 to-[var(--color-primary)]/80" />
  </div>

  {/* Decorative Elements */}
  {showDecoration && (
    <div class="cta-decorations absolute inset-0 pointer-events-none overflow-hidden">
      <div class="deco-circle deco-1 absolute -top-20 -right-20 w-96 h-96 rounded-full bg-[var(--color-accent)]/10 blur-3xl" />
      <div class="deco-circle deco-2 absolute -bottom-32 -left-32 w-[500px] h-[500px] rounded-full bg-[var(--color-primary)]/10 blur-3xl" />
      <div class="deco-lines absolute inset-0 opacity-10">
        <div class="absolute top-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white to-transparent" />
        <div class="absolute bottom-0 left-0 w-full h-px bg-gradient-to-r from-transparent via-white to-transparent" />
      </div>
    </div>
  )}

  {/* Floating Shapes */}
  {motionLevel >= 4 && (
    <div class="floating-shapes absolute inset-0 pointer-events-none">
      <div class="floating-shape shape-1 absolute w-4 h-4 bg-[var(--color-accent)] top-1/4 left-1/4 rotate-45 animate-float" />
      <div class="floating-shape shape-2 absolute w-6 h-6 border-2 border-white/30 top-1/3 right-1/4 rounded-full animate-float-delayed" />
      <div class="floating-shape shape-3 absolute w-3 h-3 bg-[var(--color-primary)] bottom-1/4 left-1/3 animate-pulse" />
      <div class="floating-shape shape-4 absolute w-8 h-8 border border-white/20 bottom-1/3 right-1/3 rotate-12 animate-float" />
    </div>
  )}

  {/* Content Layer */}
  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
    {variant === 'split' ? (
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="text-left">
          <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight cta-title">
            {title}
          </h2>
          <p class="text-xl text-white/80 mb-8 cta-subtitle">
            {subtitle}
          </p>
          <div class="flex flex-wrap gap-4 cta-buttons">
            <a
              href={getTemplateLink(ctaUrl)}
              class="group relative inline-flex items-center gap-3 px-8 py-4 bg-[var(--color-accent)] text-white font-bold rounded-full overflow-hidden transition-all duration-300 hover:bg-[var(--color-primary)] hover:scale-105"
            >
              <span class="relative z-10">{ctaText}</span>
              <svg class="relative z-10 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a
              href={getTemplateLink(secondaryCtaUrl)}
              class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/40 text-white font-semibold rounded-full hover:border-white hover:bg-white/10 transition-all"
            >
              {secondaryCtaText}
            </a>
          </div>
        </div>
        <div class="hidden lg:block">
          <div class="cta-image-wrapper relative">
            <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-primary)] rounded-3xl transform rotate-6 scale-105 opacity-50" />
            <img
              src={backgroundImage}
              alt="CTA"
              class="relative rounded-3xl shadow-2xl transform -rotate-3 hover:rotate-0 transition-transform duration-500"
            />
          </div>
        </div>
      </div>
    ) : (
      <>
        <span class="inline-block px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-sm font-semibold text-white/80 mb-6 cta-badge">
          Limited Time Offer
        </span>
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight cta-title">
          {title}
        </h2>
        <p class="text-xl md:text-2xl text-white/80 mb-10 max-w-2xl mx-auto cta-subtitle">
          {subtitle}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center cta-buttons">
          <a
            href={getTemplateLink(ctaUrl)}
            class="group relative inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-[var(--color-primary)] font-bold rounded-full overflow-hidden transition-all duration-300 hover:scale-105 hover:shadow-2xl"
          >
            <span class="relative z-10">{ctaText}</span>
            <svg class="relative z-10 w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
            <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-primary)] translate-y-full group-hover:translate-y-0 transition-transform duration-300" />
          </a>
          <a
            href={getTemplateLink(secondaryCtaUrl)}
            class="group inline-flex items-center justify-center gap-2 px-10 py-5 border-2 border-white/40 text-white font-semibold rounded-full hover:border-white hover:bg-white/10 transition-all backdrop-blur-sm"
          >
            <span>{secondaryCtaText}</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </a>
        </div>

        {/* Trust Badges */}
        <div class="mt-12 flex flex-wrap items-center justify-center gap-8 text-white/60 cta-trust">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm">Free 14-day trial</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm">No credit card required</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span class="text-sm">Cancel anytime</span>
          </div>
        </div>
      </>
    )}
  </div>
</section>

<style>
  @keyframes float {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
  }

  @keyframes float-delayed {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(-5deg); }
  }

  @keyframes badge-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
  }

  .floating-shape {
    will-change: transform;
  }

  .shape-1 { animation: float 4s ease-in-out infinite; }
  .shape-2 { animation: float-delayed 5s ease-in-out infinite; }
  .shape-3 { animation: float 3s ease-in-out infinite 1s; }
  .shape-4 { animation: float-delayed 6s ease-in-out infinite 0.5s; }

  .cta-badge {
    animation: badge-pulse 3s ease-in-out infinite;
  }

  @keyframes cta-reveal {
    from {
      opacity: 0;
      transform: translateY(40px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cta-title {
    animation: cta-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }

  .cta-subtitle {
    animation: cta-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
    opacity: 0;
  }

  .cta-buttons {
    animation: cta-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
    opacity: 0;
  }

  .cta-badge {
    animation: cta-reveal 0.6s ease-out 0.1s forwards, badge-pulse 3s ease-in-out 1s infinite;
    opacity: 0;
  }

  .cta-trust {
    animation: cta-reveal 0.8s ease-out 0.6s forwards;
    opacity: 0;
  }

  /* Parallax effect */
  .cta-bg-layer {
    will-change: transform;
  }

  /* Level 4 enhancements */
  [data-motion-level="4"] .cta-image-wrapper img {
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-motion-level="4"] .cta-image-wrapper:hover img {
    transform: rotate(0deg) scale(1.05);
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.cta-banner') as HTMLElement;
    if (!section) return;

    const bgLayer = section.querySelector('.cta-bg-layer');
    const parallaxPreset = section.dataset.parallax || 'none';
    const motionLevel = parseInt(section.dataset.motionLevel || '3');

    // Parallax effect
    if (motionLevel >= 3 && parallaxPreset !== 'none') {
      ScrollTrigger.create({
        trigger: section,
        start: 'top bottom',
        end: 'bottom top',
        scrub: true,
        onUpdate: (self) => {
          if (bgLayer) {
            const progress = self.progress;
            switch (parallaxPreset) {
              case 'softBackgroundDrift':
                gsap.set(bgLayer, { yPercent: progress * 20 });
                break;
              case 'foregroundFloat':
                gsap.set(bgLayer, { yPercent: -progress * 15 });
                break;
              case 'textOverMedia':
                gsap.set(bgLayer, { scale: 1 + progress * 0.1 });
                break;
            }
          }
        },
      });
    }

    // Staggered reveal for CTA elements
    if (motionLevel >= 3) {
      gsap.from('.cta-title, .cta-subtitle, .cta-buttons, .cta-badge, .cta-trust', {
        opacity: 0,
        y: 40,
        duration: 0.8,
        stagger: 0.15,
        ease: 'power3.out',
        delay: 0.2,
      });
    }
  });
</script>