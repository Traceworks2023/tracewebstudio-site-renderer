---
// ProcessTimeline - Vertical timeline with SVG draw-on-scroll
// For portfolios that show a process (mehndi, tattoo, etc.)
interface TimelineStep {
  title: string;
  description: string;
  time?: string;
  icon?: string;
}

interface Props {
  content?: {
    title?: string;
    steps?: TimelineStep[];
  };
  settings?: {
    templateSlug?: string;
    motionLevel?: number;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'The Process',
  steps = [],
} = content;

const { templateSlug = '', motionLevel = 4 } = settings;
---

<section class="process-timeline">
  <div class="timeline-inner">
    {title && (<h2 class="timeline-title">{title}</h2>
    )}

    <div class="timeline-track">
      <svg class="timeline-line-svg" viewBox={`0 0 2 ${steps.length * 160}`} preserveAspectRatio="none">
        <line class="timeline-line-back" x1="1" y1="0" x2="1" y2={steps.length * 160} stroke="var(--color-border, #3d1f2b)" stroke-width="2" />
        <line class="timeline-line-draw" x1="1" y1="0" x2="1" y2={steps.length * 160} stroke="var(--color-accent, #c78d6e)" stroke-width="2" stroke-dasharray={steps.length * 160} stroke-dashoffset={steps.length * 160} />
      </svg>

      <div class="timeline-steps">
        {steps.map((step, i) => (
          <div class="timeline-step" data-index={i}>
            <div class="step-node">
              <div class="step-dot"></div>
            </div>
            <div class="step-content">
              <h3 class="step-title">{step.title}</h3>
              <p class="step-desc">{step.description}</p>
              {step.time && (
                <span class="step-time">{step.time}</span>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .process-timeline {
    padding: 120px 24px;
    background: var(--color-background, #1a0b12);
  }

  .timeline-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .timeline-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    color: var(--color-text, #f5efe7);
    text-align: center;
    margin-bottom: 72px;
    letter-spacing: -0.02em;
  }

  .timeline-track {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .timeline-line-svg {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 2px;
    height: 100%;
  }

  .timeline-line-draw {
    transition: stroke-dashoffset 0.1s linear;
  }

  .timeline-steps {
    display: flex;
    flex-direction: column;
    gap: 60px;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .timeline-step {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 40px;
  }

  .timeline-step:nth-child(odd) .step-content {
    grid-column: 1;
    text-align: right;
  }

  .timeline-step:nth-child(odd) .step-node {
    grid-column: 2;
  }

  .timeline-step:nth-child(even) .step-content {
    grid-column: 3;
    text-align: left;
  }

  .timeline-step:nth-child(even) .step-node {
    grid-column: 2;
  }

  .step-node {
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .step-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-accent, #c78d6e);
    border: 3px solid var(--color-background, #1a0b12);
    box-shadow: 0 0 0 2px var(--color-accent, #c78d6e);
    transition: all 0.4s ease;
  }

  .timeline-step.active .step-dot {
    transform: scale(1.4);
    box-shadow: 0 0 0 3px var(--color-accent, #c78d6e), 0 0 24px rgba(199, 141, 110, 0.3);
  }

  .step-content {
    padding: 24px;
    background: var(--color-surface, #2d131e);
    border: 1px solid var(--color-border, #3d1f2b);
    border-radius: var(--radius-md, 12px);
    transition: all 0.4s ease;
  }

  .timeline-step.active .step-content {
    border-color: var(--color-accent, #c78d6e);
    box-shadow: 0 8px 32px -8px rgba(199, 141, 110, 0.1);
  }

  .step-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--color-text, #f5efe7);
    margin-bottom: 8px;
  }

  .step-desc {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--color-text-muted, #b8a99a);
    margin-bottom: 12px;
  }

  .step-time {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent, #c78d6e);
    padding: 4px 12px;
    border: 1px solid var(--color-accent, #c78d6e);
    border-radius: 20px;
  }

  @media (max-width: 768px) {
    .timeline-step {
      grid-template-columns: auto 1fr;
      gap: 20px;
    }

    .timeline-step:nth-child(odd) .step-content,
    .timeline-step:nth-child(even) .step-content {
      grid-column: 2;
      text-align: left;
    }

    .timeline-step:nth-child(odd) .step-node,
    .timeline-step:nth-child(even) .step-node {
      grid-column: 1;
    }

    .timeline-line-svg {
      left: 10px;
    }

    .timeline-steps {
      gap: 40px;
    }

    .process-timeline {
      padding: 80px 20px;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.process-timeline').forEach((section) => {
    const lineDraw = section.querySelector('.timeline-line-draw');
    const steps = section.querySelectorAll('.timeline-step');
    const totalLength = steps.length * 160;

    if (lineDraw) {
      ScrollTrigger.create({
        trigger: section,
        start: 'top 70%',
        end: 'bottom 30%',
        scrub: 1,
        onUpdate: (self) => {
          const drawLength = totalLength * self.progress;
          lineDraw.setAttribute('stroke-dashoffset', totalLength - drawLength);
        },
      });
    }

    steps.forEach((step) => {
      ScrollTrigger.create({
        trigger: step,
        start: 'top 75%',
        onEnter: () => step.classList.add('active'),
        onLeaveBack: () => step.classList.remove('active'),
      });
    });
  });
</script>
