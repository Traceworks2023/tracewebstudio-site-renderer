---
// MehndiHero — Tailor-made for Indian mehndi/henna artists
// Cream/green palette, traditional serif, decorative henna border
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    description?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
    motionLevel?: number;
  };
}
const { content = {}, settings = {} } = Astro.props;
const { title = '', subtitle = '', description = '', ctaText = '', ctaUrl = '#', image = '' } = content;
---

<section class="mehndi-hero">
  <div class="hero-wrap">
    <div class="hero-text">
    <div class="dotted-rule">
      {Array.from({length: 24}).map((_, i) => (
        <svg key={i} width="18" height="6" viewBox="0 0 18 6">
          <circle cx="9" cy="3" r="2" fill="var(--color-accent,#c17817)" opacity="0.35"/>
        </svg>
      ))}
    </div>

      <h1 class="hero-title">{title}</h1>

      {subtitle && <p class="hero-subtitle">{subtitle}</p>}
      {description && <p class="hero-desc">{description}</p>}

      {ctaText && (
        <a href={ctaUrl} class="hero-cta">
          <span>{ctaText}</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H7M17 7V17"/></svg>
        </a>
      )}
    </div>

    <div class="hero-visual">
      <div class="mehndi-frame">
        <!-- Decorative corner paisleys (CSS-drawn simple arcs) -->
        <div class="corner corner-tl"></div>
        <div class="corner corner-tr"></div>
        <div class="corner corner-bl"></div>
        <div class="corner corner-br"></div>

        {image ? (
          <img src={image} alt={title} loading="eager" class="hero-img" />
        ) : (
          <div class="img-placeholder">
            <span class="placeholder-label">{title.toUpperCase()}</span>
            <span class="placeholder-sub">Traditional Bridal Mehndi</span>
          </div>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .mehndi-hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background: var(--color-background, #f5f0e6);
    position: relative;
    overflow: hidden;
  }
  /* Soft green glow */
  .mehndi-hero::before {
    content: '';
    position: absolute;
    top: 10%;
    left: -5%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(26,58,26,0.06), transparent 70%);
    pointer-events: none;
  }

  .hero-wrap {
    max-width: 1200px;
    margin: 0 auto;
    padding: 120px 24px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
    position: relative;
    z-index: 1;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .dotted-rule {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
    max-width: 320px;
    margin-bottom: 8px;
    opacity: 0.7;
  }

  .hero-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(3rem, 6vw, 5.2rem);
    font-weight: 300;
    line-height: 0.95;
    color: var(--color-text, #1a2e1a);
    letter-spacing: -0.01em;
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 1.3rem;
    color: var(--color-accent, #c17817);
    margin-top: -4px;
  }

  .hero-desc {
    font-family: var(--font-body, 'DM Sans', sans-serif);
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text-muted, #6b7a5e);
    max-width: 420px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 30px;
    background: var(--color-primary, #0d1f0d);
    color: var(--color-background, #f5f0e6);
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 8px;
    border-radius: var(--radius-sm, 6px);
  }
  .hero-cta:hover {
    background: var(--color-accent, #c17817);
    color: var(--color-background, #f5f0e6);
    transform: translateY(-2px);
  }
  .hero-cta svg { transition: transform 0.3s ease; }
  .hero-cta:hover svg { transform: translateX(4px); }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mehndi-frame {
    position: relative;
    width: 100%;
    max-width: 480px;
    aspect-ratio: 3/4;
    padding: 16px;
    border: 1px solid var(--color-border, #d4c9b0);
  }

  /* Decorative corners using border-radius arcs */
  .corner {
    position: absolute;
    width: 40px;
    height: 40px;
    border: 2px solid var(--color-accent, #c17817);
    opacity: 0.3;
  }
  .corner-tl { top: 0; left: 0; border-right: none; border-bottom: none; border-top-left-radius: 20px; }
  .corner-tr { top: 0; right: 0; border-left: none; border-bottom: none; border-top-right-radius: 20px; }
  .corner-bl { bottom: 0; left: 0; border-right: none; border-top: none; border-bottom-left-radius: 20px; }
  .corner-br { bottom: 0; right: 0; border-left: none; border-top: none; border-bottom-right-radius: 20px; }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: linear-gradient(135deg, var(--color-surface, #ebe4d4), var(--color-background, #f5f0e6));
  }
  .placeholder-label {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    letter-spacing: 0.15em;
    color: var(--color-accent, #c17817);
    opacity: 0.65;
  }
  .placeholder-sub {
    font-family: var(--font-heading);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-text-muted, #6b7a5e);
    opacity: 0.5;
  }

  @media (max-width: 900px) {
    .hero-wrap { grid-template-columns: 1fr; gap: 48px; padding: 80px 24px; }
    .hero-visual { order: -1; }
    .mehndi-frame { max-width: 340px; aspect-ratio: 1/1; }
  }
</style>
