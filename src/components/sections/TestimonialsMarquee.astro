---
// Testimonials Marquee - Continuous scrolling testimonials
interface Props {
  content?: {
    title?: string;
    testimonials?: Array<{
      name?: string;
      role?: string;
      company?: string;
      quote?: string;
      image?: string;
    }>;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'What People Say',
  testimonials = [
    { name: 'Sarah Chen', role: 'CEO', company: 'TechCorp', quote: 'Transformed our business with innovative solutions. Highly recommended!' },
    { name: 'Marcus Johnson', role: 'Director', company: 'Design Studio', quote: 'Professional, creative, and incredibly efficient. Exceeded all expectations.' },
    { name: 'Emily Watson', role: 'Founder', company: 'Startup Labs', quote: 'The attention to detail is remarkable. They truly understand our needs.' },
    { name: 'David Kim', role: 'Manager', company: 'Retail Co', quote: 'Outstanding results and great communication throughout the project.' },
    { name: 'Lisa Park', role: 'VP Marketing', company: 'BrandWorks', quote: 'A true partner in success. Their expertise is invaluable.' },
  ],
} = content;
---

<section class="testimonials-marquee py-24 bg-[var(--color-primary)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 mb-12">
    <div class="text-center">
      <span class="inline-block px-4 py-1.5 bg-white/10 text-white/80 text-sm font-semibold rounded-full mb-4">
        TESTIMONIALS
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">
        {title}
      </h2>
    </div>
  </div>

  {/* Marquee */}
  <div class="relative">
    <div class="flex animate-marquee">
      {[...testimonials, ...testimonials].map((testimonial, i) => (
        <div class="flex-shrink-0 w-[400px] px-4">
          <div class="bg-white rounded-2xl p-8 shadow-xl h-full">
            {/* Quote mark */}
            <div class="text-6xl text-[var(--color-accent)]/20 font-serif leading-none mb-4">"</div>

            {/* Quote */}
            <p class="text-[var(--color-text)] text-lg leading-relaxed mb-6">
              {testimonial.quote}
            </p>

            {/* Author */}
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-white font-bold">
                {testimonial.name.charAt(0)}
              </div>
              <div>
                <div class="font-bold text-[var(--color-primary)]">{testimonial.name}</div>
                <div class="text-sm text-[var(--color-text-muted)]">{testimonial.role}, {testimonial.company}</div>
              </div>
            </div>

            {/* Rating */}
            <div class="flex gap-1 mt-4">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .animate-marquee {
    animation: marquee 30s linear infinite;
  }
</style>