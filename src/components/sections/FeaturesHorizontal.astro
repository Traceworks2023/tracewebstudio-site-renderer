---
// Features Horizontal - Horizontal scrolling feature cards
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    features?: Array<{
      icon?: string;
      title?: string;
      description?: string;
    }>;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Our Features',
  subtitle = 'Everything you need to succeed',
  features = [
    { icon: '🚀', title: 'Fast Performance', description: 'Lightning quick load times and smooth interactions' },
    { icon: '🎨', title: 'Beautiful Design', description: 'Stunning visuals crafted with attention to detail' },
    { icon: '📱', title: 'Responsive', description: 'Perfectly adapts to any screen size' },
    { icon: '🔒', title: 'Secure', description: 'Enterprise-grade security built in' },
    { icon: '⚡', title: 'Easy Setup', description: 'Get started in minutes, not hours' },
    { icon: '💬', title: '24/7 Support', description: 'Always here when you need us' },
  ],
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="features-horizontal py-24 bg-[var(--color-surface)] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-sm font-semibold rounded-full mb-4">
        FEATURES
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-[var(--color-primary)] mb-4">
        {title}
      </h2>
      <p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    {/* Horizontal scroll container */}
    <div class="relative">
      {/* Gradient fade edges */}
      <div class="absolute left-0 top-0 bottom-0 w-24 bg-gradient-to-r from-[var(--color-surface)] to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-24 bg-gradient-to-l from-[var(--color-surface)] to-transparent z-10 pointer-events-none"></div>

      {/* Scrollable cards */}
      <div class="flex gap-6 overflow-x-auto pb-6 scrollbar-hide snap-x snap-mandatory">
        {features.map((feature, i) => (
          <div
            class="flex-shrink-0 w-72 snap-center"
          >
            <div class="h-full bg-white rounded-2xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 group border border-gray-100">
              {/* Icon */}
              <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] flex items-center justify-center text-3xl mb-6 group-hover:scale-110 transition-transform">
                {feature.icon}
              </div>

              {/* Content */}
              <h3 class="text-xl font-bold text-[var(--color-primary)] mb-3">
                {feature.title}
              </h3>
              <p class="text-[var(--color-text-muted)] leading-relaxed">
                {feature.description}
              </p>

              {/* Arrow */}
              <div class="mt-6 flex items-center gap-2 text-[var(--color-accent)] font-medium">
                <span>Learn more</span>
                <svg class="w-4 h-4 group-hover:translate-x-2 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </div>
          </div>
        ))}

        {/* CTA Card */}
        <div class="flex-shrink-0 w-72 snap-center">
          <div class="h-full rounded-2xl p-8 bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] flex flex-col justify-center items-center text-center">
            <h3 class="text-xl font-bold text-white mb-4">Ready to get started?</h3>
            <a
              href="#"
              class="inline-flex items-center gap-2 px-6 py-3 bg-white text-[var(--color-primary)] font-semibold rounded-full hover:shadow-lg transition-all"
            >
              Contact Us
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>