---
// Premium Footer - Multi-column, Newsletter, Social Links
interface FooterLink {
  label: string;
  href: string;
}

interface FooterColumn {
  title: string;
  links: FooterLink[];
}

interface Props {
  content?: {
    logo?: string;
    description?: string;
    columns?: FooterColumn[];
    socialLinks?: Array<{ platform: string; url: string }>;
    newsletterText?: string;
    newsletterPlaceholder?: string;
    newsletterButton?: string;
    bottomLinks?: FooterLink[];
  };
  settings?: {
    variant?: 'dark' | 'light' | 'gradient';
    showNewsletter?: boolean;
    showSocial?: boolean;
    showBottom?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  logo = 'Brand',
  description = 'Premium templates for modern businesses. Create stunning websites in minutes.',
  columns = [
    {
      title: 'Products',
      links: [
        { label: 'Templates', href: '#' },
        { label: 'Components', href: '#' },
        { label: 'Pricing', href: '#' },
        { label: 'Changelog', href: '#' },
      ],
    },
    {
      title: 'Resources',
      links: [
        { label: 'Documentation', href: '#' },
        { label: 'Tutorials', href: '#' },
        { label: 'Blog', href: '#' },
        { label: 'Support', href: '#' },
      ],
    },
    {
      title: 'Company',
      links: [
        { label: 'About', href: '#' },
        { label: 'Careers', href: '#' },
        { label: 'Contact', href: '#' },
        { label: 'Partners', href: '#' },
      ],
    },
    {
      title: 'Legal',
      links: [
        { label: 'Privacy', href: '#' },
        { label: 'Terms', href: '#' },
        { label: 'Cookies', href: '#' },
        { label: 'Licenses', href: '#' },
      ],
    },
  ],
  socialLinks = [
    { platform: 'twitter', url: '#' },
    { platform: 'github', url: '#' },
    { platform: 'linkedin', url: '#' },
    { platform: 'youtube', url: '#' },
  ],
  newsletterText = 'Subscribe to our newsletter for updates',
  newsletterPlaceholder = 'Enter your email',
  newsletterButton = 'Subscribe',
  bottomLinks = [
    { label: 'Privacy Policy', href: '#' },
    { label: 'Terms of Service', href: '#' },
    { label: 'Cookie Policy', href: '#' },
  ],
} = content;

const {
  variant = 'dark',
  showNewsletter = true,
  showSocial = true,
  showBottom = true,
  templateSlug = '',
} = settings;

const getTemplateLink = (link: string) => {
  if (!link || link === '#') return '#';
  if (link.startsWith('http')) return link;
  return `/${templateSlug}${link.startsWith('/') ? link : `/${link}`}`;
};

const variantClasses = {
  dark: 'bg-[var(--color-primary)] text-white',
  light: 'bg-gray-50 text-gray-900',
  gradient: 'bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-primary)]/90 text-white',
};

const socialIcons: Record<string, string> = {
  twitter: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
  github: 'M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z',
  linkedin: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  youtube: 'M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
};
---

<footer class={`premium-footer ${variantClasses[variant]}`}>
  <div class="max-w-7xl mx-auto px-6">
    {/* Main Footer */}
    <div class="py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-12">
      {/* Brand Column */}
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-6 group">
          <div class="w-12 h-12 bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-primary)] rounded-xl flex items-center justify-center text-white font-bold text-2xl group-hover:scale-110 transition-transform">
            {logo.charAt(0)}
          </div>
          <span class="text-2xl font-bold">{logo}</span>
        </a>

        <p class="text-white/70 mb-8 max-w-md leading-relaxed">
          {description}
        </p>

        {/* Social Links */}
        {showSocial && (
          <div class="flex items-center gap-4">
            {socialLinks.map((social) => (
              <a
                href={getTemplateLink(social.url)}
                class="social-link w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/70 hover:bg-white hover:text-[var(--color-primary)] transition-all hover:scale-110 hover:border-white"
                aria-label={social.platform}
              >
                <svg class="w-5 h-5" fill={social.platform === 'twitter' || social.platform === 'youtube' ? 'currentColor' : 'none'} stroke="currentColor" viewBox="0 0 24 24">
                  <path d={socialIcons[social.platform]} />
                </svg>
              </a>
            ))}
          </div>
        )}
      </div>

      {/* Link Columns */}
      {columns.map((column) => (
        <div>
          <h4 class="font-semibold text-lg mb-4">{column.title}</h4>
          <ul class="space-y-3">
            {column.links.map((link) => (
              <li>
                <a
                  href={getTemplateLink(link.href)}
                  class="footer-link text-white/60 hover:text-white transition-colors inline-flex items-center gap-2 group"
                >
                  <span>{link.label}</span>
                  <svg class="w-4 h-4 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    {/* Newsletter */}
    {showNewsletter && (
      <div class="py-12 border-t border-white/10">
        <div class="max-w-2xl mx-auto text-center">
          <h3 class="text-2xl font-bold mb-3">Stay Updated</h3>
          <p class="text-white/60 mb-8">{newsletterText}</p>
          <form class="newsletter-form flex flex-col sm:flex-row gap-4 max-w-lg mx-auto">
            <div class="flex-1 relative">
              <input
                type="email"
                placeholder={newsletterPlaceholder}
                class="newsletter-input w-full px-6 py-4 bg-white/10 border border-white/20 rounded-full text-white placeholder-white/50 focus:outline-none focus:border-[var(--color-accent)] focus:ring-2 focus:ring-[var(--color-accent)]/25 transition-all"
                required
              />
            </div>
            <button
              type="submit"
              class="newsletter-btn px-8 py-4 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-primary)] text-white font-semibold rounded-full hover:shadow-lg hover:shadow-[var(--color-accent)]/25 transition-all hover:scale-105 whitespace-nowrap"
            >
              {newsletterButton}
            </button>
          </form>
        </div>
      </div>
    )}

    {/* Bottom Bar */}
    {showBottom && (
      <div class="py-6 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white/50 text-sm">
          &copy; {new Date().getFullYear()} {logo}. All rights reserved.
        </p>
        <div class="flex items-center gap-6">
          {bottomLinks.map((link) => (
            <a href={getTemplateLink(link.href)} class="text-white/50 text-sm hover:text-white transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>

  {/* Decorative Elements */}
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-1/2 -right-1/4 w-96 h-96 bg-[var(--color-accent)]/10 rounded-full blur-3xl" />
    <div class="absolute -bottom-1/4 -left-1/4 w-64 h-64 bg-[var(--color-primary)]/10 rounded-full blur-3xl" />
  </div>
</footer>

<style>
  .premium-footer {
    position: relative;
    overflow: hidden;
  }

  .social-link {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .footer-link::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 0;
    height: 1px;
    background: currentColor;
    transition: width 0.3s ease;
  }

  .footer-link:hover::before {
    width: 100%;
  }

  .newsletter-input {
    transition: all 0.3s ease;
  }

  .newsletter-input:focus {
    background: rgba(255, 255, 255, 0.15);
  }

  .newsletter-btn {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .newsletter-btn:hover {
    transform: scale(1.05);
  }

  @keyframes float-decoration {
    0%, 100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(20px, -20px) scale(1.1);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('.newsletter-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const btn = form.querySelector('.newsletter-btn') as HTMLButtonElement;
      if (btn) {
        btn.textContent = 'Subscribed!';
        btn.classList.add('bg-green-500');
        setTimeout(() => {
          btn.textContent = 'Subscribe';
          btn.classList.remove('bg-green-500');
        }, 2000);
      }
    });
  });
</script>