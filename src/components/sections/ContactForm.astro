---
// Contact form section
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    buttonText?: string;
    showName?: boolean;
    showPhone?: boolean;
    showSubject?: boolean;
    backgroundColor?: string;
    buttonColor?: string;
  };
  settings?: {
    style?: 'default' | 'minimal' | 'split';
    image?: string;
    contactInfo?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const { 
  title = 'Get in Touch',
  subtitle = 'We\'d love to hear from you. Send us a message and we\'ll respond as soon as possible.',
  buttonText = 'Send Message',
  showName = true,
  showPhone = true,
  showSubject = true,
  backgroundColor = '#ffffff',
  buttonColor = '#000032'
} = content;

const { style = 'default', image = '', contactInfo = '' } = settings;
---

<section class="py-16 lg:py-24" style={`background-color: ${backgroundColor}`}>
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    {style === 'default' && (
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
          {subtitle && <p class="text-lg text-gray-600 mb-8">{subtitle}</p>}
          
          <form class="space-y-6">
            {showName && (
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                <input 
                  type="text" 
                  name="name"
                  placeholder="John Doe"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 outline-none transition"
                  required
                />
              </div>
            )}
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
              <input 
                type="email" 
                name="email"
                placeholder="john@example.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 outline-none transition"
                required
              />
            </div>
            
            {showPhone && (
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                <input 
                  type="tel" 
                name="phone"
                  placeholder="+91 98765 43210"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 outline-none transition"
                />
              </div>
            )}
            
            {showSubject && (
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">Subject</label>
                <input 
                  type="text" 
                  name="subject"
                  placeholder="How can we help?"
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 outline-none transition"
                  required
                />
              </div>
            )}
            
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Message</label>
              <textarea 
                name="message"
                rows={5}
                placeholder="Tell us more about your inquiry..."
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange focus:ring-2 focus:ring-orange/20 outline-none transition resize-none"
                required
              ></textarea>
            </div>
            
            <button 
              type="submit"
              class="w-full py-4 rounded-lg font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg"
              style={`background-color: ${buttonColor}`}
            >
              {buttonText}
            </button>
          </form>
        </div>
        
        {contactInfo && (
          <div class="lg:pl-12 border-l border-gray-200">
            <div class="prose text-gray-600" set:html={contactInfo} />
          </div>
        )}
      </div>
    )}
    
    {style === 'minimal' && (
      <div class="max-w-xl mx-auto">
        <div class="text-center mb-8">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
          {subtitle && <p class="text-lg text-gray-600">{subtitle}</p>}
        </div>
        
        <form class="space-y-4">
          <input 
            type="text" 
            name="name"
            placeholder="Your Name"
            class="w-full px-4 py-3 rounded-lg border-b-2 border-gray-200 focus:border-orange outline-none transition bg-transparent"
            required
          />
          <input 
            type="email" 
            name="email"
            placeholder="Your Email"
            class="w-full px-4 py-3 rounded-lg border-b-2 border-gray-200 focus:border-orange outline-none transition bg-transparent"
            required
          />
          <textarea 
            name="message"
            rows={4}
            placeholder="Your Message"
            class="w-full px-4 py-3 rounded-lg border-b-2 border-gray-200 focus:border-orange outline-none transition bg-transparent resize-none"
            required
          ></textarea>
          <button 
            type="submit"
            class="w-full py-4 rounded-lg font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg"
            style={`background-color: ${buttonColor}`}
          >
            {buttonText}
          </button>
        </form>
      </div>
    )}
    
    {style === 'split' && image && (
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <div class="rounded-2xl overflow-hidden">
          <img src={image} alt="Contact" class="w-full h-full object-cover" />
        </div>
        
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">{title}</h2>
          {subtitle && <p class="text-lg text-gray-600 mb-8">{subtitle}</p>}
          
          <form class="space-y-6">
            <input 
              type="text" 
              name="name"
              placeholder="Your Name"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange outline-none transition"
              required
            />
            <input 
              type="email" 
              name="email"
              placeholder="Your Email"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange outline-none transition"
              required
            />
            <textarea 
              name="message"
              rows={4}
              placeholder="Your Message"
              class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:border-orange outline-none transition resize-none"
              required
            ></textarea>
            <button 
              type="submit"
              class="px-8 py-4 rounded-lg font-semibold text-white transition hover:-translate-y-0.5 hover:shadow-lg"
              style={`background-color: ${buttonColor}`}
            >
              {buttonText}
            </button>
          </form>
        </div>
      </div>
    )}
  </div>
</section>

<script>
  // Handle contact form submission
  document.querySelectorAll('form').forEach(form => {
    if (!form.closest('section')?.querySelector('textarea')) return;
    
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());
      
      const btn = form.querySelector('button[type="submit"]');
      if (btn) {
        const originalText = btn.textContent;
        btn.textContent = 'Sending...';
        btn.disabled = true;
        
        // Simulate API call
        await new Promise(resolve => setTimeout(resolve, 1500));
        
        btn.textContent = 'Message Sent!';
        setTimeout(() => {
          btn.textContent = originalText;
          btn.disabled = false;
          form.reset();
        }, 3000);
      }
    });
  });
</script>
