---
// FAQ Section - Multiple variants with theme integration
// Supports variants: accordion, cards, minimal, two-column

interface FAQ {
  question: string;
  answer: string;
  category?: string;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    faqs?: FAQ[];
  };
  settings?: {
    variant?: 'accordion' | 'cards' | 'minimal' | 'two-column';
    backgroundStyle?: 'light' | 'dark' | 'gradient' | 'surface';
    motionLevel?: 1 | 2 | 3 | 4;
    allowMultiple?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Frequently Asked Questions',
  subtitle = 'Find answers to common questions',
  faqs = [
    { question: 'How do I get started?', answer: 'Simply sign up for a free account and you can start building your website immediately. No credit card required.' },
    { question: 'Can I use my own domain?', answer: 'Yes! You can connect any domain you own to your website. We provide free SSL certificates for all custom domains.' },
    { question: 'What payment methods do you accept?', answer: 'We accept all major credit cards, PayPal, and bank transfers for annual plans.' },
    { question: 'Can I cancel anytime?', answer: 'Yes, you can cancel your subscription at any time. No long-term contracts required.' },
    { question: 'Do you offer support?', answer: 'We offer 24/7 email support for all plans. Professional and Enterprise plans include priority phone support.' },
  ],
} = content;

const {
  variant = 'accordion',
  backgroundStyle = 'light',
  motionLevel = 2,
  allowMultiple = false,
} = settings;

const sectionId = `faq-${Math.random().toString(36).slice(2, 9)}`;

const bgClasses = {
  light: 'bg-gray-50',
  dark: 'bg-gray-900 text-white',
  gradient: 'bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-secondary)] text-white',
  surface: 'bg-white',
};
---

<section
  id={sectionId}
  class={`faq-section faq-variant-${variant} ${bgClasses[backgroundStyle]}`}
  data-variant={variant}
  data-motion-level={motionLevel}
  data-allow-multiple={allowMultiple}
>
  <div class="faq-container max-w-4xl mx-auto px-6 py-20">
    {(title || subtitle) && (
      <div class="faq-header text-center mb-16">
        {title && <h2 class="faq-title text-4xl md:text-5xl font-bold mb-4">{title}</h2>}
        {subtitle && <p class="faq-subtitle text-lg opacity-80">{subtitle}</p>}
      </div>
    )}

    {/* Accordion Variant */}
    {variant === 'accordion' && (
      <div class="faq-accordion space-y-4">
        {faqs.map((faq, index) => (
          <details class="faq-item group bg-white rounded-xl border border-gray-200 overflow-hidden" data-faq-index={index}>
            <summary class="faq-question flex items-center justify-between p-6 cursor-pointer list-none">
              <span class="faq-question-text text-lg font-semibold text-gray-900 pr-4">{faq.question}</span>
              <span class="faq-toggle w-8 h-8 flex-shrink-0 rounded-full bg-[var(--color-primary)]/10 flex items-center justify-center transition-transform group-open:rotate-180">
                <svg class="w-4 h-4 text-[var(--color-primary)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <div class="faq-answer px-6 pb-6">
              <p class="text-gray-600 leading-relaxed">{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    )}

    {/* Cards Variant */}
    {variant === 'cards' && (
      <div class="faq-cards grid md:grid-cols-2 gap-6">
        {faqs.map((faq, index) => (
          <div class="faq-card bg-white rounded-2xl p-8 shadow-sm hover:shadow-lg transition-shadow" data-faq-index={index}>
            <h3 class="faq-card-question text-xl font-bold mb-4 text-gray-900">{faq.question}</h3>
            <p class="faq-card-answer text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    )}

    {/* Minimal Variant */}
    {variant === 'minimal' && (
      <div class="faq-minimal space-y-6">
        {faqs.map((faq, index) => (
          <div class="faq-minimal-item py-6 border-b border-gray-200 last:border-0" data-faq-index={index}>
            <h3 class="faq-minimal-question text-lg font-bold mb-3 text-gray-900">{faq.question}</h3>
            <p class="faq-minimal-answer text-gray-600 leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    )}

    {/* Two Column Variant */}
    {variant === 'two-column' && (
      <div class="faq-two-column grid md:grid-cols-2 gap-x-12 gap-y-8">
        {faqs.map((faq, index) => (
          <div class="faq-two-col-item" data-faq-index={index}>
            <h3 class="faq-two-col-question text-lg font-bold mb-3 text-gray-900 flex items-start gap-3">
              <span class="faq-two-col-icon w-6 h-6 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </span>
              {faq.question}
            </h3>
            <p class="faq-two-col-answer text-gray-600 leading-relaxed pl-9">{faq.answer}</p>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  .faq-section {
    position: relative;
  }

  .faq-title {
    font-family: var(--font-heading);
    color: inherit;
  }

  .faq-subtitle {
    font-family: var(--font-body);
  }

  /* Accordion styles */
  .faq-item {
    transition: box-shadow 0.3s ease, border-color 0.3s ease;
  }

  .faq-item:hover {
    border-color: var(--color-primary);
  }

  .faq-item[open] {
    border-color: var(--color-primary);
    box-shadow: 0 4px 20px rgba(var(--color-primary-rgb, 0, 0, 0), 0.1);
  }

  .faq-question-text {
    font-family: var(--font-heading);
  }

  .faq-answer {
    font-family: var(--font-body);
  }

  /* Cards variant */
  .faq-card {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .faq-card:hover {
    transform: translateY(-4px);
  }

  .faq-card-question {
    font-family: var(--font-heading);
  }

  .faq-card-answer {
    font-family: var(--font-body);
  }

  /* Two column */
  .faq-two-col-question {
    font-family: var(--font-heading);
  }

  .faq-two-col-answer {
    font-family: var(--font-body);
  }

  /* Motion */
  [data-motion-level="3"] .faq-item,
  [data-motion-level="4"] .faq-item {
    opacity: 0;
    transform: translateY(20px);
    animation: faq-stagger 0.5s ease-out forwards;
  }

  [data-motion-level="3"] .faq-item:nth-child(1),
  [data-motion-level="4"] .faq-item:nth-child(1) { animation-delay: 0.1s; }
  [data-motion-level="3"] .faq-item:nth-child(2),
  [data-motion-level="4"] .faq-item:nth-child(2) { animation-delay: 0.2s; }
  [data-motion-level="3"] .faq-item:nth-child(3),
  [data-motion-level="4"] .faq-item:nth-child(3) { animation-delay: 0.3s; }
  [data-motion-level="3"] .faq-item:nth-child(4),
  [data-motion-level="4"] .faq-item:nth-child(4) { animation-delay: 0.4s; }
  [data-motion-level="3"] .faq-item:nth-child(5),
  [data-motion-level="4"] .faq-item:nth-child(5) { animation-delay: 0.5s; }

  @keyframes faq-stagger {
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.faq-section').forEach((section) => {
      const el = section as HTMLElement;
      const allowMultiple = el.dataset.allowMultiple !== 'true';

      el.querySelectorAll('details').forEach((details) => {
        details.addEventListener('toggle', (e) => {
          if (!allowMultiple && (e.target as HTMLElement).open) {
            el.querySelectorAll('details').forEach((d) => {
              if (d !== e.target) d.open = false;
            });
          }
        });
      });
    });
  });
</script>