---
// Hero Split - Bold asymmetric layout with large typography
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
    badgeText?: string;
    description?: string;
    stats?: Array<{ value: string; label: string }>;
  };
  settings?: {
    templateSlug?: string;
    motionLevel?: number;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Welcome',
  subtitle = '',
  ctaText = 'Get Started',
  ctaUrl = '#',
  image = '',
  badgeText = '',
  description = '',
  stats = [],
} = content;

const { templateSlug = '' } = settings;
---

<section class="hero-split min-h-screen flex items-center relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-background, #1a0b12), var(--color-secondary, #4a1c2a));">
  {/* Decorative elements */}
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-72 h-72 rounded-full blur-3xl" style="background: var(--color-text, #f5efe7);"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 rounded-full blur-3xl" style="background: var(--color-accent, #c78d6e);"></div>
  </div>

  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white/5 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      {/* Content */}
      <div class="space-y-8">
        {badgeText && (
          <div class="inline-flex items-center gap-2 px-4 py-2 backdrop-blur-sm rounded-full" style="background: var(--color-surface, #2d131e);">
            <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--color-accent, #c78d6e);"></span>
            <span class="text-sm font-medium" style="color: var(--color-text-muted, #b8a99a);">{badgeText}</span>
          </div>
        )}

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.9] tracking-tight" style="color: var(--color-text, #f5efe7);">
          {title}
        </h1>

        {subtitle && (
          <p class="text-xl max-w-lg leading-relaxed" style="color: var(--color-text-muted, #b8a99a);">
            {subtitle}
          </p>
        )}

        {description && (
          <p class="text-lg max-w-lg leading-relaxed" style="color: var(--color-text-muted, #b8a99a);">
            {description}
          </p>
        )}

        {ctaText && (
          <div class="flex flex-wrap gap-4">
            <a
              href={ctaUrl}
              class="group inline-flex items-center gap-3 px-8 py-4 font-bold rounded-full transition-all duration-300 hover:-translate-y-1"
              style="background: var(--color-text, #f5efe7); color: var(--color-primary, #1a0b12);"
            >
              <span>{ctaText}</span>
              <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
          </div>
        )}

        {stats.length > 0 && (
          <div class="flex gap-12 pt-8" style="border-top: 1px solid var(--color-border, #3d1f2b);">
            {stats.map(s => (
              <div>
                <div class="text-3xl font-bold" style="color: var(--color-text, #f5efe7);">{s.value}</div>
                <div class="text-sm" style="color: var(--color-text-muted, #b8a99a);">{s.label}</div>
              </div>
            ))}
          </div>
        )}
      </div>

      {/* Image */}
      <div class="relative">
        <div class="absolute -inset-4 rounded-3xl blur-xl opacity-50" style="background: linear-gradient(to right, var(--color-accent, #c78d6e), var(--color-primary, #1a0b12));"></div>
        <div class="relative rounded-3xl overflow-hidden shadow-2xl">
          {image ? (
            <img src={image} alt={title} class="w-full h-[500px] object-cover" loading="eager" />
          ) : (
            <div class="w-full h-[500px] flex items-center justify-center" style="background: var(--color-surface, #2d131e);">
              <span class="text-6xl font-light opacity-30" style="color: var(--color-text, #f5efe7);">{title.charAt(0)}</span>
            </div>
          )}
        </div>
      </div>
    </div>
  </div>
</section>