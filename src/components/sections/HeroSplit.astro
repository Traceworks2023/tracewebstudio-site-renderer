---
// Hero Split - Bold asymmetric layout with large typography
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    image?: string;
    badgeText?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Welcome',
  subtitle = '',
  ctaText = 'Get Started',
  ctaUrl = '#',
  image = 'https://images.unsplash.com/photo-1497366216548-37526070297c?w=1200',
  badgeText = '',
} = content;

const templateSlug = settings.templateSlug || '';
---

<section class="hero-split min-h-screen flex items-center bg-gradient-to-br from-[var(--color-primary)] via-[var(--color-secondary)] to-[var(--color-primary)] relative overflow-hidden">
  {/* Decorative elements */}
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-20 left-10 w-72 h-72 bg-white rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-[var(--color-accent)] rounded-full blur-3xl"></div>
  </div>

  <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-white/5 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      {/* Content */}
      <div class="space-y-8">
        {badgeText && (
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/10 backdrop-blur-sm rounded-full">
            <span class="w-2 h-2 bg-[var(--color-accent)] rounded-full animate-pulse"></span>
            <span class="text-white/80 text-sm font-medium">{badgeText}</span>
          </div>
        )}

        <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold text-white leading-[0.9] tracking-tight">
          {title}
        </h1>

        <p class="text-xl text-white/70 max-w-lg leading-relaxed">
          {subtitle}
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href={ctaUrl}
            class="group inline-flex items-center gap-3 px-8 py-4 bg-white text-[var(--color-primary)] font-bold rounded-full hover:shadow-2xl transition-all duration-300 hover:-translate-y-1"
          >
            <span>{ctaText}</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a
            href="#"
            class="inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full hover:bg-white/10 transition-all"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Watch Demo
          </a>
        </div>

        {/* Stats */}
        <div class="flex gap-12 pt-8 border-t border-white/10">
          <div>
            <div class="text-3xl font-bold text-white">500+</div>
            <div class="text-white/50 text-sm">Projects</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white">98%</div>
            <div class="text-white/50 text-sm">Satisfaction</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white">24/7</div>
            <div class="text-white/50 text-sm">Support</div>
          </div>
        </div>
      </div>

      {/* Image */}
      <div class="relative">
        <div class="absolute -inset-4 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-primary)] rounded-3xl blur-xl opacity-50"></div>
        <div class="relative rounded-3xl overflow-hidden shadow-2xl">
          <img src={image} alt={title} class="w-full h-[500px] object-cover" />
          <div class="absolute inset-0 bg-gradient-to-t from-[var(--color-primary)]/50 to-transparent"></div>
        </div>

        {/* Floating badge */}
        <div class="absolute -bottom-6 -left-6 bg-white rounded-2xl shadow-xl p-4 flex items-center gap-3">
          <div class="w-12 h-12 bg-gradient-to-br from-[var(--color-accent)] to-[var(--color-primary)] rounded-full flex items-center justify-center text-white text-xl">✓</div>
          <div>
            <div class="font-bold text-gray-900">Trusted</div>
            <div class="text-gray-500 text-sm">by 10k+ clients</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>