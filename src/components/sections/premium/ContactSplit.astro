---
interface Props {
  content?: {
    title?: string;
    description?: string;
    email?: string;
    phone?: string;
    location?: string;
    image?: string;
  };
  settings?: {
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Get in Touch',
  description = 'For bookings, collaborations, or inquiries',
  email = 'hello@luminastudios.com',
  phone = '+1 (212) 555-0147',
  location = 'New York Studio\n45 West 21st Street\nNew York, NY 10010',
  image = 'https://images.unsplash.com/photo-1531746020798-e6953c6e8e04?w=800&q=80',
} = content;

const templateSlug = settings.templateSlug || '';
const sectionId = `contact-${Math.random().toString(36).slice(2, 9)}`;
---

<section id={sectionId} class="contact-section">
  <div class="contact-grid">
    <div class="contact-info">
      <span class="contact-tag">Contact</span>
      <h2 class="contact-title">{title}</h2>
      <p class="contact-description">{description}</p>

      <div class="contact-details">
        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <span class="contact-label">Email</span>
            <a href={`mailto:${email}`} class="contact-value">{email}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <span class="contact-label">Phone</span>
            <a href={`tel:${phone}`} class="contact-value">{phone}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
          <div>
            <span class="contact-label">Studio</span>
            <span class="contact-value location">{location}</span>
          </div>
        </div>
      </div>

      <form class="contact-form">
        <div class="form-row">
          <input type="text" placeholder="Name" required />
          <input type="email" placeholder="Email" required />
        </div>
        <input type="text" placeholder="Subject" />
        <textarea placeholder="Message" rows="5" required></textarea>
        <button type="submit" class="form-submit">
          <span>Send Message</span>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </button>
      </form>
    </div>

    <div class="contact-image">
      <img src={image} alt={title} />
    </div>
  </div>
</section>

<style>
  .contact-section {
    padding: 120px 24px;
    background: #0a0a0a;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    max-width: 1400px;
    margin: 0 auto;
    align-items: center;
  }

  .contact-tag {
    display: inline-block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #c9a962;
    margin-bottom: 1.5rem;
  }

  .contact-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: #ffffff;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .contact-description {
    font-family: 'Inter', sans-serif;
    font-size: 1.125rem;
    color: #888888;
    margin-bottom: 48px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
  }

  .contact-item {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: #141414;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
    color: #c9a962;
  }

  .contact-label {
    display: block;
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    color: #888888;
    margin-bottom: 4px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .contact-value {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    color: #ffffff;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .contact-value:hover {
    color: #c9a962;
  }

  .contact-value.location {
    white-space: pre-line;
    line-height: 1.6;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .contact-form input,
  .contact-form textarea {
    width: 100%;
    padding: 16px 20px;
    background: #141414;
    border: 1px solid #2a2a2a;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    color: #ffffff;
    transition: border-color 0.3s ease;
  }

  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: #666666;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: #c9a962;
  }

  .form-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px 32px;
    background: #c9a962;
    color: #0a0a0a;
    font-family: 'Inter', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-top: 8px;
  }

  .form-submit:hover {
    background: #e8d5a3;
    transform: translateY(-2px);
  }

  .form-submit svg {
    width: 18px;
    height: 18px;
  }

  .contact-image {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
  }

  .contact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 4/5;
  }

  @media (max-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }

    .contact-image {
      order: -1;
    }
  }

  @media (max-width: 640px) {
    .contact-section {
      padding: 80px 16px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.contact-section').forEach((section) => {
    const info = section.querySelector('.contact-info');
    const image = section.querySelector('.contact-image');

    gsap.fromTo(info,
      { opacity: 0, x: -40 },
      { opacity: 1, x: 0, duration: 0.8, ease: 'power3.out' }
    );

    gsap.fromTo(image,
      { opacity: 0, x: 40 },
      { opacity: 1, x: 0, duration: 0.8, ease: 'power3.out', delay: 0.2 }
    );
  });
</script>