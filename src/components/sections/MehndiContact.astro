---
// MehndiContact — Vertical card stack with henna-inspired top border of dots
interface Props {
  content?: { title?: string; phone?: string; whatsapp?: string; email?: string; instagram?: string; location?: string; availability?: string; };
  settings?: { templateSlug?: string; motionLevel?: number; };
}
const { content = {}, settings = {} } = Astro.props;
const { title = 'Book a Session', phone = '+91 98765 43210', whatsapp = '+91 98765 43210', email = 'hello@hennaheritage.in', instagram = '@hennaheritage', location = 'Delhi \u00b7 Jaipur \u00b7 Gurgaon', availability = 'Booking 2 weeks in advance recommended for bridal' } = content;
const items = [
  { label: 'Phone',    value: phone,     href: `tel:${phone.replace(/\s/g,'')}`, icon: 'phone' },
  { label: 'WhatsApp', value: whatsapp,  href: `https://wa.me/${whatsapp.replace(/\D/g,'')}`, icon: 'whatsapp' },
  { label: 'Email',    value: email,     href: `mailto:${email}`, icon: 'email' },
  { label: 'Instagram',value: instagram, href: `https://instagram.com/${instagram.replace('@','')}`, icon: 'instagram' },
];
---
<section id="contact" class="mehndi-contact">
  <div class="inner">
    {/* Henna-inspired dotted border top */}
    <div class="henna-border" set:html={Array.from({length:40}).map((_,i)=>
      `<circle cx="${i*24+12}" cy="6" r="2.5" fill="var(--color-accent)" opacity="0.35"/>`
    ).join('')}><svg width="960" height="12" viewBox="0 0 960 12" xmlns="http://www.w3.org/2000/svg"></svg></div>

    <h2 class="title">{title}</h2>
    <p class="avail">{availability}</p>
    <div class="cards">
      {items.map((it,i)=>(
        <a href={it.href} target={it.href?.startsWith('http')?'_blank':undefined} rel="noopener" class="card" key={i}>
          <span class="dot" style={`background:var(--color-accent,#c17817)`}></span>
          <div class="body">
            <span class="label">{it.label}</span>
            <span class="val">{it.value}</span>
          </div>
          <svg class="arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      ))}
    </div>
    <p class="loc">{location}</p>
  </div>
</section>
<style>
  .mehndi-contact { padding:120px 24px; background:var(--color-background,#f5f0e6); }
  .inner { max-width:560px; margin:0 auto; text-align:center; }
  .henna-border { display:flex; justify-content:center; margin-bottom:48px; opacity:0.5; }
  .title { font-family:var(--font-heading,'Cormorant Garamond',serif); font-size:clamp(2rem,4vw,3rem); font-weight:300; color:var(--color-text,#1a2e1a); margin-bottom:8px; }
  .avail { font-family:var(--font-body,'DM Sans',sans-serif); font-size:0.85rem; color:var(--color-text-muted,#6b7a5e); margin-bottom:48px; }
  .cards { display:flex; flex-direction:column; gap:12px; }
  .card { display:flex; align-items:center; gap:18px; padding:24px 28px; text-decoration:none; color:inherit; border:1px solid var(--color-border,#d4c9b0); border-radius:var(--radius-md,12px); background:var(--color-surface,#ebe4d4); transition:all .35s cubic-bezier(.16,1,.3,1); }
  .card:hover { transform:translateX(6px); border-color:var(--color-accent,#c17817); box-shadow:0 8px 28px -8px rgba(193,120,23,0.12); }
  .dot { width:10px; height:10px; border-radius:50%; flex-shrink:0; opacity:0.7; }
  .body { flex:1; display:flex; flex-direction:column; gap:2px; text-align:left; }
  .label { font-family:var(--font-heading); font-style:italic; font-size:0.8rem; color:var(--color-text-muted,#6b7a5e); letter-spacing:0.04em; }
  .val { font-family:var(--font-body); font-size:1rem; font-weight:500; color:var(--color-text,#1a2e1a); }
  .arrow { width:16px; height:16px; color:var(--color-text-muted,#6b7a5e); opacity:0; transform:translateX(-8px); transition:all .3s ease; }
  .card:hover .arrow { opacity:1; transform:translateX(0); color:var(--color-accent,#c17817); }
  .loc { margin-top:48px; font-family:var(--font-heading); font-style:italic; font-size:1rem; color:var(--color-text-muted,#6b7a5e); }
  @media(max-width:640px){ .mehndi-contact{padding:80px 16px;} .card{padding:20px 22px;} }
</style>
