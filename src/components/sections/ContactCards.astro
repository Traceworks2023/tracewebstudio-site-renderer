---
// ContactCards - Portfolio contact section with no form
// Phone, WhatsApp, Email, Instagram — horizontal row or stacked
// Designed for Indian creative professionals
interface Props {
  content?: {
    title?: string;
    phone?: string;
    whatsapp?: string;
    email?: string;
    instagram?: string;
    location?: string;
    availability?: string;
  };
  settings?: {
    variant?: 'horizontal' | 'vertical' | 'grid';
    templateSlug?: string;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Get in Touch',
  phone = '+91 98765 43210',
  whatsapp = '+91 98765 43210',
  email = 'hello@studio.in',
  instagram = '@studio',
  location = 'Mumbai · Delhi · Jaipur',
  availability = 'Booking open for 2025-26 season',
} = content;

const { variant = 'horizontal', templateSlug = '' } = settings;
---

<section id="contact" class={`contact-cards ${variant}`}>
  <div class="contact-inner">
    <h2 class="contact-title">{title}</h2>
    <p class="contact-availability">{availability}</p>

    <div class="contact-items">
      {phone && (
        <a href={`tel:${phone.replace(/\s/g, '')}`} class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <span class="contact-label">Phone</span>
          <span class="contact-value">{phone}</span>
        </a>
      )}

      {whatsapp && (
        <a href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="contact-item">
          <div class="contact-icon whatsapp">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
            </svg>
          </div>
          <span class="contact-label">WhatsApp</span>
          <span class="contact-value">{whatsapp}</span>
        </a>
      )}

      {email && (
        <a href={`mailto:${email}`} class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <span class="contact-label">Email</span>
          <span class="contact-value">{email}</span>
        </a>
      )}

      {instagram && (
        <a href={`https://instagram.com/${instagram.replace('@','')}`} target="_blank" rel="noopener" class="contact-item">
          <div class="contact-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </div>
          <span class="contact-label">Instagram</span>
          <span class="contact-value">{instagram}</span>
        </a>
      )}
    </div>

    {location && (
      <p class="contact-location">{location}</p>
    )}
  </div>
</section>

<style>
  .contact-cards {
    padding: 100px 24px;
    background: var(--color-background, #1a0b12);
  }

  .contact-inner {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--color-text, #f5efe7);
    margin-bottom: 12px;
    letter-spacing: -0.02em;
  }

  .contact-availability {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    color: var(--color-accent, #c78d6e);
    margin-bottom: 60px;
    letter-spacing: 0.05em;
  }

  .contact-items {
    display: flex;
    justify-content: center;
    align-items: stretch;
    gap: 0;
    border: 1px solid var(--color-border, #3d1f2b);
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    background: var(--color-surface, #2d131e);
  }

  .contact-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 40px 24px;
    text-decoration: none;
    color: inherit;
    transition: background 0.4s ease, transform 0.3s ease;
    position: relative;
  }

  .contact-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 20%;
    height: 60%;
    width: 1px;
    background: var(--color-border, #3d1f2b);
  }

  .contact-item:hover {
    background: rgba(199, 141, 110, 0.05);
    transform: translateY(-4px);
  }

  .contact-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border, #3d1f2b);
    border-radius: 50%;
    color: var(--color-accent, #c78d6e);
    transition: all 0.4s ease;
  }

  .contact-item:hover .contact-icon {
    border-color: var(--color-accent, #c78d6e);
    background: rgba(199, 141, 110, 0.1);
    transform: scale(1.08);
  }

  .contact-icon svg {
    width: 20px;
    height: 20px;
  }

  .contact-label {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--color-text-muted, #b8a99a);
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text, #f5efe7);
  }

  .contact-location {
    margin-top: 48px;
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--color-text-muted, #b8a99a);
    letter-spacing: 0.03em;
  }

  @media (max-width: 768px) {
    .contact-items {
      flex-direction: column;
      border-radius: var(--radius-md, 12px);
    }

    .contact-item {
      padding: 28px 16px;
      flex-direction: row;
      justify-content: flex-start;
      gap: 16px;
    }

    .contact-item:not(:last-child)::after {
      display: none;
    }

    .contact-item:not(:last-child) {
      border-bottom: 1px solid var(--color-border, #3d1f2b);
    }

    .contact-label {
      font-size: 0.8rem;
    }

    .contact-value {
      font-size: 0.9rem;
    }
  }
</style>
