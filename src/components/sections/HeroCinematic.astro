---
// Cinematic Hero with Level 4 Motion - Multi-layer Parallax & Pinned Storytelling
interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    ctaText?: string;
    ctaUrl?: string;
    badgeText?: string;
    slides?: Array<{
      image: string;
      title?: string;
      subtitle?: string;
      ctaText?: string;
      ctaUrl?: string;
    }>;
    overlayOpacity?: number;
  };
  settings?: {
    motionLevel?: 1 | 2 | 3 | 4;
    parallaxPreset?: 'none' | 'softBackgroundDrift' | 'layeredDepth' | 'foregroundFloat' | 'pinnedStorytelling' | 'videoHero';
    autoplay?: boolean;
    autoplayDelay?: number;
    height?: 'full' | 'large' | 'medium';
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Welcome',
  subtitle = '',
  ctaText = 'Get Started',
  ctaUrl = '#',
  badgeText = '',
  slides: contentSlides,
  image: fallbackImage,
  overlayOpacity = 0.5,
} = content;

// Use content slides if provided, otherwise create from single image or use default
const slides = contentSlides?.length
  ? contentSlides
  : fallbackImage
    ? [{ image: fallbackImage }]
    : [
        { image: 'https://images.unsplash.com/photo-1469334031218-e382a71b716b?w=1920&q=80' },
        { image: 'https://images.unsplash.com/photo-1483985988355-763728e1935b?w=1920&q=80' },
        { image: 'https://images.unsplash.com/photo-1445205170230-053b83016050?w=1920&q=80' }
      ];

const {
  motionLevel = 4,
  parallaxPreset = 'layeredDepth',
  autoplay = true,
  autoplayDelay = 6000,
  height = 'full',
  templateSlug = '',
} = settings;

const getTemplateLink = (link: string) => {
  if (!link || link === '#') return '#';
  if (link.startsWith('http')) return link;
  return `/${templateSlug}${link.startsWith('/') ? link : `/${link}`}`;
};

const heightClass = height === 'full' ? 'h-screen' : height === 'large' ? 'h-[90vh]' : 'h-[70vh]';
---

<section
  class={`hero-cinematic relative w-full ${heightClass} overflow-hidden`}
  data-motion-level={motionLevel}
  data-parallax={parallaxPreset}
  data-autoplay={autoplay}
  data-delay={autoplayDelay}
>
  {/* Background Layer - Parallax */}
  <div class="hero-bg-layer absolute inset-0 will-change-transform">
    {slides.map((slide, index) => (
      <div
        class={`hero-bg-slide absolute inset-0 bg-cover bg-center transition-opacity duration-[1500ms] ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
        data-index={index}
        data-image={slide.image}
      />
    ))}
    {/* Overlay */}
    <div class="absolute inset-0 bg-gradient-to-b from-black/40 via-black/20 to-black/60" style={`opacity: ${overlayOpacity}`} />
  </div>

  {/* Mid Layer - Floating Elements */}
  <div class="hero-mid-layer absolute inset-0 pointer-events-none">
    <div class="floating-shape shape-1 absolute w-64 h-64 rounded-full bg-gradient-to-br from-[var(--color-accent)]/10 to-transparent blur-3xl top-20 left-10 animate-float-slow" />
    <div class="floating-shape shape-2 absolute w-96 h-96 rounded-full bg-gradient-to-br from-[var(--color-primary)]/10 to-transparent blur-3xl bottom-20 right-10 animate-float-medium" />
    <div class="floating-shape shape-3 absolute w-48 h-48 rounded-full bg-gradient-to-br from-white/5 to-transparent blur-2xl top-1/3 right-1/4 animate-float-fast" />
  </div>

  {/* Content Layer */}
  <div class="hero-content-layer relative z-10 flex items-center justify-center w-full h-full">
    <div class="hero-slider-container max-w-7xl mx-auto px-6 w-full">
      {slides.map((slide, index) => (
        <div
          class={`hero-slide absolute inset-0 flex items-center justify-center transition-all duration-1000 ${index === 0 ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'}`}
          data-index={index}
        >
          <div class="slide-content text-center text-white max-w-4xl">
            {/* Badge */}
            {badgeText && index === 0 && (
              <div class="hero-badge inline-block px-4 py-1.5 bg-white/10 backdrop-blur-sm rounded-full text-sm font-medium mb-6 animate-fade-in" data-delay="300">
                <span class="text-[var(--color-accent)] mr-2">✦</span>
                {badgeText}
              </div>
            )}

            {/* Title - Staggered reveal */}
            <h1
              class={`hero-title text-5xl md:text-7xl lg:text-8xl font-bold mb-6 leading-[1.1] tracking-tight ${index === 0 ? 'animate-title-reveal' : ''}`}
              data-delay="500"
            >
              {slide.title || title}
            </h1>

            {/* Subtitle - Parallax text */}
            <p
              class={`hero-subtitle text-lg md:text-2xl mb-10 opacity-90 max-w-2xl mx-auto ${index === 0 ? 'animate-subtitle-reveal' : ''}`}
              data-delay="700"
            >
              {slide.subtitle || subtitle}
            </p>

            {/* CTAs */}
            <div
              class={`hero-ctas flex flex-col sm:flex-row gap-4 justify-center ${index === 0 ? 'animate-cta-reveal' : ''}`}
              data-delay="900"
            >
              <a
                href={getTemplateLink(slide.ctaUrl || ctaUrl)}
                class="cta-primary group relative inline-flex items-center gap-2 px-8 py-4 bg-white text-gray-900 font-semibold rounded-full overflow-hidden"
              >
                <span class="relative z-10">{slide.ctaText || ctaText}</span>
                <svg class="w-5 h-5 relative z-10 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
                <div class="absolute inset-0 bg-gradient-to-r from-[var(--color-accent)] to-[var(--color-primary)] translate-y-full group-hover:translate-y-0 transition-transform duration-300" />
              </a>
              <a
                href="#"
                class="cta-secondary group inline-flex items-center gap-2 px-8 py-4 border-2 border-white/30 text-white font-semibold rounded-full backdrop-blur-sm hover:border-white/60 hover:bg-white/10 transition-all"
              >
                <span>Watch Demo</span>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  {/* Navigation Layer */}
  <div class="hero-nav-layer absolute bottom-12 left-1/2 -translate-x-1/2 z-20">
    {/* Dots */}
    <div class="flex items-center gap-3 mb-6">
      {slides.map((_, i) => (
        <button
          class={`slider-dot w-3 h-3 rounded-full transition-all duration-300 ${i === 0 ? 'bg-white w-8' : 'bg-white/40 hover:bg-white/60'}`}
          data-index={i}
          aria-label={`Go to slide ${i + 1}`}
        />
      ))}
    </div>

    {/* Arrows */}
    <div class="flex items-center justify-center gap-4">
      <button class="slider-prev w-12 h-12 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-white flex items-center justify-center hover:bg-white/20 hover:border-white/40 transition-all group" aria-label="Previous slide">
        <svg class="w-6 h-6 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button class="slider-next w-12 h-12 rounded-full border border-white/20 bg-white/5 backdrop-blur-sm text-white flex items-center justify-center hover:bg-white/20 hover:border-white/40 transition-all group" aria-label="Next slide">
        <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>

  {/* Scroll Indicator */}
  <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 z-20">
    <div class="flex flex-col items-center gap-2 animate-bounce">
      <span class="text-white/60 text-xs uppercase tracking-widest">Scroll</span>
      <svg class="w-6 h-6 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<style>
  /* Level 4 Motion Animations */
  @keyframes float-slow {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
  }

  @keyframes float-medium {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }

  @keyframes float-fast {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(10px, -20px); }
    66% { transform: translate(-10px, -10px); }
  }

  @keyframes title-reveal {
    0% {
      opacity: 0;
      transform: translateY(60px) scale(0.95);
      filter: blur(10px);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
  }

  @keyframes subtitle-reveal {
    0% {
      opacity: 0;
      transform: translateY(40px);
    }
    100% {
      opacity: 0.9;
      transform: translateY(0);
    }
  }

  @keyframes cta-reveal {
    0% {
      opacity: 0;
      transform: translateY(30px) scale(0.9);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .floating-shape {
    will-change: transform;
  }

  .shape-1 { animation: float-slow 8s ease-in-out infinite; }
  .shape-2 { animation: float-medium 6s ease-in-out infinite; }
  .shape-3 { animation: float-fast 4s ease-in-out infinite; }

  .animate-title-reveal {
    animation: title-reveal 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.5s;
    opacity: 0;
  }

  .animate-subtitle-reveal {
    animation: subtitle-reveal 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.7s;
    opacity: 0;
  }

  .animate-cta-reveal {
    animation: cta-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: 0.9s;
    opacity: 0;
  }

  .animate-fade-in {
    animation: fade-in 0.6s ease-out forwards;
  }

  /* Parallax Effect */
  .hero-bg-layer {
    transform: translateZ(0);
    will-change: transform;
  }

  /* Pinned storytelling for level 4 */
  [data-motion-level="4"] .hero-slide {
    will-change: transform, opacity;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .hero-content-layer {
      padding-top: 2rem;
    }

    .scroll-indicator {
      display: none;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const hero = document.querySelector('.hero-cinematic') as HTMLElement;
    if (!hero) return;

    const slides = hero.querySelectorAll('.hero-bg-slide');
    const slideContent = hero.querySelectorAll('.hero-slide');
    const dots = hero.querySelectorAll('.slider-dot');
    const prevBtn = hero.querySelector('.slider-prev');
    const nextBtn = hero.querySelector('.slider-next');
    const bgLayer = hero.querySelector('.hero-bg-layer');

    const autoplay = hero.dataset.autoplay !== 'false';
    const delay = parseInt(hero.dataset.delay || '6000');
    const motionLevel = parseInt(hero.dataset.motionLevel || '4');
    const parallaxPreset = hero.dataset.parallax || 'layeredDepth';

    let currentIndex = 0;
    let autoplayInterval: ReturnType<typeof setInterval> | null = null;

    // Initialize background images
    slides.forEach(slide => {
      const img = slide.getAttribute('data-image');
      if (img) {
        (slide as HTMLElement).style.backgroundImage = `url('${img}')`;
      }
    });

    // Parallax effect based on preset
    if (motionLevel >= 3 && parallaxPreset !== 'none') {
      ScrollTrigger.create({
        trigger: hero,
        start: 'top top',
        end: 'bottom top',
        scrub: true,
        onUpdate: (self) => {
          if (bgLayer) {
            const progress = self.progress;
            gsap.set(bgLayer, {
              yPercent: progress * 30,
              scale: 1 + progress * 0.1,
            });
          }
        },
      });
    }

    function goToSlide(index: number) {
      // Animate out current slide
      gsap.to(slides[currentIndex], {
        opacity: 0,
        scale: 1.1,
        duration: 1,
        ease: 'power2.inOut',
      });

      gsap.to(slideContent[currentIndex], {
        opacity: 0,
        y: -30,
        duration: 0.6,
        ease: 'power2.in',
      });

      // Update dots
      dots[currentIndex].classList.remove('bg-white', 'w-8');
      dots[currentIndex].classList.add('bg-white/40');

      // Animate in new slide
      currentIndex = index;

      gsap.fromTo(slides[currentIndex],
        { opacity: 0, scale: 1.1 },
        { opacity: 1, scale: 1, duration: 1.2, ease: 'power2.inOut' }
      );

      gsap.fromTo(slideContent[currentIndex],
        { opacity: 0, y: 30 },
        { opacity: 1, y: 0, duration: 0.8, ease: 'power3.out', delay: 0.2 }
      );

      // Update dots
      dots[currentIndex].classList.remove('bg-white/40');
      dots[currentIndex].classList.add('bg-white', 'w-8');
    }

    function nextSlide() {
      const next = (currentIndex + 1) % slides.length;
      goToSlide(next);
    }

    function prevSlide() {
      const prev = (currentIndex - 1 + slides.length) % slides.length;
      goToSlide(prev);
    }

    // Event listeners
    nextBtn?.addEventListener('click', () => {
      nextSlide();
      resetAutoplay();
    });

    prevBtn?.addEventListener('click', () => {
      prevSlide();
      resetAutoplay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (i !== currentIndex) {
          goToSlide(i);
          resetAutoplay();
        }
      });
    });

    function resetAutoplay() {
      if (autoplayInterval) clearInterval(autoplayInterval);
      if (autoplay) {
        autoplayInterval = setInterval(nextSlide, delay);
      }
    }

    // Touch/Swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    hero.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    hero.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) nextSlide();
        else prevSlide();
        resetAutoplay();
      }
    }, { passive: true });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') nextSlide();
      if (e.key === 'ArrowLeft') prevSlide();
    });

    // Start autoplay
    if (autoplay && slides.length > 1) {
      autoplayInterval = setInterval(nextSlide, delay);
    }

    // Initial animation for Level 4
    if (motionLevel >= 4) {
      gsap.from('.hero-badge', {
        opacity: 0,
        y: -20,
        duration: 0.8,
        delay: 0.3,
        ease: 'power3.out',
      });
    }
  });
</script>