---
// ContactSplit - Two-column contact with animated gradient blob
// Premium Max variant for portfolio contact sections
interface Props {
  content?: {
    title?: string;
    phone?: string;
    whatsapp?: string;
    email?: string;
    instagram?: string;
    location?: string;
    availability?: string;
  };
  settings?: {
    templateSlug?: string;
    motionLevel?: number;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'Get in Touch',
  phone = '+91 98765 43210',
  whatsapp = '+91 98765 43210',
  email = 'hello@studio.in',
  instagram = '@studio',
  location = 'Mumbai · Delhi · Jaipur',
  availability = 'Booking open for 2025-26 season',
} = content;

const { templateSlug = '', motionLevel = 4 } = settings;
---

<section id="contact" class="contact-split">
  <div class="contact-split-inner">
    <!-- Left: Animated gradient blob -->
    <div class="contact-visual">
      <div class="gradient-blob"></div>
      <div class="visual-text">
        <h2 class="visual-title">{title}</h2>
        <p class="visual-availability">{availability}</p>
        <p class="visual-location">{location}</p>
      </div>
    </div>

    <!-- Right: Contact details -->
    <div class="contact-details">
      <div class="contact-list">
        {phone && (
          <a href={`tel:${phone.replace(/\s/g, '')}`} class="contact-row">
            <div class="contact-row-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div class="contact-row-text">
              <span class="row-label">Phone</span>
              <span class="row-value">{phone}</span>
            </div>
            <svg class="row-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        )}

        {whatsapp && (
          <a href={`https://wa.me/${whatsapp.replace(/\D/g, '')}`} target="_blank" rel="noopener" class="contact-row">
            <div class="contact-row-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
              </svg>
            </div>
            <div class="contact-row-text">
              <span class="row-label">WhatsApp</span>
              <span class="row-value">{whatsapp}</span>
            </div>
            <svg class="row-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        )}

        {email && (
          <a href={`mailto:${email}`} class="contact-row">
            <div class="contact-row-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
            </div>
            <div class="contact-row-text">
              <span class="row-label">Email</span>
              <span class="row-value">{email}</span>
            </div>
            <svg class="row-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        )}

        {instagram && (
          <a href={`https://instagram.com/${instagram.replace('@','')}`} target="_blank" rel="noopener" class="contact-row">
            <div class="contact-row-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
              </svg>
            </div>
            <div class="contact-row-text">
              <span class="row-label">Instagram</span>
              <span class="row-value">{instagram}</span>
            </div>
            <svg class="row-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7V17"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</section>

<style>
  .contact-split {
    padding: 120px 0;
    background: var(--color-background, #1a0b12);
    overflow: hidden;
    position: relative;
  }

  .contact-split-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 60vh;
  }

  .contact-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 500px;
    padding: 48px;
  }

  .gradient-blob {
    position: absolute;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--color-accent, #c78d6e) 0%, var(--color-secondary, #4a1c2a) 40%, transparent 70%);
    filter: blur(80px);
    opacity: 0.5;
    animation: blobMorph 8s ease-in-out infinite;
  }

  @keyframes blobMorph {
    0%, 100% {
      transform: translate(-20px, -20px) scale(1);
      opacity: 0.5;
    }
    33% {
      transform: translate(20px, 20px) scale(1.1);
      opacity: 0.35;
    }
    66% {
      transform: translate(0px, 30px) scale(0.95);
      opacity: 0.6;
    }
  }

  .visual-text {
    position: relative;
    z-index: 2;
    text-align: center;
  }

  .visual-title {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    color: var(--color-text, #f5efe7);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .visual-availability {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 0.9rem;
    color: var(--color-accent, #c78d6e);
    margin-bottom: 8px;
    letter-spacing: 0.05em;
  }

  .visual-location {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 1rem;
    color: var(--color-text-muted, #b8a99a);
  }

  .contact-details {
    padding: 48px;
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .contact-row {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border, #3d1f2b);
    border-radius: var(--radius-md, 12px);
    background: var(--color-surface, #2d131e);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .contact-row:hover {
    border-color: var(--color-accent, #c78d6e);
    transform: translateX(8px);
    box-shadow: -8px 8px 32px -8px rgba(199, 141, 110, 0.1);
  }

  .contact-row-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border, #3d1f2b);
    border-radius: 12px;
    color: var(--color-accent, #c78d6e);
    flex-shrink: 0;
    transition: all 0.3s ease;
  }

  .contact-row:hover .contact-row-icon {
    background: rgba(199, 141, 110, 0.1);
    border-color: var(--color-accent, #c78d6e);
  }

  .contact-row-icon svg {
    width: 18px;
    height: 18px;
  }

  .contact-row-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  .row-label {
    font-family: var(--font-heading, 'Cormorant Garamond', serif);
    font-style: italic;
    font-size: 0.8rem;
    color: var(--color-text-muted, #b8a99a);
  }

  .row-value {
    font-family: var(--font-body, 'Inter', sans-serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text, #f5efe7);
  }

  .row-arrow {
    width: 16px;
    height: 16px;
    color: var(--color-text-muted, #b8a99a);
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
  }

  .contact-row:hover .row-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent, #c78d6e);
  }

  @media (max-width: 900px) {
    .contact-split-inner {
      grid-template-columns: 1fr;
    }

    .contact-visual {
      min-height: 300px;
      padding: 40px 24px;
    }

    .gradient-blob {
      width: 300px;
      height: 300px;
    }

    .contact-details {
      padding: 24px;
    }

    .contact-row:hover {
      transform: translateX(4px);
    }
  }

  @media (max-width: 480px) {
    .contact-row {
      padding: 18px;
      gap: 14px;
    }

    .contact-row-icon {
      width: 38px;
      height: 38px;
    }

    .row-value {
      font-size: 0.9rem;
    }
  }
</style>

{motionLevel >= 4 && (
<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll('.contact-split').forEach((section) => {
    const rows = section.querySelectorAll('.contact-row');
    gsap.from(rows, {
      scrollTrigger: {
        trigger: section,
        start: 'top 80%',
      },
      opacity: 0,
      x: 40,
      duration: 0.7,
      stagger: 0.1,
      ease: 'power3.out',
    });
  });
</script>
)}
