---
// Testimonials Slider - Multiple Carousel Types including Quote Carousel
interface Testimonial {
  name: string;
  role: string;
  company: string;
  image?: string;
  quote: string;
  rating?: number;
}

interface Props {
  content?: {
    title?: string;
    subtitle?: string;
    testimonials?: Testimonial[];
    layout?: 'carousel' | 'grid' | 'masonry' | 'featured';
  };
  settings?: {
    carouselType?: 'classic' | 'testimonialQuote' | 'centerMode' | 'stackedCard';
    autoplay?: boolean;
    autoplayDelay?: number;
    motionLevel?: 1 | 2 | 3 | 4;
    showRatings?: boolean;
    showImages?: boolean;
  };
}

const { content = {}, settings = {} } = Astro.props;
const {
  title = 'What Our Customers Say',
  subtitle = '',
  testimonials = [
    {
      name: 'Sarah Mitchell',
      role: 'Fashion Director',
      company: 'Luxe Magazine',
      image: 'https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=150',
      quote: 'The design quality is absolutely stunning. Every detail has been carefully crafted to create an immersive experience that truly represents our brand values.',
      rating: 5,
    },
    {
      name: 'James Chen',
      role: 'Creative Lead',
      company: 'Studio 23',
      image: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=150',
      quote: 'I was blown away by the level of polish and attention to detail. This template helped us launch our portfolio three times faster than expected.',
      rating: 5,
    },
    {
      name: 'Elena Rodriguez',
      role: 'Marketing Head',
      company: 'Bloom Cosmetics',
      image: 'https://images.unsplash.com/photo-1438761681033-6461ffad8d80?w=150',
      quote: 'The perfect blend of elegance and functionality. Our conversion rates have improved dramatically since we switched to this beautiful design.',
      rating: 5,
    },
  ],
  layout = 'carousel',
} = content;

const {
  carouselType = 'testimonialQuote',
  autoplay = true,
  autoplayDelay = 5000,
  motionLevel = 3,
  showRatings = true,
  showImages = true,
} = settings;
---

<section
  class="testimonials-section py-24 bg-gradient-to-b from-[var(--color-surface)] to-[var(--color-background)] overflow-hidden"
  data-carousel-type={carouselType}
  data-motion-level={motionLevel}
  data-autoplay={autoplay}
  data-delay={autoplayDelay}
>
  <div class="max-w-7xl mx-auto px-6">
    {/* Section Header */}
    <div class="text-center mb-16">
      <span class="inline-block px-4 py-1.5 bg-[var(--color-accent)]/10 text-[var(--color-accent)] rounded-full text-sm font-semibold mb-4">
        Testimonials
      </span>
      <h2 class="text-4xl md:text-5xl font-bold text-[var(--color-text)] mb-4">
        {title}
      </h2>
      {subtitle && (
        <p class="text-xl text-gray-600 max-w-2xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>

    {/* Testimonials Carousel */}
    <div class="testimonials-carousel relative">
      <div class="testimonial-track overflow-hidden">
        <div class="testimonial-slides flex" data-current="0">
          {testimonials.map((testimonial, index) => (
            <div
              class={`testimonial-slide flex-shrink-0 w-full px-4 transition-all duration-500 ${index === 0 ? 'opacity-100' : 'opacity-0 absolute inset-0'}`}
              data-index={index}
            >
              <div class={`testimonial-card max-w-4xl mx-auto ${carouselType === 'testimonialQuote' ? 'text-center' : 'flex items-start gap-8'}`}>
                {/* Quote Icon */}
                <div class={`quote-icon mb-6 ${carouselType !== 'testimonialQuote' ? 'order-2' : 'mx-auto'}`}>
                  <svg class={`text-[var(--color-accent)] ${carouselType === 'testimonialQuote' ? 'w-16 h-16' : 'w-12 h-12'}`} fill="currentColor" viewBox="0 0 24 24">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                  </svg>
                </div>

                {/* Image */}
                {showImages && testimonial.image && (
                  <div class={`testimonial-image ${carouselType === 'testimonialQuote' ? 'mx-auto mb-6' : 'order-1'}`}>
                    <div class="relative">
                      <img
                        src={testimonial.image}
                        alt={testimonial.name}
                        class={`rounded-full object-cover border-4 border-white shadow-lg ${carouselType === 'testimonialQuote' ? 'w-24 h-24' : 'w-20 h-20'}`}
                      />
                      {showRatings && testimonial.rating && (
                        <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 flex gap-0.5">
                          {Array(testimonial.rating).fill(0).map(() => (
                            <svg class="w-4 h-4 text-yellow-400 fill-current" viewBox="0 0 20 20">
                              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                            </svg>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                )}

                {/* Quote Text */}
                <div class={`testimonial-content ${carouselType === 'testimonialQuote' ? '' : 'order-3 flex-1'}`}>
                  <blockquote class={`text-xl md:text-2xl font-medium leading-relaxed mb-6 ${carouselType === 'testimonialQuote' ? 'text-gray-800 italic' : 'text-gray-700'}`}>
                    "{testimonial.quote}"
                  </blockquote>

                  {/* Author Info */}
                  <div class="testimonial-author">
                    <div class={`font-bold text-[var(--color-text)] ${carouselType === 'testimonialQuote' ? 'text-xl' : 'text-lg'}`}>
                      {testimonial.name}
                    </div>
                    <div class="text-gray-500">
                      {testimonial.role}
                      {testimonial.company && (
                        <span class="text-gray-400"> at </span>
                      )}
                      {testimonial.company && (
                        <span class="text-[var(--color-accent)] font-medium">{testimonial.company}</span>
                      )}
                    </div>
                  </div>
                </div>

                {/* Decorative Elements for Quote Carousel */}
                {carouselType === 'testimonialQuote' && (
                  <div class="mt-8 flex justify-center gap-2">
                    <div class="w-12 h-1 bg-[var(--color-accent)] rounded-full" />
                    <div class="w-4 h-1 bg-[var(--color-accent)]/50 rounded-full" />
                    <div class="w-4 h-1 bg-[var(--color-accent)]/50 rounded-full" />
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Navigation Dots */}
      <div class="testimonial-dots flex justify-center gap-3 mt-12">
        {testimonials.map((_, i) => (
          <button
            class={`testimonial-dot w-3 h-3 rounded-full transition-all duration-300 ${i === 0 ? 'bg-[var(--color-accent)] w-8' : 'bg-gray-300 hover:bg-gray-400'}`}
            data-index={i}
            aria-label={`Go to testimonial ${i + 1}`}
          />
        ))}
      </div>

      {/* Navigation Arrows */}
      <div class="testimonial-nav absolute top-1/2 -translate-y-1/2 left-0 right-0 flex justify-between pointer-events-none px-4">
        <button class="testimonial-prev pointer-events-auto w-12 h-12 rounded-full bg-white shadow-lg flex items-center justify-center text-[var(--color-primary)] hover:bg-[var(--color-accent)] hover:text-white transition-all -translate-x-6" aria-label="Previous testimonial">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button class="testimonial-next pointer-events-auto w-12 h-12 rounded-full bg-white shadow-lg flex items-center justify-center text-[var(--color-primary)] hover:bg-[var(--color-accent)] hover:text-white transition-all translate-x-6" aria-label="Next testimonial">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-card {
    transition: transform 0.3s ease;
  }

  .testimonial-card:hover {
    transform: translateY(-4px);
  }

  @keyframes testimonial-fade {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes testimonial-slide-left {
    from {
      opacity: 0;
      transform: translateX(40px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .testimonial-slide.active {
    animation: testimonial-fade 0.6s ease-out forwards;
  }

  /* Level 4 enhancements */
  [data-motion-level="4"] .testimonial-card {
    will-change: transform, opacity;
  }

  [data-motion-level="4"] .testimonial-slide {
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .testimonial-nav {
      display: none;
    }

    .testimonial-card {
      padding: 0 1rem;
    }
  }
</style>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const section = document.querySelector('.testimonials-section') as HTMLElement;
    if (!section) return;

    const slides = section.querySelectorAll('.testimonial-slide');
    const dots = section.querySelectorAll('.testimonial-dot');
    const prevBtn = section.querySelector('.testimonial-prev');
    const nextBtn = section.querySelector('.testimonial-next');

    const autoplay = section.dataset.autoplay !== 'false';
    const delay = parseInt(section.dataset.delay || '5000');
    const carouselType = section.dataset.carouselType || 'testimonialQuote';
    const motionLevel = parseInt(section.dataset.motionLevel || '3');

    let currentIndex = 0;
    let autoplayInterval: ReturnType<typeof setInterval> | null = null;

    function goToSlide(index: number) {
      if (index === currentIndex || slides.length <= 1) return;

      // Animate out current slide
      gsap.to(slides[currentIndex], {
        opacity: 0,
        y: carouselType === 'testimonialQuote' ? -30 : 20,
        scale: 0.95,
        duration: 0.5,
        ease: 'power2.inOut',
        onComplete: () => {
          slides[currentIndex].classList.remove('opacity-100');
          slides[currentIndex].classList.add('opacity-0', 'absolute', 'inset-0');
        },
      });

      // Update dots
      dots[currentIndex].classList.remove('bg-[var(--color-accent)]', 'w-8');
      dots[currentIndex].classList.add('bg-gray-300');

      // Animate in new slide
      slides[index].classList.remove('opacity-0', 'absolute', 'inset-0');
      slides[index].classList.add('opacity-100');

      gsap.fromTo(slides[index],
        { opacity: 0, y: carouselType === 'testimonialQuote' ? 30 : -20, scale: 0.95 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.6,
          ease: 'power3.out',
        }
      );

      // Update dots
      dots[index].classList.remove('bg-gray-300');
      dots[index].classList.add('bg-[var(--color-accent)]', 'w-8');

      currentIndex = index;
    }

    function nextSlide() {
      goToSlide((currentIndex + 1) % slides.length);
    }

    function prevSlide() {
      goToSlide((currentIndex - 1 + slides.length) % slides.length);
    }

    function resetAutoplay() {
      if (autoplayInterval) clearInterval(autoplayInterval);
      if (autoplay && slides.length > 1) {
        autoplayInterval = setInterval(nextSlide, delay);
      }
    }

    // Event listeners
    nextBtn?.addEventListener('click', () => {
      nextSlide();
      resetAutoplay();
    });

    prevBtn?.addEventListener('click', () => {
      prevSlide();
      resetAutoplay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        if (i !== currentIndex) {
          goToSlide(i);
          resetAutoplay();
        }
      });
    });

    // Touch/Swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    section.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    section.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) nextSlide();
        else prevSlide();
        resetAutoplay();
      }
    }, { passive: true });

    // Keyboard navigation
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') nextSlide();
      if (e.key === 'ArrowLeft') prevSlide();
    });

    // Start autoplay
    if (autoplay && slides.length > 1) {
      autoplayInterval = setInterval(nextSlide, delay);
    }

    // Staggered entrance animation
    if (motionLevel >= 3) {
      gsap.from('.testimonial-slide', {
        opacity: 0,
        y: 40,
        duration: 0.8,
        stagger: 0.2,
        ease: 'power3.out',
        delay: 0.3,
      });
    }
  });
</script>