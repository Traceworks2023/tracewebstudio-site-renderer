---
interface Props {
  heading: string;
  subheading: string;
  cta: string;
}

const { heading, subheading, cta } = Astro.props;
---

<section class="hero">
  <div class="container">
    <h1>{heading}</h1>
    <p class="subheading">{subheading}</p>
    <button class="btn btn-accent">{cta}</button>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, var(--color-primary) 0%, #000066 100%);
    color: white;
    padding: 6rem 0;
    text-align: center;
  }
  
  .hero h1 {
    font-size: 3.5rem;
    color: white;
    margin-bottom: 1rem;
  }
  
  .subheading {
    font-size: 1.5rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
</style>
